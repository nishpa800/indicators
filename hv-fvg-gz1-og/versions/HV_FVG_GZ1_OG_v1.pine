//@version=5
indicator("HV FVG GZ1 OG THIS No tables", "HV FVG GZ1 OG", overlay = true, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500, max_bars_back=5000)

//------------------------------------------------------------------------------
// Settings
//-----------------------------------------------------------------------------{
// Core FVG Settings
thresholdPer = input.float(1, "Threshold %", minval = 0, maxval = 100, step = .1, inline = 'threshold', group = 'FVG Detection')
auto = input(true, "Auto", inline = 'threshold', group = 'FVG Detection')
showLast = input.int(15, 'Unmitigated Levels', minval = 0, group = 'FVG Detection')
mitigationLevels = input.bool(false, 'Mitigation Levels', group = 'FVG Detection')
tf = input.timeframe('', "Timeframe", group = 'FVG Detection')

// Style
bullCss = input.color(color.new(#089981, 70), "Bullish FVG", group = 'Style')
bearCss = input.color(color.new(#f23645, 70), "Bearish FVG", group = 'Style')

// GZI Signal Settings
group_gzi = "Signal 1: GZI (Gap Zone Intersection)"
showGZI = input.bool(true, "Show GZI Signals", group = group_gzi)
gziProximity = input.int(6, "Max Bar Distance", minval = 1, maxval = 200, group = group_gzi, tooltip = "FVGs must be within this many bars to count as overlap")
gziBullCss = input.color(color.new(#00ff88, 0), "Bullish GZI", group = group_gzi)
gziBearCss = input.color(color.new(#ff0055, 0), "Bearish GZI", group = group_gzi)

// HV Signal Settings
group_hv = "Signal 2: HV (High Volume FVG)"
showHV = input.bool(true, "Show HV Signals", group = group_hv)
hvBullCss = input.color(color.new(#00bfff, 0), "Bullish HV", group = group_hv)
hvBearCss = input.color(color.new(#ff6600, 0), "Bearish HV", group = group_hv)

// Hardcoded values
extend = 480

//-----------------------------------------------------------------------------}
// User Defined Types
//-----------------------------------------------------------------------------{
type fvg
    float max
    float min
    bool  isbull
    int   t
    int   barIdx
    bool  isHV

//-----------------------------------------------------------------------------}
// Methods
//-----------------------------------------------------------------------------{
n = bar_index

//-----------------------------------------------------------------------------}
// High Volume Detection
//-----------------------------------------------------------------------------{
hve_1 = ta.highest(volume, 5000)[1]
hvy_1 = ta.highest(volume, 252)[1]
hvq_1 = ta.highest(volume, 63)[1]

float vol_1 = volume[1]

bool isFormationHVE = vol_1 == hve_1
bool isFormationHVY = vol_1 == hvy_1
bool isFormationHVQ = vol_1 == hvq_1

bool isFormationHV = isFormationHVE or isFormationHVY or isFormationHVQ

//-----------------------------------------------------------------------------}
// Core FVG Detection
//-----------------------------------------------------------------------------{
threshold = auto ? ta.cum((high - low) / low) / bar_index : thresholdPer / 100

bull_fvg_raw = low > high[2] and close[1] > high[2] and (low - high[2]) / high[2] > threshold
bear_fvg_raw = high < low[2] and close[1] < low[2] and (low[2] - high) / high > threshold

[bull_fvg, bear_fvg, bull_max, bull_min, bear_max, bear_min, fvg_time] = request.security(syminfo.tickerid, tf, [bull_fvg_raw, bear_fvg_raw, low, high[2], low[2], high, time])

//-----------------------------------------------------------------------------}
// FVG State Management
//-----------------------------------------------------------------------------{
var float max_bull_fvg = na
var float min_bull_fvg = na
var int bull_count = 0
var int bull_mitigated = 0
var float max_bear_fvg = na
var float min_bear_fvg = na
var int bear_count = 0
var int bear_mitigated = 0
var int lastTime = 0

var fvg_records = array.new<fvg>(0)
var fvg_areas = array.new<box>(0)

// Signal flags for this bar only
bool bullGZI_trigger = false
bool bearGZI_trigger = false
bool bullHV_trigger = false
bool bearHV_trigger = false

//-----------------------------------------------------------------------------}
// Process New FVGs
//-----------------------------------------------------------------------------{

// === BULLISH FVG ===
if bull_fvg and fvg_time != lastTime
    float new_max = bull_max
    float new_min = bull_min
    bool newIsHV = isFormationHV
    int newBarIdx = n

    // === GZI CHECK ===
    // Must overlap in PRICE and be within PROXIMITY in TIME
    if showGZI and fvg_records.size() > 0
        for i = 0 to fvg_records.size() - 1
            fvg existing = fvg_records.get(i)

            // Same polarity check
            if existing.isbull
                // TIME PROXIMITY CHECK - must be within gziProximity bars
                int barDistance = newBarIdx - existing.barIdx
                if barDistance <= gziProximity
                    // PRICE OVERLAP CHECK
                    float overlap_bottom = math.max(existing.min, new_min)
                    float overlap_top = math.min(existing.max, new_max)

                    // Standard overlap: overlap_bottom < overlap_top
                    // Adjacent when both HV: overlap_bottom <= overlap_top
                    bool isOverlap = overlap_bottom < overlap_top
                    bool isAdjacentHV = (overlap_bottom <= overlap_top) and existing.isHV and newIsHV

                    if isOverlap or isAdjacentHV
                        bullGZI_trigger := true
                        break

    // === HV CHECK ===
    if showHV and newIsHV
        bullHV_trigger := true

    fvg newFvg = fvg.new(new_max, new_min, true, fvg_time, newBarIdx, newIsHV)
    fvg_records.unshift(newFvg)
    fvg_areas.unshift(box.new(n-2, new_max, n+extend, new_min, na, bgcolor = bullCss))

    bull_count += 1
    lastTime := fvg_time

// === BEARISH FVG ===
if bear_fvg and fvg_time != lastTime
    float new_max = bear_max
    float new_min = bear_min
    bool newIsHV = isFormationHV
    int newBarIdx = n

    // === GZI CHECK ===
    // Must overlap in PRICE and be within PROXIMITY in TIME
    if showGZI and fvg_records.size() > 0
        for i = 0 to fvg_records.size() - 1
            fvg existing = fvg_records.get(i)

            // Same polarity check
            if not existing.isbull
                // TIME PROXIMITY CHECK
                int barDistance = newBarIdx - existing.barIdx
                if barDistance <= gziProximity
                    // PRICE OVERLAP CHECK
                    float overlap_bottom = math.max(existing.min, new_min)
                    float overlap_top = math.min(existing.max, new_max)

                    bool isOverlap = overlap_bottom < overlap_top
                    bool isAdjacentHV = (overlap_bottom <= overlap_top) and existing.isHV and newIsHV

                    if isOverlap or isAdjacentHV
                        bearGZI_trigger := true
                        break

    // === HV CHECK ===
    if showHV and newIsHV
        bearHV_trigger := true

    fvg newFvg = fvg.new(new_max, new_min, false, fvg_time, newBarIdx, newIsHV)
    fvg_records.unshift(newFvg)
    fvg_areas.unshift(box.new(n-2, new_max, n+extend, new_min, na, bgcolor = bearCss))

    bear_count += 1
    lastTime := fvg_time

//-----------------------------------------------------------------------------}
// Mitigation Processing
//-----------------------------------------------------------------------------{
if fvg_records.size() > 0
    for i = fvg_records.size()-1 to 0
        fvg get = fvg_records.get(i)

        if get.isbull
            if close < get.min
                if mitigationLevels
                    line.new(get.t, get.min, time, get.min, xloc.bar_time, color = bullCss, style = line.style_dashed)
                box area = fvg_areas.remove(i)
                area.delete()
                fvg_records.remove(i)
                bull_mitigated += 1
        else if close > get.max
            if mitigationLevels
                line.new(get.t, get.max, time, get.max, xloc.bar_time, color = bearCss, style = line.style_dashed)
            box area = fvg_areas.remove(i)
            area.delete()
            fvg_records.remove(i)
            bear_mitigated += 1

//-----------------------------------------------------------------------------}
// Unmitigated Lines
//-----------------------------------------------------------------------------{
var unmitigated = array.new<line>(0)

if barstate.islast and showLast > 0 and fvg_records.size() > 0
    if unmitigated.size() > 0
        for element in unmitigated
            element.delete()
        unmitigated.clear()

    int loopEnd = math.min(showLast-1, fvg_records.size()-1)
    for i = 0 to loopEnd
        fvg get = fvg_records.get(i)
        unmitigated.push(line.new(get.t, get.isbull ? get.min : get.max, time, get.isbull ? get.min : get.max, xloc.bar_time, color = get.isbull ? bullCss : bearCss))

//-----------------------------------------------------------------------------}
// Signal Plots
//-----------------------------------------------------------------------------{
plotshape(bullGZI_trigger, title="Bullish GZI", style=shape.flag, location=location.top,
          color=gziBullCss, size=size.normal, offset=-1)

plotshape(bearGZI_trigger, title="Bearish GZI", style=shape.flag, location=location.top,
          color=gziBearCss, size=size.normal, offset=-1)

plotshape(bullHV_trigger, title="Bullish HV", style=shape.flag, location=location.belowbar,
          color=hvBullCss, size=size.normal, offset=-1)

plotshape(bearHV_trigger, title="Bearish HV", style=shape.flag, location=location.belowbar,
          color=hvBearCss, size=size.normal, offset=-1)

//-----------------------------------------------------------------------------}
// Alerts
//-----------------------------------------------------------------------------{
alertcondition(bull_count > bull_count[1], 'Bullish FVG', 'Bullish FVG detected')
alertcondition(bear_count > bear_count[1], 'Bearish FVG', 'Bearish FVG detected')
alertcondition(bull_mitigated > bull_mitigated[1], 'Bullish FVG Mitigation', 'Bullish FVG mitigated')
alertcondition(bear_mitigated > bear_mitigated[1], 'Bearish FVG Mitigation', 'Bearish FVG mitigated')

alertcondition(bullGZI_trigger, 'Bullish GZI', 'Bullish Gap Zone Intersection detected')
alertcondition(bearGZI_trigger, 'Bearish GZI', 'Bearish Gap Zone Intersection detected')
alertcondition(bullGZI_trigger or bearGZI_trigger, 'Any GZI', 'Gap Zone Intersection detected')

alertcondition(bullHV_trigger, 'Bullish HV FVG', 'Bullish FVG with milestone volume')
alertcondition(bearHV_trigger, 'Bearish HV FVG', 'Bearish FVG with milestone volume')
alertcondition(bullHV_trigger or bearHV_trigger, 'Any HV FVG', 'FVG with milestone volume')

//-----------------------------------------------------------------------------}
