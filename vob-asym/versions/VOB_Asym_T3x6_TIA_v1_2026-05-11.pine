// INPUTS — Sensitivities (preserved from canonical v8)
// ─────────────────────────────────────────────────────────────────────────────

int sens_a = input.int(2500, "Sensitivity A (Highest — fewest, strongest zones)",  group = "Sensitivities", minval = 1)
int sens_b = input.int(2250, "Sensitivity B (second highest)",            group = "Sensitivities", minval = 1)
int sens_c = input.int(2000, "Sensitivity C (middle-high)",            group = "Sensitivities", minval = 1)
int sens_d = input.int(1500, "Sensitivity D (middle-low)",            group = "Sensitivities", minval = 1)
int sens_e = input.int(1250, "Sensitivity E (second lowest)",            group = "Sensitivities", minval = 1)
int sens_f = input.int(1000, "Sensitivity F (Lowest — most, weakest zones)",   group = "Sensitivities", minval = 1)


