        str.tostring(cnt_bull_all), str.tostring(cnt_bear_all),
        str.tostring(stk_bull), str.tostring(stk_bear),
        str.tostring(math.round(bull_gap * 100) / 100), str.tostring(math.round(bear_gap * 100) / 100),
        na(I_bull) ? "na" : str.tostring(math.round(I_bull * 10000) / 10000),
        na(T_bull) ? "na" : str.tostring(math.round(T_bull * 10000) / 10000),
        na(A_bull) ? "na" : str.tostring(math.round(A_bull * 10000) / 10000),
        na(P_bull) ? "na" : str.tostring(math.round(P_bull * 10000) / 10000),
        na(I_bear) ? "na" : str.tostring(math.round(I_bear * 10000) / 10000),
        na(T_bear) ? "na" : str.tostring(math.round(T_bear * 10000) / 10000),
        na(A_bear) ? "na" : str.tostring(math.round(A_bear * 10000) / 10000),
