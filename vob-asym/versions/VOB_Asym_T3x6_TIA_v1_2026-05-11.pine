// ─────────────────────────────────────────────────────────────────────────────
// HELPER FUNCTIONS (preserved + TIA additions)
// ─────────────────────────────────────────────────────────────────────────────

f_cd_ok(int last_bar, int cd) =>
    na(last_bar) or (bar_index - last_bar) > cd

f_fmt_vol(float v) =>
    if v >= 1000000
        str.tostring(math.round(v / 1000000)) + "M"
    else if v >= 1000
        str.tostring(math.round(v / 1000)) + "K"
    else
        str.tostring(math.round(v))

f_zones_overlap(float lo1, float hi1, float lo2, float hi2) =>
    not na(lo1) and not na(hi1) and not na(lo2) and not na(hi2) and lo1 < hi2 and hi1 > lo2

f_push_hist(array<hist_entry> arr, float vol, float pool, int max_depth) =>
    float pct = pool > 0 ? (vol / pool * 100) : 100.0
    string full_ds = str.format_time(time, "MM/dd HH:mm", syminfo.timezone)
    string ds = str.substring(full_ds, 0, str.length(full_ds) - 1)
    arr.push(hist_entry.new(time, vol, pct, ds))
    if arr.size() > max_depth
        arr.shift()

f_evt_cell(array<hist_entry> arr, int idx) =>
    if idx < arr.size()
        hist_entry e = arr.get(arr.size() - 1 - idx)
        e.date_s + "\n" + f_fmt_vol(e.vol) + " " + str.tostring(math.round(e.pct))
    else
        "—"

// ─────────────────────────────────────────────────────────────────────────────
// TIA HELPERS — UDT initialization
// ─────────────────────────────────────────────────────────────────────────────

f_new_level(int idx, float upper, float lower, float mid, float vol) =>
    level.new(idx, upper, lower, mid, vol, bar_index, 0,
              array.new<float>(), array.new<float>(), array.new<int>(), array.new<float>(),
              0, na, 0.0, 0.0)

f_invalid_level() =>
    level.new(na, na, na, na, na, na, 0,
              array.new<float>(), array.new<float>(), array.new<int>(), array.new<float>(),
              0, na, 0.0, 0.0)


// ─────────────────────────────────────────────────────────────────────────────
// TIA HELPERS — zone-level utilities
// ─────────────────────────────────────────────────────────────────────────────

f_count_active(array<level> arr) =>
    int c = 0
    if arr.size() > 0
        for i = 0 to arr.size() - 1
            if not na(arr.get(i).vol)
                c += 1
    c

f_stack_near(array<level> arr, float price, float thresh_pct) =>
    int c = 0
    if arr.size() > 0 and price > 0
        for i = 0 to arr.size() - 1
            level l = arr.get(i)
            if not na(l.mid) and math.abs(price - l.mid) / price * 100 <= thresh_pct
                c += 1
    c

f_nearest_above_pct(array<level> arr, float price) =>
    float best = 100.0
    if arr.size() > 0 and price > 0
        for i = 0 to arr.size() - 1
            level l = arr.get(i)
            if not na(l.mid) and l.mid > price
                float d = (l.mid - price) / price * 100
                if d < best
                    best := d
    best

f_nearest_below_pct(array<level> arr, float price) =>
    float best = 100.0
    if arr.size() > 0 and price > 0
        for i = 0 to arr.size() - 1
            level l = arr.get(i)
            if not na(l.mid) and l.mid < price
                float d = (price - l.mid) / price * 100
                if d < best
                    best := d
    best

// Find the index of the nearest active zone in `arr` to `price`. Returns -1 if none.
f_find_nearest_idx(array<level> arr, float price) =>
    int best_idx = -1
    float best_d = 1e18
    if arr.size() > 0 and price > 0
        for i = 0 to arr.size() - 1
            level l = arr.get(i)
            if not na(l.mid)
                float d = math.abs(price - l.mid)
                if d < best_d
                    best_d  := d
                    best_idx := i
    best_idx

// Median pool volume across active zones in an array (for normalization).
f_median_pool(array<level> arr) =>
    array<float> vols = array.new<float>()
    if arr.size() > 0
        for i = 0 to arr.size() - 1
            level l = arr.get(i)
            if not na(l.vol)
                vols.push(l.vol)
    vols.size() > 0 ? array.median(vols) : 0.0


// ─────────────────────────────────────────────────────────────────────────────
// TIA HELPERS — Touch tracking per zone per bar
// ─────────────────────────────────────────────────────────────────────────────
// Tracks the close-in-zone state transition (outside → inside = touch entry;
// inside → outside = touch exit). On exit, classifies rejected vs penetrated
// based on which boundary price crossed.

// is_bull: true if this is a bull zone (defends from below, penetrated = exit DOWN)
//          false if bear zone (defends from above, penetrated = exit UP)
f_update_touches(array<level> arr, bool is_bull, int max_touches) =>
    if arr.size() > 0
        for i = 0 to arr.size() - 1
            level l = arr.get(i)
            if not na(l.upper) and not na(l.lower) and not na(l.mid)
                bool inside_now = close >= l.lower and close <= l.upper
                int was_touching = l.currently_touching
                if inside_now and was_touching == 0
                    // TOUCH ENTRY
                    l.currently_touching := 1
                    l.touch_entry_bar    := bar_index
                    l.deepest_pen_this_visit := 0.0
                    // entry_pool snapshot: store the volume of THIS bar as the "stress"
                    l.entry_pool := volume
                if inside_now and was_touching == 1
                    // CONTINUING TOUCH — update deepest pen
                    float pen = is_bull ? (l.upper - low) : (high - l.lower)
                    float zone_width = l.upper - l.lower
                    float pen_norm = zone_width > 0 ? math.max(0.0, math.min(1.0, pen / zone_width)) : 0.0
                    if pen_norm > l.deepest_pen_this_visit
                        l.deepest_pen_this_visit := pen_norm
                if not inside_now and was_touching == 1
                    // TOUCH EXIT — classify and record
                    l.currently_touching := 0
                    bool rejected = is_bull ? (close > l.upper) : (close < l.lower)
                    l.touch_vols.push(l.entry_pool)
                    l.touch_pen_depths.push(l.deepest_pen_this_visit)
                    l.touch_rejected.push(rejected ? 1 : 0)
                    l.pool_at_touch.push(l.vol)
                    l.touch_count := l.touch_count + 1
                    // Cap arrays at max_touches
                    if l.touch_vols.size() > max_touches
                        l.touch_vols.shift()
                        l.touch_pen_depths.shift()
                        l.touch_rejected.shift()
                        l.pool_at_touch.shift()


// ─────────────────────────────────────────────────────────────────────────────
// TIA HELPERS — Compute I, T, A, P for a single zone
// ─────────────────────────────────────────────────────────────────────────────
// All inputs to I/T/A are normalized to [0, 1]. Final I, T, A are arithmetic
// means (simpler v1 form; calibration can replace with logistic regression in
// v2 once 90 days of outcome data exists). P = (I × T × A)^(1/3).

// is_bull governs penetration sign + nearest_above/below interpretation.
// Returns [I, T, A, P] as a tuple.
f_compute_tia(level zone, float price, int tier_agree, int stack, float pool_median,
              float atr_local, float slope_tier, float opp_gap_pct, bool is_bull) =>

    // ── IMPERVIOUSNESS (I) ───────────────────────────────────────────────────
    // i1 — I-VAR-1 R_t (Tate-Alekseevskii target resistance)
    float pool_norm = pool_median > 0 ? zone.vol / pool_median : 1.0
    float i1 = math.min(1.0, pool_norm / 2.0)  // saturates at 2x median
    // i2 — I-VAR-2 tier agreement
    float i2 = math.min(1.0, tier_agree / 6.0)
    // i3 — I-VAR-3 stack count (capped at 8)
    float i3 = math.min(1.0, math.sqrt(stack / 8.0))
    // i4 — I-VAR-4 zone thinness (thinner = harder; Walker-Anderson h/d)
    float thickness = zone.upper - zone.lower
    float i4 = atr_local > 0 ? math.min(1.0, 1.0 / (1.0 + (thickness / atr_local))) : 0.5
    // i5 — I-VAR-5 obliquity (Walker-Anderson cos²θ proxy via slope sign alignment)
    float i5 = is_bull ? (slope_tier > 0 ? 1.0 : 0.5) : (slope_tier < 0 ? 1.0 : 0.5)
    // i6 — I-VAR-6 d_price proximity (Gao-Tian bond length analogue)
    float d_price = price > 0 ? math.abs(price - zone.mid) / price : 0.5
    float i6 = 1.0 / (1.0 + d_price * 50.0)  // strong proximity weighting
    // i7 — I-VAR-10 VWAP alignment
    float vwap_dist = price > 0 ? math.abs(vwap_session - zone.mid) / price : 1.0
    float i7 = 1.0 / (1.0 + vwap_dist * 20.0)
    // i8 — I-VAR-11 ADX strength (≥25 = trending)
    float i8 = math.min(1.0, adx_14 / 50.0)
    // External factors (Python enriches; default 1.0 = neutral)
    float i_ext = tia_ext_cross_ind * tia_ext_htf_align * tia_ext_sector_rs * tia_ext_book_depth * tia_ext_opt_strike
    // Imperviousness = weighted arithmetic mean × external multiplier (capped at 1)
    float i_internal = (i1 + i2 + i3 + i4 + i5 + i6 + i7 + i8) / 8.0
    float I_score = math.min(1.0, i_internal * math.pow(i_ext, 0.2))  // external is moderate boost

    // ── TENSILE (T) ──────────────────────────────────────────────────────────
    // t1 — T-VAR-1 v_pool_norm (UTS analogue)
    float t1 = math.min(1.0, pool_norm / 2.0)
    // t2 — T-VAR-2 success_rate (touch history); bootstrap to 0.5 if no touches
    int n_touches = zone.touch_count
    int n_rejected = 0
    if n_touches > 0
        for j = 0 to zone.touch_rejected.size() - 1
            if zone.touch_rejected.get(j) == 1
                n_rejected += 1
    float t2 = n_touches > 0 ? float(n_rejected) / n_touches : 0.5
    // t3 — T-VAR-3 K_discrete (toughness integral)
    float K_disc = 0.0
    if n_touches > 0
        for j = 0 to zone.touch_vols.size() - 1
            float vj = zone.touch_vols.get(j)
            float pj = zone.touch_pen_depths.get(j)
            int rj = zone.touch_rejected.get(j)
            K_disc += vj * pj * rj  // only rejected touches contribute toughness
    float K_threshold = pool_median > 0 ? pool_median * 0.5 : 1.0
    float t3 = math.min(1.0, K_disc / (K_threshold * math.max(1, n_touches)))
    // t4 — T-VAR-4 sigma_c Griffith critical stress (analogue)
    float max_pen = 0.0
    if n_touches > 0
        for j = 0 to zone.touch_pen_depths.size() - 1
            float pj = zone.touch_pen_depths.get(j)
            if pj > max_pen
                max_pen := pj
    float sigma_c = max_pen > 0 ? math.sqrt(2.0 * zone.vol / max_pen) : math.sqrt(2.0 * zone.vol)
    float t4 = math.min(1.0, sigma_c / math.max(1.0, pool_median))
    // t5 — T-VAR-8 RSI snap-back quality (mid-range = elastic; extremes = setup but rest follows)
    float t5 = math.min(1.0, math.abs(rsi_14 - 50.0) / 50.0)
    // t6 — T-VAR-9 CCI extremity
    float t6 = math.min(1.0, math.abs(cci_20) / 200.0)
    // t7 — T-VAR-13 KC envelope position
    float kc_position = (price - kc_lower) / math.max(1e-6, (kc_upper - kc_lower))
    float t7 = math.min(1.0, math.abs(kc_position - 0.5) * 2.0)
    // Tensile = arithmetic mean
    float T_score = (t1 + t2 + t3 + t4 + t5 + t6 + t7) / 7.0

    // ── ANTIFRAGILITY (A) ────────────────────────────────────────────────────
    // a1 — A-VAR-1 H_taleb (touch hold rates bucketed by volume)
    // Bucket touches into low / med / high volume; compute hold rate per bucket;
    // antifragile if (low + high)/2 > medium hold rate.
    float H_taleb = 0.0
    if n_touches >= 6
        // Find volume terciles
        array<float> sorted_v = array.new<float>()
        for j = 0 to zone.touch_vols.size() - 1
            sorted_v.push(zone.touch_vols.get(j))
        sorted_v.sort(order.ascending)
        float v_lo_thresh = sorted_v.get(int(sorted_v.size() / 3))
        float v_hi_thresh = sorted_v.get(int(2 * sorted_v.size() / 3))
        int lo_hold = 0, int lo_total = 0
        int md_hold = 0, int md_total = 0
        int hi_hold = 0, int hi_total = 0
        for j = 0 to zone.touch_vols.size() - 1
            float vj = zone.touch_vols.get(j)
            int rj = zone.touch_rejected.get(j)
            if vj <= v_lo_thresh
                lo_total += 1
                lo_hold += rj
            else if vj >= v_hi_thresh
                hi_total += 1
                hi_hold += rj
            else
                md_total += 1
                md_hold += rj
        float lo_rate = lo_total > 0 ? float(lo_hold) / lo_total : 0.5
        float md_rate = md_total > 0 ? float(md_hold) / md_total : 0.5
        float hi_rate = hi_total > 0 ? float(hi_hold) / hi_total : 0.5
        H_taleb := (lo_rate + hi_rate) / 2.0 - md_rate
    float a1 = math.min(1.0, math.max(0.0, (H_taleb + 0.5) / 1.0))  // map [-0.5, 0.5] → [0, 1]
    // a2 — A-VAR-2 convexity sign (cumulative pool growth across touches)
    float S_convex = 0.0
    if n_touches >= 3
        int last_idx = zone.pool_at_touch.size() - 1
        float s_first = zone.pool_at_touch.get(0)
        float s_mid   = zone.pool_at_touch.get(int(last_idx / 2))
        float s_last  = zone.pool_at_touch.get(last_idx)
        // Discrete second difference; positive = convex up = antifragile
        S_convex := (s_first + s_last) / 2.0 - s_mid
    float a2 = S_convex > 0 ? 1.0 : (S_convex < 0 ? 0.0 : 0.5)
    // a3 — A-VAR-5 Wolff stiffness (Carter-Hayes cube law)
    float wolff = thickness > 0 ? math.pow(zone.vol / math.max(1.0, thickness), 0.5) : 0.0  // sqrt instead of cube — Pine safer
    float wolff_threshold = math.sqrt(pool_median)
    float a3 = wolff_threshold > 0 ? math.min(1.0, wolff / (wolff_threshold * 2.0)) : 0.5
    // a4 — A-VAR-8 Hadfield ratio: E[v|rejected] / E[v|penetrated]
    float v_rejected_sum = 0.0, int v_rejected_n = 0
    float v_penetrated_sum = 0.0, int v_penetrated_n = 0
    if n_touches > 0
        for j = 0 to zone.touch_vols.size() - 1
            float vj = zone.touch_vols.get(j)
            int rj = zone.touch_rejected.get(j)
            if rj == 1
                v_rejected_sum += vj
                v_rejected_n += 1
            else
                v_penetrated_sum += vj
                v_penetrated_n += 1
    float v_rej_avg = v_rejected_n > 0 ? v_rejected_sum / v_rejected_n : 0.0
    float v_pen_avg = v_penetrated_n > 0 ? v_penetrated_sum / v_penetrated_n : 0.0
    float hadfield = v_pen_avg > 0 ? v_rej_avg / v_pen_avg : (v_rejected_n > 0 ? 2.0 : 1.0)
    float a4 = math.min(1.0, hadfield / 2.0)
    // a5 — A-VAR-9 Lindy term (age × touch_count, normalized)
    int age_bars = bar_index - zone.formation_bar
    float lindy = (zone.touch_count + 1.0) / (math.max(1.0, age_bars / 100.0) + 1.0)
    float a5 = math.min(1.0, lindy / 3.0)
    // External: earnings-window survival (Python enriches)
    float a_ext = tia_ext_earnings
    // Antifragility = arithmetic mean × earnings external boost
    float a_internal = (a1 + a2 + a3 + a4 + a5) / 5.0
    float A_score = math.min(1.0, a_internal * math.pow(a_ext, 0.3))

    // ── MASTER P (geometric mean) ────────────────────────────────────────────
    float wt_sum = w_imp + w_ten + w_ant
    float P = wt_sum > 0
              ? math.pow(math.pow(math.max(0.001, I_score), w_imp)
                       * math.pow(math.max(0.001, T_score), w_ten)
                       * math.pow(math.max(0.001, A_score), w_ant), 1.0 / wt_sum)
              : 0.0

    [I_score, T_score, A_score, P]


// ═══════════════════════════════════════════════════════════════════════════════
// CORE VOB FUNCTION — PRESERVED from canonical v8 (zone creation, invalidation,
// T3 signals, pool volumes). Modified ONLY to use f_new_level / f_invalid_level
// helpers for the extended UDT.
// ═══════════════════════════════════════════════════════════════════════════════

f_vob(int len1, array<level> up_lvl, array<level> lo_lvl, float atr_prox, float atr_adj, float sup_mult) =>
    int   len2    = len1 + 13
    float ema1    = ta.ema(close, len1)
    float ema2    = ta.ema(close, len2)
    bool  cup     = ta.crossover(ema1, ema2)  and barstate.isconfirmed
    bool  cdn     = ta.crossunder(ema1, ema2) and barstate.isconfirmed
    float lowest  = ta.lowest(len2)
    float highest = ta.highest(len2)

    if cup
        float vol = 0.0
        for i = 1 to len2
            if low[i] == lowest
                int index = time[i]
                for k = 0 to i
                    vol += volume[k]
                float src = math.min(open[i], close[i])
                src := (src - lowest) < atr_adj * 0.5 ? lowest + atr_adj * 0.5 : src
                float mid = math.avg(src, lowest)
                lo_lvl.push(f_new_level(index, src, lowest, mid, vol))

    if cdn
        float vol = 0.0
        for i = 1 to len2
            if high[i] == highest
                int index = time[i]
                for k = 0 to i
                    vol += volume[k]
                float src = math.max(open[i], close[i])
                src := (highest - src) < atr_adj * 0.5 ? highest - atr_adj * 0.5 : src
                float mid = math.avg(src, highest)
                up_lvl.push(f_new_level(index, highest, src, mid, vol))

    if lo_lvl.size() > 0
        for i = 0 to lo_lvl.size() - 1
            level l  = lo_lvl.get(i)
            level l1 = lo_lvl.get(i - 1)
            float mid  = l.mid
            float mid1 = l1.mid
            if math.abs(mid - mid1) < atr_prox
                lo_lvl.set(i - 1, f_invalid_level())
            if close < l.lower
                lo_lvl.set(i, f_invalid_level())
        if lo_lvl.size() > 15
            lo_lvl.shift()

    if up_lvl.size() > 0
        for i = 0 to up_lvl.size() - 1
            level l     = up_lvl.get(i)
            level l1    = up_lvl.get(i - 1)
            float upper = l.upper
            float mid   = l.mid
            float mid1  = l1.mid
            if math.abs(mid - mid1) < atr_prox
                up_lvl.set(i - 1, f_invalid_level())
            if close > upper
                up_lvl.set(i, f_invalid_level())
        if up_lvl.size() > 15
            up_lvl.shift()

    bool  t3_buy  = false
    bool  t3_sell = false
    float bp      = 0.0
    float sp      = 0.0

    if barstate.isconfirmed
        array<float> vbv = array.new<float>()
        array<float> vbl = array.new<float>()
        array<float> vbh = array.new<float>()
        if lo_lvl.size() > 0
            for i = 0 to lo_lvl.size() - 1
                level l = lo_lvl.get(i)
                if not na(l.vol)
                    vbv.push(l.vol)
                    vbl.push(l.lower)
                    vbh.push(l.upper)

        array<float> vav  = array.new<float>()
        array<float> val2 = array.new<float>()
        array<float> vah  = array.new<float>()
        if up_lvl.size() > 0
            for i = 0 to up_lvl.size() - 1
                level l = up_lvl.get(i)
                if not na(l.vol)
                    vav.push(l.vol)
                    val2.push(l.lower)
                    vah.push(l.upper)

        bp := vbv.size() > 0 ? vbv.sum() : 0.0
        sp := vav.size() > 0 ? vav.sum() : 0.0

        float db_vol = 0.0, float db_low = 0.0, float db_high = 0.0
        int bc = vbv.size()
        if bc > 0
            for i = 0 to bc - 1
                float v = vbv.get(i)
                if v > db_vol
                    db_vol  := v
                    db_low  := vbl.get(i)
                    db_high := vbh.get(i)

        float da_vol = 0.0, float da_low = 0.0, float da_high = 0.0
        int ac = vav.size()
        if ac > 0
            for i = 0 to ac - 1
                float v = vav.get(i)
                if v > da_vol
                    da_vol  := v
                    da_low  := val2.get(i)
                    da_high := vah.get(i)

        bool pat_bull = close >= db_low and close <= db_high
        bool pat_bear = close >= da_low and close <= da_high

        t3_buy  := bc == 1 and sp > 0 and db_vol > sp * sup_mult and pat_bull
        t3_sell := ac == 1 and bp > 0 and da_vol > bp * sup_mult and pat_bear

    [t3_buy, t3_sell, bp, sp]


// ─────────────────────────────────────────────────────────────────────────────
// FUNCTION CALLS — capture array sizes BEFORE for zone-creation detection
// ─────────────────────────────────────────────────────────────────────────────

int sz_la = lower_a.size(), int sz_ua = upper_a.size()
int sz_lb = lower_b.size(), int sz_ub = upper_b.size()
int sz_lc = lower_c.size(), int sz_uc = upper_c.size()
int sz_ld = lower_d.size(), int sz_ud = upper_d.size()
int sz_le = lower_e.size(), int sz_ue = upper_e.size()
int sz_lf = lower_f.size(), int sz_uf = upper_f.size()

[t3_buy_a, t3_sell_a, bpa, spa] = f_vob(sens_a, upper_a, lower_a, atr_proximity, atr_adjust, super_mult)
[t3_buy_b, t3_sell_b, bpb, spb] = f_vob(sens_b, upper_b, lower_b, atr_proximity, atr_adjust, super_mult)
[t3_buy_c, t3_sell_c, bpc, spc] = f_vob(sens_c, upper_c, lower_c, atr_proximity, atr_adjust, super_mult)
[t3_buy_d, t3_sell_d, bpd, spd] = f_vob(sens_d, upper_d, lower_d, atr_proximity, atr_adjust, super_mult)
[t3_buy_e, t3_sell_e, bpe, spe] = f_vob(sens_e, upper_e, lower_e, atr_proximity, atr_adjust, super_mult)
[t3_buy_f, t3_sell_f, bpf, spf] = f_vob(sens_f, upper_f, lower_f, atr_proximity, atr_adjust, super_mult)

// Zone-creation booleans (array grew = new zone pushed)
bool nzb_a = lower_a.size() > sz_la, bool nzs_a = upper_a.size() > sz_ua
bool nzb_b = lower_b.size() > sz_lb, bool nzs_b = upper_b.size() > sz_ub
bool nzb_c = lower_c.size() > sz_lc, bool nzs_c = upper_c.size() > sz_uc
bool nzb_d = lower_d.size() > sz_ld, bool nzs_d = upper_d.size() > sz_ud
bool nzb_e = lower_e.size() > sz_le, bool nzs_e = upper_e.size() > sz_ue
bool nzb_f = lower_f.size() > sz_lf, bool nzs_f = upper_f.size() > sz_uf


// ═══════════════════════════════════════════════════════════════════════════════
// TIA TOUCH TRACKING — update every active zone per bar
// ═══════════════════════════════════════════════════════════════════════════════

if barstate.isconfirmed
    f_update_touches(lower_a, true,  tia_max_touches)
    f_update_touches(lower_b, true,  tia_max_touches)
    f_update_touches(lower_c, true,  tia_max_touches)
    f_update_touches(lower_d, true,  tia_max_touches)
    f_update_touches(lower_e, true,  tia_max_touches)
    f_update_touches(lower_f, true,  tia_max_touches)
    f_update_touches(upper_a, false, tia_max_touches)
    f_update_touches(upper_b, false, tia_max_touches)
    f_update_touches(upper_c, false, tia_max_touches)
    f_update_touches(upper_d, false, tia_max_touches)
    f_update_touches(upper_e, false, tia_max_touches)
    f_update_touches(upper_f, false, tia_max_touches)


// ═══════════════════════════════════════════════════════════════════════════════
// ZONE METRICS (preserved — used by TIA computation + emission table)
// ═══════════════════════════════════════════════════════════════════════════════

int cnt_ba = f_count_active(lower_a), int cnt_sa = f_count_active(upper_a)
int cnt_bb = f_count_active(lower_b), int cnt_sb = f_count_active(upper_b)
int cnt_bc = f_count_active(lower_c), int cnt_sc = f_count_active(upper_c)
int cnt_bd = f_count_active(lower_d), int cnt_sd = f_count_active(upper_d)
int cnt_be = f_count_active(lower_e), int cnt_se = f_count_active(upper_e)
int cnt_bf = f_count_active(lower_f), int cnt_sf = f_count_active(upper_f)
int cnt_bull_all = cnt_ba + cnt_bb + cnt_bc + cnt_bd + cnt_be + cnt_bf
int cnt_bear_all = cnt_sa + cnt_sb + cnt_sc + cnt_sd + cnt_se + cnt_sf

int stk_bull = f_stack_near(lower_a, close, stack_thresh_pct) + f_stack_near(lower_b, close, stack_thresh_pct) + f_stack_near(lower_c, close, stack_thresh_pct) + f_stack_near(lower_d, close, stack_thresh_pct) + f_stack_near(lower_e, close, stack_thresh_pct) + f_stack_near(lower_f, close, stack_thresh_pct)
int stk_bear = f_stack_near(upper_a, close, stack_thresh_pct) + f_stack_near(upper_b, close, stack_thresh_pct) + f_stack_near(upper_c, close, stack_thresh_pct) + f_stack_near(upper_d, close, stack_thresh_pct) + f_stack_near(upper_e, close, stack_thresh_pct) + f_stack_near(upper_f, close, stack_thresh_pct)

float opp_a = f_nearest_above_pct(upper_a, close), float opp_b = f_nearest_above_pct(upper_b, close)
float opp_c = f_nearest_above_pct(upper_c, close), float opp_d = f_nearest_above_pct(upper_d, close)
float opp_e = f_nearest_above_pct(upper_e, close), float opp_f = f_nearest_above_pct(upper_f, close)
float bull_gap = math.min(opp_a, opp_b, opp_c, opp_d, opp_e, opp_f)
float opp_ba = f_nearest_below_pct(lower_a, close), float opp_bb = f_nearest_below_pct(lower_b, close)
float opp_bc = f_nearest_below_pct(lower_c, close), float opp_bd = f_nearest_below_pct(lower_d, close)
float opp_be = f_nearest_below_pct(lower_e, close), float opp_bf = f_nearest_below_pct(lower_f, close)
float bear_gap = math.min(opp_ba, opp_bb, opp_bc, opp_bd, opp_be, opp_bf)


// ═══════════════════════════════════════════════════════════════════════════════
// TIA — Find nearest bull / bear zone across all tiers, compute I/T/A/P
// ═══════════════════════════════════════════════════════════════════════════════

// Helper: across multiple per-tier arrays, find the (array, index, distance) of the nearest active zone.
// Returns tier letter (A-F) for diagnostics and a reference into the chosen array.

// Find nearest BULL zone overall — track which tier it's in
var int   bull_zone_tier_n = -1   // 0=A, 1=B, ..., 5=F; -1 = none
var int   bull_zone_idx    = -1
var float bull_zone_pool   = na

bull_zone_tier_n := -1
bull_zone_idx    := -1
bull_zone_pool   := na

float best_bull_d = 1e18

int idx_la_n = f_find_nearest_idx(lower_a, close)
if idx_la_n >= 0
    float d = math.abs(close - lower_a.get(idx_la_n).mid)
    if d < best_bull_d
        best_bull_d := d
        bull_zone_tier_n := 0
        bull_zone_idx := idx_la_n

int idx_lb_n = f_find_nearest_idx(lower_b, close)
if idx_lb_n >= 0
    float d = math.abs(close - lower_b.get(idx_lb_n).mid)
    if d < best_bull_d
        best_bull_d := d
        bull_zone_tier_n := 1
        bull_zone_idx := idx_lb_n

int idx_lc_n = f_find_nearest_idx(lower_c, close)
if idx_lc_n >= 0
    float d = math.abs(close - lower_c.get(idx_lc_n).mid)
    if d < best_bull_d
        best_bull_d := d
        bull_zone_tier_n := 2
        bull_zone_idx := idx_lc_n

int idx_ld_n = f_find_nearest_idx(lower_d, close)
if idx_ld_n >= 0
    float d = math.abs(close - lower_d.get(idx_ld_n).mid)
    if d < best_bull_d
        best_bull_d := d
        bull_zone_tier_n := 3
        bull_zone_idx := idx_ld_n

int idx_le_n = f_find_nearest_idx(lower_e, close)
if idx_le_n >= 0
    float d = math.abs(close - lower_e.get(idx_le_n).mid)
    if d < best_bull_d
        best_bull_d := d
        bull_zone_tier_n := 4
        bull_zone_idx := idx_le_n

int idx_lf_n = f_find_nearest_idx(lower_f, close)
if idx_lf_n >= 0
    float d = math.abs(close - lower_f.get(idx_lf_n).mid)
    if d < best_bull_d
        best_bull_d := d
        bull_zone_tier_n := 5
        bull_zone_idx := idx_lf_n

// Find nearest BEAR zone
var int bear_zone_tier_n = -1
var int bear_zone_idx    = -1

bear_zone_tier_n := -1
bear_zone_idx    := -1

float best_bear_d = 1e18

int idx_ua_n = f_find_nearest_idx(upper_a, close)
if idx_ua_n >= 0
    float d = math.abs(close - upper_a.get(idx_ua_n).mid)
    if d < best_bear_d
        best_bear_d := d
        bear_zone_tier_n := 0
        bear_zone_idx := idx_ua_n

int idx_ub_n = f_find_nearest_idx(upper_b, close)
if idx_ub_n >= 0
    float d = math.abs(close - upper_b.get(idx_ub_n).mid)
    if d < best_bear_d
        best_bear_d := d
        bear_zone_tier_n := 1
        bear_zone_idx := idx_ub_n

int idx_uc_n = f_find_nearest_idx(upper_c, close)
if idx_uc_n >= 0
    float d = math.abs(close - upper_c.get(idx_uc_n).mid)
    if d < best_bear_d
        best_bear_d := d
        bear_zone_tier_n := 2
        bear_zone_idx := idx_uc_n

int idx_ud_n = f_find_nearest_idx(upper_d, close)
if idx_ud_n >= 0
    float d = math.abs(close - upper_d.get(idx_ud_n).mid)
    if d < best_bear_d
        best_bear_d := d
        bear_zone_tier_n := 3
        bear_zone_idx := idx_ud_n

int idx_ue_n = f_find_nearest_idx(upper_e, close)
if idx_ue_n >= 0
    float d = math.abs(close - upper_e.get(idx_ue_n).mid)
    if d < best_bear_d
        best_bear_d := d
        bear_zone_tier_n := 4
        bear_zone_idx := idx_ue_n

int idx_uf_n = f_find_nearest_idx(upper_f, close)
if idx_uf_n >= 0
    float d = math.abs(close - upper_f.get(idx_uf_n).mid)
    if d < best_bear_d
        best_bear_d := d
        bear_zone_tier_n := 5
        bear_zone_idx := idx_uf_n


// Compute median pools per tier for normalization
float pool_med_lower = math.max(
   math.max(f_median_pool(lower_a), f_median_pool(lower_b)),
   math.max(math.max(f_median_pool(lower_c), f_median_pool(lower_d)),
            math.max(f_median_pool(lower_e), f_median_pool(lower_f))))
float pool_med_upper = math.max(
   math.max(f_median_pool(upper_a), f_median_pool(upper_b)),
   math.max(math.max(f_median_pool(upper_c), f_median_pool(upper_d)),
            math.max(f_median_pool(upper_e), f_median_pool(upper_f))))


// Tier agreement: count tiers that have an active zone within 1% of the nearest zone's mid
f_tier_agree(float ref_mid, array<level> a, array<level> b, array<level> c, array<level> d, array<level> e, array<level> f, float thresh_pct) =>
    int agree = 0
    if not na(ref_mid)
        bool found_a = false, bool found_b = false, bool found_c = false
        bool found_d = false, bool found_e = false, bool found_f = false
        if a.size() > 0
            for i = 0 to a.size() - 1
                level lv = a.get(i)
                if not na(lv.mid) and math.abs(lv.mid - ref_mid) / ref_mid * 100 <= thresh_pct
                    found_a := true
        if b.size() > 0
            for i = 0 to b.size() - 1
                level lv = b.get(i)
                if not na(lv.mid) and math.abs(lv.mid - ref_mid) / ref_mid * 100 <= thresh_pct
                    found_b := true
        if c.size() > 0
            for i = 0 to c.size() - 1
                level lv = c.get(i)
                if not na(lv.mid) and math.abs(lv.mid - ref_mid) / ref_mid * 100 <= thresh_pct
                    found_c := true
        if d.size() > 0
            for i = 0 to d.size() - 1
                level lv = d.get(i)
                if not na(lv.mid) and math.abs(lv.mid - ref_mid) / ref_mid * 100 <= thresh_pct
                    found_d := true
        if e.size() > 0
            for i = 0 to e.size() - 1
                level lv = e.get(i)
                if not na(lv.mid) and math.abs(lv.mid - ref_mid) / ref_mid * 100 <= thresh_pct
                    found_e := true
        if f.size() > 0
            for i = 0 to f.size() - 1
                level lv = f.get(i)
                if not na(lv.mid) and math.abs(lv.mid - ref_mid) / ref_mid * 100 <= thresh_pct
                    found_f := true
        if found_a
            agree += 1
        if found_b
            agree += 1
        if found_c
            agree += 1
        if found_d
            agree += 1
        if found_e
            agree += 1
        if found_f
            agree += 1
    agree

// Compute TIA scores for nearest bull and bear zones
float I_bull = na, float T_bull = na, float A_bull = na, float P_bull = na
float I_bear = na, float T_bear = na, float A_bear = na, float P_bear = na

if bull_zone_tier_n >= 0 and bull_zone_idx >= 0
    level lv_b = bull_zone_tier_n == 0 ? lower_a.get(bull_zone_idx)
              : bull_zone_tier_n == 1 ? lower_b.get(bull_zone_idx)
              : bull_zone_tier_n == 2 ? lower_c.get(bull_zone_idx)
              : bull_zone_tier_n == 3 ? lower_d.get(bull_zone_idx)
              : bull_zone_tier_n == 4 ? lower_e.get(bull_zone_idx)
              : lower_f.get(bull_zone_idx)
    int tier_agree_bull = f_tier_agree(lv_b.mid, lower_a, lower_b, lower_c, lower_d, lower_e, lower_f, 1.0)
    float slope_for_tier = bull_zone_tier_n == 0 ? slope_ema_a
                        : bull_zone_tier_n == 1 ? slope_ema_b
                        : bull_zone_tier_n == 2 ? slope_ema_c
                        : bull_zone_tier_n == 3 ? slope_ema_d
                        : bull_zone_tier_n == 4 ? slope_ema_e
                        : slope_ema_f
    [I_b_, T_b_, A_b_, P_b_] = f_compute_tia(lv_b, close, tier_agree_bull, stk_bull, pool_med_lower, atr_base, slope_for_tier, bull_gap, true)
    I_bull := I_b_
    T_bull := T_b_
    A_bull := A_b_
    P_bull := P_b_

if bear_zone_tier_n >= 0 and bear_zone_idx >= 0
    level lv_s = bear_zone_tier_n == 0 ? upper_a.get(bear_zone_idx)
              : bear_zone_tier_n == 1 ? upper_b.get(bear_zone_idx)
              : bear_zone_tier_n == 2 ? upper_c.get(bear_zone_idx)
              : bear_zone_tier_n == 3 ? upper_d.get(bear_zone_idx)
              : bear_zone_tier_n == 4 ? upper_e.get(bear_zone_idx)
              : upper_f.get(bear_zone_idx)
    int tier_agree_bear = f_tier_agree(lv_s.mid, upper_a, upper_b, upper_c, upper_d, upper_e, upper_f, 1.0)
    float slope_for_tier = bear_zone_tier_n == 0 ? slope_ema_a
                        : bear_zone_tier_n == 1 ? slope_ema_b
                        : bear_zone_tier_n == 2 ? slope_ema_c
                        : bear_zone_tier_n == 3 ? slope_ema_d
                        : bear_zone_tier_n == 4 ? slope_ema_e
                        : slope_ema_f
    [I_s_, T_s_, A_s_, P_s_] = f_compute_tia(lv_s, close, tier_agree_bear, stk_bear, pool_med_upper, atr_base, slope_for_tier, bear_gap, false)
    I_bear := I_s_
    T_bear := T_s_
    A_bear := A_s_
    P_bear := P_s_


// ═══════════════════════════════════════════════════════════════════════════════
// TIA THRESHOLD CROSSING DETECTION (with cooldown)
// ═══════════════════════════════════════════════════════════════════════════════

bool cross_t1_bull = not na(P_bull) and not na(prev_p_bull) and prev_p_bull < tia_thresh_t1 and P_bull >= tia_thresh_t1
bool cross_t2_bull = not na(P_bull) and not na(prev_p_bull) and prev_p_bull < tia_thresh_t2 and P_bull >= tia_thresh_t2
bool cross_t3_bull = not na(P_bull) and not na(prev_p_bull) and prev_p_bull < tia_thresh_t3 and P_bull >= tia_thresh_t3

bool cross_t1_bear = not na(P_bear) and not na(prev_p_bear) and prev_p_bear < tia_thresh_t1 and P_bear >= tia_thresh_t1
bool cross_t2_bear = not na(P_bear) and not na(prev_p_bear) and prev_p_bear < tia_thresh_t2 and P_bear >= tia_thresh_t2
bool cross_t3_bear = not na(P_bear) and not na(prev_p_bear) and prev_p_bear < tia_thresh_t3 and P_bear >= tia_thresh_t3

// Apply cooldown
bool fire_tia_t1_bull = show_tia_t1_bull and cross_t1_bull and f_cd_ok(last_tia_t1_bull, cooldown_bars)
bool fire_tia_t2_bull = show_tia_t2_bull and cross_t2_bull and f_cd_ok(last_tia_t2_bull, cooldown_bars)
bool fire_tia_t3_bull = show_tia_t3_bull and cross_t3_bull and f_cd_ok(last_tia_t3_bull, cooldown_bars)
bool fire_tia_t1_bear = show_tia_t1_bear and cross_t1_bear and f_cd_ok(last_tia_t1_bear, cooldown_bars)
bool fire_tia_t2_bear = show_tia_t2_bear and cross_t2_bear and f_cd_ok(last_tia_t2_bear, cooldown_bars)
bool fire_tia_t3_bear = show_tia_t3_bear and cross_t3_bear and f_cd_ok(last_tia_t3_bear, cooldown_bars)

// Stamp cooldown timestamps
if fire_tia_t1_bull
    last_tia_t1_bull := bar_index
if fire_tia_t2_bull
    last_tia_t2_bull := bar_index
if fire_tia_t3_bull
    last_tia_t3_bull := bar_index
if fire_tia_t1_bear
    last_tia_t1_bear := bar_index
if fire_tia_t2_bear
    last_tia_t2_bear := bar_index
if fire_tia_t3_bear
    last_tia_t3_bear := bar_index

// Update prev_p for next bar
if barstate.isconfirmed
    prev_p_bull := P_bull
    prev_p_bear := P_bear


// ═══════════════════════════════════════════════════════════════════════════════
// TIA PLOTSHAPES — six detection plots
// ═══════════════════════════════════════════════════════════════════════════════

plotshape(fire_tia_t1_bull, "TIA T1 Bull", shape.triangleup,   location.belowbar, color.new(#76FF03, 0), size = size.normal, text = "T1B", textcolor = color.new(#76FF03, 0))
plotshape(fire_tia_t2_bull, "TIA T2 Bull", shape.triangleup,   location.belowbar, color.new(#00C853, 0), size = size.large,  text = "T2B", textcolor = color.new(#00C853, 0))
plotshape(fire_tia_t3_bull, "TIA T3 Bull", shape.diamond,      location.belowbar, color.new(#1B5E20, 0), size = size.huge,   text = "T3B\nIRON", textcolor = color.new(#1B5E20, 0))

plotshape(fire_tia_t1_bear, "TIA T1 Bear", shape.triangledown, location.abovebar, color.new(#FF6E40, 0), size = size.normal, text = "T1S", textcolor = color.new(#FF6E40, 0))
plotshape(fire_tia_t2_bear, "TIA T2 Bear", shape.triangledown, location.abovebar, color.new(#D50000, 0), size = size.large,  text = "T2S", textcolor = color.new(#D50000, 0))
plotshape(fire_tia_t3_bear, "TIA T3 Bear", shape.diamond,      location.abovebar, color.new(#B71C1C, 0), size = size.huge,   text = "T3S\nIRON", textcolor = color.new(#B71C1C, 0))


// ═══════════════════════════════════════════════════════════════════════════════
// TIA ALERT — single any-call + Bloomberg-format alert()
// ═══════════════════════════════════════════════════════════════════════════════

bool any_tia = fire_tia_t1_bull or fire_tia_t2_bull or fire_tia_t3_bull or fire_tia_t1_bear or fire_tia_t2_bear or fire_tia_t3_bear

alertcondition(any_tia, "TIA Any Detection",
     "TIA detection plot fired — Imperviousness/Tensile/Antifragile score crossed a configured threshold. See Bloomberg message for which tier + direction.")

f_tia_alert_msg(string tier, string dir, float I_, float T_, float A_, float P_, int sens_val, level zone) =>
    "TIA_DETECTION" +
        "|TICKER:" + syminfo.ticker + "|EXCHANGE:" + syminfo.prefix +
        "|TF:" + timeframe.period +
        "|TIER:" + tier + "|DIR:" + dir +
        "|P:" + str.tostring(math.round(P_ * 10000) / 10000) +
        "|I:" + str.tostring(math.round(I_ * 10000) / 10000) +
        "|T:" + str.tostring(math.round(T_ * 10000) / 10000) +
        "|A:" + str.tostring(math.round(A_ * 10000) / 10000) +
        "|SENS:" + str.tostring(sens_val) +
        "|CLOSE:" + str.tostring(math.round(close * 100) / 100) +
        "|VOL:" + str.tostring(math.round(volume)) +
        "|VOLRANK:" + str.tostring(math.round(vol_rank)) +
        "|RSI:" + str.tostring(math.round(rsi_14 * 100) / 100) +
        "|CCI:" + str.tostring(math.round(cci_20 * 100) / 100) +
        "|ADX:" + str.tostring(math.round(adx_14 * 100) / 100) +
        "|SESS:" + str.tostring(sess_bar_count) +
        "|ZONE_MID:" + str.tostring(math.round(zone.mid * 100) / 100) +
        "|ZONE_VOL:" + str.tostring(math.round(zone.vol)) +
        "|ZONE_TOUCHES:" + str.tostring(zone.touch_count) +
        "|ZONE_AGE_BARS:" + str.tostring(bar_index - zone.formation_bar) +
        "|BULLZONES:" + str.tostring(cnt_bull_all) +
        "|BEARZONES:" + str.tostring(cnt_bear_all) +
        "|BULLSTACK:" + str.tostring(stk_bull) +
        "|BEARSTACK:" + str.tostring(stk_bear) +
        "|BULLGAP:" + str.tostring(math.round(bull_gap * 100) / 100) +
        "|BEARGAP:" + str.tostring(math.round(bear_gap * 100) / 100)

// Get the firing tier's sens value + zone reference for the alert payload
int sens_for_tier(int tn) =>
    tn == 0 ? sens_a : tn == 1 ? sens_b : tn == 2 ? sens_c : tn == 3 ? sens_d : tn == 4 ? sens_e : sens_f

if fire_tia_t1_bull and bull_zone_tier_n >= 0
    level zb = bull_zone_tier_n == 0 ? lower_a.get(bull_zone_idx)
            : bull_zone_tier_n == 1 ? lower_b.get(bull_zone_idx)
            : bull_zone_tier_n == 2 ? lower_c.get(bull_zone_idx)
            : bull_zone_tier_n == 3 ? lower_d.get(bull_zone_idx)
            : bull_zone_tier_n == 4 ? lower_e.get(bull_zone_idx)
            : lower_f.get(bull_zone_idx)
    alert(f_tia_alert_msg("1", "BULL", I_bull, T_bull, A_bull, P_bull, sens_for_tier(bull_zone_tier_n), zb), alert.freq_once_per_bar_close)
if fire_tia_t2_bull and bull_zone_tier_n >= 0
    level zb = bull_zone_tier_n == 0 ? lower_a.get(bull_zone_idx)
            : bull_zone_tier_n == 1 ? lower_b.get(bull_zone_idx)
            : bull_zone_tier_n == 2 ? lower_c.get(bull_zone_idx)
            : bull_zone_tier_n == 3 ? lower_d.get(bull_zone_idx)
            : bull_zone_tier_n == 4 ? lower_e.get(bull_zone_idx)
            : lower_f.get(bull_zone_idx)
    alert(f_tia_alert_msg("2", "BULL", I_bull, T_bull, A_bull, P_bull, sens_for_tier(bull_zone_tier_n), zb), alert.freq_once_per_bar_close)
if fire_tia_t3_bull and bull_zone_tier_n >= 0
    level zb = bull_zone_tier_n == 0 ? lower_a.get(bull_zone_idx)
            : bull_zone_tier_n == 1 ? lower_b.get(bull_zone_idx)
            : bull_zone_tier_n == 2 ? lower_c.get(bull_zone_idx)
            : bull_zone_tier_n == 3 ? lower_d.get(bull_zone_idx)
            : bull_zone_tier_n == 4 ? lower_e.get(bull_zone_idx)
            : lower_f.get(bull_zone_idx)
    alert(f_tia_alert_msg("3", "BULL", I_bull, T_bull, A_bull, P_bull, sens_for_tier(bull_zone_tier_n), zb), alert.freq_once_per_bar_close)
if fire_tia_t1_bear and bear_zone_tier_n >= 0
    level zb = bear_zone_tier_n == 0 ? upper_a.get(bear_zone_idx)
            : bear_zone_tier_n == 1 ? upper_b.get(bear_zone_idx)
            : bear_zone_tier_n == 2 ? upper_c.get(bear_zone_idx)
            : bear_zone_tier_n == 3 ? upper_d.get(bear_zone_idx)
            : bear_zone_tier_n == 4 ? upper_e.get(bear_zone_idx)
            : upper_f.get(bear_zone_idx)
    alert(f_tia_alert_msg("1", "BEAR", I_bear, T_bear, A_bear, P_bear, sens_for_tier(bear_zone_tier_n), zb), alert.freq_once_per_bar_close)
if fire_tia_t2_bear and bear_zone_tier_n >= 0
    level zb = bear_zone_tier_n == 0 ? upper_a.get(bear_zone_idx)
            : bear_zone_tier_n == 1 ? upper_b.get(bear_zone_idx)
            : bear_zone_tier_n == 2 ? upper_c.get(bear_zone_idx)
            : bear_zone_tier_n == 3 ? upper_d.get(bear_zone_idx)
            : bear_zone_tier_n == 4 ? upper_e.get(bear_zone_idx)
            : upper_f.get(bear_zone_idx)
    alert(f_tia_alert_msg("2", "BEAR", I_bear, T_bear, A_bear, P_bear, sens_for_tier(bear_zone_tier_n), zb), alert.freq_once_per_bar_close)
if fire_tia_t3_bear and bear_zone_tier_n >= 0
    level zb = bear_zone_tier_n == 0 ? upper_a.get(bear_zone_idx)
            : bear_zone_tier_n == 1 ? upper_b.get(bear_zone_idx)
            : bear_zone_tier_n == 2 ? upper_c.get(bear_zone_idx)
            : bear_zone_tier_n == 3 ? upper_d.get(bear_zone_idx)
            : bear_zone_tier_n == 4 ? upper_e.get(bear_zone_idx)
            : upper_f.get(bear_zone_idx)
    alert(f_tia_alert_msg("3", "BEAR", I_bear, T_bear, A_bear, P_bear, sens_for_tier(bear_zone_tier_n), zb), alert.freq_once_per_bar_close)


// ═══════════════════════════════════════════════════════════════════════════════
// NAGASAKI computation preserved (no longer plotted, no longer alerted, still
// tracked for historical reference + future TIA antifragility input).
// ═══════════════════════════════════════════════════════════════════════════════

var float maxVolEver = 0.0
bool isNagasaki = false
if volume[1] > maxVolEver
    maxVolEver := volume[1]
    isNagasaki := true


// ═══════════════════════════════════════════════════════════════════════════════
// LEGACY T3 COMPUTATION (still tracked for history; not plotted, not alerted)
// ═══════════════════════════════════════════════════════════════════════════════

bool plot_t3_buy_a  = t3_buy_a  and f_cd_ok(last_t3_buy_a,  cooldown_bars)
