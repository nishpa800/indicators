//@version=6
indicator("VOB Asym T3 ×6 + TIA v1", overlay = true
             , max_lines_count = 500, max_labels_count = 500, max_bars_back = 5000)

// ═══════════════════════════════════════════════════════════════════════════════
// VOB ASYM T3 ×6 + TIA v1 — IMPLEMENTATION OF TIA FRAMEWORK
// ═══════════════════════════════════════════════════════════════════════════════
//
// NEW FILE per SD-002 (never modify, always new-version). The canonical
// VOB_Asym_T3x6_MutEx_Claude_v8_2026-05-02.pine stays untouched. This is the
// TIA-v1 derivative.
//
// REFERENCE: docs/agentic-os/research/2026-05-11-tia-vob-framework-v2.html
//
// WHAT THIS FILE DOES (delta from canonical v8):
//
//   1. Per-zone TOUCH TRACKING — every active zone records its own history of
//      touches (price entries), with per-touch volume, penetration depth,
//      rejected/penetrated outcome, and pool-snapshot at the touch. State
//      lives in the extended `level` UDT.
//
//   2. TIA SCORE COMPUTATION — each bar computes Imperviousness (I),
//      Tensile (T), Antifragility (A) for the NEAREST bull zone and the
//      NEAREST bear zone (one zone each direction). Combined into master
//      probability P = (I × T × A)^(1/3). Variables sourced per the v2 research
//      doc §8 — 20 variables in Pine + 6 external-data placeholders that
//      the Python port enriches downstream.
//
//   3. SIX NEW DETECTION PLOTS — replacing the 12 zone-formation crosshatches
//      and 13 T3/Nagasaki plotshapes from canonical. Fire on first crossing
//      of P thresholds 0.50, 0.625, 0.875 (TIER 1, TIER 2, TIER 3):
//         • TIA TIER 1 Bull / Bear (P ≥ 0.50)
//         • TIA TIER 2 Bull / Bear (P ≥ 0.625)
//         • TIA TIER 3 Bull / Bear (P ≥ 0.875)
//
//   4. SINGLE ANY-CALL ALERTCONDITION — `any_tia` fires on ANY TIA detection.
//      Bloomberg-format alert() carries the full TIA payload (I, T, A, P,
//      tier crossed, direction, zone metadata).
//
// WHAT THIS FILE REMOVED from canonical v8:
//   - The 12 zone-formation crosshatch plotshapes (ZoneBull/Bear A-F)
//   - The 13 T3/Nagasaki plotshapes (T3a-f Buy/Sell + Nagasaki)
//   - The "any_t3" and "any_zone" alertconditions
//   - The T3 alert() multiplexer (13 alert calls)
//   - The zone formation alert() emission
//
// WHAT THIS FILE PRESERVED from canonical v8:
//   - The entire zone DRAWING engine (lines + fills + midlines + MutEx overlap)
//   - The audit table (last N zone events per tier)
//   - The T3 signal table (last N T3 signals — still computed for history)
//   - The zone formation labels (data_get_pine_labels — research input)
//   - The log.info() per-bar streaming (pine_get_console)
//   - The comprehensive emission table — ENHANCED with TIA score rows
//   - All supplementary market state (RSI, vol_rank, sess_bar_count,
//     ATH volume, EMA slopes)
//
// TIA SOURCES (per v2 research doc §8):
//
//   Imperviousness (I) — 15 vars, 8 implemented in Pine + 7 external
//     I-VAR-1 R_t (pool × tier × stack)                  [Pine]
//     I-VAR-2 tier_agreement_count                        [Pine]
//     I-VAR-3 stack_count_2pct                            [Pine]
//     I-VAR-4 zone_thickness_atr                          [Pine]
//     I-VAR-5 obliquity_slope                             [Pine]
//     I-VAR-6 d_price_norm                                [Pine]
//     I-VAR-10 vwap_alignment                             [Pine — ta.vwap]
//     I-VAR-11 adx_strength                               [Pine — ta.adx]
//     I-VAR-7 plug_consumption                            [Python port]
//     I-VAR-8 cross_indicator_confluence                  [Python port]
//     I-VAR-9 htf_alignment                               [Python port — request.security in v2]
//     I-VAR-12 HVL_volume                                 [Python port]
//     I-VAR-13 sector_relative_strength                   [Python port]
//     I-VAR-14 book_depth_imbalance                       [Python port — external MCP]
//     I-VAR-15 options_strike_density                     [Python port — external MCP]
//
//   Tensile (T) — 13 vars, 7 implemented in Pine + 6 external
//     T-VAR-1 v_pool_norm                                 [Pine]
//     T-VAR-2 success_rate                                [Pine — touch history]
//     T-VAR-3 K_discrete (toughness integral)             [Pine — touch history]
//     T-VAR-4 sigma_c (Griffith critical stress)          [Pine]
//     T-VAR-8 rsi_snap_back_quality                       [Pine — ta.rsi]
//     T-VAR-9 cci_extremity                               [Pine — ta.cci]
//     T-VAR-13 volatility_envelope                        [Pine — ta.kc]
//     T-VAR-5,6,7,10,11,12                                [Python port v2]
//
//   Antifragility (A) — 10 vars, 5 implemented in Pine + 5 external
//     A-VAR-1 H_taleb                                     [Pine — touch history]
//     A-VAR-2 S_convexity_c                               [Pine — touch history]
//     A-VAR-5 wolff_stiffness                             [Pine]
//     A-VAR-8 hadfield_ratio                              [Pine — touch history]
//     A-VAR-9 lindy_term                                  [Pine]
//     A-VAR-3,4,6,7,10                                    [Python port v2]
//
// External-data placeholders default to 1.0 (neutral) — the Python port at
// python_ports/vob_asym/canonical_tia_v1.py enriches them with real values
// from TradingView MCP, Massive.com options data, Benzinga, WhaleWisdom.
//
// ═══════════════════════════════════════════════════════════════════════════════


// ─────────────────────────────────────────────────────────────────────────────
// UDTs — extended `level` with TIA touch tracking
// ─────────────────────────────────────────────────────────────────────────────

type level
    int   indx              // Origin bar time (xloc.bar_time)
    float upper
    float lower
    float mid
    float vol               // Accumulated pool volume at formation
    // ── TIA touch tracking ──
    int   formation_bar     // bar_index at formation (for age/Lindy)
    int   touch_count
    array<float> touch_vols          // volume on bar that entered the zone
    array<float> touch_pen_depths    // deepest penetration during visit, normalized to zone width
    array<int>   touch_rejected      // 1 = rejected (held), 0 = penetrated (broke through)
    array<float> pool_at_touch       // pool-volume snapshot when this touch began
    int   currently_touching         // 0 = outside, 1 = inside (touch in progress)
    int   touch_entry_bar            // bar_index when current visit began
    float deepest_pen_this_visit     // deepest penetration during current visit
    float entry_pool                 // pool snapshot when current visit began

type hist_entry
    int   t
    float vol
    float pct
    string date_s


