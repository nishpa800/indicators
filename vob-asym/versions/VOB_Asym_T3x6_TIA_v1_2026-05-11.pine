    table.cell(tbl, 2, 1, f_evt_cell(hb_a, 0), text_color=tbl_fc, bgcolor=tbl_bc, text_size=tbl_sz, text_halign=text.align_left)
    table.cell(tbl, 3, 1, f_evt_cell(hb_a, 1), text_color=tbl_fc, bgcolor=tbl_bc, text_size=tbl_sz, text_halign=text.align_left)
    table.cell(tbl, 4, 1, f_evt_cell(hb_a, 2), text_color=tbl_fc, bgcolor=tbl_bc, text_size=tbl_sz, text_halign=text.align_left)
    table.cell(tbl, 0, 2, sla, text_color=color.new(col_bear_a, 0), bgcolor=color.new(col_bear_a, 88), text_size=tbl_sz, text_halign=text.align_center)
    table.cell(tbl, 1, 2, "▼", text_color=color.new(col_bear_a, 0), bgcolor=color.new(col_bear_a, 88), text_size=tbl_sz, text_halign=text.align_center)
