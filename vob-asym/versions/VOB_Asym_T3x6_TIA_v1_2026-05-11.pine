        syminfo.ticker, timeframe.period,
        str.tostring(close), str.tostring(math.round(rsi_14 * 100) / 100),
        str.tostring(math.round(cci_20 * 100) / 100), str.tostring(math.round(adx_14 * 100) / 100),
        str.tostring(sess_bar_count), str.tostring(math.round(vol_rank)),
