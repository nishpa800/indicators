// ═══════════════════════════════════════════════════════════════════════════════
// EMISSION TABLE — extended with TIA score row
// ═══════════════════════════════════════════════════════════════════════════════

if en_emission_table and barstate.islast
    color efc = color.new(#E0E0E0, 0)
    color ebc = color.new(#1A1A1A, 30)
    color ehc = color.new(#333333, 15)
    string esz = size.tiny
    var table etbl = table.new(position.top_left, 5, 12, border_color=color.new(#444444, 50), border_width=1)

    table.cell(etbl, 0, 0, "TIA SCORES", text_color=color.yellow, bgcolor=ehc, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 1, 0, "I",  text_color=efc, bgcolor=ehc, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 2, 0, "T",  text_color=efc, bgcolor=ehc, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 3, 0, "A",  text_color=efc, bgcolor=ehc, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 4, 0, "P",  text_color=efc, bgcolor=ehc, text_size=esz, text_halign=text.align_center)

    color bull_col = color.new(#00C853, 70)
    color bear_col = color.new(#D50000, 70)
    table.cell(etbl, 0, 1, "BULL", text_color=color.white, bgcolor=bull_col, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 1, 1, na(I_bull) ? "—" : str.tostring(math.round(I_bull * 1000) / 1000), text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_right)
    table.cell(etbl, 2, 1, na(T_bull) ? "—" : str.tostring(math.round(T_bull * 1000) / 1000), text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_right)
    table.cell(etbl, 3, 1, na(A_bull) ? "—" : str.tostring(math.round(A_bull * 1000) / 1000), text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_right)
    color p_bull_col = na(P_bull) ? ebc : (P_bull >= tia_thresh_t3 ? color.new(#1B5E20, 0) : P_bull >= tia_thresh_t2 ? color.new(#00C853, 30) : P_bull >= tia_thresh_t1 ? color.new(#76FF03, 50) : ebc)
    table.cell(etbl, 4, 1, na(P_bull) ? "—" : str.tostring(math.round(P_bull * 1000) / 1000), text_color=na(P_bull) ? efc : color.white, bgcolor=p_bull_col, text_size=esz, text_halign=text.align_right)

    table.cell(etbl, 0, 2, "BEAR", text_color=color.white, bgcolor=bear_col, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 1, 2, na(I_bear) ? "—" : str.tostring(math.round(I_bear * 1000) / 1000), text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_right)
    table.cell(etbl, 2, 2, na(T_bear) ? "—" : str.tostring(math.round(T_bear * 1000) / 1000), text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_right)
    table.cell(etbl, 3, 2, na(A_bear) ? "—" : str.tostring(math.round(A_bear * 1000) / 1000), text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_right)
    color p_bear_col = na(P_bear) ? ebc : (P_bear >= tia_thresh_t3 ? color.new(#B71C1C, 0) : P_bear >= tia_thresh_t2 ? color.new(#D50000, 30) : P_bear >= tia_thresh_t1 ? color.new(#FF6E40, 50) : ebc)
    table.cell(etbl, 4, 2, na(P_bear) ? "—" : str.tostring(math.round(P_bear * 1000) / 1000), text_color=na(P_bear) ? efc : color.white, bgcolor=p_bear_col, text_size=esz, text_halign=text.align_right)

    table.cell(etbl, 0, 3, "THRESHOLDS", text_color=color.yellow, bgcolor=ehc, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 1, 3, "T1=" + str.tostring(tia_thresh_t1), text_color=efc, bgcolor=ebc, text_size=esz)
    table.cell(etbl, 2, 3, "T2=" + str.tostring(tia_thresh_t2), text_color=efc, bgcolor=ebc, text_size=esz)
    table.cell(etbl, 3, 3, "T3=" + str.tostring(tia_thresh_t3), text_color=efc, bgcolor=ebc, text_size=esz)
    table.cell(etbl, 4, 3, "wI/wT/wA=" + str.tostring(w_imp) + "/" + str.tostring(w_ten) + "/" + str.tostring(w_ant), text_color=efc, bgcolor=ebc, text_size=esz)

    table.cell(etbl, 0, 4, "MARKET", text_color=color.yellow, bgcolor=ehc, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 1, 4, syminfo.ticker, text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_left)
    table.cell(etbl, 2, 4, "TF:" + timeframe.period, text_color=efc, bgcolor=ebc, text_size=esz, text_halign=text.align_left)
    table.cell(etbl, 3, 4, "RSI:" + str.tostring(math.round(rsi_14)), text_color=rsi_14 < 30 ? color.lime : rsi_14 > 70 ? color.red : efc, bgcolor=ebc, text_size=esz)
    table.cell(etbl, 4, 4, "ADX:" + str.tostring(math.round(adx_14)), text_color=adx_14 >= 25 ? color.lime : efc, bgcolor=ebc, text_size=esz)

    table.cell(etbl, 0, 5, "STACK", text_color=color.yellow, bgcolor=ehc, text_size=esz, text_halign=text.align_center)
    table.cell(etbl, 1, 5, "BULL:" + str.tostring(stk_bull), text_color=stk_bull >= 3 ? color.lime : efc, bgcolor=ebc, text_size=esz)
    table.cell(etbl, 2, 5, "BEAR:" + str.tostring(stk_bear), text_color=stk_bear >= 3 ? color.red : efc, bgcolor=ebc, text_size=esz)
    table.cell(etbl, 3, 5, "GAP_B:" + str.tostring(math.round(bull_gap * 100) / 100) + "%", text_color=bull_gap >= 30 ? color.lime : efc, bgcolor=ebc, text_size=esz)
    table.cell(etbl, 4, 5, "GAP_S:" + str.tostring(math.round(bear_gap * 100) / 100) + "%", text_color=bear_gap >= 30 ? color.red : efc, bgcolor=ebc, text_size=esz)


