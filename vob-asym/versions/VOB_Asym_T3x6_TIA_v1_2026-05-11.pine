    table.cell(tbl, 2, 0, "Last 1", text_color=tbl_fc, bgcolor=tbl_hc, text_size=tbl_sz, text_halign=text.align_center)
    table.cell(tbl, 3, 0, "Last 2", text_color=tbl_fc, bgcolor=tbl_hc, text_size=tbl_sz, text_halign=text.align_center)
    table.cell(tbl, 4, 0, "Last 3", text_color=tbl_fc, bgcolor=tbl_hc, text_size=tbl_sz, text_halign=text.align_center)

    string sla = str.tostring(sens_a)
    table.cell(tbl, 0, 1, sla, text_color=color.new(col_bull_a, 0), bgcolor=color.new(col_bull_a, 88), text_size=tbl_sz, text_halign=text.align_center)
