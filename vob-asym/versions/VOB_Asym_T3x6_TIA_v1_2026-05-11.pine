bool show_tia_t1_bear = input.bool(true, "TIA TIER 1 Bear (P ≥ 0.50)",  group = "TIA Detection Plots")
bool show_tia_t2_bear = input.bool(true, "TIA TIER 2 Bear (P ≥ 0.625)", group = "TIA Detection Plots")
bool show_tia_t3_bear = input.bool(true, "TIA TIER 3 Bear (P ≥ 0.875)", group = "TIA Detection Plots")


