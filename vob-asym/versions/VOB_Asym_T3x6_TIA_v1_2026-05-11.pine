color tbl_fc = color.new(tbl_font_col, 0)
color tbl_bc = color.new(tbl_bg_col, tbl_bg_tr)
color tbl_hc = color.new(tbl_hdr_col, tbl_hdr_tr)

if tbl_show and barstate.islast
    var table tbl = table.new(tbl_pos, 5, 14, border_color = color.new(#444444, 50), border_width = 1)

    table.cell(tbl, 0, 0, "Sens",   text_color=tbl_fc, bgcolor=tbl_hc, text_size=tbl_sz, text_halign=text.align_center)
