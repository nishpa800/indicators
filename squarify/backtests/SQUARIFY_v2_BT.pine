        bool bhvd = i >= 1 ? nz(hvd_fire_bear[i - 1]) : false
        bool bdisp = nz(sigDISPBear[i]) or bhvd, bool bfauna = nz(sigFAUNABear[i])
        bool bsaab = nz(sigKratos[i]) or nz(sigBearRVOL1x[i]) or nz(sigMOAB[i])
        bool bsa = nz(sigKratos[i]), bool br1 = nz(sigBearRVOL1x[i]), bool bgs = nz(sigMOAB[i])
        bool bdf = bdisp or bfauna
        if bpbj
            _has_pbj := true
        if bpb
            _has_pb := true
        if bhvd
            _has_hvd := true
        if bdisp
            _has_disp := true
        if bfauna
            _has_fauna := true
        if bsa
            _has_sa := true
        if br1
            _has_r1 := true
        if bgs
            _has_gs := true
        if not bdisp
            _all_disp := false
        if not bsaab or not bdf
            _all_saab_df := false
        if bdf and not bpbj
            _df_not_pbj := true
        if bpbj and not bdf
            _pbj_not_df := true
    bool pA = u_bear_hasDay1 and _has_pbj, bool pB = _all_disp, bool pC = _all_saab_df
    bool pD = _has_hvd, bool pE = (_df_not_pbj and _has_pbj) or (_pbj_not_df and (_has_disp or _has_fauna))
    bool pF = (_has_fauna or _has_disp) and _has_pbj
    int _qcnt = (_has_pbj?1:0)+(_has_disp?1:0)+(_has_fauna?1:0)+(_has_sa?1:0)+(_has_r1?1:0)+(_has_gs?1:0)
    bool pG = _qcnt >= 4
    sigP21BearUUUU := pA or pB or pC or pD or pE or pF or pG
    sigP21BearUUUU_indep := pA or pB or pC or pE or pF or pG

// ─── BEAR DDD (exactly 3) ───
bool sigP21BearUUU = false, bool sigP21BearUUU_indep = false
if conf and u_bear_streak == 3
    bool _has_pbj = false, bool _has_pb = false, bool _has_hvd = false, bool _has_disp = false, bool _has_fauna = false
    bool _all_disp = true, bool _all_saab_df = true, bool _df_not_pbj = false, bool _pbj_not_df = false
    bool _has_sa = false, bool _has_r1 = false, bool _has_gs = false
    for i = 0 to 2
        bool bpbj = nz(sigBearPBJ[i]), bool bpb = nz(sigBearPB[i])
        bool bhvd = i >= 1 ? nz(hvd_fire_bear[i - 1]) : false
        bool bdisp = nz(sigDISPBear[i]) or bhvd, bool bfauna = nz(sigFAUNABear[i])
        bool bsaab = nz(sigKratos[i]) or nz(sigBearRVOL1x[i]) or nz(sigMOAB[i])
        bool bsa = nz(sigKratos[i]), bool br1 = nz(sigBearRVOL1x[i]), bool bgs = nz(sigMOAB[i])
        bool bdf = bdisp or bfauna
        if bpbj
            _has_pbj := true
        if bpb
            _has_pb := true
        if bhvd
            _has_hvd := true
        if bdisp
            _has_disp := true
        if bfauna
            _has_fauna := true
        if bsa
            _has_sa := true
        if br1
            _has_r1 := true
        if bgs
            _has_gs := true
        if not bdisp
            _all_disp := false
        if not bsaab or not bdf
            _all_saab_df := false
        if bdf and not bpbj
            _df_not_pbj := true
        if bpbj and not bdf
            _pbj_not_df := true
    bool pA = u_bear_hasDay1 and _has_pbj, bool pB = _all_disp, bool pC = _all_saab_df
    bool pD = _has_hvd, bool pE = (_df_not_pbj and _has_pbj) or (_pbj_not_df and (_has_disp or _has_fauna))
    int _qcnt = (_has_pbj?1:0)+(_has_disp?1:0)+(_has_fauna?1:0)+(_has_sa?1:0)+(_has_r1?1:0)+(_has_gs?1:0)
    bool pG = _qcnt >= 3
    sigP21BearUUU := pA or pB or pC or pD or pE or pG
    sigP21BearUUU_indep := pA or pB or pC or pE or pG

// ─── BEAR DD (exactly 2) ───
bool sigUUBear = false, bool sigUUBear_indep = false
if conf and u_bear_streak == 2
    bool _has_pbj = false, bool _has_pb = false, bool _has_hvd = false, bool _has_disp = false, bool _has_fauna = false
    bool _all_disp = true, bool _all_saab_df = true, bool _df_not_pbj = false, bool _pbj_not_df = false
    bool _has_sa = false, bool _has_r1 = false, bool _has_gs = false
    for i = 0 to 1
        bool bpbj = nz(sigBearPBJ[i]), bool bpb = nz(sigBearPB[i])
        bool bhvd = i >= 1 ? nz(hvd_fire_bear[i - 1]) : false
        bool bdisp = nz(sigDISPBear[i]) or bhvd, bool bfauna = nz(sigFAUNABear[i])
        bool bsaab = nz(sigKratos[i]) or nz(sigBearRVOL1x[i]) or nz(sigMOAB[i])
        bool bsa = nz(sigKratos[i]), bool br1 = nz(sigBearRVOL1x[i]), bool bgs = nz(sigMOAB[i])
        bool bdf = bdisp or bfauna
        if bpbj
            _has_pbj := true
        if bpb
            _has_pb := true
        if bhvd
            _has_hvd := true
        if bdisp
            _has_disp := true
        if bfauna
            _has_fauna := true
        if bsa
            _has_sa := true
        if br1
            _has_r1 := true
        if bgs
            _has_gs := true
        if not bdisp
            _all_disp := false
        if not bsaab or not bdf
            _all_saab_df := false
        if bdf and not bpbj
            _df_not_pbj := true
        if bpbj and not bdf
            _pbj_not_df := true
    bool pA = u_bear_hasDay1 and _has_pbj, bool pB = _all_disp, bool pC = _all_saab_df
    bool pD = _has_hvd and (_has_pb or _has_pbj), bool pE = (_df_not_pbj and _has_pbj) or (_pbj_not_df and (_has_disp or _has_fauna))
    int _qcnt = (_has_pbj?1:0)+(_has_disp?1:0)+(_has_fauna?1:0)+(_has_sa?1:0)+(_has_r1?1:0)+(_has_gs?1:0)
    bool pG = _qcnt >= 2
    sigUUBear := pA or pB or pC or pD or pE or pG
    sigUUBear_indep := pA or pB or pC or pE or pG

bool is_matrix_number=volume==ta.highest(volume,neo_len)
bool sigNeoBull=conf and is_matrix_number and sigFAUNABull, bool sigNeoBear=conf and is_matrix_number and sigFAUNABear
bool sigTrinityBull=conf and is_matrix_number and not sigFAUNABull and close>open, bool sigTrinityBear=conf and is_matrix_number and not sigFAUNABear and close<open

// === ENGINE 9: SESSION + ALPHA STRIKE ===
var bool daySignalFired=false
if is_new_day
    daySignalFired:=false
bool firstOfDay=not daySignalFired

bool sigFoxtrotBull=conf and sigFAUNABull and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2]) and nz(sigFAUNABull[3])
bool sigFoxtrotBear=conf and sigFAUNABear and nz(sigFAUNABear[1]) and nz(sigFAUNABear[2]) and nz(sigFAUNABear[3])

// === ENGINE 11: LONG/SHORT ===
[currentVol_r,pastVol_r,_r2]=tv_ta.relativeVolume(reg_length,reg_anchorTimeframe,false,reg_adjustRealtime)
[currentVol_c,pastVol_c,_c2]=tv_ta.relativeVolume(reg_length,reg_anchorTimeframe,true,reg_adjustRealtime)
float ls_regRatio=nz(currentVol_r/pastVol_r), float ls_cumRatio=nz(currentVol_c/pastVol_c)
float ls_bodyRat=(high-low)==0?0.0:math.abs(close-open)/(high-low)
bool sigLong1=conf and ls_regRatio>ls_reg1 and ls_cumRatio>ls_cum1 and close>open and ls_bodyRat>=ls_body1
bool sigShort1=conf and ls_regRatio>ls_reg1 and ls_cumRatio>ls_cum1 and close<open and ls_bodyRat>=ls_body1
bool sigLong2=conf and ls_regRatio>ls_reg2 and ls_cumRatio>ls_cum2 and close>open and ls_bodyRat>=ls_body2
bool sigShort2=conf and ls_regRatio>ls_reg2 and ls_cumRatio>ls_cum2 and close<open and ls_bodyRat>=ls_body2

bool neo_bull_aligned=sigNeoBull and (sigLong1 or sigLong2), bool neo_bear_aligned=sigNeoBear and (sigShort1 or sigShort2)
bool trinity_bull_aligned=sigTrinityBull and (sigLong1 or sigLong2), bool trinity_bear_aligned=sigTrinityBear and (sigShort1 or sigShort2)

// === COMBO SETS ===
float cs_bp1=high[1]-low[1]==0?0.0:math.abs(close[1]-open[1])/(high[1]-low[1])
bool cs_vb=cs_bp1>=cs_bodyPct_FVG
bool comboSet1_Bull=conf and cs_vb and (gz_bullHV or gz_bullGZI) and (sigSAAB[1] or sigBullRVOL1x[1] or sigGrandSlam[1])
bool comboSet1_Bear=conf and cs_vb and (gz_bearHV or gz_bearGZI) and (sigKratos[1] or sigBearRVOL1x[1] or sigMOAB[1])
bool comboSet2_Bull=conf and cs_vb and (gz_bullHV or gz_bullGZI) and ((cs_inc_pentagon_FVG and sigPentagon[1]) or sigWTC[1] or sigHiroshima[1] or sigNagasaki[1])
bool comboSet2_Bear=conf and cs_vb and (gz_bearHV or gz_bearGZI) and ((cs_inc_pentagon_FVG and sigPentagon[1]) or sigWTC[1] or sigHiroshima[1] or sigNagasaki[1])
bool cs_vm=ls_bodyRat>=cs_bodyPct_MAT
bool matrix_any_bull=sigNeoBull or sigTrinityBull or neo_bull_aligned or trinity_bull_aligned
bool matrix_any_bear=sigNeoBear or sigTrinityBear or neo_bear_aligned or trinity_bear_aligned
bool comboSet3_Bull=cs_vm and matrix_any_bull and (sigSAAB or sigBullRVOL1x or sigGrandSlam)
bool comboSet3_Bear=cs_vm and matrix_any_bear and (sigKratos or sigBearRVOL1x or sigMOAB)
bool comboSet4_Bull=cs_vm and matrix_any_bull and ((cs_inc_pentagon_MAT and sigPentagon) or sigWTC or sigHiroshima or sigNagasaki)
bool comboSet4_Bear=cs_vm and matrix_any_bear and ((cs_inc_pentagon_MAT and sigPentagon) or sigWTC or sigHiroshima or sigNagasaki)

bool csNew1_Bull=comboSet1_Bull or comboSet2_Bull, bool csNew1_Bear=comboSet1_Bear or comboSet2_Bear
bool csNew2_Bull=comboSet3_Bull or comboSet4_Bull, bool csNew2_Bear=comboSet3_Bear or comboSet4_Bear
bool csNew3_Bull=csNew1_Bull and nz(csNew2_Bull[1]), bool csNew3_Bear=csNew1_Bear and nz(csNew2_Bear[1])

// Alpha Strike — FIX: PBJ ONLY (PB removed per spec)
bool as_fauna_bull=sigFAUNABull or sigLong1 or sigDISPBull or sigPUP or sigWTC or sigHiroshima or sigNagasaki
bool as_fauna_bear=sigFAUNABear or sigShort1 or sigDISPBear or sigPPD or sigWTC or sigHiroshima or sigNagasaki
bool sigAlphaStrikeBull=conf and firstOfDay and bull_pp and (sigGrandSlam or sigBullRVOL1x) and sigBullPBJ and as_fauna_bull
bool sigAlphaStrikeBear=conf and firstOfDay and bear_pp and (sigMOAB or sigBearRVOL1x) and sigBearPBJ and as_fauna_bear

// Opening Drive — FIX: offset -1 (disp_prevDisp+FVG). PUP/PBJ at [1].
bool od_fvg_bull=gz_bullGZI or comboSet1_Bull or comboSet2_Bull or comboSet3_Bull or comboSet4_Bull
bool od_fvg_bear=gz_bearGZI or comboSet1_Bear or comboSet2_Bear or comboSet3_Bear or comboSet4_Bear
bool sigODBull=conf and sessionBarCount<=(od_max_bars+1) and od_fvg_bull and disp_prevDisp and nz(sigPUP[1]) and nz(sigBullPBJ[1])
bool sigODBear=conf and sessionBarCount<=(od_max_bars+1) and od_fvg_bear and disp_prevDisp and nz(sigPPD[1]) and nz(sigBearPBJ[1])

// HV 75-1000
bool sigHV75=conf and volume>=ta.highest(volume,75)[1], bool sigHV150=conf and volume>=ta.highest(volume,hv150_len)[1]
bool sigHV500=conf and volume>=ta.highest(volume,500)[1], bool sigHV1000=conf and volume>=ta.highest(volume,1000)[1]

// Golf + PAF
bool sigGolfBull=conf and sigDISPBull and nz(sigFAUNABull[1]) and nz(sigPUP[1]) and nz(sigDISPBull[1]) and nz(sigFAUNABull[2]) and nz(sigPUP[2])
bool sigGolfBear=conf and sigDISPBear and nz(sigFAUNABear[1]) and nz(sigPPD[1]) and nz(sigDISPBear[1]) and nz(sigFAUNABear[2]) and nz(sigPPD[2])
bool sigPAFBull=conf and sigPUP and sigFAUNABull and nz(sigPUP[1]) and nz(sigFAUNABull[1])
bool sigPAFBear=conf and sigPPD and sigFAUNABear and nz(sigPPD[1]) and nz(sigFAUNABear[1])

// Combo Chain
int cc_win_bull=0, bool cc_pbj_bull=false
for i=0 to cc_window-1
    if nz(csNew1_Bull[i]) or nz(csNew2_Bull[i])
        cc_win_bull+=1
    if nz(sigBullPBJ[i]) or nz(sigBullPB[i])
        cc_pbj_bull:=true
for i=0 to math.max(cc_window-2, 0)
    if i+1 <= cc_window-1 and nz(csNew3_Bull[i])
        cc_win_bull-=1
int cc_win_bear=0, bool cc_pbj_bear=false
for i=0 to cc_window-1
    if nz(csNew1_Bear[i]) or nz(csNew2_Bear[i])
        cc_win_bear+=1
    if nz(sigBearPBJ[i]) or nz(sigBearPB[i])
        cc_pbj_bear:=true
for i=0 to math.max(cc_window-2, 0)
    if i+1 <= cc_window-1 and nz(csNew3_Bear[i])
        cc_win_bear-=1

var bool cc_bull_active=false, var bool cc_bear_active=false
if conf
    if not (csNew1_Bull or csNew2_Bull)
        cc_bull_active:=false
    else if not cc_bull_active and cc_win_bull>=cc_min_hits and cc_pbj_bull
        cc_bull_active:=true
if conf
    if not (csNew1_Bear or csNew2_Bear)
        cc_bear_active:=false
    else if not cc_bear_active and cc_win_bear>=cc_min_hits and cc_pbj_bear
        cc_bear_active:=true
bool sigCCBull=conf and cc_bull_active, bool sigCCBear=conf and cc_bear_active

// LS Chain
bool lsc_L1=conf and ls_regRatio>lsc_reg1 and ls_cumRatio>lsc_cum1 and close>open and ls_bodyRat>=lsc_body1
bool lsc_S1=conf and ls_regRatio>lsc_reg1 and ls_cumRatio>lsc_cum1 and close<open and ls_bodyRat>=lsc_body1
bool lsc_L2=conf and ls_regRatio>lsc_reg2 and ls_cumRatio>lsc_cum2 and close>open and ls_bodyRat>=lsc_body2
bool lsc_S2=conf and ls_regRatio>lsc_reg2 and ls_cumRatio>lsc_cum2 and close<open and ls_bodyRat>=lsc_body2
int lsc_wb=0, bool lsc_pbj_bull=false
for i=0 to lsc_window-1
    if nz(lsc_L1[i]) or nz(lsc_L2[i])
        lsc_wb+=1
    if nz(sigBullPBJ[i]) or nz(sigBullPB[i])
        lsc_pbj_bull:=true
int lsc_ws=0, bool lsc_pbj_bear=false
for i=0 to lsc_window-1
    if nz(lsc_S1[i]) or nz(lsc_S2[i])
        lsc_ws+=1
    if nz(sigBearPBJ[i]) or nz(sigBearPB[i])
        lsc_pbj_bear:=true
var bool lsc_bull_active=false, var bool lsc_bear_active=false
if conf
    if not (lsc_L1 or lsc_L2)
        lsc_bull_active:=false
    else if not lsc_bull_active and lsc_wb>=lsc_min_hits and lsc_pbj_bull
        lsc_bull_active:=true
if conf
    if not (lsc_S1 or lsc_S2)
        lsc_bear_active:=false
    else if not lsc_bear_active and lsc_ws>=lsc_min_hits and lsc_pbj_bear
        lsc_bear_active:=true
bool sigLSCBull=conf and lsc_bull_active, bool sigLSCBear=conf and lsc_bear_active

// Nagasaki directional
bool nag_dir_bull=sigBullRVOL1x or sigGrandSlam or sigFAUNABull or sigDISPBull or sigBullPBJ or sigPUP or gz_bullHV or gz_bullGZI
bool nag_dir_bear=sigBearRVOL1x or sigMOAB or sigFAUNABear or sigDISPBear or sigBearPBJ or sigPPD or gz_bearHV or gz_bearGZI

// Floor / Rooftop / 2F / PH
bool bull_hw_slot=sigBullRVOL1x or sigGrandSlam or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bull)
bool bear_hw_slot=sigBearRVOL1x or sigMOAB or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bear)
bool anyBullFloor=conf and bull_pp and sigBullPBJ and bull_hw_slot
bool anyBull2nd=conf and bull_pp and sigBullPB and bull_hw_slot
bool anyBearRoof=conf and bear_pp and sigBearPBJ and bear_hw_slot
bool anyBearPent=conf and bear_pp and sigBearPB and bear_hw_slot

// HW — disp5 is NOT displacement (no FVG). Offset=0. Protocol Common Mistake #6.
bool hwBull=(close>open) and disp5_bull and sigBullPBJ and (sigGrandSlam or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bull)) and (anyBullFloor or anyBull2nd)
bool hwBear=(close<open) and disp5_bear and sigBearPBJ and (sigMOAB or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bear)) and (anyBearRoof or anyBearPent)

// ════════════════════════════════════════════════════════════════════════════
// TNT PROPULSION BLOCK ENGINE
// ════════════════════════════════════════════════════════════════════════════
grpTNT = "TNT Engine"
int SENS = input.int(100, "TNT Sensitivity", minval=1, group=grpTNT)
int SWING_LEN = input.int(10, "TNT Swing Length", minval=3, group=grpTNT)
string DISP_TYPE_T = input.string("Open to Close", "TNT Range Type", options=["Open to Close","High to Low"], group=grpTNT)
int DISP_STD_LEN_T = input.int(100, "TNT Std Dev Len", minval=1, group=grpTNT)
int DISP_STD_X_T = input.int(5, "TNT Std Dev Mult", minval=0, group=grpTNT)
float RET_TNT_PCT = input.float(100.0, "Return to TNT %", minval=-10, step=0.1, group=grpTNT)
int SUDDEN_PROX = input.int(10, "Sudden Change Max Bars", minval=1, group=grpTNT)
int maxZones_t = 15, int maxSuperZones_t = 8
int EMA_FAST_T=SENS, int EMA_SLOW_T=SENS+13
float ATR_VAL_T=ta.atr(200), float ATR14_T=ta.atr(14), float ATR_MULT_T=3.5, float ATR_MIN_T=0.5
int MIN_SIG_GAP_T=EMA_SLOW_T
type tZone
    int oi
    int ci
    float u
    float l
    float lv
    float v
    bool ib
    bool ia=true
    bool rf=false
type tCL
    float lv
    bool ib
    int bi
    bool vi=false
type tSP
    float v=na
    int i=na
    bool c=false
type tBBE
    int bi
    float lv
    float u
    float l
    bool ib
    bool it

float ema_f_t=ta.ema(close,EMA_FAST_T), float ema_s_t=ta.ema(close,EMA_SLOW_T)
bool vob_bc=ta.crossover(ema_f_t,ema_s_t) and barstate.isconfirmed
bool vob_sc=ta.crossunder(ema_f_t,ema_s_t) and barstate.isconfirmed
var float vbu=na, var float vbl=na, var int vbo=na, var float vbv=na, var bool vbn=false
var float vsu=na, var float vsl=na, var int vso=na, var float vsv=na, var bool vsn=false
float atr_hi_t=ta.highest(ATR_VAL_T,200)*2.0
if vob_bc
    float cv=0.0, int ob=bar_index, float ol=low
    for i=1 to EMA_SLOW_T
        if low[i]<=ol
            ol:=low[i], ob:=bar_index-i
        cv+=volume[i]
    float s=math.min(open[bar_index-ob],close[bar_index-ob])
    s:=(s-ol)<atr_hi_t*0.5?ol+atr_hi_t*0.5:s
    vbu:=s, vbl:=ol, vbo:=ob, vbv:=cv, vbn:=true
else
    vbn:=false
if vob_sc
    float cv=0.0, int ob=bar_index, float oh=high
    for i=1 to EMA_SLOW_T
        if high[i]>=oh
            oh:=high[i], ob:=bar_index-i
        cv+=volume[i]
    float s=math.max(open[bar_index-ob],close[bar_index-ob])
    s:=(oh-s)<atr_hi_t*0.5?oh-atr_hi_t*0.5:s
    vsu:=oh, vsl:=s, vso:=ob, vsv:=cv, vsn:=true
else
    vsn:=false

var int swSt_t=0
var tSP swH_t=tSP.new(na,na), var tSP swL_t=tSP.new(na,na)
float swU_t=ta.highest(high,SWING_LEN), float swLL_t=ta.lowest(low,SWING_LEN)
swSt_t:=high[SWING_LEN]>swU_t?0:low[SWING_LEN]<swLL_t?1:swSt_t
if swSt_t==0 and swSt_t[1]!=0
    swH_t:=tSP.new(high[SWING_LEN],bar_index[SWING_LEN])
if swSt_t==1 and swSt_t[1]!=1
    swL_t:=tSP.new(low[SWING_LEN],bar_index[SWING_LEN])

var float abu=na, var float abl=na, var int abi=na, var float apu=na, var float apl=na, var int api=na, var bool abn=false
var float asu=na, var float asl=na, var int asi=na, var float aspu=na, var float aspl=na, var int aspi=na, var bool asn=false
if close>swH_t.v and not swH_t.c and barstate.isconfirmed and not na(swH_t.v)
    swH_t.c:=true
    float oL=low[1], float oH=high[1], int oI=bar_index-1
    int lb=bar_index-swH_t.i
    if lb>1
        for i=1 to lb-1
            if open[i]>close[i] and low[i]<=oL
                oL:=low[i], oH:=high[i], oI:=bar_index-i
    apu:=abu, apl:=abl, api:=abi
    abu:=oH, abl:=oL, abi:=oI
    abn:=not na(apu) and oI<=nz(api,0)+EMA_SLOW_T and oH>nz(apl,na) and oL<nz(apu,na)
else
    abn:=false
if close<swL_t.v and not swL_t.c and barstate.isconfirmed and not na(swL_t.v)
    swL_t.c:=true
    float oL=low[1], float oH=high[1], int oI=bar_index-1
    int lb=bar_index-swL_t.i
    if lb>1
        for i=1 to lb-1
            if open[i]<close[i] and high[i]>=oH
                oH:=high[i], oL:=low[i], oI:=bar_index-i
    aspu:=asu, aspl:=asl, aspi:=asi
    asu:=oH, asl:=oL, asi:=oI
    asn:=not na(aspl) and oI<=nz(aspi,0)+EMA_SLOW_T and oL<nz(aspu,na) and oH>nz(aspl,na)
else
    asn:=false

var float fbu=na, var float fbl=na, var int fbt=na, var bool fba=false, var bool fbpn=false, var int fbpi=na
var float fsu=na, var float fsl=na, var int fst=na, var bool fsa=false, var bool fspn=false, var int fspi=na
var tSP fswH=tSP.new(na,na), var tSP fswL=tSP.new(na,na)
if swSt_t==0 and swSt_t[1]!=0
    fswH:=tSP.new(high[SWING_LEN],bar_index[SWING_LEN])
if swSt_t==1 and swSt_t[1]!=1
    fswL:=tSP.new(low[SWING_LEN],bar_index[SWING_LEN])
if close>fswH.v and not fswH.c and barstate.isconfirmed and not na(fswH.v)
    fswH.c:=true
    float bB=math.min(open[1],close[1]), float bT=math.max(open[1],close[1]), int bI=bar_index-1
    int lb=bar_index-fswH.i
    if lb>1
        for i=1 to lb-1
            if math.min(open[i],close[i])<bB
                bB:=math.min(open[i],close[i]), bT:=math.max(open[i],close[i]), bI:=bar_index-i
    float os=math.abs(bT-bB)
    if os<=ATR_VAL_T*ATR_MULT_T and os>ATR_VAL_T*ATR_MIN_T
        fbu:=bT, fbl:=bB, fbt:=bI, fba:=true
if close<fswL.v and not fswL.c and barstate.isconfirmed and not na(fswL.v)
    fswL.c:=true
    float bT=math.max(open[1],close[1]), float bB=math.min(open[1],close[1]), int bI=bar_index-1
    int lb=bar_index-fswL.i
    if lb>1
        for i=1 to lb-1
            if math.max(open[i],close[i])>bT
                bT:=math.max(open[i],close[i]), bB:=math.min(open[i],close[i]), bI:=bar_index-i
    float os=math.abs(bT-bB)
    if os<=ATR_VAL_T*ATR_MULT_T and os>ATR_VAL_T*ATR_MIN_T
        fsu:=bT, fsl:=bB, fst:=bI, fsa:=true
fbpn:=false
if fba and barstate.isconfirmed
    if close<fbl
        fba:=false
    else if low[1]<fbu and low[1]>fbl and close>open and close>high[1]
        fbpn:=true, fbpi:=fbt
fspn:=false
if fsa and barstate.isconfirmed
    if close>fsu
        fsa:=false
    else if high[1]>fsl and high[1]<fsu and close<open and close<low[1]
        fspn:=true, fspi:=fst

int CW_T=EMA_SLOW_T*2
var int vcb=0, var int acb=0, var int fcb=0, var int vcs=0, var int acs=0, var int fcs=0
var float vcu=na, var float vcl=na, var float vdu=na, var float vdl=na
if vbn
    vcb:=bar_index, vcu:=vbu, vcl:=vbl
if vsn
    vcs:=bar_index, vdu:=vsu, vdl:=vsl
if abn
    acb:=bar_index
if asn
    acs:=bar_index
if fbpn
    fcb:=bar_index
if fspn
    fcs:=bar_index
f_tok(int a,int b,int c)=>int mn=math.min(a,math.min(b,c)), int mx=math.max(a,math.max(b,c)), mx-mn<=CW_T and mn>0
f_zov(float u1,float l1,float u2,float l2)=>not na(u1) and not na(u2) and u1>=l2 and u2>=l1
float vMed_t=ta.median(volume,EMA_SLOW_T), float eSl_t=ema_f_t-ema_f_t[5], float rsi_t=ta.rsi(close,14)
f_sb(float vV,float vU,float vL,float aU,float aL)=>vV>vMed_t*EMA_SLOW_T*0.5 and eSl_t>0 and rsi_t<80 and (math.min(vU-vL,aU-aL)>0?math.max(0,math.min(vU,aU)-math.max(vL,aL))/math.min(vU-vL,aU-aL)>0.3:false)
f_ss(float vV,float vU,float vL,float aU,float aL)=>vV>vMed_t*EMA_SLOW_T*0.5 and eSl_t<0 and rsi_t>20 and (math.min(vU-vL,aU-aL)>0?math.max(0,math.min(vU,aU)-math.max(vL,aL))/math.min(vU-vL,aU-aL)>0.3:false)
var tnt_z=array.new<tZone>(0)
var int lBSB=0, var int lSSB=0
bool bConf_t=f_tok(vcb,acb,fcb) and f_zov(vcu,vcl,abu,abl)
bool sConf_t=f_tok(vcs,acs,fcs) and f_zov(vdu,vdl,asu,asl)
bool raw_bullTNT=bConf_t and f_sb(nz(vbv),nz(vcu),nz(vcl),nz(abu),nz(abl)) and barstate.isconfirmed and (bar_index-lBSB)>MIN_SIG_GAP_T
bool raw_bearTNT=sConf_t and f_ss(nz(vsv),nz(vdu),nz(vdl),nz(asu),nz(asl)) and barstate.isconfirmed and (bar_index-lSSB)>MIN_SIG_GAP_T

f_bl_t()=>math.avg(math.min(nz(vcu,high),nz(abu,high)),math.max(nz(vcl,low),nz(abl,low)))
f_sl_t()=>math.avg(math.min(nz(vdu,high),nz(asu,high)),math.max(nz(vdl,low),nz(asl,low)))
f_bo_t()=>int o=math.min(nz(vbo,bar_index),math.min(nz(abi,bar_index),nz(fbpi,bar_index))), o>0?o:bar_index
f_so_t()=>int o=math.min(nz(vso,bar_index),math.min(nz(asi,bar_index),nz(fspi,bar_index))), o>0?o:bar_index
var cl_t=array.new<tCL>(0)
if raw_bullTNT
    lBSB:=bar_index
    float oU=math.min(nz(vcu,high),nz(abu,high)), float oL=math.max(nz(vcl,low),nz(abl,low)), float lv=math.avg(oU,oL)
    tnt_z.push(tZone.new(f_bo_t(),bar_index,oU,oL,lv,nz(vbv),true))
    cl_t.push(tCL.new(lv,true,bar_index))
if raw_bearTNT
    lSSB:=bar_index
    float oU=math.min(nz(vdu,high),nz(asu,high)), float oL=math.max(nz(vdl,low),nz(asl,low)), float lv=math.avg(oU,oL)
    tnt_z.push(tZone.new(f_so_t(),bar_index,oU,oL,lv,nz(vsv),false))
    cl_t.push(tCL.new(lv,false,bar_index))

bool raw_retBullTNT=false, bool raw_retBearTNT=false
if tnt_z.size()>0
    for i=tnt_z.size()-1 to 0
        tZone z=tnt_z.get(i)
        if z.ia
            if z.ib and close<z.l
                z.ia:=false
            if not z.ib and close>z.u
                z.ia:=false
            if z.ia and not z.rf and barstate.isconfirmed and bar_index>z.ci
                float zH=z.u-z.l
                if z.ib
                    float rL=z.l+zH*(RET_TNT_PCT/100.0)
                    if low<=rL and close>z.l
                        z.rf:=true, raw_retBullTNT:=true
                if not z.ib
                    float rL=z.u-zH*(RET_TNT_PCT/100.0)
                    if high>=rL and close<z.u
                        z.rf:=true, raw_retBearTNT:=true
    while tnt_z.size()>maxZones_t
        tnt_z.shift()

float dr_t=DISP_TYPE_T=="Open to Close"?math.abs(open-close):high-low
float ds_t=ta.stdev(dr_t,DISP_STD_LEN_T), float dt_t=ds_t*DISP_STD_X_T
bool iBFVG_t=low>high[2] and open[1]<close[1], bool iSFVG_t=high<low[2] and open[1]>close[1]
bool pBD_t=dr_t[1]>dt_t[1]
bool dispBull_t=pBD_t and iBFVG_t and barstate.isconfirmed, bool dispBear_t=pBD_t and iSFVG_t and barstate.isconfirmed

bool raw_napalmBull=false, bool raw_napalmBear=false
if barstate.isconfirmed and tnt_z.size()>0
    if dispBull_t
        for i=tnt_z.size()-1 to 0
            tZone z=tnt_z.get(i)
            if not z.ib and z.ia and low[1]>z.lv
                raw_napalmBull:=true
                break
    if dispBear_t
        for i=tnt_z.size()-1 to 0
            tZone z=tnt_z.get(i)
            if z.ib and z.ia and high[1]<z.lv
                raw_napalmBear:=true
                break

bool raw_bullCharge=false, bool raw_bearCharge=false
if barstate.isconfirmed and cl_t.size()>0
    if dispBull_t
        for i=cl_t.size()-1 to 0
            tCL c=cl_t.get(i)
            if not c.ib and not c.vi and close[1]>c.lv
                c.vi:=true, raw_bullCharge:=true
                cl_t.push(tCL.new(low[1],true,bar_index))
                break
    if dispBear_t
        for i=cl_t.size()-1 to 0
            tCL c=cl_t.get(i)
            if c.ib and not c.vi and close[1]<c.lv
                c.vi:=true, raw_bearCharge:=true
                cl_t.push(tCL.new(high[1],false,bar_index))
                break
while cl_t.size()>100
    cl_t.shift()

var bull_ev=array.new<tBBE>(0), var bear_ev=array.new<tBBE>(0)
bool eBullCh=raw_bullCharge and not raw_bearTNT, bool eBearCh=raw_bearCharge and not raw_bullTNT
bool anyBullEv=raw_bullTNT or raw_napalmBull or eBullCh, bool anyBearEv=raw_bearTNT or raw_napalmBear or eBearCh
if anyBullEv
    float eLv=raw_bullTNT?f_bl_t():low[1], float eU=high[1], float eL=low[1]
    int eB=raw_bullTNT?bar_index:bar_index-1
    bull_ev.push(tBBE.new(eB,eLv,eU,eL,true,raw_bullTNT))
    bear_ev.clear()
    while bull_ev.size()>20
        bull_ev.shift()
if anyBearEv and not anyBullEv
    float eLv=raw_bearTNT?f_sl_t():high[1], float eU=high[1], float eL=low[1]
    int eB=raw_bearTNT?bar_index:bar_index-1
    bear_ev.push(tBBE.new(eB,eLv,eU,eL,false,raw_bearTNT))
    bull_ev.clear()
    while bear_ev.size()>20
        bear_ev.shift()
var int lSBB=0, var int lSSBB=0
bool raw_bullTNT2=false, bool raw_bearTNT2=false
if bull_ev.size()>=2 and anyBullEv and barstate.isconfirmed and (bar_index-lSBB)>MIN_SIG_GAP_T
    raw_bullTNT2:=true, lSBB:=bar_index
if bear_ev.size()>=2 and anyBearEv and not anyBullEv and barstate.isconfirmed and (bar_index-lSSBB)>MIN_SIG_GAP_T
    raw_bearTNT2:=true, lSSBB:=bar_index

var int scBC=na, var int scSC=na, var int scRB=na, var int scRS=na
var int scBT=na, var int scST=na, var int scBT2=na, var int scST2=na
bool raw_contBull=(raw_bullCharge and not na(scRB) and (bar_index-1-scRB)<=SUDDEN_PROX) or ((raw_bullTNT or raw_bullTNT2) and not na(scBC) and (bar_index-scBC)<=SUDDEN_PROX) or (raw_bullCharge and ((not na(scBT) and (bar_index-1-scBT)<=SUDDEN_PROX) or (not na(scBT2) and (bar_index-1-scBT2)<=SUDDEN_PROX)))
bool raw_contBear=(raw_bearCharge and not na(scRS) and (bar_index-1-scRS)<=SUDDEN_PROX) or ((raw_bearTNT or raw_bearTNT2) and not na(scSC) and (bar_index-scSC)<=SUDDEN_PROX) or (raw_bearCharge and ((not na(scST) and (bar_index-1-scST)<=SUDDEN_PROX) or (not na(scST2) and (bar_index-1-scST2)<=SUDDEN_PROX)))
if raw_bullCharge
    scBC:=bar_index-1
if raw_bearCharge
    scSC:=bar_index-1
if raw_retBullTNT
    scRB:=bar_index
if raw_retBearTNT
    scRS:=bar_index
if raw_bullTNT
    scBT:=bar_index
if raw_bearTNT
    scST:=bar_index
if raw_bullTNT2
    scBT2:=bar_index
if raw_bearTNT2
    scST2:=bar_index

bool det_bullNapalmCons=raw_napalmBull or raw_bullCharge
bool det_bearNapalmCons=raw_napalmBear or raw_bearCharge
bool det_b2bBullNapalm=det_bullNapalmCons and nz(det_bullNapalmCons[1])
bool det_b2bBearNapalm=det_bearNapalmCons and nz(det_bearNapalmCons[1])
bool det_npmTntBull=raw_napalmBull and nz(raw_bullTNT[1])
// ┌──────────────────────────────────────────────────────────────────────────┐
// │  SUPER/SD! — OFFSET -1 (sigDISPBull = displacement+FVG in chain)       │
// │  Per Protocol RULE 2: disp+FVG at any depth → offset -1.               │
// │  Per Protocol RULE 5: offset-0 booleans at [1], offset-1 at [0].       │
// │  csNew1 stays [0] (its two-bar FVG pattern already describes bar[1]).   │
// │  csNew2 shifted to [1] (single-bar matrix event describes bar[0]).      │
// │  All offset-0 signals (PBJ/FAUNA/PUP/RVOL/Floor) shifted to [1].      │
// └──────────────────────────────────────────────────────────────────────────┘
bool super_combo_b = csNew1_Bull or nz(csNew2_Bull[1])
bool super_combo_s = csNew1_Bear or nz(csNew2_Bear[1])
bool super_hw_b = nz(sigBullRVOL1x[1]) or nz(sigGrandSlam[1]) or nz(sigWTC[1]) or nz(sigHiroshima[1]) or nz(sigNagasaki[1])
bool super_hw_s = nz(sigBearRVOL1x[1]) or nz(sigMOAB[1]) or nz(sigWTC[1]) or nz(sigHiroshima[1]) or nz(sigNagasaki[1])
bool super_hw_bull = sigBullRVOL1x or sigGrandSlam or sigWTC or sigHiroshima or sigNagasaki
bool super_hw_bear = sigBearRVOL1x or sigMOAB or sigWTC or sigHiroshima or sigNagasaki
bool super_comboAny_bull=csNew1_Bull or csNew2_Bull, bool super_comboAny_bear=csNew1_Bear or csNew2_Bear

// SUPER and SDUPER — REDEFINED v2 per Anish:
//   SUPER  = UC (Unified Combo) + Napalm (consolidated)
//   SDUPER = UC + Napalm + PUP
// UC = csNew3 (CS1[0] AND CS2[1]) — both events on visual bar 1, offset -1.
// Napalm (det_*NapalmCons) is offset -1, visual bar 1. PUP is offset 0; align with [1].
bool superBull = conf and csNew3_Bull and det_bullNapalmCons
bool superBear = conf and csNew3_Bear and det_bearNapalmCons
bool sduperBull = conf and csNew3_Bull and det_bullNapalmCons and nz(sigPUP[1])
bool sduperBear = conf and csNew3_Bear and det_bearNapalmCons and nz(sigPPD[1])

// === BOOM HUNTER + OMEGA ===
float bh_K2=0.3, float bh_pi=2*math.asin(1)
float bh_alpha1=(math.cos(.707*2*bh_pi/100)+math.sin(.707*2*bh_pi/100)-1)/math.cos(.707*2*bh_pi/100)
float bh_HP=0.0
bh_HP:=(1-bh_alpha1/2)*(1-bh_alpha1/2)*(close-2*nz(close[1])+nz(close[2]))+2*(1-bh_alpha1)*nz(bh_HP[1])-(1-bh_alpha1)*(1-bh_alpha1)*nz(bh_HP[2])
float bh_a1=math.exp(-1.414*bh_pi/bh_LPPeriod), float bh_b1=2*bh_a1*math.cos(1.414*bh_pi/bh_LPPeriod)
float bh_c2=bh_b1, float bh_c3=-bh_a1*bh_a1, float bh_c1=1-bh_c2-bh_c3
float bh_Filt=0.0
bh_Filt:=bh_c1*(bh_HP+nz(bh_HP[1]))/2+bh_c2*nz(bh_Filt[1])+bh_c3*nz(bh_Filt[2])
float bh_Peak=0.0
bh_Peak:=.991*nz(bh_Peak[1])
if math.abs(bh_Filt)>bh_Peak
    bh_Peak:=math.abs(bh_Filt)
float bh_X=bh_Peak!=0?bh_Filt/bh_Peak:0.0
float bh_Quotient1=(bh_X+bh_K1)/(bh_K1*bh_X+1), float bh_Quotient2=(bh_X+bh_K2)/(bh_K2*bh_X+1)

float bh_HP2=0.0
bh_HP2:=(1-bh_alpha1/2)*(1-bh_alpha1/2)*(close-2*nz(close[1])+nz(close[2]))+2*(1-bh_alpha1)*nz(bh_HP2[1])-(1-bh_alpha1)*(1-bh_alpha1)*nz(bh_HP2[2])
float bh_a12=math.exp(-1.414*bh_pi/bh_LPPeriod2), float bh_b12=2*bh_a12*math.cos(1.414*bh_pi/bh_LPPeriod2)
float bh_c22=bh_b12, float bh_c32=-bh_a12*bh_a12, float bh_c12=1-bh_c22-bh_c32
float bh_Filt2=0.0
bh_Filt2:=bh_c12*(bh_HP2+nz(bh_HP2[1]))/2+bh_c22*nz(bh_Filt2[1])+bh_c32*nz(bh_Filt2[2])
float bh_Peak2=0.0
bh_Peak2:=.991*nz(bh_Peak2[1])
if math.abs(bh_Filt2)>bh_Peak2
    bh_Peak2:=math.abs(bh_Filt2)
float bh_X2=bh_Peak2!=0?bh_Filt2/bh_Peak2:0.0
float bh_Quotient3=(bh_X2+bh_K12)/(bh_K12*bh_X2+1)

float bh_HP3=0.0
bh_HP3:=(1-bh_alpha1/3)*(1-bh_alpha1/2)*(close-2*nz(close[1])+nz(close[2]))+2*(1-bh_alpha1)*nz(bh_HP3[1])-(1-bh_alpha1)*(1-bh_alpha1)*nz(bh_HP3[2])
float bh_a13=math.exp(-1.414*bh_pi/bh_LPPeriod3), float bh_b13=2*bh_a13*math.cos(1.414*bh_pi/bh_LPPeriod3)
float bh_c33x=bh_b13, float bh_c333=-bh_a13*bh_a13, float bh_c13=1-bh_c33x-bh_c333
float bh_Filt3=0.0
bh_Filt3:=bh_c13*(bh_HP3+nz(bh_HP3[1]))/2+bh_c33x*nz(bh_Filt3[1])+bh_c333*nz(bh_Filt3[2])
float bh_Peak3=0.0
bh_Peak3:=.991*nz(bh_Peak3[1])
if math.abs(bh_Filt3)>bh_Peak3
    bh_Peak3:=math.abs(bh_Filt3)
float bh_X3=bh_Peak3!=0?bh_Filt3/bh_Peak3:0.0
float bh_Quotient5=(bh_X3+0.9999)/(0.9999*bh_X3+1)

bh_src5=hlc3
bh_tci(src)=>ta.ema((src-ta.ema(src,bh_n1))/(0.025*ta.ema(math.abs(src-ta.ema(src,bh_n1)),bh_n1)),bh_n2)+50
bh_mf(src)=>100.0-100.0/(1.0+math.sum(volume*(ta.change(src)<=0?0:src),bh_n3)/math.sum(volume*(ta.change(src)>=0?0:src),bh_n3))
bh_tradition(src)=>math.avg(bh_tci(src),bh_mf(src),ta.rsi(src,bh_n3))

float bh_wt1=bh_tradition(bh_src5), float bh_wt2=ta.sma(bh_wt1,6), float bh_wt3=ta.linreg(bh_wt1,bh_n4,bh_n5)
bool bh_bounceUp=ta.barssince(ta.crossunder(bh_wt2,20))<=1 and ta.crossover(bh_wt2,20)
bool bh_bounceDown=ta.barssince(ta.crossover(bh_wt2,80))<=1 and ta.crossunder(bh_wt2,80)

float bh_q1=bh_Quotient1*60+50, float bh_trigger2=ta.sma(bh_q1,bh_trigno)
float bh_highUsePivot=fixnan(ta.pivothigh(bh_q1,bh_leftBars,bh_rightBars)[1])
float bh_lowUsePivot=fixnan(ta.pivotlow(bh_q1,bh_leftBars2,bh_rightBars2)[1])
bool bh_crossover2=ta.crossover(bh_q1,bh_trigger2), bool bh_crossunder2=ta.crossunder(bh_q1,bh_trigger2)
bool bh_entry=ta.crossunder(bh_Quotient2,-0.9)

var int bh_ubreak=0, var int bh_dbreak=0
if bh_entry
    bh_dbreak:=0, bh_ubreak:=0
if ta.crossunder(bh_q1,bh_lowUsePivot)
    bh_dbreak+=1
if ta.crossover(bh_q1,bh_highUsePivot) and bh_dbreak>=1
    bh_ubreak+=1

bool bh_warn2=ta.crossover(bh_Quotient1,-0.9), bool bh_warn3=ta.crossunder(bh_Quotient1,0.9)
bool bh_enter3=bh_Quotient3<=-0.9 and ta.crossover(bh_q1,bh_trigger2) and ta.barssince(bh_warn2)<=7 and bh_q1<=20 and ta.barssince(ta.crossover(bh_q1,20))<=21
bool bh_enter5=ta.barssince(bh_q1<=0 and ta.crossunder(bh_q1,bh_trigger2))<=5 and ta.crossover(bh_q1,bh_trigger2)
bool bh_enter6=ta.barssince(bh_q1<=20 and ta.crossunder(bh_q1,bh_trigger2))<=11 and ta.crossover(bh_q1,bh_trigger2)
bool bh_enter7=bh_Quotient3<=-0.9 and ta.crossover(bh_q1,bh_trigger2)
bool bh_greyFired=bh_enter6 and bh_q1<=60
bool bh_loneLimeOnly=bh_enter3 and not bh_enter5 and not bh_enter7 and not bh_greyFired
bool bh_anyOmega=(bh_enter3 and bh_enter5 and bh_enter7) or bh_loneLimeOnly or bh_bounceUp or bh_bounceDown

bool bh_senter3=bh_Quotient3>=-0.9 and ta.crossunder(bh_q1,bh_trigger2) and ta.barssince(bh_warn3)<=7 and bh_q1>=99 and ta.barssince(ta.crossover(bh_q1,80))<=21
bool sigShortPlusPress=conf and bh_senter3 and bh_wt2>=80 and bh_crossunder2

// Omega cosignal
bool omega_cosignal=(tfSec>=45?(sigSAAB or sigPentagon):false) or sigBullRVOL1x or sigGrandSlam or (tfSec>=60?sigBullPBJ:false) or (tfSec>=300?sigBullPB:false) or sigPUP or (tfSec>=300?(gz_bullGZI or gz_bullHV):false) or sigLong1 or sigLong2 or sigP21BullUUUU or sigP21BullUUU or sigUUBull or sigNeoBull or (tfSec>=300?sigTrinityBull:false) or (tfSec>=120?sigHV500:false) or (tfSec>=60?sigHV1000:false) or sigWTC or sigHiroshima or sigNagasaki or sigAlphaStrikeBull or sigFoxtrotBull or comboSet1_Bull or comboSet2_Bull or comboSet3_Bull or comboSet4_Bull or sigDispConsBull2 or sigDispConsBull3 or sigODBull or sigCCBull or sigLSCBull or sigGolfBull or sigPAFBull or anyBullFloor or anyBull2nd or hwBull or superBull or sduperBull
bool sigOmegaLong=conf and bh_anyOmega and omega_cosignal and not sigMOAB and not sigDISPBear

bool omega_cosignal_A=(tfSec>=60?sigBullPBJ:false) or sigP21BullUUUU or anyBullFloor or anyBull2nd or hwBull or superBull or sduperBull or sigAlphaStrikeBull or sigFoxtrotBull or sigODBull or sigDispConsBull3 or sigGolfBull or sigGrandSlam or (sigBullRVOL1x and sigDISPBull)
bool sigOmegaLongA=conf and bh_anyOmega and omega_cosignal_A and not sigMOAB and not sigDISPBear

// TF Gate
int tf_req=(tfSec<=1800?2:tfSec<=3000?1:0)
int bull_ec=(sigFAUNABull?1:0)+(sigDISPBull?1:0)+(sigPUP?1:0)+(gz_bullGZI?1:0)+(gz_bullHV?1:0)+(sigBullRVOL1x?1:0)+(sigGrandSlam?1:0)+(sigLong1?1:0)+(sigLong2?1:0)+(sigHV75?1:0)+(sigHV150?1:0)+(sigHV500?1:0)+(sigHV1000?1:0)+(sigWTC?1:0)+(sigHiroshima?1:0)+(sigNagasaki?1:0)+(is_matrix_number?1:0)+(rawBullUU or rawBullUUU or rawBullUUUU?1:0)+(sigOmegaLong?1:0)+(sigBullPBJ?1:0)+(sigCCBull?1:0)+(sigLSCBull?1:0)
int bear_ec=(sigFAUNABear?1:0)+(sigDISPBear?1:0)+(sigPPD?1:0)+(gz_bearGZI?1:0)+(gz_bearHV?1:0)+(sigBearRVOL1x?1:0)+(sigMOAB?1:0)+(sigShort1?1:0)+(sigShort2?1:0)+(sigHV75?1:0)+(sigHV150?1:0)+(sigHV500?1:0)+(sigHV1000?1:0)+(sigWTC?1:0)+(sigHiroshima?1:0)+(sigNagasaki?1:0)+(is_matrix_number?1:0)+(rawBearUU or rawBearUUU or rawBearUUUU?1:0)+(sigShortPlusPress?1:0)+(sigBearPBJ?1:0)+(sigCCBear?1:0)+(sigLSCBear?1:0)
bool tf_bull_ok=bull_ec>=(tf_req+1), bool tf_bear_ok=bear_ec>=(tf_req+1)

// First-of-day tracker
if conf and (sigP21BullUUUU or sigP21BearUUUU or sigP21BullUUU or sigP21BearUUU or sigUUBull or sigUUBear or sigAlphaStrikeBull or sigAlphaStrikeBear or sigFoxtrotBull or sigFoxtrotBear or sigOmegaLong or sigOmegaLongA or sigODBull or sigODBear or sigDispConsBull2 or sigDispConsBear2 or sigDispConsBull3 or sigDispConsBear3 or csNew1_Bull or csNew1_Bear or csNew2_Bull or csNew2_Bear or csNew3_Bull or csNew3_Bear or anyBullFloor or anyBull2nd or anyBearRoof or anyBearPent or hwBull or hwBear or sigCCBull or sigCCBear or sigLSCBull or sigLSCBear or sigGolfBull or sigGolfBear or sigPAFBull or sigPAFBear or superBull or superBear or sduperBull or sduperBear)
    daySignalFired:=true

// PIPELINE C TERMINAL OUTPUTS
bool fire_BullUUUU=show_BullUUUU and sigP21BullUUUU, bool fire_BullUUU=show_BullUUU and sigP21BullUUU
bool fire_BullUU=show_BullUU and sigUUBull
bool fire_AlphaStrikeB=show_AlphaStrikeB and sigAlphaStrikeBull, bool fire_FoxtrotB=show_FoxtrotB and sigFoxtrotBull
bool fire_OmegaLong=show_OmegaLong and sigOmegaLong, bool fire_OmegaLongA=show_OmegaLongA and sigOmegaLongA, bool fire_ODBull=show_ODBull and sigODBull
bool fire_DispConsBull2=show_DispConsBull2 and sigDispConsBull2, bool fire_DispConsBull3=show_DispConsBull3 and sigDispConsBull3
bool fire_GolfBull=show_GolfBull and sigGolfBull, bool fire_PAFBull=show_PAFBull and sigPAFBull
bool fire_CS1B=show_CS1B and csNew1_Bull, bool fire_CS2B=show_CS2B and csNew2_Bull, bool fire_CS3B=show_CS3B and csNew3_Bull
bool fire_CCBull=show_CCBull and sigCCBull, bool fire_LSCBull=show_LSCBull and sigLSCBull
bool fire_BullFloor=show_BullFloor and anyBullFloor, bool fire_Bull2ndFloor=show_Bull2ndFloor and anyBull2nd
bool fire_HWBull=show_HWBull and hwBull, bool fire_SuperBull=show_SuperBull and superBull, bool fire_SDuperBull=show_SDuperBull and sduperBull

bool fire_BearUUUU=show_BearUUUU and sigP21BearUUUU, bool fire_BearUUU=show_BearUUU and sigP21BearUUU, bool fire_BearUU=show_BearUU and sigUUBear
bool fire_AlphaStrikeR=show_AlphaStrikeR and sigAlphaStrikeBear, bool fire_FoxtrotR=show_FoxtrotR and sigFoxtrotBear
bool fire_ODBear=show_ODBear and sigODBear
bool fire_DispConsBear2=show_DispConsBear2 and sigDispConsBear2, bool fire_DispConsBear3=show_DispConsBear3 and sigDispConsBear3
bool fire_GolfBear=show_GolfBear and sigGolfBear, bool fire_PAFBear=show_PAFBear and sigPAFBear
bool fire_CS1R=show_CS1R and csNew1_Bear, bool fire_CS2R=show_CS2R and csNew2_Bear, bool fire_CS3R=show_CS3R and csNew3_Bear
bool fire_CCBear=show_CCBear and sigCCBear, bool fire_LSCBear=show_LSCBear and sigLSCBear
bool fire_BearRooftop=show_BearRooftop and anyBearRoof, bool fire_BearPent=show_BearPenthouse and anyBearPent
bool fire_HWBear=show_HWBear and hwBear, bool fire_SuperBear=show_SuperBear and superBear, bool fire_SDuperBear=show_SDuperBear and sduperBear

// HV+D named bools
bool hvd_pb_bull  = hvd_fire_bull and nz(sigBullPB[1])
bool hvd_pbj_bull = hvd_fire_bull and nz(sigBullPBJ[1])
bool hvd_pb_bear  = hvd_fire_bear and nz(sigBearPB[1])
bool hvd_pbj_bear = hvd_fire_bear and nz(sigBearPBJ[1])

// Pipeline D CO-occurrence
grp_co = "★★★ PIPELINE D: TRIPLE CO-OCCURRENCE ★★★"
bool co_en_bullPBJ = input.bool(true, "Bull PBJ co-occurrence", group=grp_co, inline="co1")
bool co_en_bullPB  = input.bool(true, "Bull PB co-occurrence",  group=grp_co, inline="co1")
bool co_en_bearPBJ = true, bool co_en_bearPB = true

bool use_any_bull = sigP21BullUUUU_indep or sigP21BullUUU_indep or sigUUBull_indep or sigAlphaStrikeBull or sigFoxtrotBull or sigOmegaLong or sigOmegaLongA or sigODBull or sigDispConsBull2 or sigDispConsBull3 or sigGolfBull or sigPAFBull or csNew1_Bull or csNew2_Bull or csNew3_Bull or sigCCBull or sigLSCBull or anyBullFloor or anyBull2nd or hwBull or superBull or sduperBull
bool use_any_bear = sigP21BearUUUU_indep or sigP21BearUUU_indep or sigUUBear_indep or sigAlphaStrikeBear or sigFoxtrotBear or sigODBear or sigDispConsBear2 or sigDispConsBear3 or sigGolfBear or sigPAFBear or csNew1_Bear or csNew2_Bear or csNew3_Bear or sigCCBear or sigLSCBear or anyBearRoof or anyBearPent or hwBear or superBear or sduperBear

// v2: CO restructured per Anish — must include UC (Unified Combo) OR FVG Combo Set,
//     not just any bullish/bearish signal. Old `use_any_bull/bear[1]` gate replaced.
bool co_uc_or_fvg_bull = csNew3_Bull or csNew1_Bull
bool co_uc_or_fvg_bear = csNew3_Bear or csNew1_Bear
bool co_bull_pbj = hvd_fire_bull and co_en_bullPBJ and nz(sigBullPBJ[1]) and co_uc_or_fvg_bull
bool co_bull_pb  = hvd_fire_bull and co_en_bullPB  and nz(sigBullPB[1])  and co_uc_or_fvg_bull
bool co_bear_pbj = hvd_fire_bear and co_en_bearPBJ and nz(sigBearPBJ[1]) and co_uc_or_fvg_bear
bool co_bear_pb  = hvd_fire_bear and co_en_bearPB  and nz(sigBearPB[1])  and co_uc_or_fvg_bear
bool co_any = co_bull_pbj or co_bull_pb or co_bear_pbj or co_bear_pb

// B2B HV+D
bool b2b_bull_raw = hvd_fire_bull and nz(hvd_fire_bull[1])
bool b2b_bear_raw = hvd_fire_bear and nz(hvd_fire_bear[1])
bool b2b_bull_pbj = b2b_bull_raw and (nz(sigBullPBJ[1]) or nz(sigBullPBJ[2]))
bool b2b_bear_pbj = b2b_bear_raw and (nz(sigBearPBJ[1]) or nz(sigBearPBJ[2]))
bool b2b_bull_pb  = b2b_bull_raw and (nz(sigBullPB[1]) or nz(sigBullPB[2])) and not b2b_bull_pbj
bool b2b_bear_pb  = b2b_bear_raw and (nz(sigBearPB[1]) or nz(sigBearPB[2])) and not b2b_bear_pbj
bool b2b_bull_nopb = b2b_bull_raw and not b2b_bull_pbj and not b2b_bull_pb
bool b2b_bear_nopb = b2b_bear_raw and not b2b_bear_pbj and not b2b_bear_pb


// ════════════════════════════════════════════════════════════════════════════
// ULTRA 57 FAUNA COMBOS
// ════════════════════════════════════════════════════════════════════════════
bool u57_inSession=not na(time(timeframe.period,"0930-1600","America/New_York"))
var bool u57_newDay=false
if ta.change(dayofmonth)!=0
    u57_newDay:=true
var int u57_sessBar=0
if u57_newDay and u57_inSession
    u57_sessBar:=1, u57_newDay:=false
else if u57_inSession and u57_sessBar>0
    u57_sessBar+=1
else if not u57_inSession
    u57_sessBar:=0
bool u57_bMB=conf and MB_b, bool u57_bRE=conf and RE_b, bool u57_bTA=conf and TA_b
bool u57_sMB=conf and MB_r, bool u57_sRE=conf and RE_r, bool u57_sTA=conf and TA_r
bool sBullF2=conf and u57_sessBar==2 and u57_bMB and u57_bMB[1]
bool sBearF2=conf and u57_sessBar==2 and u57_sMB and u57_sMB[1]
bool u57_bEv=u57_bMB or u57_bRE or u57_bTA, bool u57_sEv=u57_sMB or u57_sRE or u57_sTA
bool sBullE3=conf and u57_sessBar==3 and u57_bEv and u57_bEv[1] and u57_bEv[2]
bool sBearE3=conf and u57_sessBar==3 and u57_sEv and u57_sEv[1] and u57_sEv[2]

// FC Cluster Bull
var int b1_s1=0
b1_s1:=u57_bMB?b1_s1+1:0
bool b1_ind1=u57_bMB and b1_s1>=2
var int b1_s2=0
if ta.change(dayofmonth)!=0
    b1_s2:=0
else if not u57_bEv
    b1_s2:=0
if u57_bEv
    b1_s2+=1
bool b1_ind2=u57_bEv and b1_s2>=2
bool b1_ev3=(u57_bMB or u57_bRE) and u57_inSession
var int b1_s3=0
b1_s3:=b1_ev3?b1_s3+1:0
bool b1_ind3=b1_ev3 and b1_s3>=2
bool b1_2of3=(b1_ind1?1:0)+(b1_ind2?1:0)+(b1_ind3?1:0)>=2
float b1_spk=math.abs(close-open), float b1_avgSpk=ta.sma(b1_spk,30)[1], float b1_rvolP=b1_spk/nz(b1_avgSpk,1)
float b1_avgVolD=ta.sma(volume,30)[1], float b1_rvolV=volume/nz(b1_avgVolD,1)
float b1_diff=b1_rvolP-b1_rvolV, float b1_pos=b1_diff>0?b1_diff:na, float b1_smaP=ta.sma(b1_pos,20)
bool b1_base=close>open and nz(b1_pos)>nz(b1_smaP)
b1_inRng(v)=>v>2.9 and v<1000000.0
bool b1_thEv=b1_base and b1_inRng(b1_rvolP) and conf
bool b1_uBar=b1_base and b1_inRng(b1_rvolP)
var float b1_sum=0.0, var int b1_len=0
if b1_uBar
    b1_len+=1, b1_sum+=b1_rvolP
else
    b1_len:=0, b1_sum:=0.0
bool b1_seqEv=(b1_len>=2 and b1_sum>=0.1) and conf
var int[] b1_thIdx=array.new_int(), var float[] b1_thHi=array.new_float(), var float[] b1_thLo=array.new_float()
var int[] b1_sqIdx=array.new_int(), var float[] b1_sqHi=array.new_float(), var float[] b1_sqLo=array.new_float()
bool b1_ovlp=false
if array.size(b1_thIdx)>0
    while bar_index-array.get(b1_thIdx,0)>20
        array.shift(b1_thIdx), array.shift(b1_thHi), array.shift(b1_thLo)
        if array.size(b1_thIdx)==0
            break
if array.size(b1_sqIdx)>0
    while bar_index-array.get(b1_sqIdx,0)>20
        array.shift(b1_sqIdx), array.shift(b1_sqHi), array.shift(b1_sqLo)
        if array.size(b1_sqIdx)==0
            break
b1_chk(loA,hiA,loB,hiB)=>loA<=hiB and loB<=hiA
if b1_thEv
    array.push(b1_thIdx,bar_index), array.push(b1_thHi,high), array.push(b1_thLo,low)
    if array.size(b1_sqIdx)>0
        for i=0 to array.size(b1_sqIdx)-1
            if b1_chk(low,high,array.get(b1_sqLo,i),array.get(b1_sqHi,i))
                b1_ovlp:=true
                break
if b1_seqEv and not b1_ovlp
    array.push(b1_sqIdx,bar_index), array.push(b1_sqHi,high), array.push(b1_sqLo,low)
    if array.size(b1_thIdx)>0
        for i=0 to array.size(b1_thIdx)-1
            if b1_chk(low,high,array.get(b1_thLo,i),array.get(b1_thHi,i))
                b1_ovlp:=true
                break
bool sBullFC=conf and b1_2of3 and b1_ovlp

// FC Cluster Bear
var int b4_s1=0
b4_s1:=u57_sMB?b4_s1+1:0
bool b4_ind1=u57_sMB and b4_s1>=2
var int b4_s2=0
if ta.change(dayofmonth)!=0
    b4_s2:=0
else if not u57_sEv
    b4_s2:=0
if u57_sEv
    b4_s2+=1
bool b4_ind2=u57_sEv and b4_s2>=2
bool b4_ev3=(u57_sMB or u57_sRE) and u57_inSession
var int b4_s3=0
b4_s3:=b4_ev3?b4_s3+1:0
bool b4_ind3=b4_ev3 and b4_s3>=2
bool b4_2of3=(b4_ind1?1:0)+(b4_ind2?1:0)+(b4_ind3?1:0)>=2
float b4_spk=math.abs(close-open), float b4_avgSpk=ta.sma(b4_spk,30)[1], float b4_rvolP=b4_spk/nz(b4_avgSpk,1)
float b4_avgVolD=ta.sma(volume,30)[1], float b4_rvolV=volume/nz(b4_avgVolD,1)
float b4_diff=b4_rvolP-b4_rvolV, float b4_neg=(b4_diff>0 and close<open)?b4_diff:na, float b4_smaN=ta.sma(b4_neg,20)
bool b4_base=close<open and nz(b4_neg)>nz(b4_smaN)
b4_inRng(v)=>v>2.9 and v<1000000.0
bool b4_thEv=b4_base and b4_inRng(b4_rvolP) and conf
bool b4_dBar=b4_base and b4_inRng(b4_rvolP)
var float b4_sum=0.0, var int b4_len=0
if b4_dBar
    b4_len+=1, b4_sum+=b4_rvolP
else
    b4_len:=0, b4_sum:=0.0
bool b4_seqEv=(b4_len>=2 and b4_sum>=0.1) and conf
var int[] b4_thIdx=array.new_int(), var float[] b4_thHi=array.new_float(), var float[] b4_thLo=array.new_float()
var int[] b4_sqIdx=array.new_int(), var float[] b4_sqHi=array.new_float(), var float[] b4_sqLo=array.new_float()
bool b4_ovlp=false
if array.size(b4_thIdx)>0
    while bar_index-array.get(b4_thIdx,0)>20
        array.shift(b4_thIdx), array.shift(b4_thHi), array.shift(b4_thLo)
        if array.size(b4_thIdx)==0
            break
if array.size(b4_sqIdx)>0
    while bar_index-array.get(b4_sqIdx,0)>20
        array.shift(b4_sqIdx), array.shift(b4_sqHi), array.shift(b4_sqLo)
        if array.size(b4_sqIdx)==0
            break
b4_chk(loA,hiA,loB,hiB)=>loA<=hiB and loB<=hiA
if b4_thEv
    array.push(b4_thIdx,bar_index), array.push(b4_thHi,high), array.push(b4_thLo,low)
    if array.size(b4_sqIdx)>0
        for i=0 to array.size(b4_sqIdx)-1
            if b4_chk(low,high,array.get(b4_sqLo,i),array.get(b4_sqHi,i))
                b4_ovlp:=true
                break
if b4_seqEv and not b4_ovlp
    array.push(b4_sqIdx,bar_index), array.push(b4_sqHi,high), array.push(b4_sqLo,low)
    if array.size(b4_thIdx)>0
        for i=0 to array.size(b4_thIdx)-1
            if b4_chk(low,high,array.get(b4_thLo,i),array.get(b4_thHi,i))
                b4_ovlp:=true
                break
bool sBearFC=conf and b4_2of3 and b4_ovlp

// B2B Days
bool _dayChg=ta.change(dayofmonth)!=0
f_hadYesterday(bool sig)=>
    bool found=false
    if _dayChg
        for i=1 to 500
            if i>1 and dayofmonth[i]!=dayofmonth[i+1]
                break
            if sig[i]
                found:=true
                break
    found
bool comboF2_B2BDays_Bull=sBullF2 and f_hadYesterday(sBullF2)
bool comboE3_B2BDays_Bull=sBullE3 and f_hadYesterday(sBullE3)
bool comboF2E3_Consec_Bull=sBullE3 and f_hadYesterday(sBullF2)
bool comboCluster_B2BDays_Bull=sBullFC and f_hadYesterday(sBullFC)
bool comboPBJ_F2_Bull=sigBullPBJ and sBullF2, bool comboPBJ_E3_Bull=sigBullPBJ and sBullE3
bool comboPBJ_Cluster_Bull=sigBullPBJ and sBullFC
bool comboF2Cluster_E3_Bull=sBullF2[1] and sBullFC[1] and sBullE3

bool det_b2bPUP=sigPUP and nz(sigPUP[1]), bool det_b2bPPD=sigPPD and nz(sigPPD[1])
bool comboF2ClusterB2B_Bull=sBullF2 and sBullFC and det_b2bPUP
bool comboB2B_F2_Bull=det_b2bPUP and sBullF2
int pupCntE3=(sigPUP?1:0)+(nz(sigPUP[1])?1:0)+(nz(sigPUP[2])?1:0)
bool comboE3_2of3PUP_Bull=sBullE3 and pupCntE3>=2

// Foster
var bool fosterWindowOpen=false, var int fosterWindowCount=0
if u57_bMB
    fosterWindowOpen:=true, fosterWindowCount:=0
bool fosterSignal=false, bool fosterPBJSignal=false
if fosterWindowOpen
    fosterWindowCount+=1
    if fosterWindowCount>1
        fosterWindowOpen:=false
    else if sigBullPBJ
        fosterPBJSignal:=true, fosterWindowOpen:=false
    else if fosterWindowCount>1
        fosterWindowOpen:=false

// ════════════════════════════════════════════════════════════════════════════
// HEAVY PENTAGON COMBOS + WBUSH (replaces WMD in v2)
// ────────────────────────────────────────────────────────────────────────────
// 5 Heavy Combo families × 3 directions = 15 sub-signals.
// WBUSH = any of the 15 fired, OR'd by direction.
// Direction classifier: sigDISPBull / sigDISPBear / noDisp (FVG-confirmed disp).
// ════════════════════════════════════════════════════════════════════════════
bool hp_groupA_Bull = sigBullRVOL1x or sigGrandSlam
bool hp_groupA_Bear = sigBearRVOL1x or sigMOAB
bool hp_groupB      = sigPentagon or sigWTC or sigHiroshima

bool hp_baseYinYang   = (hp_groupA_Bull or hp_groupA_Bear) and hp_groupB
bool hp_baseNagasaki  = sigNagasaki and (hp_groupA_Bull or hp_groupA_Bear)
bool hp_baseNagasakiV = sigNagasaki and hp_groupB
bool hp_baseTrident   = sigNagasaki and (hp_groupA_Bull or hp_groupA_Bear) and hp_groupB
bool hp_baseNHx2      = (sigPentagon and sigWTC) or (sigPentagon and sigHiroshima) or (sigWTC and sigHiroshima)

bool hp_noDisp = (not sigDISPBull) and (not sigDISPBear)

// Heavy Yin-Yang (P1 + P2)
bool hp_HYYBull    = hp_baseYinYang and sigDISPBull
bool hp_HYYBear    = hp_baseYinYang and sigDISPBear
bool hp_HYYNeutral = hp_baseYinYang and hp_noDisp
// Heavy Nagasaki (P3 + P1)
bool hp_HNBull     = hp_baseNagasaki and sigDISPBull
bool hp_HNBear     = hp_baseNagasaki and sigDISPBear
bool hp_HNNeutral  = hp_baseNagasaki and hp_noDisp
// Heavy Nagasaki Vol (P3 + P2)
bool hp_HNVBull    = hp_baseNagasakiV and sigDISPBull
bool hp_HNVBear    = hp_baseNagasakiV and sigDISPBear
bool hp_HNVNeutral = hp_baseNagasakiV and hp_noDisp
// Heavy Trident (P1 + P2 + P3)
bool hp_HTBull     = hp_baseTrident and sigDISPBull
bool hp_HTBear     = hp_baseTrident and sigDISPBear
bool hp_HTNeutral  = hp_baseTrident and hp_noDisp
// Neutral Heavy x2 (P2 × 2)
bool hp_NHx2Bull    = hp_baseNHx2 and sigDISPBull
bool hp_NHx2Bear    = hp_baseNHx2 and sigDISPBear
bool hp_NHx2Neutral = hp_baseNHx2 and hp_noDisp

// WBUSH aggregates — any of the 15 fired
bool sig_WBUSH_Bull    = hp_HYYBull    or hp_HNBull    or hp_HNVBull    or hp_HTBull    or hp_NHx2Bull
bool sig_WBUSH_Bear    = hp_HYYBear    or hp_HNBear    or hp_HNVBear    or hp_HTBear    or hp_NHx2Bear
bool sig_WBUSH_Neutral = hp_HYYNeutral or hp_HNNeutral or hp_HNVNeutral or hp_HTNeutral or hp_NHx2Neutral

// Backward-compat: sigWMD aliased to sig_WBUSH_Bull (old WMD = bullish heavy weapons; WBUSH supersedes).
bool sigWMD = sig_WBUSH_Bull

// UC NAGASAKI — Unified Combo + Nagasaki same visual bar
// csNew3 (UC) at bar[0] = visual bar 1; sigNagasaki[1] = visual bar 1. Offset = -1.
bool sig_UCNagasakiBull = csNew3_Bull and nz(sigNagasaki[1])
bool sig_UCNagasakiBear = csNew3_Bear and nz(sigNagasaki[1])

bool comboAnyB2B_F2E3=det_b2bPUP and (sBullF2 or sBullE3)

// ════════════════════════════════════════════════════════════════════════════
// B2B PUP COMBINATION SIGNALS + CHECKBOX + ONE-OF-THESE + CORRECTED FUSIONS
// ════════════════════════════════════════════════════════════════════════════

bool b2b_fauna_bull=det_b2bPUP and sigFAUNABull and nz(sigFAUNABull[1])
bool b2b_disp_bull=nz(sigPUP[1]) and nz(sigPUP[2]) and sigDISPBull and nz(sigDISPBull[1])
bool b2b_hvd_disp_bull=nz(sigPUP[1]) and nz(sigPUP[2]) and hvd_fire_bull and nz(hvd_fire_bull[1])
bool b2b_disp_any_bull=b2b_disp_bull or b2b_hvd_disp_bull
bool b2b_fauna_disp_bull=nz(sigPUP[1]) and nz(sigPUP[2]) and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2]) and sigDISPBull and nz(sigDISPBull[1])
bool b2b_fauna_hvd_bull=nz(sigPUP[1]) and nz(sigPUP[2]) and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2]) and hvd_fire_bull and nz(hvd_fire_bull[1])
bool b2b_fauna_disp_any=b2b_fauna_disp_bull or b2b_fauna_hvd_bull
bool saab_c0=sigSAAB or sigBullRVOL1x or sigGrandSlam, bool saab_c1=nz(sigSAAB[1]) or nz(sigBullRVOL1x[1]) or nz(sigGrandSlam[1])
bool b2b_saab_bull=det_b2bPUP and saab_c0 and saab_c1
bool b2b_anyB2B=det_b2bPUP or b2b_fauna_bull or b2b_disp_any_bull or b2b_fauna_disp_any or b2b_saab_bull
bool b2b_pbj_bull=b2b_anyB2B and (sigBullPBJ or nz(sigBullPBJ[1]))
bool b2b_combo_bull=det_b2bPUP and (csNew3_Bull or nz(csNew3_Bull[1]))
bool b2b_cc_bull=det_b2bPUP and (sigCCBull or nz(sigCCBull[1]))
bool b2b_uu_bull=det_b2bPUP and (sigP21BullUUUU or sigP21BullUUU or sigUUBull or nz(sigP21BullUUUU[1]) or nz(sigP21BullUUU[1]) or nz(sigUUBull[1]))
bool b2b_npm_b2b_pup=det_b2bPUP and (det_b2bBullNapalm or nz(det_b2bBullNapalm[1]))
bool b2b_tnt_bull=det_b2bPUP and (raw_bullTNT or nz(raw_bullTNT[1]))
bool b2b_npm_pup=det_b2bPUP and (det_bullNapalmCons or nz(det_bullNapalmCons[1]))
bool b2b_heavy_bull=b2b_tnt_bull or b2b_npm_pup
bool b2b_cont_pup=det_b2bPUP and (raw_contBull or nz(raw_contBull[1]))
bool b2b_hvdpbj_pup=det_b2bPUP and (hvd_pbj_bull or nz(hvd_pbj_bull[1]))
bool b2b_long1=sigLong1 and nz(sigLong1[1])
bool b2b_long1_pup=det_b2bPUP and b2b_long1

// ONE-OF-THESE gates
bool oneOfThese=sigP21BullUUUU or sigP21BullUUU or sigUUBull or sigOmegaLongA or det_bullNapalmCons or det_b2bBullNapalm or csNew3_Bull or (csNew1_Bull or csNew2_Bull) or sigWMD
bool oneOfThese_forUU=sigP21BullUUUU or sigP21BullUUU or sigOmegaLongA or det_bullNapalmCons or det_b2bBullNapalm or csNew3_Bull or (csNew1_Bull or csNew2_Bull) or sigWMD or sigDISPBull or hvd_fire_bull or sigFAUNABull or sigPUP or sigBullPBJ or sigLong1 or sigGrandSlam or sigBullRVOL1x
// oneOfThese aligned to bar[1] for SUPER (displacement candle visual)
bool oneOfThese_p1=nz(sigP21BullUUUU[1]) or nz(sigP21BullUUU[1]) or nz(sigUUBull[1]) or nz(sigOmegaLongA[1]) or det_bullNapalmCons or det_b2bBullNapalm or csNew3_Bull or csNew1_Bull or nz(csNew2_Bull[1]) or nz(sigWMD[1])

// CHECKBOX SYSTEM
grpCB="Checkbox Qualifiers"
bool cb1_uu=input.bool(true,"UU family",group=grpCB), bool cb1_combo=input.bool(true,"Uni.Combo",group=grpCB)
bool cb1_d9=input.bool(true,"Disp (9 strength)",group=grpCB), bool cb1_pup=input.bool(true,"PUP",group=grpCB)
bool cb1_pbj=input.bool(true,"PBJ",group=grpCB), bool cb1_l1=input.bool(true,"Long1",group=grpCB), bool cb1_wmd=input.bool(true,"WMD",group=grpCB)
bool cb2_uu=input.bool(true,"UU family (2)",group=grpCB), bool cb2_combo=input.bool(true,"Uni.Combo (2)",group=grpCB)
bool cb2_d9=input.bool(true,"Disp 9 (2)",group=grpCB), bool cb2_pup=input.bool(true,"PUP (2)",group=grpCB)
bool cb2_pbj=input.bool(true,"PBJ (2)",group=grpCB), bool cb2_l1=input.bool(true,"Long1 (2)",group=grpCB), bool cb2_wmd=input.bool(true,"WMD (2)",group=grpCB)
bool cb3_uu=input.bool(true,"UU family (3)",group=grpCB), bool cb3_combo=input.bool(true,"Uni.Combo (3)",group=grpCB)
bool cb3_d9=input.bool(true,"Disp 9 (3)",group=grpCB), bool cb3_pup=input.bool(true,"PUP (3)",group=grpCB)
bool cb3_pbj=input.bool(true,"PBJ (3)",group=grpCB), bool cb3_l1=input.bool(true,"Long1 (3)",group=grpCB), bool cb3_wmd=input.bool(true,"WMD (3)",group=grpCB)

float d9_thresh=disp_std*9.0
bool d9_bull=conf and disp_rng>d9_thresh and close>open

bool uu_any=sigP21BullUUUU or sigP21BullUUU or sigUUBull
bool disp_or_hvd=sigDISPBull or hvd_fire_bull
bool pbj_or_hvdpbj=sigBullPBJ or hvd_pbj_bull

// Standard checkbox (bar[0] signals — for non-displacement combos)
f_cb(bool e_uu,bool e_co,bool e_d9,bool e_pup,bool e_pbj,bool e_l1,bool e_wmd)=>
    (e_uu and uu_any) or (e_co and csNew3_Bull) or (e_d9 and d9_bull) or (e_pup and sigPUP) or (e_pbj and pbj_or_hvdpbj) or (e_l1 and sigLong1) or (e_wmd and sigWMD)
bool cb1_pass=f_cb(cb1_uu,cb1_combo,cb1_d9,cb1_pup,cb1_pbj,cb1_l1,cb1_wmd)
bool cb1_pass_floor=f_cb(cb1_uu,cb1_combo,cb1_d9,cb1_pup,false,cb1_l1,cb1_wmd)
bool cb2_pass=f_cb(cb2_uu,cb2_combo,cb2_d9,cb2_pup,cb2_pbj,cb2_l1,cb2_wmd)
bool cb3_pass=f_cb(cb3_uu,cb3_combo,cb3_d9,cb3_pup,cb3_pbj,cb3_l1,cb3_wmd)

// Napalm-aligned checkbox (bar[1] signals — for displacement+FVG combos)
f_cb_npm(bool e_uu,bool e_co,bool e_d9,bool e_pup,bool e_pbj,bool e_l1,bool e_wmd)=>
    (e_uu and (nz(sigP21BullUUUU[1]) or nz(sigP21BullUUU[1]) or nz(sigUUBull[1]))) or (e_co and csNew3_Bull) or (e_d9 and nz(d9_bull[1])) or (e_pup and nz(sigPUP[1])) or (e_pbj and (nz(sigBullPBJ[1]) or hvd_pbj_bull)) or (e_l1 and nz(sigLong1[1])) or (e_wmd and nz(sigWMD[1]))
bool cb1_pass_npm=f_cb_npm(cb1_uu,cb1_combo,cb1_d9,cb1_pup,cb1_pbj,cb1_l1,cb1_wmd)
bool cb2_pass_npm=f_cb_npm(cb2_uu,cb2_combo,cb2_d9,cb2_pup,cb2_pbj,cb2_l1,cb2_wmd)
bool cb3_pass_npm=f_cb_npm(cb3_uu,cb3_combo,cb3_d9,cb3_pup,cb3_pbj,cb3_l1,cb3_wmd)

// Alpha Strike expanded FAUNA slot
bool as_fauna_expanded=sigFAUNABull or sigLong1 or disp_or_hvd or sigPUP or det_bullNapalmCons or sigWTC or sigHiroshima or sigNagasaki
bool sigAlphaStrikeBull_sq=conf and firstOfDay and bull_pp and (sigGrandSlam or sigBullRVOL1x) and sigBullPBJ and as_fauna_expanded

// Super with bar[1]-aligned oneOfThese gate
bool superBull_sq=superBull and oneOfThese_p1

// Floor/2F with checkbox + one-of-these
bool floor_sq=anyBullFloor and oneOfThese and cb1_pass_floor
bool floor2_sq=anyBull2nd and oneOfThese and cb1_pass
bool uu_gated=sigUUBull and oneOfThese_forUU
bool foxtrot_sq=sigFoxtrotBull and (hvd_pbj_bull or oneOfThese)

// NPM12/NPM3 — FIX: use napalm-aligned checkbox (bar[1] signals)
bool npm12=det_bullNapalmCons and (cb1_pass_npm or cb2_pass_npm)
bool npm3=det_bullNapalmCons and cb3_pass_npm

// ┌──────────────────────────────────────────────────────────────────────────┐
// │  CROSS-INDICATOR FUSIONS — OFFSET-CORRECTED                            │
// │  All napalm combos: offset -1 (displacement+FVG in TNT engine).        │
// │  Per RULE 5: AND'd offset-0 booleans shifted to [1].                   │
// │  csNew3_Bull stays [0] (two-bar pattern already describes bar[1]).      │
// └──────────────────────────────────────────────────────────────────────────┘

// Signal 38 NPM+: PBJ/HW/WMD shifted to [1]
bool sig38=det_bullNapalmCons and ((nz(sigBullPBJ[1]) and (csNew3_Bull or nz(hwBull[1]) or nz(sigWMD[1]))) or nz(sigWMD[1]))

// Signal 49 GRAIL: PBJ/PUP shifted to [1]
bool holy_grail=det_bullNapalmCons and nz(sigBullPBJ[1]) and nz(sigPUP[1]) and csNew3_Bull

// Signal 50 FLR+NPM: Floor shifted to [1]
bool floor_npm=nz(anyBullFloor[1]) and det_bullNapalmCons

// Signal 51 NPM+PBJ+PUP: PBJ/PUP shifted to [1]
bool npm_pbj_pup=det_bullNapalmCons and nz(sigBullPBJ[1]) and nz(sigPUP[1])

// Signal 52 NAG+
bool nag_any_bull=sigNagasaki and (sigBullRVOL1x or sigGrandSlam or sigFAUNABull or sigDISPBull or sigBullPBJ or sigPUP or gz_bullHV or gz_bullGZI)

// Signal 53 UU+HVD: UU shifted to [1] (hvd_pbj_bull is offset -1)
bool uu_hvdpbj=(nz(sigP21BullUUUU[1]) or nz(sigP21BullUUU[1]) or nz(sigUUBull[1])) and hvd_pbj_bull

// Signal 54 UU+NPM: UU shifted to [1] (napalm is offset -1)
bool uu_npm=(nz(sigP21BullUUUU[1]) or nz(sigP21BullUUU[1]) or nz(sigUUBull[1])) and det_bullNapalmCons

// Signal 55 FLR+UU (both offset 0 — no displacement in chain)
bool floor_uu=(anyBullFloor or anyBull2nd) and uu_any

// Signal 56 FOS+PUP+1x
bool foster_pup_rvol=fosterPBJSignal and sigPUP and (sigBullRVOL1x or det_bullNapalmCons)

// Signal 57 B2B+NPM+PBJ: B2B PUP and PBJ shifted to [1]
bool b2b_npm_pbj=nz(det_b2bPUP[1]) and det_bullNapalmCons and nz(sigBullPBJ[1])

// Signal 60 NPM+UC: Both describe bar[1]. No shift needed.
bool sig_npm_combo=det_bullNapalmCons and csNew3_Bull

// Signal 63 NPM+UC+PBJ: PBJ shifted to [1]
bool sig_npm_combo_pbj=det_bullNapalmCons and csNew3_Bull and nz(sigBullPBJ[1])

// Signal 48 UU+UC
bool sig_uu_combo=uu_any and csNew3_Bull

// Signal 61 WMD (already offset 0)
// Signal 64 WMD+BULL
bool wmd_any_bull=sigWMD and (sigBullRVOL1x or sigGrandSlam or sigFAUNABull or sigDISPBull or sigBullPBJ or sigPUP or gz_bullHV or gz_bullGZI or uu_any or det_bullNapalmCons or anyBullFloor or anyBull2nd or sigLong1)

// Signal 62 L1²+B2B (offset 0)
// (b2b_long1_pup already defined above)

// ════════════════════════════════════════════════════════════════════════════
// 46 BULLISH/BEARISH PLOTSHAPES — every plot is a buy/sell trigger
// v2: 64 → 46 contiguous. B2B-overlap removals (kept GOLF), reserved removed,
// CONT removed, WMD replaced with WBUSH (3), UC NAGASAKI added (Bull/Bear).
// Offset: -1 = displacement+FVG in chain (visual on bar[1])
//          0 = single-bar event (visual on bar[0])
// ════════════════════════════════════════════════════════════════════════════

// USE STANDALONE (1-13)
plotshape(_masterGate and en_1 and sduperBull, "1 SD!",shape.flag,location.bottom,#FFD700,text="SD!",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_2 and superBull and not sduperBull, "2 SUPER",shape.flag,location.top,#00FF00,text="SUPER",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_3 and hwBull, "3 HW",shape.xcross,location.abovebar,#FF6D00,text="HW",textcolor=color.white,size=size.large)
plotshape(_masterGate and en_4 and floor_sq, "4 FLOOR",shape.circle,location.belowbar,#00E5FF,text="FLOOR",textcolor=color.white,size=size.large)
plotshape(_masterGate and en_5 and floor2_sq and not floor_sq, "5 2F",shape.cross,location.belowbar,#80DEEA,text="2F",textcolor=color.white,size=size.normal)
plotshape(_masterGate and en_6 and sigP21BullUUUU, "6 UUUU",shape.labelup,location.belowbar,#00FF00,text="UUUU",textcolor=color.white,size=size.large)
plotshape(_masterGate and en_7 and sigP21BullUUU and not sigP21BullUUUU, "7 UUU",shape.labelup,location.belowbar,#76FF03,text="UUU",textcolor=color.white,size=size.normal)
plotshape(_masterGate and en_8 and uu_gated and not sigP21BullUUU and not sigP21BullUUUU, "8 UU",shape.labelup,location.belowbar,#A5D6A7,text="UU",textcolor=color.white,size=size.small)
plotshape(_masterGate and en_9 and sigAlphaStrikeBull_sq, "9 A★",shape.flag,location.belowbar,#00E676,text="A★",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_10 and sigOmegaLongA, "10 ΩA",shape.circle,location.abovebar,#FFD700,text="ΩA",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_11 and foxtrot_sq, "11 FOX",shape.triangleup,location.top,#1B5E20,text="FOX",textcolor=color.white,size=size.large)
plotshape(_masterGate and en_12 and sigODBull, "12 OD",shape.flag,location.bottom,#00FFFF,text="OD",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_13 and sigGolfBull, "13 GOLF",shape.labelup,location.bottom,color.new(#00FF00,25),text="GOLF",textcolor=color.white,size=size.huge,offset=-1)

// ULTRA 57 (14-21)
plotshape(_masterGate and en_28 and (comboPBJ_F2_Bull or comboPBJ_E3_Bull), "14 PBJ+F2/E3",shape.labelup,location.belowbar,color.lime,text="PBJ\nF2E3",textcolor=color.white,size=size.large)
plotshape(_masterGate and en_29 and comboPBJ_Cluster_Bull, "15 PBJ+CL",shape.labelup,location.top,color.lime,text="PBJ\nCL",textcolor=color.white,size=size.large)
plotshape(_masterGate and en_30 and comboF2Cluster_E3_Bull, "16 F2CL→E3",shape.diamond,location.top,color.aqua,text="F2CL\n→E3",textcolor=color.white,size=size.large)
plotshape(_masterGate and en_33 and comboE3_2of3PUP_Bull, "17 E3⅔PP",shape.diamond,location.abovebar,color.teal,text="E3\n⅔PP",textcolor=color.white,size=size.normal)
plotshape(_masterGate and en_34 and comboF2_B2BDays_Bull, "18 F2×2D",shape.flag,location.top,color.lime,text="F2×2D",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_35 and comboE3_B2BDays_Bull, "19 E3×2D",shape.flag,location.top,#76FF03,text="E3×2D",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_36 and comboF2E3_Consec_Bull, "20 F2E3seq",shape.flag,location.top,#FFFF00,text="F2E3\nseq",textcolor=color.black,size=size.huge)
plotshape(_masterGate and en_37 and comboCluster_B2BDays_Bull, "21 CL×2D",shape.flag,location.bottom,#FFFF00,text="CL×2D",textcolor=color.black,size=size.huge)

// NPM (22-26)
plotshape(_masterGate and en_38 and sig38, "22 NPM+",shape.labelup,location.bottom,#00FFAA,text="NPM+",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_39 and npm12, "23 NPM12",shape.triangleup,location.belowbar,#00BCD4,text="NPM12",textcolor=color.white,size=size.normal,offset=-1)
plotshape(_masterGate and en_41 and npm3 and not npm12, "24 NPM3",shape.triangleup,location.top,#0097A7,text="NPM3",textcolor=color.white,size=size.small,offset=-1)
plotshape(_masterGate and en_42 and det_b2bBullNapalm, "25 B2BNPM",shape.labelup,location.bottom,#1DE9B6,text="B2B\nNPM",textcolor=color.white,size=size.large,offset=-1)
plotshape(_masterGate and en_43 and det_npmTntBull, "26 NPM+TNT",shape.labelup,location.belowbar,#089981,text="NPM\nTNT",textcolor=color.white,size=size.large,offset=-1)

// HV+D (27-31)
plotshape(_masterGate and en_44 and co_bull_pbj, "27 CO",shape.diamond,location.belowbar,#FFD700,text="CO",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_45 and hvd_pbj_bull and not co_bull_pbj and (tfSec>=180 or cb1_pass_npm), "28 HVD+PBJ",shape.diamond,location.bottom,color.new(color.yellow,25),text="HVD\nPBJ",textcolor=color.white,size=size.normal,offset=-1)
plotshape(_masterGate and en_46 and b2b_bull_pbj, "29 B2BHVD+PBJ",shape.flag,location.bottom,#E040FB,text="B2B\nHVD\nPBJ",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_47 and b2b_bull_nopb and not b2b_bull_pbj, "30 B2BHVD",shape.flag,location.belowbar,#4CAF50,text="B2B\nHVD",textcolor=color.white,size=size.large,offset=-1)
plotshape(_masterGate and en_48 and sig_uu_combo, "31 UU+UC",shape.labelup,location.bottom,#7C4DFF,text="UU\nUC",textcolor=color.white,size=size.huge,offset=-1)

// FUSIONS (32-39)
plotshape(_masterGate and en_49 and holy_grail, "32 GRAIL",shape.labelup,location.bottom,#FFD700,text="GRAIL",textcolor=color.black,size=size.huge,offset=-1)
plotshape(_masterGate and en_50 and floor_npm, "33 FLR+NPM",shape.circle,location.bottom,#00FFFF,text="FLR\nNPM",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_51 and npm_pbj_pup and not holy_grail, "34 NPM+PBJ+PUP",shape.labelup,location.belowbar,#00E676,text="NPM\nPBJ\nPUP",textcolor=color.white,size=size.large,offset=-1)
plotshape(_masterGate and en_52 and nag_any_bull, "35 NAG+",shape.labelup,location.abovebar,#FF00FF,text="NAG+",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_53 and uu_hvdpbj, "36 UU+HVD",shape.labelup,location.belowbar,#7C4DFF,text="UU\nHVD",textcolor=color.white,size=size.large,offset=-1)
plotshape(_masterGate and en_54 and uu_npm, "37 UU+NPM",shape.labelup,location.abovebar,#00BCD4,text="UU\nNPM",textcolor=color.white,size=size.normal,offset=-1)
plotshape(_masterGate and en_55 and floor_uu, "38 FLR+UU",shape.square,location.belowbar,#00E5FF,text="FLR\nUU",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_56 and foster_pup_rvol, "39 FOS+PUP+1x",shape.labelup,location.bottom,#88FF00,text="FOS\nPUP\n1x",textcolor=color.black,size=size.huge)

// NPM+UC (40)
plotshape(_masterGate and en_60 and sig_npm_combo and not sig_npm_combo_pbj, "40 NPM+UC",shape.labelup,location.belowbar,#00E5FF,text="NPM\nUC",textcolor=color.white,size=size.large,offset=-1)

// WBUSH (41-43) — replaces WMD slot
plotshape(_masterGate and en_wbushBull and sig_WBUSH_Bull, "41 WBUSH+ANY Bull",shape.diamond,location.belowbar,#00BFA5,text="WBUSH",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_wbushBear and sig_WBUSH_Bear, "42 WBUSH+ANY Bear",shape.diamond,location.abovebar,#C2185B,text="WBUSH",textcolor=color.white,size=size.huge)
plotshape(_masterGate and en_wbushNeutral and sig_WBUSH_Neutral, "43 WBUSH Neutral",shape.diamond,location.top,#9E9E9E,text="WBUSH N",textcolor=color.white,size=size.normal)

// NPM+UC+PBJ (44)
plotshape(_masterGate and en_63 and sig_npm_combo_pbj, "44 NPM+UC+PBJ",shape.labelup,location.bottom,#FFC107,text="NPM\nUC\nPBJ",textcolor=color.black,size=size.huge,offset=-1)

// UC NAGASAKI (45-46) — new
plotshape(_masterGate and en_ucNagBull and sig_UCNagasakiBull, "45 UC NAGASAKI Bull",shape.labelup,location.belowbar,#FF00FF,text="UC\nNAG",textcolor=color.white,size=size.huge,offset=-1)
plotshape(_masterGate and en_ucNagBear and sig_UCNagasakiBear, "46 UC NAGASAKI Bear",shape.labeldown,location.abovebar,#9C27B0,text="UC\nNAG",textcolor=color.white,size=size.huge,offset=-1)

// ════════════════════════════════════════════════════════════════════════════
// ALERT AGGREGATOR — Bloomberg format
// Format: BULL | FIRST !!!/FIRST XXX/NOT !!! | signal_names
// NEVER ticker/exchange/timeframe — TradingView adds those automatically.
// ════════════════════════════════════════════════════════════════════════════
if conf and _masterGate
    string s=""
    if en_1 and sduperBull
        s:=f_add(s,"SD!")
    if en_2 and superBull and not sduperBull
        s:=f_add(s,"SUPER")
    if en_3 and hwBull
        s:=f_add(s,"HW")
    if en_4 and floor_sq
        s:=f_add(s,"FLOOR")
    if en_5 and floor2_sq
        s:=f_add(s,"2F")
    if en_6 and sigP21BullUUUU
        s:=f_add(s,"UUUU")
    if en_7 and sigP21BullUUU and not sigP21BullUUUU
        s:=f_add(s,"UUU")
    if en_8 and uu_gated and not sigP21BullUUU and not sigP21BullUUUU
        s:=f_add(s,"UU")
    if en_9 and sigAlphaStrikeBull_sq
        s:=f_add(s,"A★")
    if en_10 and sigOmegaLongA
        s:=f_add(s,"ΩA")
    if en_11 and foxtrot_sq
        s:=f_add(s,"FOX")
    if en_12 and sigODBull
        s:=f_add(s,"OD")
    if en_13 and sigGolfBull
        s:=f_add(s,"GOLF")
    if en_28 and comboPBJ_F2_Bull
        s:=f_add(s,"PBJ+F2")
    if en_28 and comboPBJ_E3_Bull
        s:=f_add(s,"PBJ+E3")
    if en_29 and comboPBJ_Cluster_Bull
        s:=f_add(s,"PBJ+CL")
    if en_30 and comboF2Cluster_E3_Bull
        s:=f_add(s,"F2CL→E3")
    if en_33 and comboE3_2of3PUP_Bull
        s:=f_add(s,"E3⅔PP")
    if en_34 and comboF2_B2BDays_Bull
        s:=f_add(s,"F2×2D")
    if en_35 and comboE3_B2BDays_Bull
        s:=f_add(s,"E3×2D")
    if en_36 and comboF2E3_Consec_Bull
        s:=f_add(s,"F2E3seq")
    if en_37 and comboCluster_B2BDays_Bull
        s:=f_add(s,"CL×2D")
    if en_38 and sig38
        s:=f_add(s,"NPM+"+(csNew3_Bull?"UC":nz(hwBull[1])?"HW":"WBUSH"))
    if en_39 and npm12
        s:=f_add(s,"NPM12")
    if en_41 and npm3 and not npm12
        s:=f_add(s,"NPM3")
    if en_42 and det_b2bBullNapalm
        s:=f_add(s,"B2BNPM")
    if en_43 and det_npmTntBull
        s:=f_add(s,"NPM+TNT")
    if en_44 and co_bull_pbj
        s:=f_add(s,"CO")
    if en_45 and hvd_pbj_bull and not co_bull_pbj and (tfSec>=180 or cb1_pass_npm)
        s:=f_add(s,"HVD+PBJ")
    if en_46 and b2b_bull_pbj
        s:=f_add(s,"B2BHVD+PBJ")
    if en_47 and b2b_bull_nopb and not b2b_bull_pbj
        s:=f_add(s,"B2BHVD")
    if en_48 and sig_uu_combo
        s:=f_add(s,"UU+UC")
    if en_49 and holy_grail
        s:=f_add(s,"GRAIL")
    if en_50 and floor_npm
        s:=f_add(s,"FLR+NPM")
    if en_51 and npm_pbj_pup and not holy_grail
        s:=f_add(s,"NPM+PBJ+PUP")
    if en_52 and nag_any_bull
        s:=f_add(s,"NAG+")
    if en_53 and uu_hvdpbj
        s:=f_add(s,"UU+HVD")
    if en_54 and uu_npm
        s:=f_add(s,"UU+NPM")
    if en_55 and floor_uu
        s:=f_add(s,"FLR+UU")
    if en_56 and foster_pup_rvol
        s:=f_add(s,"FOS+PUP+1x")
    if en_60 and sig_npm_combo and not sig_npm_combo_pbj
        s:=f_add(s,"NPM+UC")
    if en_wbushBull and sig_WBUSH_Bull
        s:=f_add(s,"WBUSH+ANY")
    if en_wbushNeutral and sig_WBUSH_Neutral
        s:=f_add(s,"WBUSH-N")
    if en_63 and sig_npm_combo_pbj
        s:=f_add(s,"NPM+UC+PBJ")
    if en_ucNagBull and sig_UCNagasakiBull
        s:=f_add(s,"UC NAGASAKI")
    if str.length(s)>0
        if master_aggAlerts
            alert("BULL | " + _gapQual + " | " + s, alert.freq_once_per_bar_close)
    // Bear aggregator (WBUSH bear + UC NAGASAKI bear — bear-side new in v2)
    string sb=""
    if en_wbushBear and sig_WBUSH_Bear
        sb:=f_add(sb,"WBUSH+ANY")
    if en_ucNagBear and sig_UCNagasakiBear
        sb:=f_add(sb,"UC NAGASAKI")
    if str.length(sb)>0
        if master_aggAlerts
            alert("BEAR | " + _gapQual + " | " + sb, alert.freq_once_per_bar_close)

// ════════════════════════════════════════════════════════════════════════════
// BACKTEST LAYER — NAG+ AND B2B BULL NAPALM ENTRY/EXIT
// ════════════════════════════════════════════════════════════════════════════
// Three modes (selected via input):
//   NAG_PLUS         → Nagasaki + any qualifying bull signal, fires any candle
//   B2B_NPM_FIRST2   → Back-to-back Bull Napalm only on candle 1 or 2 of session
//   B2B_NPM_AFTER2   → Back-to-back Bull Napalm only after candle 2
//
// Entries are LONG-ONLY. Exit is fixed-bar hold (default 20 bars).
// Equity = 100% per trade, commission = 0.05%, no pyramiding.

string bt_mode  = input.string("NAG_PLUS", "Backtest Mode",
     options=["NAG_PLUS", "B2B_NPM_FIRST2", "B2B_NPM_AFTER2"], group="★ BACKTEST ★")
int    bt_hold  = input.int(20, "Hold N Bars Then Exit", minval=1, group="★ BACKTEST ★",
     tooltip="Bars to hold each long trade before exit. 20 = ~100 minutes on 5m, ~5 hours on 15m.")

// Session bar counter — resets on day change, counts confirmed bars.
var int bt_sessBar = 0
if ta.change(time("D")) != 0
    bt_sessBar := 1
else if barstate.isconfirmed
    bt_sessBar += 1
bool bt_isFirst2 = bt_sessBar <= 2

// Entry triggers per mode. nag_any_bull is offset 0 (current bar); det_b2bBullNapalm
// is offset -1 (describes bar[1]) so we fire on the next bar.
bool bt_entry_nagPlus     = nag_any_bull
bool bt_entry_b2bFirst2   = det_b2bBullNapalm and bt_isFirst2
bool bt_entry_b2bAfter2   = det_b2bBullNapalm and not bt_isFirst2

bool bt_fire = (bt_mode == "NAG_PLUS"        and bt_entry_nagPlus)
             or (bt_mode == "B2B_NPM_FIRST2" and bt_entry_b2bFirst2)
             or (bt_mode == "B2B_NPM_AFTER2" and bt_entry_b2bAfter2)

if bt_fire and strategy.position_size == 0 and barstate.isconfirmed
    strategy.entry("L", strategy.long)

if strategy.position_size > 0 and (bar_index - strategy.opentrades.entry_bar_index(0)) >= bt_hold
    strategy.close("L", comment="hold_exit")

// Visual marker for backtest entries (overlays a tag at entry bar)
plotshape(bt_fire, "BT Entry", shape.triangleup, location.belowbar, color.new(color.lime, 0),
     size=size.small, text="BT", textcolor=color.lime)

