    bool pB = _all_disp
    bool pC = _all_saab_df
    bool pD = _has_hvd and (_has_pb or _has_pbj)
    bool pE = (_df_not_pbj and _has_pbj) or (_pbj_not_df and (_has_disp or _has_fauna))
    int _qcnt = (_has_pbj?1:0)+(_has_disp?1:0)+(_has_fauna?1:0)+(_has_sa?1:0)+(_has_r1?1:0)+(_has_gs?1:0)
    bool pG = _qcnt >= 2
    float _sum2 = bb_normalizedPrice + nz(bb_normalizedPrice[1])
    bool _pbj2 = nz(sigBullPBJ) or nz(sigBullPBJ[1])
    bool _sub2min_ok_2 = tfSec > 120 or (_sum2 >= th_saab_kratos and (_sum2 >= th_1x or _pbj2))
    sigUUBull := (pA or pB or pC or pD or pE or pG) and _sub2min_ok_2
    sigUUBull_indep := (pA or pB or pC or pE or pG) and _sub2min_ok_2

// ─── BEAR DDDD (≥4) ───
bool sigP21BearUUUU = false, bool sigP21BearUUUU_indep = false
if conf and u_bear_streak >= 4
    int _n = math.min(u_bear_streak, 4)
    bool _has_pbj = false, bool _has_pb = false, bool _has_hvd = false, bool _has_disp = false, bool _has_fauna = false
    bool _all_disp = true, bool _all_saab_df = true, bool _df_not_pbj = false, bool _pbj_not_df = false
    bool _has_sa = false, bool _has_r1 = false, bool _has_gs = false
    for i = 0 to _n - 1
