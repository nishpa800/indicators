// SQUARIFY 46 v2 — every plot is a buy/sell trigger
// ════════════════════════════════════════════════════════════════════════════
// CHANGELOG v1 (64 signals) → v2 (46 signals)
// ──────────────────────────────────────────────────────────────────────────────
//   1. NAPALM BUG FIX. v1 used `raw_napalmBull/Bear` (raw napalm only) in 19+
//      detection plots. v2 uses `det_bull/bearNapalmCons` (raw OR Charge) per
//      Anish's framework — Napalm and Charge are equivalent. Fixes silent
//      under-firing of NPM-based plots.
//   2. SUPER + SDUPER REDEFINED per Anish:
//        SUPER  = UC (Unified Combo, csNew3) + Napalm consolidated
//        SDUPER = UC + Napalm + PUP
//      Old "perfect-storm" definitions never fired in practice.
//   3. UC NAGASAKI added (#45 Bull, #46 Bear): Unified Combo + Nagasaki on
//      same visual bar. Offset = -1.
//   4. WMD ripped out, replaced with WBUSH (#41 Bull, #42 Bear, #43 Neutral).
//      WBUSH = HEAVY PENTAGON's 5 Heavy Combo families × 3 directions = 15
//      sub-signals OR'd. More granular than WMD's 2-of-3 axes.
//   5. CO restructured: now requires UC OR FVG Combo Set (csNew3 or csNew1).
//      Old `use_any_bull[1]` broad gate replaced.
//   6. UU/UUU/UUUU + new path pG: count distinct qualifier types in streak
//      from {PBJ, DISP, FAUNA, SAAB, RVOL1x, GS}. UU=2, UUU=3, UUUU=4.
//      ORs into existing pA/pB/pC/pD/pE/pF — additive.
//   7. REMOVED 22 signals:
//        - Reserved (en_25, en_40)
//        - B2B PUP overlaps (en_14-24, 26, 27, 31, 32, 57, 58, 62) — kept GOLF
//        - CONT (en_59) — per Anish
//        - WMD (en_61) — replaced by WBUSH
//        - WMD+BULL (en_64) — covered by WBUSH
//   8. RENUMBERED 1-46 contiguously. No reserved IDs.
// ──────────────────────────────────────────────────────────────────────────────
// EXCEPTIONS:
//   CHECKBOX BYPASSERS: None. All 46 detections gated by their en_* toggles.
//   AGGREGATOR BYPASSERS: None.
// ════════════════════════════════════════════════════════════════════════════
//@version=5
strategy("SQUARIFY v2 BT — NAG+ / B2B NPM",
     shorttitle="SQ46 v2 BT",
     overlay=true,
     max_labels_count=500,
     max_lines_count=500,
     max_boxes_count=500,
     max_bars_back=1500,
     pyramiding=0,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     calc_on_every_tick=false,
     process_orders_on_close=true)
import TradingView/ta/7 as tv_ta

// SHARED
// ============================================================================
conf = barstate.isconfirmed
int tfSec = timeframe.in_seconds(timeframe.period)
f_add(string base, string part) => base == "" ? part : base + " + " + part
atr14 = ta.atr(14)

// ════════════════════════════════════════════════════════════════════════════
// MASTER TOGGLES
// ════════════════════════════════════════════════════════════════════════════
grpMASTER = "★★★ MASTER TOGGLES ★★★"
bool master_firstBarOnly = input.bool(false, "First Bar Only", group=grpMASTER, tooltip="ON: requires first bar of session AND any HV rank on bar[0]. Both must be true. Detections blocked if either missing.")
bool master_aggAlerts = input.bool(true, "Aggregate Alerts", group=grpMASTER, tooltip="ON = one combined alert per bar. OFF = individual alerts per detection.")

// Gap qualifier for FIRST/NOT alert format
float _gapSize = math.abs(open - close[1])
float _barRange = high - low
bool _isGapBar = ta.change(time("D")) != 0
string _gapQual = not _isGapBar ? "NOT !!!" : (_gapSize <= _barRange ? "FIRST !!!" : "FIRST XXX")


// ╔════════════════════════════════════════════════════════════════════════════╗
// ║  PIPELINE A: HV+D — HIGH VOLUME + DISPLACEMENT                         ║
// ║  This pipeline knows NOTHING about PBJ, Zoo, Supertrend, FAUNA,         ║
// ║  RVOL, Ping Pong, Combo Sets, or any USE engine.                        ║
// ║  It checks volume rank and candle displacement. That is ALL.             ║
// ╚════════════════════════════════════════════════════════════════════════════╝

hvd_tf2sec(string t) =>
    switch t
        "1 Min"   => 60
        "2 Min"   => 120
        "3 Min"   => 180
        "4 Min"   => 240
        "5 Min"   => 300
        "10 Min"  => 600
        "15 Min"  => 900
        "30 Min"  => 1800
        "1 Hour"  => 3600
        "2 Hour"  => 7200
        "3 Hour"  => 10800
        "4 Hour"  => 14400
        "1 Day"   => 86400
        "2 Day"   => 172800
        "3 Day"   => 259200
        "1 Week"  => 604800
        "1 Month" => 2592000
        "3 Month" => 7776000
        => 0

// === PIPELINE A: DISPLACEMENT 1 (BASE) ===
grp_hvd1 = "── HV+D: DISP BASE ──"
d1_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_hvd1)
d1_len  = input.int(100, "Std Dev Length", minval=1, group=grp_hvd1)
d1_mult = input.float(5.0, "Std Dev Multiplier", minval=0.1, step=0.1, group=grp_hvd1)
float d1_rng = d1_type == "Open to Close" ? math.abs(open - close) : high - low
float d1_std = ta.stdev(d1_rng, d1_len)
float d1_thresh = d1_std * d1_mult
bool  d1_prevDisp = d1_rng[1] > d1_thresh[1]
bool  d1_bullFVG  = low > high[2] and close[1] > open[1]
bool  d1_bearFVG  = high < low[2] and close[1] < open[1]
bool  d1_bull = conf and d1_prevDisp and d1_bullFVG
bool  d1_bear = conf and d1_prevDisp and d1_bearFVG

// === PIPELINE A: DISPLACEMENT 2 (HTF1) ===
grp_hvd2 = "── HV+D: DISP HTF1 ──"
d2_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_hvd2)
d2_len  = input.int(100, "Std Dev Length", minval=1, group=grp_hvd2)
d2_mult = input.float(2.5, "Std Dev Multiplier", minval=0.1, step=0.1, group=grp_hvd2)
float d2_rng = d2_type == "Open to Close" ? math.abs(open - close) : high - low
float d2_std = ta.stdev(d2_rng, d2_len)
float d2_thresh = d2_std * d2_mult
bool  d2_prevDisp = d2_rng[1] > d2_thresh[1]
bool  d2_bullFVG  = low > high[2] and close[1] > open[1]
bool  d2_bearFVG  = high < low[2] and close[1] < open[1]
bool  d2_bull = conf and d2_prevDisp and d2_bullFVG
bool  d2_bear = conf and d2_prevDisp and d2_bearFVG

// === PIPELINE A: DISPLACEMENT 3 (HTF2) ===
grp_hvd3 = "── HV+D: DISP HTF2 ──"
d3_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_hvd3)
d3_len  = input.int(100, "Std Dev Length", minval=1, group=grp_hvd3)
d3_mult = input.float(1.5, "Std Dev Multiplier", minval=0.1, step=0.1, group=grp_hvd3)
float d3_rng = d3_type == "Open to Close" ? math.abs(open - close) : high - low
float d3_std = ta.stdev(d3_rng, d3_len)
float d3_thresh = d3_std * d3_mult
bool  d3_prevDisp = d3_rng[1] > d3_thresh[1]
bool  d3_bullFVG  = low > high[2] and close[1] > open[1]
bool  d3_bearFVG  = high < low[2] and close[1] < open[1]
bool  d3_bull = conf and d3_prevDisp and d3_bullFVG
bool  d3_bear = conf and d3_prevDisp and d3_bearFVG

// === PIPELINE A: BASE HV INPUTS ===
// v2: 64 → 45 contiguous signals. B2B-overlap removals (kept GOLF), reserved removed,
//     CONT removed, WMD replaced with WBUSH (3 plots), UC NAGASAKI added, Super/SDuper
//     redefined to UC+NPM / UC+NPM+PUP per Anish.
grpSIG = "★ SIGNAL TOGGLES ★"
bool en_1  = input.bool(true, "1. SD!",            group=grpSIG, tooltip="SD! (Super Duper) — REDEFINED v2: Unified Combo (csNew3) + Napalm (consolidated NPM=raw OR Charge) + PUP. All on same visual bar. Offset = -1.")
bool en_2  = input.bool(true, "2. SUPER",          group=grpSIG, tooltip="SUPER — REDEFINED v2: Unified Combo (csNew3) + Napalm (consolidated). All on same visual bar. Offset = -1.")
bool en_3  = input.bool(true, "3. HW",             group=grpSIG, tooltip="HW (Heavy Weapon): Green bar + 5x displacement (std dev, NO FVG) + PBJ + (GrandSlam or WTC or Hiroshima or directional Nagasaki) + Platform. ALL required. No gate. Offset=0.")
bool en_4  = input.bool(true, "4. FLOOR",          group=grpSIG, tooltip="FLOOR: Ping Pong bull (structural support) + PBJ + directional RVOL (1x/GS/WTC/Hiro/dirNag). GATE: one-of-these + checkbox qualifiers Set 1 (PBJ EXCLUDED from checkbox since Floor already requires it). Offset=0.")
bool en_5  = input.bool(true, "5. 2F",             group=grpSIG, tooltip="2F (2nd Floor): Ping Pong bull (structural support) + PB (not PBJ) + directional RVOL. GATE: one-of-these + checkbox qualifiers Set 1. Offset=0.")
bool en_6  = input.bool(true, "6. UUUU",           group=grpSIG, tooltip="UUUU: 4+ consecutive qualified U bars. Paths A/B/C/D/E/F + new pG (≥4 distinct qualifiers from {PBJ,DISP,FAUNA,SAAB,RVOL1x,GS} in streak). SUB-2MIN RULE applies. Offset=0.")
bool en_7  = input.bool(true, "7. UUU",            group=grpSIG, tooltip="UUU: 3 consecutive qualified U bars. Paths A-E + new pG (≥3 distinct qualifiers in streak). SUB-2MIN RULE applies. Offset=0.")
bool en_8  = input.bool(true, "8. UU",             group=grpSIG, tooltip="UU: 2 consecutive qualified U bars. Paths A-E + new pG (≥2 distinct qualifiers in streak). GATE: one-of-these-for-UU. SUB-2MIN RULE applies. Offset=0.")
bool en_9  = input.bool(true, "9. A★",             group=grpSIG, tooltip="A★ (Alpha Strike): First signal of session + Ping Pong bull + (GrandSlam or RVOL1x) + PBJ ONLY + expanded FAUNA slot. PB does NOT qualify. Offset=0.")
bool en_10 = input.bool(true, "10. ΩA",            group=grpSIG, tooltip="ΩA (Omega-A): Boom Hunter omega event + high-confidence cosignal ONLY. Requires NOT MOAB and NOT bear displacement. Offset=0.")
bool en_11 = input.bool(true, "11. FOX",           group=grpSIG, tooltip="FOX (Foxtrot): 4 consecutive FAUNA-confirmed bullish bars. GATE: (HV+D + PBJ) OR one-of-these. Offset=0.")
bool en_12 = input.bool(true, "12. OD",            group=grpSIG, tooltip="OD (Opening Drive): Session bar ≤ max bars into session + FVG + displacement from bar[1] + PUP + PBJ on displacement candle. ALL required. No gate. Offset=-1.")
bool en_13 = input.bool(true, "13. GOLF",          group=grpSIG, tooltip="GOLF: 3-bar sequence: bar[2]=FAUNA+PUP, bar[1]=FAUNA+PUP+DISP, bar[0]=DISP confirmation. Offset=-1.")
bool en_28 = input.bool(true, "14. PBJ+F2/E3",     group=grpSIG, tooltip="PBJ+F2/E3: PBJ + Foster Pair or Exhaustion Triple. Offset=0.")
bool en_29 = input.bool(true, "15. PBJ+CL",        group=grpSIG, tooltip="PBJ+CL: PBJ + full FAUNA Cluster. Offset=0.")
bool en_30 = input.bool(true, "16. F2CL→E3",       group=grpSIG, tooltip="F2CL→E3: Sequential Foster Pair + Cluster then Exhaustion Triple. Offset=0.")
bool en_33 = input.bool(true, "17. E3⅔PP",         group=grpSIG, tooltip="E3⅔PP: Exhaustion Triple where 2 of 3 bars are PUP. Offset=0.")
bool en_34 = input.bool(true, "18. F2×2D",         group=grpSIG, tooltip="F2×2D: Foster Pair on consecutive trading sessions. Offset=0.")
bool en_35 = input.bool(true, "19. E3×2D",         group=grpSIG, tooltip="E3×2D: Exhaustion Triple on consecutive sessions. Offset=0.")
bool en_36 = input.bool(true, "20. F2E3seq",       group=grpSIG, tooltip="F2E3seq: Foster Pair one session then Exhaustion Triple next. Offset=0.")
bool en_37 = input.bool(true, "21. CL×2D",         group=grpSIG, tooltip="CL×2D: FAUNA Cluster on consecutive sessions. Offset=0.")
bool en_38 = input.bool(true, "22. NPM+",          group=grpSIG, tooltip="NPM+: Napalm (consolidated NPM) + ((PBJ + (UC or HW or WBUSH)) OR WBUSH alone). Offset=-1.")
bool en_39 = input.bool(true, "23. NPM12",         group=grpSIG, tooltip="NPM12: Napalm (consolidated) + checkbox qualifier Set 1 OR Set 2. Offset=-1.")
bool en_41 = input.bool(true, "24. NPM3",          group=grpSIG, tooltip="NPM3: Napalm (consolidated) + checkbox qualifier Set 3. Fires only when NPM12 does NOT fire. Offset=-1.")
bool en_42 = input.bool(true, "25. B2BNPM",        group=grpSIG, tooltip="B2BNPM: Back-to-back Napalm (consolidated NPM=raw OR Charge). Offset=-1.")
bool en_43 = input.bool(true, "26. NPM+TNT",       group=grpSIG, tooltip="NPM+TNT: Napalm + TNT on same visual candle. Offset=-1.")
bool en_44 = input.bool(true, "27. CO",            group=grpSIG, tooltip="CO — RESTRUCTURED v2: HV+D + PBJ + (Unified Combo OR FVG Combo Set). No longer fires on any bullish signal — must be UC or FVG combo set. Offset=-1.")
bool en_45 = input.bool(true, "28. HVD+PBJ",       group=grpSIG, tooltip="HVD+PBJ: HV+D + PBJ on same candle. Sub-3min requires checkbox. Excludes CO. Offset=-1.")
bool en_46 = input.bool(true, "29. B2BHVD+PBJ",    group=grpSIG, tooltip="B2BHVD+PBJ: Consecutive HV+D + PBJ on either bar. Offset=-1.")
bool en_47 = input.bool(true, "30. B2BHVD",        group=grpSIG, tooltip="B2BHVD: Consecutive HV+D without PBJ. Offset=-1.")
bool en_48 = input.bool(true, "31. UU+UC",         group=grpSIG, tooltip="UU+UC: Any UU family + Uni.Combo on same candle. Offset=-1.")
bool en_49 = input.bool(true, "32. GRAIL",         group=grpSIG, tooltip="GRAIL: Napalm (consolidated) + PBJ + PUP + Uni.Combo ALL on same visual candle. Offset=-1.")
bool en_50 = input.bool(true, "33. FLR+NPM",       group=grpSIG, tooltip="FLR+NPM: Floor + Napalm (consolidated) on same candle. Offset=-1.")
bool en_51 = input.bool(true, "34. NPM+PBJ+PUP",   group=grpSIG, tooltip="NPM+PBJ+PUP: Napalm (consolidated) + PBJ + PUP without Uni.Combo. Offset=-1.")
bool en_52 = input.bool(true, "35. NAG+",          group=grpSIG, tooltip="NAG+: Nagasaki + any bullish signal. Offset=0.")
bool en_53 = input.bool(true, "36. UU+HVD",        group=grpSIG, tooltip="UU+HVD: Any UU family + HV+D + PBJ on same candle. Offset=-1.")
bool en_54 = input.bool(true, "37. UU+NPM",        group=grpSIG, tooltip="UU+NPM: Any UU family + Napalm (consolidated) on same window. Offset=-1.")
bool en_55 = input.bool(true, "38. FLR+UU",        group=grpSIG, tooltip="FLR+UU: Floor or 2F + any UU family. Offset=0.")
bool en_56 = input.bool(true, "39. FOS+PUP+1x",    group=grpSIG, tooltip="FOS+PUP+1x: Foster + PUP + (RVOL1x or Napalm consolidated). Offset=0.")
bool en_60 = input.bool(true, "40. NPM+UC",        group=grpSIG, tooltip="NPM+UC: Napalm (consolidated) + Uni.Combo WITHOUT PBJ. Offset=-1.")
bool en_wbushBull    = input.bool(true, "41. WBUSH+ANY Bull",    group=grpSIG, tooltip="WBUSH = any of HEAVY PENTAGON's 5 Heavy Combos (Yin-Yang, Nagasaki, Nagasaki Vol, Trident, Neutral Heavy x2) firing bullish. Replaces WMD. Offset = 0.")
bool en_wbushBear    = input.bool(true, "42. WBUSH+ANY Bear",    group=grpSIG, tooltip="Mirror of WBUSH bull — any of the 5 Heavy Combos firing bearish. Offset = 0.")
bool en_wbushNeutral = input.bool(true, "43. WBUSH Neutral",     group=grpSIG, tooltip="WBUSH-neutral classification (no FVG-confirmed displacement either direction). Standalone alert — fires when any of the 5 Heavy Combos hits neutral. Offset = 0.")
bool en_63 = input.bool(true, "44. NPM+UC+PBJ",    group=grpSIG, tooltip="NPM+UC+PBJ: Napalm (consolidated) + Uni.Combo + PBJ. Offset=-1.")
bool en_ucNagBull = input.bool(true, "45. UC NAGASAKI Bull",  group=grpSIG, tooltip="UC NAGASAKI: Unified Combo (csNew3) + Nagasaki on same visual bar. Offset = -1.")
bool en_ucNagBear = input.bool(true, "46. UC NAGASAKI Bear",  group=grpSIG, tooltip="UC NAGASAKI Bear mirror. Offset = -1.")

string grpHVBase = "── HV+D: BASE HV ──"
bool ub50   = input.bool(false, "50-Bar",   group=grpHVBase)
bool ub75   = input.bool(false, "75-Bar",   group=grpHVBase)
bool ub100  = input.bool(false, "100-Bar",  group=grpHVBase)
bool ub150  = input.bool(false, "150-Bar",  group=grpHVBase)
bool ub200  = input.bool(false, "200-Bar",  group=grpHVBase)
bool ub250  = input.bool(true,  "250-Bar",  group=grpHVBase)
bool ub300  = input.bool(true,  "300-Bar",  group=grpHVBase)
bool ub350  = input.bool(true,  "350-Bar",  group=grpHVBase)
bool ub400  = input.bool(true,  "400-Bar",  group=grpHVBase)
bool ub450  = input.bool(true,  "450-Bar",  group=grpHVBase)
bool ub500  = input.bool(true,  "500-Bar",  group=grpHVBase)
bool ub550  = input.bool(true,  "550-Bar",  group=grpHVBase)
bool ub600  = input.bool(true,  "600-Bar",  group=grpHVBase)
bool ub650  = input.bool(true,  "650-Bar",  group=grpHVBase)
bool ub700  = input.bool(true,  "700-Bar",  group=grpHVBase)
bool ub750  = input.bool(true,  "750-Bar",  group=grpHVBase)
bool ub1000 = input.bool(true,  "1000-Bar", group=grpHVBase)
bool useHEV = input.bool(true,  "All-Time High Volume (HEV)", group=grpHVBase)

// === PIPELINE A: HTF PROFILE 1 ===
string grpHTF1 = "── HV+D: HTF1 ──"
bool   h1On   = input.bool(true, "Enable HTF Profile 1", group=grpHTF1)
string h1From = input.string("15 Min", "From TF", group=grpHTF1, options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
string h1To   = input.string("2 Hour", "To TF",   group=grpHTF1, options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
bool uh1_5  = input.bool(true, "5-Bar",  group=grpHTF1)
bool uh1_10 = input.bool(true, "10-Bar", group=grpHTF1)
bool uh1_20 = input.bool(true, "20-Bar", group=grpHTF1)
bool uh1_25 = input.bool(true, "25-Bar", group=grpHTF1)
bool uh1_30 = input.bool(true, "30-Bar", group=grpHTF1)
bool uh1_40 = input.bool(true, "40-Bar", group=grpHTF1)
bool uh1_50 = input.bool(true, "50-Bar", group=grpHTF1)
bool uh1_60 = input.bool(true, "60-Bar", group=grpHTF1)
bool uh1_70 = input.bool(true, "70-Bar", group=grpHTF1)
bool uh1_75 = input.bool(true, "75-Bar", group=grpHTF1)
bool uh1_80 = input.bool(true, "80-Bar", group=grpHTF1)
bool uh1_90 = input.bool(true, "90-Bar", group=grpHTF1)

// === PIPELINE A: HTF PROFILE 2 ===
string grpHTF2 = "── HV+D: HTF2 ──"
bool   h2On   = input.bool(true, "Enable HTF Profile 2", group=grpHTF2)
string h2From = input.string("3 Hour", "From TF", group=grpHTF2, options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
string h2To   = input.string("3 Month","To TF",   group=grpHTF2, options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
bool uh2_5  = input.bool(false, "5-Bar",  group=grpHTF2)
bool uh2_10 = input.bool(false, "10-Bar", group=grpHTF2)
bool uh2_20 = input.bool(false, "20-Bar", group=grpHTF2)
bool uh2_25 = input.bool(false, "25-Bar", group=grpHTF2)
bool uh2_30 = input.bool(false, "30-Bar", group=grpHTF2)
bool uh2_40 = input.bool(true, "40-Bar", group=grpHTF2)
bool uh2_50 = input.bool(true, "50-Bar", group=grpHTF2)
bool uh2_60 = input.bool(true, "60-Bar", group=grpHTF2)
bool uh2_70 = input.bool(true, "70-Bar", group=grpHTF2)
bool uh2_75 = input.bool(true, "75-Bar", group=grpHTF2)
bool uh2_80 = input.bool(true, "80-Bar", group=grpHTF2)
bool uh2_90 = input.bool(true, "90-Bar", group=grpHTF2)

// === PIPELINE A: HTF ACTIVATION ===
bool htf1Active = h1On and tfSec >= hvd_tf2sec(h1From) and tfSec <= hvd_tf2sec(h1To)
bool htf2Active = h2On and tfSec >= hvd_tf2sec(h2From) and tfSec <= hvd_tf2sec(h2To)

// === PIPELINE A: HV CALCULATIONS [1] ===
bool is50   = volume[1] == ta.highest(volume, 50)[1]
bool is75   = volume[1] == ta.highest(volume, 75)[1]
bool is100  = volume[1] == ta.highest(volume, 100)[1]
bool is150  = volume[1] == ta.highest(volume, 150)[1]
bool is200  = volume[1] == ta.highest(volume, 200)[1]
bool is250  = volume[1] == ta.highest(volume, 250)[1]
bool is300  = volume[1] == ta.highest(volume, 300)[1]
bool is350  = volume[1] == ta.highest(volume, 350)[1]
bool is400  = volume[1] == ta.highest(volume, 400)[1]
bool is450  = volume[1] == ta.highest(volume, 450)[1]
bool is500  = volume[1] == ta.highest(volume, 500)[1]
bool is550  = volume[1] == ta.highest(volume, 550)[1]
bool is600  = volume[1] == ta.highest(volume, 600)[1]
bool is650  = volume[1] == ta.highest(volume, 650)[1]
bool is700  = volume[1] == ta.highest(volume, 700)[1]
bool is750  = volume[1] == ta.highest(volume, 750)[1]
bool is1000 = volume[1] == ta.highest(volume, 1000)[1]
bool isH5  = volume[1] == ta.highest(volume, 5)[1]
bool isH10 = volume[1] == ta.highest(volume, 10)[1]
bool isH20 = volume[1] == ta.highest(volume, 20)[1]
bool isH25 = volume[1] == ta.highest(volume, 25)[1]
bool isH30 = volume[1] == ta.highest(volume, 30)[1]
bool isH40 = volume[1] == ta.highest(volume, 40)[1]
bool isH50 = volume[1] == ta.highest(volume, 50)[1]
bool isH60 = volume[1] == ta.highest(volume, 60)[1]
bool isH70 = volume[1] == ta.highest(volume, 70)[1]
bool isH75 = volume[1] == ta.highest(volume, 75)[1]
bool isH80 = volume[1] == ta.highest(volume, 80)[1]
bool isH90 = volume[1] == ta.highest(volume, 90)[1]

var float maxVolEver = 0.0
var bool _hev_pending = false
if volume[1] > maxVolEver
    maxVolEver := volume[1]
    _hev_pending := true
bool isHEV = _hev_pending
if conf and _hev_pending
    _hev_pending := false

// === PIPELINE A: PRIORITY RANKING ===
int baseRank = is1000 ? 1000 : is750 ? 750 : is700 ? 700 : is650 ? 650 : is600 ? 600 : is550 ? 550 : is500 ? 500 : is450 ? 450 : is400 ? 400 : is350 ? 350 : is300 ? 300 : is250 ? 250 : is200 ? 200 : is150 ? 150 : is100 ? 100 : is75 ? 75 : is50 ? 50 : 0
int h1Rank = not htf1Active ? 0 : uh1_90 and isH90 ? 90 : uh1_80 and isH80 ? 80 : uh1_75 and isH75 ? 75 : uh1_70 and isH70 ? 70 : uh1_60 and isH60 ? 60 : uh1_50 and isH50 ? 50 : uh1_40 and isH40 ? 40 : uh1_30 and isH30 ? 30 : uh1_25 and isH25 ? 25 : uh1_20 and isH20 ? 20 : uh1_10 and isH10 ? 10 : uh1_5 and isH5 ? 5 : 0
int h2Rank = not htf2Active ? 0 : uh2_90 and isH90 ? 90 : uh2_80 and isH80 ? 80 : uh2_75 and isH75 ? 75 : uh2_70 and isH70 ? 70 : uh2_60 and isH60 ? 60 : uh2_50 and isH50 ? 50 : uh2_40 and isH40 ? 40 : uh2_30 and isH30 ? 30 : uh2_25 and isH25 ? 25 : uh2_20 and isH20 ? 20 : uh2_10 and isH10 ? 10 : uh2_5 and isH5 ? 5 : 0

// === PIPELINE A: COMBO + TERMINAL BOOLEANS ===
bool base_enabled = (ub50 and baseRank == 50) or (ub75 and baseRank == 75) or (ub100 and baseRank == 100) or (ub150 and baseRank == 150) or (ub200 and baseRank == 200) or (ub250 and baseRank == 250) or (ub300 and baseRank == 300) or (ub350 and baseRank == 350) or (ub400 and baseRank == 400) or (ub450 and baseRank == 450) or (ub500 and baseRank == 500) or (ub550 and baseRank == 550) or (ub600 and baseRank == 600) or (ub650 and baseRank == 650) or (ub700 and baseRank == 700) or (ub750 and baseRank == 750) or (ub1000 and baseRank == 1000)
bool hev_hit = useHEV and isHEV
bool base_hv_hit = hev_hit or (base_enabled and not isHEV)
bool base_combo_bull = base_hv_hit and d1_bull
bool base_combo_bear = base_hv_hit and d1_bear
bool htf1_combo_bull = h1Rank > 0 and d2_bull
bool htf1_combo_bear = h1Rank > 0 and d2_bear
bool htf2_combo_bull = h2Rank > 0 and d3_bull
bool htf2_combo_bear = h2Rank > 0 and d3_bear

// ┌──────────────────────────────────────────────────────────────────────────┐
// │  PIPELINE A TERMINAL OUTPUTS — the ONLY thing Pipeline D may read      │
// │  hvd_fire_bull describes bar N-1. hvd_fire_bear describes bar N-1.     │
// └──────────────────────────────────────────────────────────────────────────┘
bool hvd_fire_bull = base_combo_bull or htf1_combo_bull or htf2_combo_bull
bool hvd_fire_bear = base_combo_bear or htf1_combo_bear or htf2_combo_bear

// Master toggle gate
bool _anyHVRank = baseRank > 0 or h1Rank > 0 or h2Rank > 0 or isHEV
bool _masterGate = not master_firstBarOnly or (_isGapBar and _anyHVRank)


// ╔════════════════════════════════════════════════════════════════════════════╗
// ║  PIPELINES B + C: USE ALARM 1293                                         ║
// ║  Engine 6 (PBJ) terminal outputs = PIPELINE B                            ║
// ║  All signal booleans = PIPELINE C                                        ║
// ║  This code knows NOTHING about Pipeline A (volume rank, HV+D disp).      ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// === HARDCODED — RVOL ===
bb_avgLength = 30, bb_smaLength = 20
reg_anchorTimeframe = "", reg_length = 30, reg_calculationMode = "Cumulative", reg_adjustRealtime = true
// === HARDCODED — FAUNA NRA ===
fauna_gg_master = true, fauna_gg_body = 0.80

// === SIGNAL TOGGLES ===
bool show_BullUUUU = true, bool show_BearUUUU = false
bool show_BullUUU = true, bool show_BearUUU = false
bool show_BullUU = true, bool show_BearUU = false
bool show_AlphaStrikeB = true, bool show_AlphaStrikeR = false
bool show_FoxtrotB = true, bool show_FoxtrotR = false
bool show_OmegaLong = false, bool show_OmegaLongA = true
bool show_ODBull = true, bool show_ODBear = false
bool show_DispConsBull2 = true, bool show_DispConsBear2 = false
bool show_DispConsBull3 = true, bool show_DispConsBear3 = false
bool show_GolfBull = true, bool show_GolfBear = false
bool show_PAFBull = true, bool show_PAFBear = false
bool show_CS1B = true, bool show_CS1R = false
bool show_CS2B = true, bool show_CS2R = false
bool show_CS3B = true, bool show_CS3R = false
bool show_CCBull = true, bool show_CCBear = false
bool show_LSCBull = true, bool show_LSCBear = false
bool show_BullFloor = true, bool show_Bull2ndFloor = true
bool show_BearRooftop = false, bool show_BearPenthouse = false
bool show_HWBull = true, bool show_HWBear = false
bool show_SuperBull = true, bool show_SuperBear = false
bool show_SDuperBull = true, bool show_SDuperBear = false

// === INPUTS — USE DISPLACEMENT ===
grp_disp = "Displacement"
i_disp_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_disp)
i_std_len   = input.int(100, "Std Dev Length", minval=1, group=grp_disp)
i_std_min   = input.float(3.0, "Min Mult", minval=0, step=0.5, group=grp_disp)
i_std_max   = input.float(100.0, "Max Mult", minval=0, step=0.5, group=grp_disp)
i_req_fvg   = input.bool(true, "Require FVG", group=grp_disp)

grp_disp2 = "Displacement 2+"
i_disp2_type    = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_disp2)
i_disp2_std_len = input.int(100, "Std Dev Length", minval=1, group=grp_disp2)
i_disp2_std_min = input.float(3.0, "Min Mult", minval=0, step=0.5, group=grp_disp2)
i_disp2_std_max = input.float(100.0, "Max Mult", minval=0, step=0.5, group=grp_disp2)
i_disp2_req_fvg = input.bool(true, "Require FVG", group=grp_disp2)

grp_disp3 = "Displacement 3+"
i_disp3_type    = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_disp3)
i_disp3_std_len = input.int(100, "Std Dev Length", minval=1, group=grp_disp3)
i_disp3_std_min = input.float(3.0, "Min Mult", minval=0, step=0.5, group=grp_disp3)
i_disp3_std_max = input.float(100.0, "Max Mult", minval=0, step=0.5, group=grp_disp3)
i_disp3_req_fvg = input.bool(true, "Require FVG", group=grp_disp3)

// === INPUTS — GZ1 / HV FVG ===
grp_fvg = "GZ1 & HV FVG"
gz1_auto   = input.bool(true, "Auto Threshold", group=grp_fvg)
gz1_thresh = input.float(2, "FVG Threshold %", minval=0, step=0.1, group=grp_fvg)
gz1_dist   = input.int(7, "GZ1 Max Bar Distance", minval=1, group=grp_fvg)

grp_hv = "HV Settings"
hv150_len = input.int(150, "Hotspot Lookback", minval=10, group=grp_hv)

// Hardcoded constants
pp_barSize=3.0, pp_lookback=10
zoo_ma_type="VWMA", zoo_ma_len=5, zoo_price_src=close, enable_PB=true
zoo_pbj_ma_period=20, zoo_pbj_atr_period=14, zoo_pbj_hh_ll=25, zoo_pbj_atr_mult=3.0, zoo_pbj_vol_period=20, zoo_pbj_vol_mult=0.1
zoo_use_st=true, zoo_st_period=10, zoo_st_mult=2.0
pp_min_candles=2, pp_buffer_ticks=10, pp_atr_mult=2.0, pp_trend_cnt=1, pp_max_levels=50
pp_trust_mode="Trusted Only", pp_min_count=3

grp_swing = "Swingin (Pivot)"
sw_leftBars = input.int(3, "Left Bars", minval=1, group=grp_swing)
sw_rightBars = input.int(2, "Right Bars", minval=1, group=grp_swing)
sw_useAtr = input.bool(true, "Use ATR Filter", group=grp_swing)
sw_atrMult = input.float(2.0, "ATR Multiplier", step=0.1, group=grp_swing)
pp_atr_len = input.int(100, "ATR Length", group=grp_swing)

grp_od = "Opening Drive"
od_max_bars = input.int(1, "Max Bars Into Session", minval=1, maxval=10, group=grp_od)

grp_neo = "Matrix Number (Neo)"
neo_len = input.int(67, "Matrix Number Lookback", minval=1, group=grp_neo)

grp_m1 = "Momentum 1"
ls_reg1=input.float(7.0,"Reg Floor",minval=0.5,step=0.1,group=grp_m1), ls_cum1=input.float(3.5,"Cum Floor",minval=0.5,step=0.1,group=grp_m1), ls_body1=input.float(0.60,"Body Ratio",minval=0.0,maxval=1.0,step=0.05,group=grp_m1)
grp_m2 = "Momentum 2"
ls_reg2=input.float(5.0,"Reg Floor",minval=0.5,step=0.1,group=grp_m2), ls_cum2=input.float(2.5,"Cum Floor",minval=0.5,step=0.1,group=grp_m2), ls_body2=input.float(0.75,"Body Ratio",minval=0.0,maxval=1.0,step=0.05,group=grp_m2)

grp_cs_set = "Combo Set Settings"
cs_bodyPct_FVG=input.float(0.85,"Min Body% FVG",minval=0.0,maxval=1.0,step=0.05,group=grp_cs_set)
cs_bodyPct_MAT=input.float(0.85,"Min Body% Matrix",minval=0.0,maxval=1.0,step=0.05,group=grp_cs_set)
cs_inc_pentagon_FVG=input.bool(true,"Pentagon in FVG Sets",group=grp_cs_set)
cs_inc_pentagon_MAT=input.bool(true,"Pentagon in Matrix Sets",group=grp_cs_set)

grp_cc = "Combo Chain"
cc_min_hits=input.int(2,"Min Hits",minval=1,group=grp_cc), cc_window=input.int(2,"Within Bars",minval=1,group=grp_cc)

grp_lsc = "Long/Short Chain"
lsc_min_hits=input.int(2,"Min Hits",minval=1,group=grp_lsc), lsc_window=input.int(2,"Within Bars",minval=1,group=grp_lsc)
grp_lsc_m1 = "LS Chain Mom 1"
lsc_reg1=input.float(7.0,"Reg",minval=0.5,step=0.1,group=grp_lsc_m1), lsc_cum1=input.float(3.5,"Cum",minval=0.5,step=0.1,group=grp_lsc_m1), lsc_body1=input.float(0.60,"Body",minval=0.0,maxval=1.0,step=0.05,group=grp_lsc_m1)
grp_lsc_m2 = "LS Chain Mom 2"
lsc_reg2=input.float(5.0,"Reg",minval=0.5,step=0.1,group=grp_lsc_m2), lsc_cum2=input.float(2.5,"Cum",minval=0.5,step=0.1,group=grp_lsc_m2), lsc_body2=input.float(0.75,"Body",minval=0.0,maxval=1.0,step=0.05,group=grp_lsc_m2)

// Boom Hunter hardcoded
bh_LPPeriod=6, bh_K1=0, bh_trigno=2, bh_LPPeriod2=27, bh_K12=0.8, bh_K22=0.3
bh_LPPeriod3=11, bh_n1=9, bh_n2=6, bh_n3=3, bh_n4=21, bh_n5=0, bh_lsmaline=200
bh_leftBars=1, bh_rightBars=1, bh_leftBars2=5, bh_rightBars2=5, bh_greyDist=30

// === USE SHARED ===
pp_atr = ta.atr(pp_atr_len)
bb_spike=math.abs(close-open), bb_avgSpikeDenom=ta.sma(bb_spike,bb_avgLength)[1], bb_normalizedPrice=bb_spike/nz(bb_avgSpikeDenom,1.0)
bb_avgVolDenom=ta.sma(volume,bb_avgLength)[1], bb_normalizedVolume=volume/nz(bb_avgVolDenom,1.0)
bb_diff=bb_normalizedPrice-bb_normalizedVolume, bb_positiveDiff=bb_diff>0?bb_diff:na, bb_smaDiff=ta.sma(bb_positiveDiff,bb_smaLength)
bb_baseBullish=(close>open) and (bb_positiveDiff>bb_smaDiff), bb_baseBearish=(close<open) and (bb_positiveDiff>bb_smaDiff)
bb_inRange(v,lo,hi) => v>=lo and v<hi

// === ENGINE 1: RVOL ===
f_rvol_1x_threshold(_s) => _s<=10?38.0:_s<=15?33.0:_s<=30?28.0:_s<=45?23.0:_s<=60?20.0:_s<=120?18.0:_s<=300?13.0:_s<=360?13.0:_s<=540?11.0:_s<=600?10.0:_s<=660?9.0:_s<=900?7.5:_s<=1560?6.5:_s<=2340?6.0:_s<=3600?4.5:_s<=9000?4.0:_s<=11700?3.5:_s<259200?1.8:1.0
f_gs_moab_threshold(_s) => _s<60?f_rvol_1x_threshold(_s)*3.0:_s<=300?35.0:_s<=600?25.0:_s<=1500?20.0:_s<=3000?20.0:_s<=7260?10.0:_s<=11700?8.0:_s<=86400?7.5:_s<=259200?3.5:3.0
f_saab_kratos_threshold(_s) => f_rvol_1x_threshold(_s) * 0.56
f_wtc_threshold(_s) => f_rvol_1x_threshold(_s) * 2.0
f_hiroshima_threshold(_s) => _s<60?f_rvol_1x_threshold(_s)*3.0:_s<=300?35.0:_s<=600?25.0:_s<=1500?25.0:_s<=3060?20.0:_s<=7260?10.0:_s<=11700?8.0:_s<=86400?7.5:_s<=259200?5:3.5

th_saab_kratos=f_saab_kratos_threshold(tfSec), th_1x=f_rvol_1x_threshold(tfSec), th_gs_moab=f_gs_moab_threshold(tfSec), th_wtc=f_wtc_threshold(tfSec), th_hiroshima=f_hiroshima_threshold(tfSec)

sigSAAB=conf and bb_baseBullish and bb_inRange(bb_normalizedPrice,th_saab_kratos,th_1x)
sigKratos=conf and bb_baseBearish and bb_inRange(bb_normalizedPrice,th_saab_kratos,th_1x)
sigGrandSlam=conf and bb_baseBullish and (bb_normalizedPrice>=th_gs_moab)
sigMOAB=conf and bb_baseBearish and (bb_normalizedPrice>=th_gs_moab)
sigBullRVOL1x=conf and bb_baseBullish and bb_inRange(bb_normalizedPrice,th_1x,th_gs_moab) and not sigGrandSlam
sigBearRVOL1x=conf and bb_baseBearish and bb_inRange(bb_normalizedPrice,th_1x,th_gs_moab) and not sigMOAB

[currentVolume_reg,pastVolume_reg,_unused]=tv_ta.relativeVolume(reg_length,reg_anchorTimeframe,reg_calculationMode=="Cumulative",reg_adjustRealtime)
relVolRatio=currentVolume_reg/pastVolume_reg
sigWTC=conf and (relVolRatio>th_wtc) and (relVolRatio<=th_hiroshima)
sigHiroshima=conf and (relVolRatio>th_hiroshima)
sigPentagon=conf and (relVolRatio>=th_1x) and (relVolRatio<=th_wtc)

var float maxVol=0.0
bool isNagasaki=false
if bar_index==0
    maxVol:=volume
else if volume>maxVol
    isNagasaki:=true
    maxVol:=volume
sigNagasaki=isNagasaki

// === SESSION TRACKING ===
bool is_new_day=ta.change(time("D"))!=0
var int sessionBarCount=0, var int lastCountedBar=-1
if is_new_day and bar_index!=lastCountedBar
    sessionBarCount:=1
    lastCountedBar:=bar_index
else if bar_index!=lastCountedBar
    sessionBarCount+=1
    lastCountedBar:=bar_index

// === ENGINE 2: FAUNA ===
fauna_atr=atr14, fauna_avgVol=ta.sma(volume,20), fauna_avgBody=ta.sma(math.abs(close-open),20)
fauna_avgDelta=ta.sma(math.abs(close-close[1]),10), fauna_trendMA=ta.sma(close,50)
fauna_body=close-open, fauna_rng=high-low, fauna_bodySz=math.abs(fauna_body)
fauna_bodyRat=fauna_rng==0?0.0:fauna_bodySz/fauna_rng
fauna_up=fauna_body>0, fauna_dn=fauna_body<0
fauna_prev_body=close[1]-open[1], fauna_prev_range=high[1]-low[1]

MB_b=fauna_up and fauna_bodySz>1.6*fauna_atr and fauna_bodyRat>0.70 and volume>1.8*fauna_avgVol
RE_b=fauna_up and fauna_rng>2.2*fauna_atr and (high-close)<0.15*fauna_rng and volume>1.8*fauna_avgVol
TA_b=fauna_trendMA>fauna_trendMA[1] and (close-close[1])>1.6*fauna_avgDelta and fauna_up and volume>1.8*fauna_avgVol
GG_b=(open-close[1])>0.9*fauna_atr and fauna_up and low>close[1] and volume>1.8*fauna_avgVol
StrongBear=close[1]<open[1] and math.abs(fauna_prev_body)>1.5*fauna_avgBody[1] and volume[1]>1.5*fauna_avgVol[1]
WeakBear=close[1]<open[1] and (fauna_prev_range==0?0.0:math.abs(fauna_prev_body)/fauna_prev_range)<=0.2
TR_b=WeakBear and (MB_b or RE_b or TA_b), ES_b=StrongBear and (MB_b or RE_b or TA_b), GDR_b=close[1]<open[1] and GG_b
int b_core_cnt=(MB_b?1:0)+(RE_b?1:0)+(TA_b?1:0)
bool b_gg_pass=fauna_gg_master and (b_core_cnt>=2) and (fauna_bodyRat>=fauna_gg_body)
bool b_gg_exc=GG_b and not b_gg_pass
excluded_bull=TR_b or ES_b or GDR_b or b_gg_exc
sigFAUNABull=conf and (MB_b or RE_b or TA_b) and not excluded_bull

MB_r=fauna_dn and fauna_bodySz>1.6*fauna_atr and fauna_bodyRat>0.70 and volume>1.8*fauna_avgVol
RE_r=fauna_dn and fauna_rng>2.2*fauna_atr and (close-low)<0.15*fauna_rng and volume>1.8*fauna_avgVol
TA_r=fauna_trendMA<fauna_trendMA[1] and (close[1]-close)>1.6*fauna_avgDelta and fauna_dn and volume>1.8*fauna_avgVol
GG_r=(close[1]-open)>0.9*fauna_atr and fauna_dn and high<close[1] and volume>1.8*fauna_avgVol
StrongBull=close[1]>open[1] and math.abs(fauna_prev_body)>1.5*fauna_avgBody[1] and volume[1]>1.5*fauna_avgVol[1]
WeakBull=close[1]>open[1] and (fauna_prev_range==0?0.0:math.abs(fauna_prev_body)/fauna_prev_range)<=0.2
TR_r=WeakBull and (MB_r or RE_r or TA_r), ES_r=StrongBull and (MB_r or RE_r or TA_r), GDR_r=close[1]>open[1] and GG_r
int s_core_cnt=(MB_r?1:0)+(RE_r?1:0)+(TA_r?1:0)
bool s_gg_pass=fauna_gg_master and (s_core_cnt>=2) and (fauna_bodyRat>=fauna_gg_body)
bool s_gg_exc=GG_r and not s_gg_pass
excluded_bear=TR_r or ES_r or GDR_r or s_gg_exc
sigFAUNABear=conf and (MB_r or RE_r or TA_r) and not excluded_bear

// === ENGINE 3: USE DISPLACEMENT ===
float disp_rng=i_disp_type=="Open to Close"?math.abs(open-close):high-low
float disp_std=ta.stdev(disp_rng,i_std_len)
float disp_thresh_min=disp_std*i_std_min, float disp_thresh_max=disp_std*i_std_max
bool disp_prevDisp=disp_rng[1]>disp_thresh_min[1] and disp_rng[1]<=disp_thresh_max[1]
bool disp_currDisp=disp_rng[0]>disp_thresh_min[0] and disp_rng[0]<=disp_thresh_max[0]
bool disp_bullFVG=low>high[2] and close[1]>open[1], bool disp_bearFVG=high<low[2] and close[1]<open[1]
sigDISPBull=conf and (i_req_fvg?(disp_prevDisp and disp_bullFVG):(disp_currDisp and close>open))
sigDISPBear=conf and (i_req_fvg?(disp_prevDisp and disp_bearFVG):(disp_currDisp and close<open))
float disp5_thresh=disp_std*5.0
bool disp5_bull=conf and disp_std>0 and disp_rng>disp5_thresh and close>open
bool disp5_bear=conf and disp_std>0 and disp_rng>disp5_thresh and close<open

// Disp 2+
float disp2_rng=i_disp2_type=="Open to Close"?math.abs(open-close):high-low
float disp2_std=ta.stdev(disp2_rng,i_disp2_std_len)
bool sigDISP2Bull=conf and (i_disp2_req_fvg?(disp2_rng[1]>disp2_std[1]*i_disp2_std_min and disp2_rng[1]<=disp2_std[1]*i_disp2_std_max and low>high[2] and close[1]>open[1]):(disp2_rng>disp2_std*i_disp2_std_min and disp2_rng<=disp2_std*i_disp2_std_max and close>open))
bool sigDISP2Bear=conf and (i_disp2_req_fvg?(disp2_rng[1]>disp2_std[1]*i_disp2_std_min and disp2_rng[1]<=disp2_std[1]*i_disp2_std_max and high<low[2] and close[1]<open[1]):(disp2_rng>disp2_std*i_disp2_std_min and disp2_rng<=disp2_std*i_disp2_std_max and close<open))
var int disp2_bullStreak=0, var int disp2_bearStreak=0
if sigDISP2Bull
    disp2_bullStreak:=disp2_bullStreak+1
else
    disp2_bullStreak:=0
if sigDISP2Bear
    disp2_bearStreak:=disp2_bearStreak+1
else
    disp2_bearStreak:=0
// D2+/D3+ FAUNA check: bar[1] and bar[2] (displacement candles), NOT bar[0]
bool sigDispConsBull2=sigDISP2Bull and disp2_bullStreak>=2 and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2])
bool sigDispConsBear2=sigDISP2Bear and disp2_bearStreak>=2 and nz(sigFAUNABear[1]) and nz(sigFAUNABear[2])

// Disp 3+
float disp3_rng=i_disp3_type=="Open to Close"?math.abs(open-close):high-low
float disp3_std=ta.stdev(disp3_rng,i_disp3_std_len)
bool sigDISP3Bull=conf and (i_disp3_req_fvg?(disp3_rng[1]>disp3_std[1]*i_disp3_std_min and disp3_rng[1]<=disp3_std[1]*i_disp3_std_max and low>high[2] and close[1]>open[1]):(disp3_rng>disp3_std*i_disp3_std_min and disp3_rng<=disp3_std*i_disp3_std_max and close>open))
bool sigDISP3Bear=conf and (i_disp3_req_fvg?(disp3_rng[1]>disp3_std[1]*i_disp3_std_min and disp3_rng[1]<=disp3_std[1]*i_disp3_std_max and high<low[2] and close[1]<open[1]):(disp3_rng>disp3_std*i_disp3_std_min and disp3_rng<=disp3_std*i_disp3_std_max and close<open))
var int disp3_bullStreak=0, var int disp3_bearStreak=0
if sigDISP3Bull
    disp3_bullStreak:=disp3_bullStreak+1
else
    disp3_bullStreak:=0
if sigDISP3Bear
    disp3_bearStreak:=disp3_bearStreak+1
else
    disp3_bearStreak:=0
// D3+ FAUNA: bar[1], bar[2], bar[3] (displacement candles)
bool sigDispConsBull3=sigDISP3Bull and disp3_bullStreak>=3 and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2]) and nz(sigFAUNABull[3])
bool sigDispConsBear3=sigDISP3Bear and disp3_bearStreak>=3 and nz(sigFAUNABear[1]) and nz(sigFAUNABear[2]) and nz(sigFAUNABear[3])

// === ENGINE 4: GZ1/HV FVG ===
type fvg_struct
    float mx
    float mn
    bool bull
    int t
    int idx
    bool hv

float gz_v1=volume[1], float _hv5000=ta.highest(volume,5000)[1], float _hv252=ta.highest(volume,252)[1], float _hv63=ta.highest(volume,63)[1]
bool gz_isHV=(gz_v1==_hv5000) or (gz_v1==_hv252) or (gz_v1==_hv63)
float gz_thresh=gz1_auto?ta.cum((high-low)/low)/bar_index:gz1_thresh/100
bool gz_bFVG=low>high[2] and close[1]>high[2] and (low-high[2])/high[2]>gz_thresh
bool gz_sFVG=high<low[2] and close[1]<low[2] and (low[2]-high)/high>gz_thresh

var gz_fvgs=array.new<fvg_struct>(0)
var int gz_lastT=0
bool gz_bullGZI=false, bool gz_bearGZI=false, bool gz_bullHV=false, bool gz_bearHV=false

if conf and gz_bFVG and time!=gz_lastT
    float mx=low, float mn=high[2]
    if gz_isHV
        gz_bullHV:=true
    if gz_fvgs.size()>0
        for i=0 to gz_fvgs.size()-1
            fvg_struct e=gz_fvgs.get(i)
            if e.bull and bar_index-e.idx<=gz1_dist
                if math.max(e.mn,mn)<math.min(e.mx,mx) or (math.max(e.mn,mn)<=math.min(e.mx,mx) and e.hv and gz_isHV)
                    gz_bullGZI:=true
                    break
    gz_fvgs.unshift(fvg_struct.new(mx,mn,true,time,bar_index,gz_isHV))
    gz_lastT:=time

if conf and gz_sFVG and time!=gz_lastT
    float mx=low[2], float mn=high
    if gz_isHV
        gz_bearHV:=true
    if gz_fvgs.size()>0
        for i=0 to gz_fvgs.size()-1
            fvg_struct e=gz_fvgs.get(i)
            if not e.bull and bar_index-e.idx<=gz1_dist
                if math.max(e.mn,mn)<math.min(e.mx,mx) or (math.max(e.mn,mn)<=math.min(e.mx,mx) and e.hv and gz_isHV)
                    gz_bearGZI:=true
                    break
    gz_fvgs.unshift(fvg_struct.new(mx,mn,false,time,bar_index,gz_isHV))
    gz_lastT:=time

if gz_fvgs.size()>0
    for i=gz_fvgs.size()-1 to 0
        fvg_struct g=gz_fvgs.get(i)
        if g.bull and close<g.mn
            gz_fvgs.remove(i)
        else if not g.bull and close>g.mx
            gz_fvgs.remove(i)
if gz_fvgs.size()>50
    gz_fvgs.pop()

// === ENGINE 5: PUP/PPD ===
float pp_redVol=close<open?volume:0.0, float pp_greenVol=close>open?volume:0.0
float pp_hiRedVol=ta.highest(pp_redVol[1],pp_lookback), float pp_hiGreenVol=ta.highest(pp_greenVol[1],pp_lookback)
bool pp_priceUp=((close-open)/open)*100>pp_barSize, bool pp_priceDn=((open-close)/open)*100>pp_barSize
bool sigPUP=conf and pp_priceUp and volume>pp_hiRedVol
bool sigPPD=conf and pp_priceDn and volume>pp_hiGreenVol

// ┌──────────────────────────────────────────────────────────────────────────┐
// │  ENGINE 6: PBJ — THIS IS PIPELINE B                                    │
// └──────────────────────────────────────────────────────────────────────────┘
type lvl
    float upper
    float lower
    float vol
    bool approached

float atr_pb=atr14*2.0
f_ma(src,len,t) => switch t
    "EMA"=>ta.ema(src,len)
    "SMA"=>ta.sma(src,len)
    "WMA"=>ta.wma(src,len)
    "HMA"=>ta.hma(src,len)
    "VWMA"=>ta.vwma(src,len)
    =>ta.sma(src,len)

float base_ma=f_ma(zoo_price_src,zoo_ma_len,zoo_ma_type)
float zoo_st_atr=zoo_st_mult*ta.atr(zoo_st_period)
var int st_dir=1
float curr_long=0.0
curr_long:=base_ma>nz(curr_long[1],base_ma-zoo_st_atr)?math.max(base_ma-zoo_st_atr,nz(curr_long[1])):base_ma-zoo_st_atr
float curr_short=0.0
curr_short:=base_ma<nz(curr_short[1],base_ma+zoo_st_atr)?math.min(base_ma+zoo_st_atr,nz(curr_short[1])):base_ma+zoo_st_atr
float sig_line=0.0
if zoo_use_st
    if nz(st_dir[1])==-1 and zoo_price_src>nz(curr_short[1])
        st_dir:=1
    else if nz(st_dir[1])==1 and zoo_price_src<nz(curr_long[1])
        st_dir:=-1
    sig_line:=st_dir==1?curr_long:curr_short
else
    sig_line:=base_ma

bool buy_cross=ta.crossover(zoo_price_src,sig_line), bool sell_cross=ta.crossunder(zoo_price_src,sig_line)
bool bull_reaccel=st_dir==1 and sig_line>nz(sig_line[1]) and nz(sig_line[1])==nz(sig_line[2])
bool bear_reaccel=st_dir==-1 and sig_line<nz(sig_line[1]) and nz(sig_line[1])==nz(sig_line[2])

float pbj_ma=ta.ema(close,zoo_pbj_ma_period), float pbj_atr=ta.atr(zoo_pbj_atr_period)
float zoo_avg_vol=ta.sma(volume,zoo_pbj_vol_period)
float zoo_thresh=close==0?0:(pbj_atr/close*zoo_pbj_atr_mult)
bool pbj_buy=low<pbj_ma*(1-zoo_thresh) and low==ta.lowest(low,zoo_pbj_hh_ll) and volume>zoo_avg_vol*zoo_pbj_vol_mult
bool pbj_sell=high>pbj_ma*(1+zoo_thresh) and high==ta.highest(high,zoo_pbj_hh_ll) and volume>zoo_avg_vol*zoo_pbj_vol_mult

var bull_lvls=array.new<lvl>(), var bear_lvls=array.new<lvl>()
f_add_lvl(arr,up,lo,v)=>
    if math.abs(up-lo)>=syminfo.mintick
        array.push(arr,lvl.new(up,lo,v,false))
f_add_lander(is_bull,cross_sig,arr)=>
    if cross_sig
        float up=0.0, float lo=0.0
        if is_bull
            up:=math.max(open[1],close[1]), lo:=low[1]
            if up-lo<atr_pb*0.5
                up:=lo+atr_pb*0.5
        else
            up:=high[1], lo:=math.min(open[1],close[1])
            if up-lo<atr_pb*0.5
                lo:=up-atr_pb*0.5
        f_add_lvl(arr,up,lo,volume[1])
f_add_reaccel(is_bull,sig,arr)=>
    if sig and not na(sig_line)
        float p1=sig_line, float p2=is_bull?math.min(open,close):math.max(open,close)
        f_add_lvl(arr,math.max(p1,p2),math.min(p1,p2),volume)
f_check_approach(arr,is_bull)=>
    bool approached=false
    if array.size(arr)>0
        for i=array.size(arr)-1 to 0
            if i>=array.size(arr)
                continue
            l=array.get(arr,i)
            if is_bull and close<l.lower
                array.remove(arr,i)
                continue
            if not is_bull and close>l.upper
                array.remove(arr,i)
                continue
            float ap=is_bull?l.upper*1.005:l.lower*0.995
            if is_bull
                if not l.approached and low<=ap
                    approached:=true
                    l.approached:=true
                else if l.approached and low>l.upper
                    l.approached:=false
            else
                if not l.approached and high>=ap
                    approached:=true
                    l.approached:=true
                else if l.approached and high<l.lower
                    l.approached:=false
    approached

f_add_lander(true,buy_cross,bull_lvls), f_add_lander(false,sell_cross,bear_lvls)
f_add_reaccel(true,bull_reaccel,bull_lvls), f_add_reaccel(false,bear_reaccel,bear_lvls)

var bool wait_buy=false, var bool wait_sell=false, var bool wait_pbj_buy=false, var bool wait_pbj_sell=false
if conf
    if f_check_approach(bull_lvls,true)
        wait_buy:=true
    if f_check_approach(bear_lvls,false)
        wait_sell:=true
if pbj_buy
    wait_pbj_buy:=true
if pbj_sell
    wait_pbj_sell:=true
while array.size(bull_lvls)>30
    array.shift(bull_lvls)
while array.size(bear_lvls)>30
    array.shift(bear_lvls)

bool sig_pbj_buy=buy_cross and wait_pbj_buy, bool sig_pb_buy=buy_cross and wait_buy
bool sig_pbj_sell=sell_cross and wait_pbj_sell, bool sig_pb_sell=sell_cross and wait_sell
if sig_pb_buy
    wait_buy:=false
if sig_pbj_buy
    wait_pbj_buy:=false
if sig_pb_sell
    wait_sell:=false
if sig_pbj_sell
    wait_pbj_sell:=false

// PIPELINE B TERMINAL OUTPUTS
bool sigBullPBJ=conf and sig_pbj_buy, bool sigBullPB=conf and enable_PB and sig_pb_buy and not sig_pbj_buy
bool sigBearPBJ=conf and sig_pbj_sell, bool sigBearPB=conf and enable_PB and sig_pb_sell and not sig_pbj_sell

// === ENGINE 7: PING PONG SR ===
type srLevel
    float price
    int levelType
    int originType
    int state
    int count
    line lnID

var srLevels=array.new<srLevel>(0)
var int last_bounce_side=0, var string lastBreakType=na
float sig_bull_break=na, float sig_bear_break=na, float sig_res_bounce=na, float sig_sup_bounce=na
float sig_piv_bull=na, float sig_piv_bear=na, float sig_res_reject=na, float sig_sup_reject=na
bool bullRegime=false, bool bearRegime=false

float body_top=math.max(open,close), float body_bot=math.min(open,close)
float price_tolerance=math.max(syminfo.mintick*pp_buffer_ticks,syminfo.mintick/10)
bool is_new_flat_res=true, bool is_new_flat_sup=true
for i=0 to pp_min_candles-1
    if math.abs(math.max(open[i],close[i])-body_top)>price_tolerance
        is_new_flat_res:=false
    if math.abs(math.min(open[i],close[i])-body_bot)>price_tolerance
        is_new_flat_sup:=false

rawHigh=ta.pivothigh(high,sw_leftBars,sw_rightBars), rawLow=ta.pivotlow(low,sw_leftBars,sw_rightBars)
var float lastValidSwingLevel=na
thresholdSwing=sw_useAtr?(pp_atr*sw_atrMult):0

bool validSwingHigh=false
if not na(rawHigh)
    if na(lastValidSwingLevel) or math.abs(rawHigh-lastValidSwingLevel)>=thresholdSwing
        validSwingHigh:=true
        lastValidSwingLevel:=rawHigh
bool validSwingLow=false
if not na(rawLow)
    if na(lastValidSwingLevel) or math.abs(rawLow-lastValidSwingLevel)>=thresholdSwing
        validSwingLow:=true
        lastValidSwingLevel:=rawLow

has_level(price,type_val)=>
    bool found=false
    if array.size(srLevels)>0
        for i=0 to array.size(srLevels)-1
            lv=array.get(srLevels,i)
            if math.abs(lv.price-price)<=price_tolerance and lv.levelType==type_val
                found:=true
                break
    found

if is_new_flat_res and not has_level(body_top,1)
    ln=line.new(bar_index-pp_min_candles+1,body_top,bar_index,body_top,color=color.new(color.white,100),style=line.style_dashed)
    array.push(srLevels,srLevel.new(body_top,1,0,0,0,ln))
if is_new_flat_sup and not has_level(body_bot,-1)
    ln=line.new(bar_index-pp_min_candles+1,body_bot,bar_index,body_bot,color=color.new(color.white,100),style=line.style_dashed)
    array.push(srLevels,srLevel.new(body_bot,-1,0,0,0,ln))
if validSwingHigh
    ln=line.new(bar_index-sw_rightBars,rawHigh,bar_index,rawHigh,color=color.new(color.white,100),width=1,style=line.style_solid)
    array.push(srLevels,srLevel.new(rawHigh,1,1,1,0,ln))
if validSwingLow
    ln=line.new(bar_index-sw_rightBars,rawLow,bar_index,rawLow,color=color.new(color.white,100),width=1,style=line.style_solid)
    array.push(srLevels,srLevel.new(rawLow,-1,1,1,0,ln))

if array.size(srLevels)>0
    for i=array.size(srLevels)-1 to 0
        lv=array.get(srLevels,i)
        bool remove_lv=false
        if lv.levelType==1
            if close>lv.price
                if lv.state==1 or lv.originType==1
                    sig_bull_break:=high
                    if lastBreakType=="BD"
                        bullRegime:=true
                    lastBreakType:="BO"
                remove_lv:=true
            else
                line.set_x2(lv.lnID,bar_index)
                if (lv.state==1 or lv.originType==1) and high>=lv.price
                    sig_res_reject:=high
                    lv.count:=0
                if lv.state==0 or (lv.state==1 and lv.count>=0)
                    if close<open
                        lv.count+=1
                    if (lv.price-close)>(pp_atr*pp_atr_mult) and lv.count>=pp_trend_cnt
                        if lv.state==0
                            lv.state:=1
                            line.set_style(lv.lnID,line.style_solid)
                            line.set_width(lv.lnID,2)
                        lv.count:=-1
                        sig_res_bounce:=high
                        if last_bounce_side==1
                            sig_piv_bear:=high
                        last_bounce_side:=-1
        else if lv.levelType==-1
            if close<lv.price
                if lv.state==1 or lv.originType==1
                    sig_bear_break:=low
                    if lastBreakType=="BO"
                        bearRegime:=true
                    lastBreakType:="BD"
                remove_lv:=true
            else
                line.set_x2(lv.lnID,bar_index)
                if (lv.state==1 or lv.originType==1) and low<=lv.price
                    sig_sup_reject:=low
                    lv.count:=0
                if lv.state==0 or (lv.state==1 and lv.count>=0)
                    if close>open
                        lv.count+=1
                    if (close-lv.price)>(pp_atr*pp_atr_mult) and lv.count>=pp_trend_cnt
                        if lv.state==0
                            lv.state:=1
                            line.set_style(lv.lnID,line.style_solid)
                            line.set_width(lv.lnID,2)
                        lv.count:=-1
                        sig_sup_bounce:=low
                        if last_bounce_side==-1
                            sig_piv_bull:=low
                        last_bounce_side:=1
        if remove_lv
            line.set_x2(lv.lnID,bar_index)
            array.remove(srLevels,i)

while array.size(srLevels)>pp_max_levels
    oldLv=array.get(srLevels,0)
    line.delete(oldLv.lnID)
    array.remove(srLevels,0)

int bull_state=(validSwingLow?32:0)+(not na(sig_piv_bull)?16:0)+(bullRegime?8:0)+(not na(sig_sup_bounce)?4:0)+(not na(sig_bull_break)?2:0)+(not na(sig_res_reject)?1:0)
int bull_cnt=(validSwingLow?1:0)+(not na(sig_piv_bull)?1:0)+(bullRegime?1:0)+(not na(sig_sup_bounce)?1:0)+(not na(sig_bull_break)?1:0)+(not na(sig_res_reject)?1:0)
bool bull_has_floor_gravity=(bull_state%8>=4) or (bull_state%32>=16) or (bull_state>=32)
int bear_state=(validSwingHigh?32:0)+(not na(sig_piv_bear)?16:0)+(bearRegime?8:0)+(not na(sig_res_bounce)?4:0)+(not na(sig_bear_break)?2:0)+(not na(sig_sup_reject)?1:0)
int bear_cnt=(validSwingHigh?1:0)+(not na(sig_piv_bear)?1:0)+(bearRegime?1:0)+(not na(sig_res_bounce)?1:0)+(not na(sig_bear_break)?1:0)+(not na(sig_sup_reject)?1:0)
bool bear_has_ceiling_gravity=(bear_state%8>=4) or (bear_state%32>=16) or (bear_state>=32)

bool bull_pp=bull_cnt>=pp_min_count and bull_has_floor_gravity and bull_state>0
bool bear_pp=bear_cnt>=pp_min_count and bear_has_ceiling_gravity and bear_state>0

// === ENGINE 8: UU / UUU / UUUU — UNIFIED STREAK ===
bool u_qual_bull = conf and bb_baseBullish and bb_normalizedPrice >= 0.5
bool u_qual_bear = conf and bb_baseBearish and bb_normalizedPrice >= 0.5

var int u_bull_streak = 0, var int u_bear_streak = 0
var bool u_bull_hasDay1 = false, var bool u_bear_hasDay1 = false

if conf
    if u_qual_bull
        u_bull_streak += 1
        u_bull_hasDay1 := u_bull_hasDay1 or is_new_day
    else
        u_bull_streak := 0
        u_bull_hasDay1 := false
    if u_qual_bear
        u_bear_streak += 1
        u_bear_hasDay1 := u_bear_hasDay1 or is_new_day
    else
        u_bear_streak := 0
        u_bear_hasDay1 := false

bool rawBullUU = conf and u_bull_streak == 2
bool rawBullUUU = conf and u_bull_streak == 3
bool rawBullUUUU = conf and u_bull_streak >= 4
bool rawBearUU = conf and u_bear_streak == 2
bool rawBearUUU = conf and u_bear_streak == 3
bool rawBearUUUU = conf and u_bear_streak >= 4

// ─── BULL UUUU (≥4 bars) ───
bool sigP21BullUUUU = false
bool sigP21BullUUUU_indep = false
if conf and u_bull_streak >= 4
    int _n = math.min(u_bull_streak, 4)
    bool _has_pbj = false, bool _has_pb = false, bool _has_hvd = false
    bool _has_disp = false, bool _has_fauna = false
    bool _all_disp = true, bool _all_saab_df = true
    bool _df_not_pbj = false, bool _pbj_not_df = false
    bool _has_sa = false, bool _has_r1 = false, bool _has_gs = false
    for i = 0 to _n - 1
        bool bpbj = nz(sigBullPBJ[i])
        bool bpb = nz(sigBullPB[i])
        bool bhvd = i >= 1 ? nz(hvd_fire_bull[i - 1]) : false
        bool bdisp = nz(sigDISPBull[i]) or bhvd
        bool bfauna = nz(sigFAUNABull[i])
        bool bsaab = nz(sigSAAB[i]) or nz(sigBullRVOL1x[i]) or nz(sigGrandSlam[i])
        bool bsa = nz(sigSAAB[i]), bool br1 = nz(sigBullRVOL1x[i]), bool bgs = nz(sigGrandSlam[i])
        bool bdf = bdisp or bfauna
        if bpbj
            _has_pbj := true
        if bpb
            _has_pb := true
        if bhvd
            _has_hvd := true
        if bdisp
            _has_disp := true
        if bfauna
            _has_fauna := true
        if bsa
            _has_sa := true
        if br1
            _has_r1 := true
        if bgs
            _has_gs := true
        if not bdisp
            _all_disp := false
        if not bsaab or not bdf
            _all_saab_df := false
        if bdf and not bpbj
            _df_not_pbj := true
        if bpbj and not bdf
            _pbj_not_df := true
    bool pA = u_bull_hasDay1 and _has_pbj
    bool pB = _all_disp
    bool pC = _all_saab_df
    bool pD = _has_hvd
    bool pE = (_df_not_pbj and _has_pbj) or (_pbj_not_df and (_has_disp or _has_fauna))
    bool pF = (_has_fauna or _has_disp) and _has_pbj
    // v2 pG path: ≥4 distinct qualifiers in streak (PBJ/DISP/FAUNA/SAAB/RVOL1x/GS).
    int _qcnt = (_has_pbj?1:0)+(_has_disp?1:0)+(_has_fauna?1:0)+(_has_sa?1:0)+(_has_r1?1:0)+(_has_gs?1:0)
    bool pG = _qcnt >= 4
    float _sum4 = bb_normalizedPrice + nz(bb_normalizedPrice[1]) + nz(bb_normalizedPrice[2]) + nz(bb_normalizedPrice[3])
    bool _pbj4 = nz(sigBullPBJ) or nz(sigBullPBJ[1]) or nz(sigBullPBJ[2]) or nz(sigBullPBJ[3])
    bool _sub2min_ok_4 = tfSec > 120 or (_sum4 >= th_saab_kratos and (_sum4 >= th_1x or _pbj4))
    sigP21BullUUUU := (pA or pB or pC or pD or pE or pF or pG) and _sub2min_ok_4
    sigP21BullUUUU_indep := (pA or pB or pC or pE or pF or pG) and _sub2min_ok_4

// ─── BULL UUU (exactly 3) ───
bool sigP21BullUUU = false
bool sigP21BullUUU_indep = false
if conf and u_bull_streak == 3
    bool _has_pbj = false, bool _has_pb = false, bool _has_hvd = false
    bool _has_disp = false, bool _has_fauna = false
    bool _all_disp = true, bool _all_saab_df = true
    bool _df_not_pbj = false, bool _pbj_not_df = false
    bool _has_sa = false, bool _has_r1 = false, bool _has_gs = false
    for i = 0 to 2
        bool bpbj = nz(sigBullPBJ[i])
        bool bpb = nz(sigBullPB[i])
        bool bhvd = i >= 1 ? nz(hvd_fire_bull[i - 1]) : false
        bool bdisp = nz(sigDISPBull[i]) or bhvd
        bool bfauna = nz(sigFAUNABull[i])
        bool bsaab = nz(sigSAAB[i]) or nz(sigBullRVOL1x[i]) or nz(sigGrandSlam[i])
        bool bsa = nz(sigSAAB[i]), bool br1 = nz(sigBullRVOL1x[i]), bool bgs = nz(sigGrandSlam[i])
        bool bdf = bdisp or bfauna
        if bpbj
            _has_pbj := true
        if bpb
            _has_pb := true
        if bhvd
            _has_hvd := true
        if bdisp
            _has_disp := true
        if bfauna
            _has_fauna := true
        if bsa
            _has_sa := true
        if br1
            _has_r1 := true
        if bgs
            _has_gs := true
        if not bdisp
            _all_disp := false
        if not bsaab or not bdf
            _all_saab_df := false
        if bdf and not bpbj
            _df_not_pbj := true
        if bpbj and not bdf
            _pbj_not_df := true
    bool pA = u_bull_hasDay1 and _has_pbj
    bool pB = _all_disp
    bool pC = _all_saab_df
    bool pD = _has_hvd
    bool pE = (_df_not_pbj and _has_pbj) or (_pbj_not_df and (_has_disp or _has_fauna))
    int _qcnt = (_has_pbj?1:0)+(_has_disp?1:0)+(_has_fauna?1:0)+(_has_sa?1:0)+(_has_r1?1:0)+(_has_gs?1:0)
    bool pG = _qcnt >= 3
    float _sum3 = bb_normalizedPrice + nz(bb_normalizedPrice[1]) + nz(bb_normalizedPrice[2])
    bool _pbj3 = nz(sigBullPBJ) or nz(sigBullPBJ[1]) or nz(sigBullPBJ[2])
    bool _sub2min_ok_3 = tfSec > 120 or (_sum3 >= th_saab_kratos and (_sum3 >= th_1x or _pbj3))
    sigP21BullUUU := (pA or pB or pC or pD or pE or pG) and _sub2min_ok_3
    sigP21BullUUU_indep := (pA or pB or pC or pE or pG) and _sub2min_ok_3

// ─── BULL UU (exactly 2) ───
bool sigUUBull = false
bool sigUUBull_indep = false
if conf and u_bull_streak == 2
    bool _has_pbj = false, bool _has_pb = false, bool _has_hvd = false
    bool _has_disp = false, bool _has_fauna = false
    bool _all_disp = true, bool _all_saab_df = true
    bool _df_not_pbj = false, bool _pbj_not_df = false
    bool _has_sa = false, bool _has_r1 = false, bool _has_gs = false
    for i = 0 to 1
        bool bpbj = nz(sigBullPBJ[i])
        bool bpb = nz(sigBullPB[i])
        bool bhvd = i >= 1 ? nz(hvd_fire_bull[i - 1]) : false
        bool bdisp = nz(sigDISPBull[i]) or bhvd
        bool bfauna = nz(sigFAUNABull[i])
        bool bsaab = nz(sigSAAB[i]) or nz(sigBullRVOL1x[i]) or nz(sigGrandSlam[i])
        bool bsa = nz(sigSAAB[i]), bool br1 = nz(sigBullRVOL1x[i]), bool bgs = nz(sigGrandSlam[i])
