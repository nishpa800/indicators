//@version=6
indicator("Volume Order Blocks + Asymmetric Signals", overlay = true
             , max_lines_count = 500, max_labels_count = 500, max_bars_back = 5000)

// ─────────────────────────────────────────────────────────────────────────────
// UDT
// ─────────────────────────────────────────────────────────────────────────────

type level 
    int   indx
    float upper
    float lower 
    float mid 
    float vol

type draw 
    line     upper 
    line     lower 
    line     mid 
    linefill fill 
    label    vol

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

int   length1        = input.int(5,     "Sensitivity Detection")
int   length2        = length1 + 13
bool  mid_l          = input.bool(true, "Mid Line")
bool  trend_shadow   = input.bool(true, "Trend Shadow")
color col1           = input.color(#26ba9f, "", inline = "col")
color col2           = input.color(#6626ba, "", inline = "col")

// Signal inputs
float asym_threshold = input.float(50.0, "Tier 1 — Asymmetric % Threshold", minval = 1, step = 5,
     tooltip = "Dominant OB must hold at least this % of its pool to trigger Tier 1")
float super_mult     = input.float(1.0,  "Tier 3 — Super Volume Multiplier", step = 0.1,
     tooltip = "Dominant OB raw volume must exceed opposing pool total × this multiplier")
int   cooldown_bars  = input.int(20,    "Signal Cooldown (Bars)", minval = 0,
     tooltip = "Minimum number of bars to wait after any signal before allowing a new one")

// ─────────────────────────────────────────────────────────────────────────────
// CALCULATIONS (original — untouched)
// ─────────────────────────────────────────────────────────────────────────────

float ema1     = ta.ema(close, length1)
float ema2     = ta.ema(close, length2)

bool  cross_up = ta.crossover(ema1, ema2)  and barstate.isconfirmed
bool  cross_dn = ta.crossunder(ema1, ema2) and barstate.isconfirmed
float lowest   = ta.lowest(length2) 
float highest  = ta.highest(length2)

var upper_draw = array.new<draw>()
var lower_draw = array.new<draw>()

var upper_lvl  = array.new<level>()
var lower_lvl  = array.new<level>()

array_vol_upper = array.new<float>()
array_vol_lower = array.new<float>()

difff       = ema2 - ema1
color_trend = trend_shadow ? difff > 0 ? color.from_gradient(difff, 0, ta.highest(difff,100), color(na), col2) : color.from_gradient(difff, ta.lowest(difff,100), 0, col1, color(na)) : color(na)

p1 = plot(ema1, "", display = display.none, editable = false)
p2 = plot(ema2, "", display = display.none, editable = false)
fill(p1, p2, color_trend)

atr  = ta.highest(ta.atr(200), 200) * 3
atr1 = ta.highest(ta.atr(200), 200) * 2

f_clear_previous_lines(draw__) =>
    if draw__.size() > 0
        for l in draw__
            line.delete(l.upper)
            line.delete(l.lower)
            line.delete(l.mid)
            linefill.delete(l.fill)
            label.delete(l.vol)
        array.clear(draw__)

if cross_up
    var vol = 0.0
    vol := 0
    for i = 1 to length2
        if low[i] == lowest
            index = time[i]
            for k = 0 to i
                vol += volume[k]
            src = math.min(open[i], close[i])
            src := (src - lowest) < atr1 * 0.5 ? lowest + atr1 * 0.5 : src
            mid = math.avg(src, lowest)    
            l = level.new(index, src, lowest, mid, vol)
            lower_lvl.push(l)

if cross_dn
    var vol = 0.0
    vol := 0
    for i = 1 to length2
        if high[i] == highest
            index = time[i]
            for k = 0 to i
                vol += volume[k]
            src = math.max(open[i], close[i])
            src := (highest - src) < atr1 * 0.5 ? highest - atr1 * 0.5 : src
            mid = math.avg(src, highest) 
            l = level.new(index, highest, src, mid, vol)
            upper_lvl.push(l)

// ─────────────────────────────────────────────────────────────────────────────
// INVALIDATION (original — untouched)
// ─────────────────────────────────────────────────────────────────────────────

if lower_lvl.size() > 0
    for i = 0 to lower_lvl.size() - 1
        l  = lower_lvl.get(i)
        l1 = lower_lvl.get(i - 1)
        mid  = l.mid
        mid1 = l1.mid
        if math.abs(mid - mid1) < atr 
            l_ = level.new(na, na, na, na, na)
            lower_lvl.set(i - 1, l_)
        if close < l.lower
            l_ = level.new(na, na, na, na, na)
            lower_lvl.set(i, l_)
    if lower_lvl.size() > 15 
        lower_lvl.shift()

if upper_lvl.size() > 0
    for i = 0 to upper_lvl.size() - 1
        l     = upper_lvl.get(i)
        l1    = upper_lvl.get(i - 1)
        upper = l.upper
        mid   = l.mid
        mid1  = l1.mid
        if math.abs(mid - mid1) < atr 
            l_ = level.new(na, na, na, na, na)
            upper_lvl.set(i - 1, l_)
        if close > upper
            l_ = level.new(na, na, na, na, na)
            upper_lvl.set(i, l_)
    if upper_lvl.size() > 15 
        upper_lvl.shift()

// ─────────────────────────────────────────────────────────────────────────────
// ASYMMETRIC SIGNAL ENGINE
// ─────────────────────────────────────────────────────────────────────────────

// Pre-declare signal variables at GLOBAL scope (plotshape cannot be in local scope)
var bool sig_t1_buy  = false
var bool sig_t1_sell = false
var bool sig_t2_buy  = false
var bool sig_t2_sell = false
var bool sig_t3_buy  = false
var bool sig_t3_sell = false
var int  last_signal_bar = na

// Reset each bar
sig_t1_buy  := false
sig_t1_sell := false
sig_t2_buy  := false
sig_t2_sell := false
sig_t3_buy  := false
sig_t3_sell := false

// Only run on confirmed bar close — guarantees non-repainting
if barstate.isconfirmed

    // ── Collect valid bullish OB volumes ──────────────────────────────────────
    valid_bull_vol  = array.new<float>()
    valid_bull_low  = array.new<float>()
    valid_bull_high = array.new<float>()

    if lower_lvl.size() > 0
        for i = 0 to lower_lvl.size() - 1
            l = lower_lvl.get(i)
            if not na(l.vol)
                valid_bull_vol.push(l.vol)
                valid_bull_low.push(l.lower)
                valid_bull_high.push(l.upper)

    // ── Collect valid bearish OB volumes ─────────────────────────────────────
    valid_bear_vol  = array.new<float>()
    valid_bear_low  = array.new<float>()
    valid_bear_high = array.new<float>()

    if upper_lvl.size() > 0
        for i = 0 to upper_lvl.size() - 1
            l = upper_lvl.get(i)
            if not na(l.vol)
                valid_bear_vol.push(l.vol)
                valid_bear_low.push(l.lower)
                valid_bear_high.push(l.upper)

    bull_pool_total = valid_bull_vol.size() > 0 ? valid_bull_vol.sum() : 0.0
    bear_pool_total = valid_bear_vol.size() > 0 ? valid_bear_vol.sum() : 0.0

    // ── Find dominant bullish OB (highest vol) ────────────────────────────────
    dom_bull_vol   = 0.0
    dom_bull_low   = 0.0
    dom_bull_high  = 0.0
    dom_bull_pct   = 0.0
    bull_count     = valid_bull_vol.size()

    if bull_count > 0
        for i = 0 to bull_count - 1
            v = valid_bull_vol.get(i)
            if v > dom_bull_vol
                dom_bull_vol  := v
                dom_bull_low  := valid_bull_low.get(i)
                dom_bull_high := valid_bull_high.get(i)
        dom_bull_pct := bull_pool_total > 0 ? dom_bull_vol / bull_pool_total * 100 : 0.0

    // ── Find dominant bearish OB (highest vol) ────────────────────────────────
    dom_bear_vol   = 0.0
    dom_bear_low   = 0.0
    dom_bear_high  = 0.0
    dom_bear_pct   = 0.0
    bear_count     = valid_bear_vol.size()

    if bear_count > 0
        for i = 0 to bear_count - 1
            v = valid_bear_vol.get(i)
            if v > dom_bear_vol
                dom_bear_vol  := v
                dom_bear_low  := valid_bear_low.get(i)
                dom_bear_high := valid_bear_high.get(i)
        dom_bear_pct := bear_pool_total > 0 ? dom_bear_vol / bear_pool_total * 100 : 0.0

    // ── Price at zone checks ──────────────────────────────────────────────────
    price_at_bull = close >= dom_bull_low  and close <= dom_bull_high
    price_at_bear = close >= dom_bear_low  and close <= dom_bear_high

    // ─────────────────────────────────────────────────────────────────────────
    // TIER 1 — ASYMMETRIC BUY
    // ─────────────────────────────────────────────────────────────────────────
    tier1_buy = dom_bull_pct >= asym_threshold
         and dom_bull_vol > dom_bear_vol
         and price_at_bull
         and bull_count > 0

    // ─────────────────────────────────────────────────────────────────────────
    // TIER 1 — ASYMMETRIC SELL
    // ─────────────────────────────────────────────────────────────────────────
    tier1_sell = dom_bear_pct >= asym_threshold
         and dom_bear_vol > dom_bull_vol
         and price_at_bear
         and bear_count > 0

    // ─────────────────────────────────────────────────────────────────────────
    // TIER 2 — PURE 100% BUY
    // ─────────────────────────────────────────────────────────────────────────
    tier2_buy  = bull_count == 1 and price_at_bull

    // ─────────────────────────────────────────────────────────────────────────
    // TIER 2 — PURE 100% SELL
    // ─────────────────────────────────────────────────────────────────────────
    tier2_sell = bear_count == 1 and price_at_bear

    // ─────────────────────────────────────────────────────────────────────────
    // TIER 3 — SUPER 100% BUY
    // ─────────────────────────────────────────────────────────────────────────
    tier3_buy  = bull_count == 1
         and bear_pool_total > 0
         and dom_bull_vol > bear_pool_total * super_mult
         and price_at_bull

    // ─────────────────────────────────────────────────────────────────────────
    // TIER 3 — SUPER 100% SELL
    // ─────────────────────────────────────────────────────────────────────────
    tier3_sell = bear_count == 1
         and bull_pool_total > 0
         and dom_bear_vol > bull_pool_total * super_mult
         and price_at_bear

    // ── Assign to global signal variables ────────────────────────────────────
    cooldown_ready = na(last_signal_bar) or (bar_index - last_signal_bar > cooldown_bars)

    raw_t1_buy  = tier1_buy  and not tier2_buy  and not tier3_buy
    raw_t1_sell = tier1_sell and not tier2_sell and not tier3_sell
    raw_t2_buy  = tier2_buy  and not tier3_buy
    raw_t2_sell = tier2_sell and not tier3_sell
    raw_t3_buy  = tier3_buy
    raw_t3_sell = tier3_sell

    sig_t1_buy  := cooldown_ready and raw_t1_buy
    sig_t1_sell := cooldown_ready and raw_t1_sell
    sig_t2_buy  := cooldown_ready and raw_t2_buy
    sig_t2_sell := cooldown_ready and raw_t2_sell
    sig_t3_buy  := cooldown_ready and raw_t3_buy
    sig_t3_sell := cooldown_ready and raw_t3_sell

    if sig_t1_buy or sig_t1_sell or sig_t2_buy or sig_t2_sell or sig_t3_buy or sig_t3_sell
        last_signal_bar := bar_index

    // ─────────────────────────────────────────────────────────────────────────
    // ALERTS — 1:1 parity with plots, all on bar close
    // ─────────────────────────────────────────────────────────────────────────

    if sig_t1_buy
        alert("T1 Asymmetric BUY — dom bull vol: " + str.tostring(dom_bull_vol, format.volume) + " vs bear: " + str.tostring(dom_bear_vol, format.volume), alert.freq_once_per_bar_close)

    if sig_t1_sell
        alert("T1 Asymmetric SELL — dom bear vol: " + str.tostring(dom_bear_vol, format.volume) + " vs bull: " + str.tostring(dom_bull_vol, format.volume), alert.freq_once_per_bar_close)

    if sig_t2_buy
        alert("T2 Pure 100% BUY — single bull block: " + str.tostring(dom_bull_vol, format.volume), alert.freq_once_per_bar_close)

    if sig_t2_sell
        alert("T2 Pure 100% SELL — single bear block: " + str.tostring(dom_bear_vol, format.volume), alert.freq_once_per_bar_close)

    if sig_t3_buy
        alert("T3 SUPER BUY — bull: " + str.tostring(dom_bull_vol, format.volume) + " vs entire bear pool: " + str.tostring(bear_pool_total, format.volume), alert.freq_once_per_bar_close)

    if sig_t3_sell
        alert("T3 SUPER SELL — bear: " + str.tostring(dom_bear_vol, format.volume) + " vs entire bull pool: " + str.tostring(bull_pool_total, format.volume), alert.freq_once_per_bar_close)

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS — at GLOBAL scope (FIX: moved out of if block)
// ─────────────────────────────────────────────────────────────────────────────

// Tier 1 — small diamonds
plotshape(sig_t1_buy,
     title     = "T1 Buy",
     style     = shape.diamond,
     location  = location.belowbar,
     color     = color.new(#26ba9f, 0),
     size      = size.small,
     text      = "T1",
     textcolor = color.new(#26ba9f, 0))

plotshape(sig_t1_sell,
     title     = "T1 Sell",
     style     = shape.diamond,
     location  = location.abovebar,
     color     = color.new(#6626ba, 0),
     size      = size.small,
     text      = "T1",
     textcolor = color.new(#6626ba, 0))

// Tier 2 — medium triangles
plotshape(sig_t2_buy,
     title     = "T2 Buy",
     style     = shape.triangleup,
     location  = location.belowbar,
     color     = color.new(#00e5ff, 0),
     size      = size.normal,
     text      = "T2",
     textcolor = color.new(#00e5ff, 0))

plotshape(sig_t2_sell,
     title     = "T2 Sell",
     style     = shape.triangledown,
     location  = location.abovebar,
     color     = color.new(#ff00e5, 0),
     size      = size.normal,
     text      = "T2",
     textcolor = color.new(#ff00e5, 0))

// Tier 3 — large circles (FIX: shape.star does not exist, using shape.circle)
plotshape(sig_t3_buy,
     title     = "T3 SUPER Buy",
     style     = shape.circle,
     location  = location.belowbar,
     color     = color.new(#ffff00, 0),
     size      = size.large,
     text      = "T3",
     textcolor = color.new(#ffff00, 0))

plotshape(sig_t3_sell,
     title     = "T3 SUPER Sell",
     style     = shape.circle,
     location  = location.abovebar,
     color     = color.new(#ff4400, 0),
     size      = size.large,
     text      = "T3",
     textcolor = color.new(#ff4400, 0))

// ─────────────────────────────────────────────────────────────────────────────
// ORIGINAL PLOTS (untouched)
// ─────────────────────────────────────────────────────────────────────────────

if lower_lvl.size() > 0 and barstate.islast
    f_clear_previous_lines(lower_draw)
    for i = 0 to lower_lvl.size() - 1
        l = lower_lvl.get(i)
        array_vol_lower.push(l.vol)
    for i = 0 to lower_lvl.size() - 1
        l   = lower_lvl.get(i)
        txt = "⮜ " + str.tostring(l.vol / array_vol_lower.sum() * 100, format.percent) + " (" + str.tostring(l.vol, format.volume) + ")"
        l_1   = line.new(l.indx, l.upper, time, l.upper, color = col1, width = 2, xloc = xloc.bar_time)
        l_2   = line.new(l.indx, l.lower, time, l.lower, color = col1, width = 2, xloc = xloc.bar_time)
        l_mid = line.new(l.indx, l.mid,   time, l.mid,   color = mid_l ? col1 : color(na), style = line.style_dashed, xloc = xloc.bar_time)
        vol_l = label.new(time, l.mid, txt, style = label.style_label_left, color = color(na), textcolor = chart.fg_color, xloc = xloc.bar_time)
        fill  = linefill.new(l_1, l_2, color.new(col1, 90))
        draw_ = draw.new(l_1, l_2, l_mid, fill, vol_l)
        lower_draw.push(draw_)

if upper_lvl.size() > 0 and barstate.islast
    f_clear_previous_lines(upper_draw)
    for i = 0 to array.size(upper_lvl) - 1
        l = array.get(upper_lvl, i)
        array_vol_upper.push(l.vol) 
    for i = 0 to array.size(upper_lvl) - 1
        l   = array.get(upper_lvl, i)
        txt = "⮜ " + str.tostring(l.vol / array_vol_upper.sum() * 100, format.percent) + " (" + str.tostring(l.vol, format.volume) + ")"
        l_1   = line.new(l.indx, l.upper, time, l.upper, color = col2, width = 2, xloc = xloc.bar_time)
        l_2   = line.new(l.indx, l.lower, time, l.lower, color = col2, width = 2, xloc = xloc.bar_time)
        l_mid = line.new(l.indx, l.mid,   time, l.mid,   color = mid_l ? col2 : color(na), style = line.style_dashed, xloc = xloc.bar_time)
        vol_l = label.new(time, l.mid, txt, style = label.style_label_left, color = color(na), textcolor = chart.fg_color, xloc = xloc.bar_time)
        fill  = linefill.new(l_1, l_2, color.new(col2, 90))
        draw_ = draw.new(l_1, l_2, l_mid, fill, vol_l)
        upper_draw.push(draw_)
