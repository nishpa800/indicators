f_log(f_fire(s_14), 14)
f_log(f_fire(s_15), 15)
f_log(f_fire(s_16), 16)
f_log(f_fire(s_17), 17)
f_log(f_fire(s_18), 18)
f_log(f_fire(s_19), 19)
f_log(f_fire(s_20), 20)
f_log(f_fire(s_21), 21)
f_log(f_fire(s_22), 22)
f_log(f_fire(s_23), 23)
f_log(f_fire(s_24), 24)
f_log(f_fire(s_25), 25)
f_log(f_fire(s_26), 26)
f_log(f_fire(s_27), 27)
f_log(f_fire(s_28), 28)
f_log(f_fire(s_29), 29)
f_log(f_fire(s_30), 30)
f_log(f_fire(s_31), 31)
f_log(f_fire(s_32), 32)
f_log(f_fire(s_33), 33)
f_log(f_fire(s_34), 34)
f_log(f_fire(s_35), 35)
f_log(f_fire(s_36), 36)
f_log(f_fire(s_37), 37)
f_log(f_fire(s_38), 38)
f_log(f_fire(s_39), 39)
f_log(f_fire(s_40), 40)
f_log(f_fire(s_41), 41)
f_log(f_fire(s_42), 42)
f_log(f_fire(s_43), 43)
f_log(f_fire(s_44), 44)
f_log(f_fire(s_45), 45)
f_log(f_fire(s_46), 46)
f_log_str(f_fire(s_t1), "T1OC")
f_log_str(f_fire(s_t2), "T2OC")

plot(0, display=display.data_window)
