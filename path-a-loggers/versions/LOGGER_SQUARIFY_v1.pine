//@version=5
// =============================================================================
// LOGGER — SQUARIFY 46 v2 (top-level fund signal aggregator)
// =============================================================================
// PURPOSE: emit one label.new() per fire of Squarify's 46 numbered composites
// + T1/T2 Opening Confluence so data_get_pine_labels can pull full history.
//
// SETUP: load AFTER "SQUARIFY 46 v2" on the chart. Point each "Source: ..."
// input at the corresponding plot.
// =============================================================================

indicator("LOGGER SQUARIFY", overlay=true, max_labels_count=500, max_bars_back=5000)

grp = "★ Source Plots — point at SQUARIFY 46 v2 ★"

s_01 = input.source(close, "1 SD!",          group=grp)
s_02 = input.source(close, "2 SUPER",        group=grp)
s_03 = input.source(close, "3 HW",           group=grp)
s_04 = input.source(close, "4 FLOOR",        group=grp)
s_05 = input.source(close, "5 2F",           group=grp)
s_06 = input.source(close, "6 UUUU",         group=grp)
s_07 = input.source(close, "7 UUU",          group=grp)
s_08 = input.source(close, "8 UU",           group=grp)
s_09 = input.source(close, "9 A★",           group=grp)
s_10 = input.source(close, "10 ΩA",          group=grp)
s_11 = input.source(close, "11 FOX",         group=grp)
s_12 = input.source(close, "12 OD",          group=grp)
s_13 = input.source(close, "13 GOLF",        group=grp)
s_14 = input.source(close, "14 PBJ+F2/E3",   group=grp)
s_15 = input.source(close, "15 PBJ+CL",      group=grp)
s_16 = input.source(close, "16 F2CL→E3",     group=grp)
s_17 = input.source(close, "17 E3⅔PP",       group=grp)
s_18 = input.source(close, "18 F2×2D",       group=grp)
s_19 = input.source(close, "19 E3×2D",       group=grp)
s_20 = input.source(close, "20 F2E3seq",     group=grp)
s_21 = input.source(close, "21 CL×2D",       group=grp)
s_22 = input.source(close, "22 NPM+",        group=grp)
s_23 = input.source(close, "23 NPM12",       group=grp)
s_24 = input.source(close, "24 NPM3",        group=grp)
s_25 = input.source(close, "25 B2BNPM",      group=grp)
s_26 = input.source(close, "26 NPM+TNT",     group=grp)
s_27 = input.source(close, "27 CO",          group=grp)
s_28 = input.source(close, "28 HVD+PBJ",     group=grp)
s_29 = input.source(close, "29 B2BHVD+PBJ",  group=grp)
s_30 = input.source(close, "30 B2BHVD",      group=grp)
s_31 = input.source(close, "31 UU+UC",       group=grp)
s_32 = input.source(close, "32 GRAIL",       group=grp)
s_33 = input.source(close, "33 FLR+NPM",     group=grp)
s_34 = input.source(close, "34 NPM+PBJ+PUP", group=grp)
s_35 = input.source(close, "35 NAG+",        group=grp)
s_36 = input.source(close, "36 UU+HVD",      group=grp)
s_37 = input.source(close, "37 UU+NPM",      group=grp)
s_38 = input.source(close, "38 FLR+UU",      group=grp)
s_39 = input.source(close, "39 FOS+PUP+1x",  group=grp)
s_40 = input.source(close, "40 NPM+UC",      group=grp)
s_41 = input.source(close, "41 WBUSH+ANY Bull",   group=grp)
s_42 = input.source(close, "42 WBUSH+ANY Bear",   group=grp)
s_43 = input.source(close, "43 WBUSH Neutral",    group=grp)
s_44 = input.source(close, "44 NPM+UC+PBJ",       group=grp)
s_45 = input.source(close, "45 UC NAGASAKI Bull", group=grp)
s_46 = input.source(close, "46 UC NAGASAKI Bear", group=grp)
s_t1 = input.source(close, "T1 OPENING CONFLU",   group=grp)
s_t2 = input.source(close, "T2 OPENING CONFLU",   group=grp)

f_fire(s) => not na(s) and s != 0 and barstate.isconfirmed
f_log(cond, n) =>
    if cond
        label.new(bar_index, high, "S"+str.tostring(n), color=color.new(color.gray, 90), style=label.style_label_down, textcolor=color.white, size=size.tiny, yloc=yloc.abovebar)
f_log_str(cond, tag) =>
    if cond
        label.new(bar_index, high, tag, color=color.new(color.gray, 90), style=label.style_label_down, textcolor=color.white, size=size.tiny, yloc=yloc.abovebar)

f_log(f_fire(s_01), 1)
f_log(f_fire(s_02), 2)
f_log(f_fire(s_03), 3)
f_log(f_fire(s_04), 4)
f_log(f_fire(s_05), 5)
f_log(f_fire(s_06), 6)
f_log(f_fire(s_07), 7)
f_log(f_fire(s_08), 8)
f_log(f_fire(s_09), 9)
f_log(f_fire(s_10), 10)
f_log(f_fire(s_11), 11)
