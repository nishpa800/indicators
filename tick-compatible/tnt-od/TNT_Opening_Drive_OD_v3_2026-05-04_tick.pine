plotshape(p_pnBear,   "PBJ+NPM Bear",         shape.diamond,   location.abovebar, #e91e63, size=size.small,  text="PBJ+NPM",       textcolor=#e91e63, display=display.pane, offset=-1)
// TIER 1 — offset 0
plotshape(p_ptBull,   "PBJ+TNT Bull",         shape.diamond,   location.belowbar, #66bb6a, size=size.small,  text="PBJ+TNT",       textcolor=#66bb6a, display=display.pane)
