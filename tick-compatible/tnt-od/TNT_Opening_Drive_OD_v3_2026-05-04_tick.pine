bool en_wbushBear    = input.bool(true, "✓ WBUSH+TNTOD ANY Bear",    group = grpWB, tooltip = "Mirror of bull: WBUSH-bear state (any of 5 Heavy Combo Bears) AND any TNTOD bearish detection. Offset = 0.")
