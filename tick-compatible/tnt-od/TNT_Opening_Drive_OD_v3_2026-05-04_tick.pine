grpDyn = "★ DYNAMITE ★"
float dynStdMult = input.float(5.0, "Displacement Std Dev Multiplier", minval = 1.0, step = 0.5, group = grpDyn,
     tooltip = "Displacement range must exceed stdev(100) × this value on BOTH consecutive bars. Adjust per timeframe.")

