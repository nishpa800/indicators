// ─── USE V5 BOWL SETTINGS ───────────────────────────────────────────────────
grpU5 = "USE V5 Bowl"
int   u5_std_len   = input.int(100, "Disp Std Dev Len", minval = 1, group = grpU5)
float u5_std_min   = input.float(3.0, "Disp Min Mult", step = 0.1, group = grpU5)
int   u5_od_max_bars = input.int(1, "Opening Drive Max Bars", minval = 1, group = grpU5)

int maxZones = input.int(30, "Max TNT 1.0 Zones", minval = 1, group = "Zones", tooltip = "How many active TNT 1.0 zones to keep tracking for Napalm/Charge/Return scans. Higher = more historical zones considered. Default 30.")
int maxSuperZones = input.int(30, "Max TNT 2.0 Zones", minval = 1, group = "Zones", tooltip = "How many TNT 2.0 (super) zones to track. Default 30.")

// ─── CONSTANTS ──────────────────────────────────────────────────────────────
int EMA_FAST = SENS, int EMA_SLOW = SENS + 13
float ATR_VAL = ta.atr(200), float ATR14 = ta.atr(14)
float ATR_MULT = 3.5, float ATR_MIN = 0.5
int MIN_SIG_GAP = EMA_SLOW
bool isFirstBar = session.isfirstbar
var int sessionFirstBarIdx = na
if isFirstBar
    sessionFirstBarIdx := bar_index
int u5_tfSec = nz(timeframe.in_seconds(timeframe.period), 60)
bool isSubMinute = u5_tfSec <= 60

// ─── TYPES ──────────────────────────────────────────────────────────────────
type Zone
    int    originIdx
    int    confirmIdx
    float  upper
    float  lower
    float  level
    float  vol
    bool   isBull
    bool   isActive     = true
    bool   returnFired  = false
    line   lvlLine
    label  sigLabel

type SuperZone
    int    formBar
    float  zoneTop
    float  zoneBtm
    float  returnLevel
    bool   isBull
    bool   isActive     = true
    bool   returnFired  = false
    box    zoneBox
    label  formLabel
    label  returnLabel
    line   returnLine

type SwingPoint
    float  val = na
    int    idx = na
    bool   crossed = false

type BullBearEvent
    int    barIdx
    float  level
    float  upper
    float  lower
    bool   isBull
    bool   isTrue

type ChargeLevel
    float  level
    bool   isBull
    int    barIdx
    bool   violated = false

// ══════════════════════════════════════════════════════════════════════════════
// ENGINE 1: VOB
// ══════════════════════════════════════════════════════════════════════════════
float ema_fast = ta.ema(close, EMA_FAST), float ema_slow = ta.ema(close, EMA_SLOW)
bool vob_bull_cross = ta.crossover(ema_fast, ema_slow) and barstate.isconfirmed
bool vob_bear_cross = ta.crossunder(ema_fast, ema_slow) and barstate.isconfirmed
var float vob_bull_upper = na, var float vob_bull_lower = na, var int vob_bull_origin = na, var float vob_bull_vol = na, var bool vob_bull_new = false
var float vob_bear_upper = na, var float vob_bear_lower = na, var int vob_bear_origin = na, var float vob_bear_vol = na, var bool vob_bear_new = false
float atr_hi = ta.highest(ATR_VAL, 200) * 2.0
if vob_bull_cross
    float cumVol = 0.0, int originBar = bar_index, float originLow = low
    for i = 1 to EMA_SLOW
        if low[i] <= originLow
            originLow := low[i], originBar := bar_index - i
        cumVol += volume[i]
    float src = math.min(open[bar_index - originBar], close[bar_index - originBar])
    src := (src - originLow) < atr_hi * 0.5 ? originLow + atr_hi * 0.5 : src
    vob_bull_upper := src, vob_bull_lower := originLow, vob_bull_origin := originBar, vob_bull_vol := cumVol, vob_bull_new := true
else
    vob_bull_new := false
if vob_bear_cross
    float cumVol = 0.0, int originBar = bar_index, float originHigh = high
    for i = 1 to EMA_SLOW
        if high[i] >= originHigh
            originHigh := high[i], originBar := bar_index - i
        cumVol += volume[i]
    float src = math.max(open[bar_index - originBar], close[bar_index - originBar])
    src := (originHigh - src) < atr_hi * 0.5 ? originHigh - atr_hi * 0.5 : src
    vob_bear_upper := originHigh, vob_bear_lower := src, vob_bear_origin := originBar, vob_bear_vol := cumVol, vob_bear_new := true
else
    vob_bear_new := false

// ══════════════════════════════════════════════════════════════════════════════
// SWING + ENGINE 2: ANISH + ENGINE 3: FLUX
// ══════════════════════════════════════════════════════════════════════════════
var int swingState = 0
var SwingPoint swHigh = SwingPoint.new(na, na), var SwingPoint swLow = SwingPoint.new(na, na)
float sw_upper = ta.highest(high, SWING_LEN), float sw_lower = ta.lowest(low, SWING_LEN)
swingState := high[SWING_LEN] > sw_upper ? 0 : low[SWING_LEN] < sw_lower ? 1 : swingState
if swingState == 0 and swingState[1] != 0
    swHigh := SwingPoint.new(high[SWING_LEN], bar_index[SWING_LEN])
if swingState == 1 and swingState[1] != 1
    swLow := SwingPoint.new(low[SWING_LEN], bar_index[SWING_LEN])

var float anish_bull_ob_upper = na, var float anish_bull_ob_lower = na, var int anish_bull_ob_idx = na
var float anish_bull_prev_upper = na, var float anish_bull_prev_lower = na, var int anish_bull_prev_idx = na, var bool anish_bull_new = false
var float anish_bear_ob_upper = na, var float anish_bear_ob_lower = na, var int anish_bear_ob_idx = na
var float anish_bear_prev_upper = na, var float anish_bear_prev_lower = na, var int anish_bear_prev_idx = na, var bool anish_bear_new = false

if close > swHigh.val and not swHigh.crossed and barstate.isconfirmed and not na(swHigh.val)
    swHigh.crossed := true
    float obLow = low[1], float obHigh = high[1], int obIdx = bar_index - 1
    int lookback = bar_index - swHigh.idx
    if lookback > 1
        for i = 1 to lookback - 1
            if open[i] > close[i] and low[i] <= obLow
                obLow := low[i], obHigh := high[i], obIdx := bar_index - i
    anish_bull_prev_upper := anish_bull_ob_upper, anish_bull_prev_lower := anish_bull_ob_lower, anish_bull_prev_idx := anish_bull_ob_idx
    anish_bull_ob_upper := obHigh, anish_bull_ob_lower := obLow, anish_bull_ob_idx := obIdx
    anish_bull_new := not na(anish_bull_prev_upper) and obIdx <= nz(anish_bull_prev_idx, 0) + EMA_SLOW and obHigh > nz(anish_bull_prev_lower, na) and obLow < nz(anish_bull_prev_upper, na)
else
    anish_bull_new := false

if close < swLow.val and not swLow.crossed and barstate.isconfirmed and not na(swLow.val)
    swLow.crossed := true
    float obLow = low[1], float obHigh = high[1], int obIdx = bar_index - 1
    int lookback = bar_index - swLow.idx
    if lookback > 1
        for i = 1 to lookback - 1
            if open[i] < close[i] and high[i] >= obHigh
                obHigh := high[i], obLow := low[i], obIdx := bar_index - i
    anish_bear_prev_upper := anish_bear_ob_upper, anish_bear_prev_lower := anish_bear_ob_lower, anish_bear_prev_idx := anish_bear_ob_idx
    anish_bear_ob_upper := obHigh, anish_bear_ob_lower := obLow, anish_bear_ob_idx := obIdx
    anish_bear_new := not na(anish_bear_prev_lower) and obIdx <= nz(anish_bear_prev_idx, 0) + EMA_SLOW and obLow < nz(anish_bear_prev_upper, na) and obHigh > nz(anish_bear_prev_lower, na)
else
    anish_bear_new := false

// FLUX
var float flux_bull_ob_top = na, var float flux_bull_ob_btm = na, var int flux_bull_ob_time = na
var bool flux_bull_ob_active = false, var bool flux_bull_pb_new = false, var int flux_bull_pb_idx = na
var float flux_bear_ob_top = na, var float flux_bear_ob_btm = na, var int flux_bear_ob_time = na
var bool flux_bear_ob_active = false, var bool flux_bear_pb_new = false, var int flux_bear_pb_idx = na
var SwingPoint flux_swH = SwingPoint.new(na, na), var SwingPoint flux_swL = SwingPoint.new(na, na)
if swingState == 0 and swingState[1] != 0
    flux_swH := SwingPoint.new(high[SWING_LEN], bar_index[SWING_LEN])
if swingState == 1 and swingState[1] != 1
    flux_swL := SwingPoint.new(low[SWING_LEN], bar_index[SWING_LEN])
if close > flux_swH.val and not flux_swH.crossed and barstate.isconfirmed and not na(flux_swH.val)
    flux_swH.crossed := true
    float boxBtm = math.min(open[1], close[1]), float boxTop = math.max(open[1], close[1]), int boxIdx = bar_index - 1
    int lookback = bar_index - flux_swH.idx
    if lookback > 1
        for i = 1 to lookback - 1
            if math.min(open[i], close[i]) < boxBtm
                boxBtm := math.min(open[i], close[i]), boxTop := math.max(open[i], close[i]), boxIdx := bar_index - i
    float obSize = math.abs(boxTop - boxBtm)
    if obSize <= ATR_VAL * ATR_MULT and obSize > ATR_VAL * ATR_MIN
        flux_bull_ob_top := boxTop, flux_bull_ob_btm := boxBtm, flux_bull_ob_time := boxIdx, flux_bull_ob_active := true
if close < flux_swL.val and not flux_swL.crossed and barstate.isconfirmed and not na(flux_swL.val)
    flux_swL.crossed := true
    float boxTop = math.max(open[1], close[1]), float boxBtm = math.min(open[1], close[1]), int boxIdx = bar_index - 1
    int lookback = bar_index - flux_swL.idx
    if lookback > 1
        for i = 1 to lookback - 1
            if math.max(open[i], close[i]) > boxTop
                boxTop := math.max(open[i], close[i]), boxBtm := math.min(open[i], close[i]), boxIdx := bar_index - i
    float obSize = math.abs(boxTop - boxBtm)
    if obSize <= ATR_VAL * ATR_MULT and obSize > ATR_VAL * ATR_MIN
        flux_bear_ob_top := boxTop, flux_bear_ob_btm := boxBtm, flux_bear_ob_time := boxIdx, flux_bear_ob_active := true
flux_bull_pb_new := false
if flux_bull_ob_active and barstate.isconfirmed
    if close < flux_bull_ob_btm
        flux_bull_ob_active := false
    else if low[1] < flux_bull_ob_top and low[1] > flux_bull_ob_btm and close > open and close > high[1]
        flux_bull_pb_new := true, flux_bull_pb_idx := flux_bull_ob_time
flux_bear_pb_new := false
if flux_bear_ob_active and barstate.isconfirmed
    if close > flux_bear_ob_top
        flux_bear_ob_active := false
    else if high[1] > flux_bear_ob_btm and high[1] < flux_bear_ob_top and close < open and close < low[1]
        flux_bear_pb_new := true, flux_bear_pb_idx := flux_bear_ob_time

// ══════════════════════════════════════════════════════════════════════════════
// CONFLUENCE → TNT 1.0 + ZONES + CHARGE + RETURN + DISPLACEMENT + NAPALM + CHARGE + SUDDEN CHANGE
// ══════════════════════════════════════════════════════════════════════════════
int CONF_WINDOW = EMA_SLOW * 2
var int vob_bull_conf_bar = 0, var int anish_bull_conf_bar = 0, var int flux_bull_conf_bar = 0
var int vob_bear_conf_bar = 0, var int anish_bear_conf_bar = 0, var int flux_bear_conf_bar = 0
var float vob_bull_u = na, var float vob_bull_l = na, var float vob_bear_u = na, var float vob_bear_l = na
if vob_bull_new
    vob_bull_conf_bar := bar_index, vob_bull_u := vob_bull_upper, vob_bull_l := vob_bull_lower
if vob_bear_new
    vob_bear_conf_bar := bar_index, vob_bear_u := vob_bear_upper, vob_bear_l := vob_bear_lower
if anish_bull_new
    anish_bull_conf_bar := bar_index
if anish_bear_new
    anish_bear_conf_bar := bar_index
if flux_bull_pb_new
    flux_bull_conf_bar := bar_index
if flux_bear_pb_new
    flux_bear_conf_bar := bar_index

f_temporal_ok(int a, int b, int c) =>
    int mn = math.min(a, math.min(b, c)), int mx = math.max(a, math.max(b, c))
    mx - mn <= CONF_WINDOW and mn > 0
f_zones_overlap(float u1, float l1, float u2, float l2) => not na(u1) and not na(u2) and u1 >= l2 and u2 >= l1
float volMedian = ta.median(volume, EMA_SLOW), float emaSlope = ema_fast - ema_fast[5], float rsiVal = ta.rsi(close, 14)
f_synergy_bull(float vV, float vU, float vL, float aU, float aL) => vV > volMedian * EMA_SLOW * 0.5 and emaSlope > 0 and rsiVal < 80 and (math.min(vU - vL, aU - aL) > 0 ? math.max(0, math.min(vU, aU) - math.max(vL, aL)) / math.min(vU - vL, aU - aL) > 0.3 : false)
f_synergy_bear(float vV, float vU, float vL, float aU, float aL) => vV > volMedian * EMA_SLOW * 0.5 and emaSlope < 0 and rsiVal > 20 and (math.min(vU - vL, aU - aL) > 0 ? math.max(0, math.min(vU, aU) - math.max(vL, aL)) / math.min(vU - vL, aU - aL) > 0.3 : false)

var tnt_zones = array.new<Zone>(0)
var int lastBullSigBar = 0, var int lastBearSigBar = 0
bool bullConf = f_temporal_ok(vob_bull_conf_bar, anish_bull_conf_bar, flux_bull_conf_bar) and f_zones_overlap(vob_bull_u, vob_bull_l, anish_bull_ob_upper, anish_bull_ob_lower)
bool bearConf = f_temporal_ok(vob_bear_conf_bar, anish_bear_conf_bar, flux_bear_conf_bar) and f_zones_overlap(vob_bear_u, vob_bear_l, anish_bear_ob_upper, anish_bear_ob_lower)
bool raw_bullTNT = bullConf and f_synergy_bull(nz(vob_bull_vol), nz(vob_bull_u), nz(vob_bull_l), nz(anish_bull_ob_upper), nz(anish_bull_ob_lower)) and barstate.isconfirmed and (bar_index - lastBullSigBar) > MIN_SIG_GAP
bool raw_bearTNT = bearConf and f_synergy_bear(nz(vob_bear_vol), nz(vob_bear_u), nz(vob_bear_l), nz(anish_bear_ob_upper), nz(anish_bear_ob_lower)) and barstate.isconfirmed and (bar_index - lastBearSigBar) > MIN_SIG_GAP

f_bull_level() => math.avg(math.min(nz(vob_bull_u, high), nz(anish_bull_ob_upper, high)), math.max(nz(vob_bull_l, low), nz(anish_bull_ob_lower, low)))
f_bear_level() => math.avg(math.min(nz(vob_bear_u, high), nz(anish_bear_ob_upper, high)), math.max(nz(vob_bear_l, low), nz(anish_bear_ob_lower, low)))
f_bull_origin() => int org = math.min(nz(vob_bull_origin, bar_index), math.min(nz(anish_bull_ob_idx, bar_index), nz(flux_bull_pb_idx, bar_index))), org > 0 ? org : bar_index
f_bear_origin() => int org = math.min(nz(vob_bear_origin, bar_index), math.min(nz(anish_bear_ob_idx, bar_index), nz(flux_bear_pb_idx, bar_index))), org > 0 ? org : bar_index
var charge_levels = array.new<ChargeLevel>(0)

color c_bullTNT = #089981, color c_bearTNT = #f23645
if raw_bullTNT
    lastBullSigBar := bar_index
    int origin = f_bull_origin()
    float oU = math.min(nz(vob_bull_u, high), nz(anish_bull_ob_upper, high)), float oL = math.max(nz(vob_bull_l, low), nz(anish_bull_ob_lower, low)), float lvl = math.avg(oU, oL)
    tnt_zones.push(Zone.new(origin, bar_index, oU, oL, lvl, nz(vob_bull_vol), true, true, false, line.new(origin, lvl, bar_index, lvl, color = c_bullTNT, width = 2), label.new(na, na, na)))
    charge_levels.push(ChargeLevel.new(lvl, true, bar_index))
if raw_bearTNT
    lastBearSigBar := bar_index
    int origin = f_bear_origin()
    float oU = math.min(nz(vob_bear_u, high), nz(anish_bear_ob_upper, high)), float oL = math.max(nz(vob_bear_l, low), nz(anish_bear_ob_lower, low)), float lvl = math.avg(oU, oL)
    tnt_zones.push(Zone.new(origin, bar_index, oU, oL, lvl, nz(vob_bear_vol), false, true, false, line.new(origin, lvl, bar_index, lvl, color = c_bearTNT, width = 2), label.new(na, na, na)))
    charge_levels.push(ChargeLevel.new(lvl, false, bar_index))

// Return
bool raw_retBullTNT = false, bool raw_retBearTNT = false
if tnt_zones.size() > 0
    for i = tnt_zones.size() - 1 to 0
        Zone z = tnt_zones.get(i)
        if z.isActive
            z.lvlLine.set_x2(bar_index)
            if z.isBull and close < z.lower
                z.isActive := false, z.lvlLine.set_style(line.style_dotted)
            if not z.isBull and close > z.upper
                z.isActive := false, z.lvlLine.set_style(line.style_dotted)
            if z.isActive and not z.returnFired and barstate.isconfirmed and bar_index > z.confirmIdx
                float zH = z.upper - z.lower
                if z.isBull
                    float retLvl = z.lower + zH * (RET_TNT_PCT / 100.0)
                    if low <= retLvl and close > z.lower
                        z.returnFired := true, raw_retBullTNT := true
                if not z.isBull
                    float retLvl = z.upper - zH * (RET_TNT_PCT / 100.0)
                    if high >= retLvl and close < z.upper
                        z.returnFired := true, raw_retBearTNT := true
    while tnt_zones.size() > maxZones
        Zone old = tnt_zones.shift()
        old.lvlLine.delete(), old.sigLabel.delete()

// Displacement
float disp_range = DISP_TYPE == "Open to Close" ? math.abs(open - close) : high - low
float disp_std = ta.stdev(disp_range, DISP_STD_LEN), float disp_threshold = disp_std * DISP_STD_X
bool isBullishFVG = low > high[2] and open[1] < close[1], bool isBearishFVG = high < low[2] and open[1] > close[1]
bool prevBarDisplaced = disp_range[1] > disp_threshold[1]
bool dispSignal = prevBarDisplaced and (isBullishFVG or isBearishFVG) and barstate.isconfirmed
bool dispBull = dispSignal and close[1] > open[1], bool dispBear = dispSignal and close[1] < open[1]

// Napalm + Charge
bool raw_napalmBull = false, bool raw_napalmBear = false
float pseudoBullLevel = na, float pseudoBearLevel = na
if barstate.isconfirmed and tnt_zones.size() > 0
    if dispBull
        for i = tnt_zones.size() - 1 to 0
            Zone z = tnt_zones.get(i)
            if not z.isBull and z.isActive and low[1] > z.level
                raw_napalmBull := true, pseudoBullLevel := z.level
                break
    if dispBear
        for i = tnt_zones.size() - 1 to 0
            Zone z = tnt_zones.get(i)
            if z.isBull and z.isActive and high[1] < z.level
                raw_napalmBear := true, pseudoBearLevel := z.level
                break
bool raw_bullCharge = false, bool raw_bearCharge = false
float chargeBullLevel = na, float chargeBearLevel = na
if barstate.isconfirmed and charge_levels.size() > 0
    if dispBull
        for i = charge_levels.size() - 1 to 0
            ChargeLevel cl = charge_levels.get(i)
            if not cl.isBull and not cl.violated and close[1] > cl.level
                cl.violated := true, raw_bullCharge := true, chargeBullLevel := cl.level
                charge_levels.push(ChargeLevel.new(low[1], true, bar_index))
                break
    if dispBear
        for i = charge_levels.size() - 1 to 0
            ChargeLevel cl = charge_levels.get(i)
            if cl.isBull and not cl.violated and close[1] < cl.level
                cl.violated := true, raw_bearCharge := true, chargeBearLevel := cl.level
                charge_levels.push(ChargeLevel.new(high[1], false, bar_index))
                break
while charge_levels.size() > 100
    charge_levels.shift()

// Super Charge + Super TNT (internal)
bool raw_superTNTBull = raw_bullTNT and raw_bearCharge, bool raw_superTNTBear = raw_bearTNT and raw_bullCharge

// Event log + TNT 2.0 (compact)
var bull_events = array.new<BullBearEvent>(0), var bear_events = array.new<BullBearEvent>(0)
bool effectiveBullCharge = raw_bullCharge and not raw_bearTNT, bool effectiveBearCharge = raw_bearCharge and not raw_bullTNT
bool anyBullEvent = raw_bullTNT or raw_napalmBull or effectiveBullCharge, bool anyBearEvent = raw_bearTNT or raw_napalmBear or effectiveBearCharge
if anyBullEvent
    int evtBar = raw_bullTNT ? bar_index : bar_index - 1
    float evtLvl = raw_bullTNT ? f_bull_level() : raw_napalmBull ? pseudoBullLevel : chargeBullLevel
    bull_events.push(BullBearEvent.new(evtBar, evtLvl, high, low, true, raw_bullTNT))
    bear_events.clear()
    while bull_events.size() > 20
        bull_events.shift()
if anyBearEvent and not anyBullEvent
    int evtBar = raw_bearTNT ? bar_index : bar_index - 1
    float evtLvl = raw_bearTNT ? f_bear_level() : raw_napalmBear ? pseudoBearLevel : chargeBearLevel
    bear_events.push(BullBearEvent.new(evtBar, evtLvl, high, low, false, raw_bearTNT))
    bull_events.clear()
    while bear_events.size() > 20
        bear_events.shift()

var super_zones = array.new<SuperZone>(0)
var int lastSuperBullBar = 0, var int lastSuperBearBar = 0
bool raw_bullTNT2 = false, bool raw_bearTNT2 = false
if bull_events.size() >= 2 and anyBullEvent and barstate.isconfirmed and (bar_index - lastSuperBullBar) > MIN_SIG_GAP
    raw_bullTNT2 := true, lastSuperBullBar := bar_index
if bear_events.size() >= 2 and anyBearEvent and not anyBullEvent and barstate.isconfirmed and (bar_index - lastSuperBearBar) > MIN_SIG_GAP
    raw_bearTNT2 := true, lastSuperBearBar := bar_index

// Return TNT 2.0 (compact)
bool raw_retBullTNT2 = false, bool raw_retBearTNT2 = false
if super_zones.size() > 0 and barstate.isconfirmed
    for i = super_zones.size() - 1 to 0
        SuperZone sz = super_zones.get(i)
        if sz.isActive and not sz.returnFired
            if sz.isBull and low <= sz.returnLevel and close > sz.zoneBtm
                sz.returnFired := true, raw_retBullTNT2 := true
            if not sz.isBull and high >= sz.returnLevel and close < sz.zoneTop
                sz.returnFired := true, raw_retBearTNT2 := true
    while super_zones.size() > maxSuperZones
        super_zones.shift()

// Sudden Change — Continuous only
var int sc_lastBullChargeBar = na, var int sc_lastBearChargeBar = na
var int sc_lastRetBullBar = na, var int sc_lastRetBearBar = na
var int sc_lastBullTNTBar = na, var int sc_lastBearTNTBar = na
var int sc_lastBullTNT2Bar = na, var int sc_lastBearTNT2Bar = na
bool raw_contBull = (raw_bullCharge and not na(sc_lastRetBullBar) and (bar_index - 1 - sc_lastRetBullBar) <= SUDDEN_PROX) or ((raw_bullTNT or raw_bullTNT2) and not na(sc_lastBullChargeBar) and (bar_index - sc_lastBullChargeBar) <= SUDDEN_PROX) or (raw_bullCharge and ((not na(sc_lastBullTNTBar) and (bar_index - 1 - sc_lastBullTNTBar) <= SUDDEN_PROX) or (not na(sc_lastBullTNT2Bar) and (bar_index - 1 - sc_lastBullTNT2Bar) <= SUDDEN_PROX)))
bool raw_contBear = (raw_bearCharge and not na(sc_lastRetBearBar) and (bar_index - 1 - sc_lastRetBearBar) <= SUDDEN_PROX) or ((raw_bearTNT or raw_bearTNT2) and not na(sc_lastBearChargeBar) and (bar_index - sc_lastBearChargeBar) <= SUDDEN_PROX) or (raw_bearCharge and ((not na(sc_lastBearTNTBar) and (bar_index - 1 - sc_lastBearTNTBar) <= SUDDEN_PROX) or (not na(sc_lastBearTNT2Bar) and (bar_index - 1 - sc_lastBearTNT2Bar) <= SUDDEN_PROX)))
if raw_bullCharge
    sc_lastBullChargeBar := bar_index - 1
if raw_bearCharge
    sc_lastBearChargeBar := bar_index - 1
if raw_retBullTNT or raw_retBullTNT2
    sc_lastRetBullBar := bar_index
if raw_retBearTNT or raw_retBearTNT2
    sc_lastRetBearBar := bar_index
if raw_bullTNT
    sc_lastBullTNTBar := bar_index
if raw_bearTNT
    sc_lastBearTNTBar := bar_index
if raw_bullTNT2
    sc_lastBullTNT2Bar := bar_index
if raw_bearTNT2
    sc_lastBearTNT2Bar := bar_index

// Consolidated detection
bool det_bullTNT = raw_bullTNT or raw_bullTNT2 or raw_superTNTBull
bool det_bearTNT = raw_bearTNT or raw_bearTNT2 or raw_superTNTBear
bool det_bullNapalm = raw_napalmBull or raw_bullCharge
bool det_bearNapalm = raw_napalmBear or raw_bearCharge
bool det_bullRetTNT = raw_retBullTNT or raw_retBullTNT2
bool det_bearRetTNT = raw_retBearTNT or raw_retBearTNT2
bool det_contBull = raw_contBull, bool det_contBear = raw_contBear

// ══════════════════════════════════════════════════════════════════════════════
// USE V5 ENGINE — RVOL + WMD + FAUNA + PBJ + DISPLACEMENT + CS1 + PUP
// ══════════════════════════════════════════════════════════════════════════════
bool u5_is_new_day = ta.change(_dayKey()) != 0
var int u5_sessionBarCount = 0, var int u5_lastCountedBar = -1
if u5_is_new_day and bar_index != u5_lastCountedBar
    u5_sessionBarCount := 1, u5_lastCountedBar := bar_index
else if bar_index != u5_lastCountedBar
    u5_sessionBarCount += 1, u5_lastCountedBar := bar_index

// RVOL Engine (decoupled Engine A)
int u5_bb_avgLen = 30, int u5_bb_smaLen = 20
float u5_bb_spike = math.abs(close - open)
float u5_bb_avgSpikeDenom = ta.sma(u5_bb_spike, u5_bb_avgLen)[1]
float u5_bb_normPrice = u5_bb_spike / nz(u5_bb_avgSpikeDenom, 1.0)
float u5_bb_avgVolDenom = ta.sma(volume, u5_bb_avgLen)[1]
float u5_bb_normVol = volume / nz(u5_bb_avgVolDenom, 1.0)
float u5_bb_diff = u5_bb_normPrice - u5_bb_normVol
float u5_bb_posDiff = u5_bb_diff > 0 ? u5_bb_diff : na
float u5_bb_smaDiff = ta.sma(u5_bb_posDiff, u5_bb_smaLen)
bool u5_bb_baseBull = (close > open) and (u5_bb_posDiff > u5_bb_smaDiff) and barstate.isconfirmed
bool u5_bb_baseBear = (close < open) and (u5_bb_posDiff > u5_bb_smaDiff) and barstate.isconfirmed
u5_bb_inRange(v, lo, hi) => v >= lo and v < hi

f_u5_1x(int _s) => _s<=10?38.0:_s<=15?33.0:_s<=30?28.0:_s<=45?23.0:_s<=60?20.0:_s<=120?18.0:_s<=300?13.0:_s<=360?13.0:_s<=540?11.0:_s<=600?10.0:_s<=660?9.0:_s<=900?7.5:_s<=1560?6.5:_s<=2340?6.0:_s<=3600?4.5:_s<=9000?4.0:_s<=11700?3.5:_s<259200?1.8:1.0
f_u5_gs(int _s) => _s<60?f_u5_1x(_s)*3.0:_s<=300?35.0:_s<=600?25.0:_s<=1500?20.0:_s<=3000?20.0:_s<=7260?10.0:_s<=11700?8.0:_s<=86400?7.5:_s<=259200?3.5:3.0
f_u5_saab(int _s) => f_u5_1x(_s) * 0.56
f_u5_wtc(int _s) => f_u5_1x(_s) * 2.0
f_u5_hiro(int _s) => _s<60?f_u5_1x(_s)*3.0:_s<=300?35.0:_s<=600?25.0:_s<=1500?25.0:_s<=3060?20.0:_s<=7260?10.0:_s<=11700?8.0:_s<=86400?7.5:_s<=259200?5:3.5
float u5_th_saab = f_u5_saab(u5_tfSec), float u5_th_1x = f_u5_1x(u5_tfSec), float u5_th_gs = f_u5_gs(u5_tfSec)
float u5_th_wtc = f_u5_wtc(u5_tfSec), float u5_th_hiro = f_u5_hiro(u5_tfSec)

bool u5_SAAB = u5_bb_baseBull and u5_bb_inRange(u5_bb_normPrice, u5_th_saab, u5_th_1x)
bool u5_Kratos = u5_bb_baseBear and u5_bb_inRange(u5_bb_normPrice, u5_th_saab, u5_th_1x)
bool u5_GrandSlam = u5_bb_baseBull and (u5_bb_normPrice >= u5_th_gs)
bool u5_MOAB = u5_bb_baseBear and (u5_bb_normPrice >= u5_th_gs)
bool u5_RVOL1xB = u5_bb_baseBull and u5_bb_inRange(u5_bb_normPrice, u5_th_1x, u5_th_gs) and not u5_GrandSlam
bool u5_RVOL1xR = u5_bb_baseBear and u5_bb_inRange(u5_bb_normPrice, u5_th_1x, u5_th_gs) and not u5_MOAB

// WMD Engine (decoupled Engine B — relativeVolume)
[u5_currentVol_reg, u5_pastVol_reg, _u5_unused] = _rvol(30, true)
float u5_relVolRatio = u5_currentVol_reg / u5_pastVol_reg
bool u5_WTC = barstate.isconfirmed and (u5_relVolRatio > u5_th_wtc) and (u5_relVolRatio <= u5_th_hiro)
bool u5_Hiroshima = barstate.isconfirmed and (u5_relVolRatio > u5_th_hiro)
bool u5_Pentagon = barstate.isconfirmed and (u5_relVolRatio >= u5_th_1x) and (u5_relVolRatio <= u5_th_wtc)
var float u5_maxVol = 0.0
bool u5_isNag = false
if bar_index == 0
    u5_maxVol := volume
else if volume > u5_maxVol
    u5_isNag := true, u5_maxVol := volume
bool u5_Nagasaki = u5_isNag
bool u5_WMD = u5_Pentagon or u5_WTC or u5_Hiroshima or u5_Nagasaki

// HV1000
bool u5_HV1000 = barstate.isconfirmed and volume >= ta.highest(volume, 1000)[1]

// FAUNA
float u5_f_atr = ATR14, float u5_f_avgVol = ta.sma(volume, 20), float u5_f_avgBody = ta.sma(math.abs(close - open), 20)
float u5_f_avgDelta = ta.sma(math.abs(close - close[1]), 10), float u5_f_trendMA = ta.sma(close, 50)
float u5_f_body = close - open, float u5_f_rng = high - low, float u5_f_bodySz = math.abs(u5_f_body)
float u5_f_bodyRat = u5_f_rng == 0 ? 0.0 : u5_f_bodySz / u5_f_rng
bool u5_f_up = u5_f_body > 0, bool u5_f_dn = u5_f_body < 0
float u5_f_prev_body = close[1] - open[1], float u5_f_prev_range = high[1] - low[1]
bool u5_MB_b = u5_f_up and u5_f_bodySz > 1.6 * u5_f_atr and u5_f_bodyRat > 0.70 and volume > 1.8 * u5_f_avgVol
bool u5_RE_b = u5_f_up and u5_f_rng > 2.2 * u5_f_atr and (high - close) < 0.15 * u5_f_rng and volume > 1.8 * u5_f_avgVol
bool u5_TA_b = u5_f_trendMA > u5_f_trendMA[1] and (close - close[1]) > 1.6 * u5_f_avgDelta and u5_f_up and volume > 1.8 * u5_f_avgVol
bool u5_GG_b = (open - close[1]) > 0.9 * u5_f_atr and u5_f_up and low > close[1] and volume > 1.8 * u5_f_avgVol
bool u5_StrongBear = close[1] < open[1] and math.abs(u5_f_prev_body) > 1.5 * u5_f_avgBody[1] and volume[1] > 1.5 * u5_f_avgVol[1]
bool u5_WeakBear = close[1] < open[1] and (u5_f_prev_range == 0 ? 0.0 : math.abs(u5_f_prev_body) / u5_f_prev_range) <= 0.2
bool u5_TR_b = u5_WeakBear and (u5_MB_b or u5_RE_b or u5_TA_b), bool u5_ES_b = u5_StrongBear and (u5_MB_b or u5_RE_b or u5_TA_b), bool u5_GDR_b = close[1] < open[1] and u5_GG_b
int u5_b_core = (u5_MB_b ? 1 : 0) + (u5_RE_b ? 1 : 0) + (u5_TA_b ? 1 : 0)
bool u5_b_gg_exc = u5_GG_b and not ((u5_b_core >= 2) and (u5_f_bodyRat >= 0.80))
bool u5_FAUNABull = barstate.isconfirmed and (u5_MB_b or u5_RE_b or u5_TA_b) and not (u5_TR_b or u5_ES_b or u5_GDR_b or u5_b_gg_exc)

bool u5_MB_r = u5_f_dn and u5_f_bodySz > 1.6 * u5_f_atr and u5_f_bodyRat > 0.70 and volume > 1.8 * u5_f_avgVol
bool u5_RE_r = u5_f_dn and u5_f_rng > 2.2 * u5_f_atr and (close - low) < 0.15 * u5_f_rng and volume > 1.8 * u5_f_avgVol
bool u5_TA_r = u5_f_trendMA < u5_f_trendMA[1] and (close[1] - close) > 1.6 * u5_f_avgDelta and u5_f_dn and volume > 1.8 * u5_f_avgVol
bool u5_GG_r = (close[1] - open) > 0.9 * u5_f_atr and u5_f_dn and high < close[1] and volume > 1.8 * u5_f_avgVol
bool u5_StrongBull = close[1] > open[1] and math.abs(u5_f_prev_body) > 1.5 * u5_f_avgBody[1] and volume[1] > 1.5 * u5_f_avgVol[1]
bool u5_WeakBull = close[1] > open[1] and (u5_f_prev_range == 0 ? 0.0 : math.abs(u5_f_prev_body) / u5_f_prev_range) <= 0.2
bool u5_TR_r = u5_WeakBull and (u5_MB_r or u5_RE_r or u5_TA_r), bool u5_ES_r = u5_StrongBull and (u5_MB_r or u5_RE_r or u5_TA_r), bool u5_GDR_r = close[1] > open[1] and u5_GG_r
int u5_s_core = (u5_MB_r ? 1 : 0) + (u5_RE_r ? 1 : 0) + (u5_TA_r ? 1 : 0)
bool u5_s_gg_exc = u5_GG_r and not ((u5_s_core >= 2) and (u5_f_bodyRat >= 0.80))
bool u5_FAUNABear = barstate.isconfirmed and (u5_MB_r or u5_RE_r or u5_TA_r) and not (u5_TR_r or u5_ES_r or u5_GDR_r or u5_s_gg_exc)

// Displacement (USE V5)
float u5_disp_rng = math.abs(open - close), float u5_disp_std = ta.stdev(u5_disp_rng, u5_std_len)
float u5_disp_thresh_min = u5_disp_std * u5_std_min
bool u5_disp_bullFVG = low > high[2] and close[1] > open[1], bool u5_disp_bearFVG = high < low[2] and close[1] < open[1]
bool u5_DISPBull = barstate.isconfirmed and (u5_disp_rng[1] > u5_disp_thresh_min[1]) and u5_disp_bullFVG
bool u5_DISPBear = barstate.isconfirmed and (u5_disp_rng[1] > u5_disp_thresh_min[1]) and u5_disp_bearFVG

// PUP / PPD
float u5_pp_redVol = close < open ? volume : 0.0, float u5_pp_greenVol = close > open ? volume : 0.0
float u5_pp_hiRedVol = ta.highest(u5_pp_redVol[1], 10), float u5_pp_hiGreenVol = ta.highest(u5_pp_greenVol[1], 10)
bool u5_PUP = barstate.isconfirmed and ((close - open) / open) * 100 > 3.0 and volume > u5_pp_hiRedVol
bool u5_PPD = barstate.isconfirmed and ((open - close) / open) * 100 > 3.0 and volume > u5_pp_hiGreenVol

// PBJ Engine (compact)
float u5_base_ma = ta.vwma(close, 5), float u5_st_atr = 2.0 * ta.atr(10)
float u5_dyn_long = u5_base_ma - u5_st_atr, float u5_dyn_short = u5_base_ma + u5_st_atr
var int u5_st_dir = 1
float u5_sig_line = 0.0, float u5_curr_long = 0.0
u5_curr_long := u5_base_ma > nz(u5_curr_long[1], u5_dyn_long) ? math.max(u5_dyn_long, nz(u5_curr_long[1])) : u5_dyn_long
float u5_curr_short = 0.0
u5_curr_short := u5_base_ma < nz(u5_curr_short[1], u5_dyn_short) ? math.min(u5_dyn_short, nz(u5_curr_short[1])) : u5_dyn_short
if nz(u5_st_dir[1]) == -1 and close > nz(u5_curr_short[1])
    u5_st_dir := 1
else if nz(u5_st_dir[1]) == 1 and close < nz(u5_curr_long[1])
    u5_st_dir := -1
u5_sig_line := u5_st_dir == 1 ? u5_curr_long : u5_curr_short
bool u5_buy_cross = ta.crossover(close, u5_sig_line), bool u5_sell_cross = ta.crossunder(close, u5_sig_line)
bool u5_bull_reaccel = u5_st_dir == 1 and u5_sig_line > nz(u5_sig_line[1]) and nz(u5_sig_line[1]) == nz(u5_sig_line[2])
bool u5_bear_reaccel = u5_st_dir == -1 and u5_sig_line < nz(u5_sig_line[1]) and nz(u5_sig_line[1]) == nz(u5_sig_line[2])
float u5_pbjMA = ta.ema(close, 20), float u5_pbjATR = ta.atr(14), float u5_zoo_avg_vol = ta.sma(volume, 20)
float u5_zoo_thresh = close == 0 ? 0 : (u5_pbjATR / close * 3.0)
bool u5_pbj_buy = low < u5_pbjMA * (1 - u5_zoo_thresh) and low == ta.lowest(low, 25) and volume > u5_zoo_avg_vol * 0.1
bool u5_pbj_sell = high > u5_pbjMA * (1 + u5_zoo_thresh) and high == ta.highest(high, 25) and volume > u5_zoo_avg_vol * 0.1

type u5_lvl
    float upper
    float lower
    float vol
    bool  approached
var u5_bull_lvls = array.new<u5_lvl>(), var u5_bear_lvls = array.new<u5_lvl>()
float u5_atr_pb = ATR14 * 2.0
f_u5_add_lvl(arr, up, lo, v) => if math.abs(up - lo) >= syminfo.mintick
    array.push(arr, u5_lvl.new(up, lo, v, false))
if u5_buy_cross
    float up = math.max(open[1], close[1]), float lo = low[1]
    if up - lo < u5_atr_pb * 0.5
        up := lo + u5_atr_pb * 0.5
    f_u5_add_lvl(u5_bull_lvls, up, lo, volume[1])
if u5_sell_cross
    float up = high[1], float lo = math.min(open[1], close[1])
    if up - lo < u5_atr_pb * 0.5
        lo := up - u5_atr_pb * 0.5
    f_u5_add_lvl(u5_bear_lvls, up, lo, volume[1])
if u5_bull_reaccel and not na(u5_sig_line)
    float p2 = math.min(open, close)
    f_u5_add_lvl(u5_bull_lvls, math.max(u5_sig_line, p2), math.min(u5_sig_line, p2), volume)
if u5_bear_reaccel and not na(u5_sig_line)
    float p2 = math.max(open, close)
    f_u5_add_lvl(u5_bear_lvls, math.max(u5_sig_line, p2), math.min(u5_sig_line, p2), volume)

var bool u5_wait_buy = false, var bool u5_wait_sell = false
var bool u5_wait_pbj_buy = false, var bool u5_wait_pbj_sell = false
f_u5_check_approach(arr, is_bull) =>
    bool approached = false
    if array.size(arr) > 0
        for i = array.size(arr) - 1 to 0
            if i >= array.size(arr)
                continue
            u5_lvl l = array.get(arr, i)
            if is_bull and close < l.lower
                array.remove(arr, i)
                continue
            if not is_bull and close > l.upper
                array.remove(arr, i)
                continue
            float ap = is_bull ? l.upper * 1.005 : l.lower * 0.995
            if is_bull
                if not l.approached and low <= ap
                    approached := true, l.approached := true
                else if l.approached and low > l.upper
                    l.approached := false
            else
                if not l.approached and high >= ap
                    approached := true, l.approached := true
                else if l.approached and high < l.lower
                    l.approached := false
    approached
if barstate.isconfirmed
    if f_u5_check_approach(u5_bull_lvls, true)
        u5_wait_buy := true
    if f_u5_check_approach(u5_bear_lvls, false)
        u5_wait_sell := true
if u5_pbj_buy
    u5_wait_pbj_buy := true
if u5_pbj_sell
    u5_wait_pbj_sell := true
while u5_bull_lvls.size() > 30
    u5_bull_lvls.shift()
while u5_bear_lvls.size() > 30
    u5_bear_lvls.shift()
bool u5_sig_pbj_buy = u5_buy_cross and u5_wait_pbj_buy, bool u5_sig_pb_buy = u5_buy_cross and u5_wait_buy
bool u5_sig_pbj_sell = u5_sell_cross and u5_wait_pbj_sell, bool u5_sig_pb_sell = u5_sell_cross and u5_wait_sell
if u5_sig_pb_buy
    u5_wait_buy := false
if u5_sig_pbj_buy
    u5_wait_pbj_buy := false
if u5_sig_pb_sell
    u5_wait_sell := false
if u5_sig_pbj_sell
    u5_wait_pbj_sell := false
bool u5_PBJBull = barstate.isconfirmed and u5_sig_pbj_buy
bool u5_PBJBear = barstate.isconfirmed and u5_sig_pbj_sell

// CS1 (FVG Combo — for CATALYST and enrichment)
type u5_fvg_s
    float mx
    float mn
    bool  bull
    int   t
    int   idx
    bool  hv
float u5_gz_v1 = volume[1], float u5_hv5k = ta.highest(volume, 5000)[1], float u5_hv252 = ta.highest(volume, 252)[1], float u5_hv63 = ta.highest(volume, 63)[1]
bool u5_gz_isHV = (u5_gz_v1 == u5_hv5k) or (u5_gz_v1 == u5_hv252) or (u5_gz_v1 == u5_hv63)
float u5_gz_thresh = ta.cum((high - low) / low) / bar_index
bool u5_gz_bFVG = low > high[2] and close[1] > high[2] and (low - high[2]) / high[2] > u5_gz_thresh
bool u5_gz_sFVG = high < low[2] and close[1] < low[2] and (low[2] - high) / high > u5_gz_thresh
var u5_gz_fvgs = array.new<u5_fvg_s>(0), var int u5_gz_lastT = 0
bool u5_gz_bullGZI = false, bool u5_gz_bearGZI = false, bool u5_gz_bullHV = false, bool u5_gz_bearHV = false
if barstate.isconfirmed and u5_gz_bFVG and time != u5_gz_lastT
    float mx = low, float mn = high[2]
    if u5_gz_isHV
        u5_gz_bullHV := true
    if u5_gz_fvgs.size() > 0
        for i = 0 to u5_gz_fvgs.size() - 1
            u5_fvg_s e = u5_gz_fvgs.get(i)
            if e.bull and bar_index - e.idx <= 7 and (math.max(e.mn, mn) < math.min(e.mx, mx) or (math.max(e.mn, mn) <= math.min(e.mx, mx) and e.hv and u5_gz_isHV))
                u5_gz_bullGZI := true
                break
    u5_gz_fvgs.unshift(u5_fvg_s.new(mx, mn, true, time, bar_index, u5_gz_isHV)), u5_gz_lastT := time
if barstate.isconfirmed and u5_gz_sFVG and time != u5_gz_lastT
    float mx = low[2], float mn = high
    if u5_gz_isHV
        u5_gz_bearHV := true
    if u5_gz_fvgs.size() > 0
        for i = 0 to u5_gz_fvgs.size() - 1
            u5_fvg_s e = u5_gz_fvgs.get(i)
            if not e.bull and bar_index - e.idx <= 7 and (math.max(e.mn, mn) < math.min(e.mx, mx) or (math.max(e.mn, mn) <= math.min(e.mx, mx) and e.hv and u5_gz_isHV))
                u5_gz_bearGZI := true
                break
    u5_gz_fvgs.unshift(u5_fvg_s.new(mx, mn, false, time, bar_index, u5_gz_isHV)), u5_gz_lastT := time
if u5_gz_fvgs.size() > 0
    for i = u5_gz_fvgs.size() - 1 to 0
        u5_fvg_s g = u5_gz_fvgs.get(i)
        if (g.bull and close < g.mn) or (not g.bull and close > g.mx)
            u5_gz_fvgs.remove(i)
if u5_gz_fvgs.size() > 50
    u5_gz_fvgs.pop()

float u5_cs_bp1 = high[1] - low[1] == 0 ? 0.0 : math.abs(close[1] - open[1]) / (high[1] - low[1])
bool u5_cs_vb = u5_cs_bp1 >= 0.85
bool u5_CS1_Bull = barstate.isconfirmed and u5_cs_vb and (u5_gz_bullHV or u5_gz_bullGZI) and (nz(u5_SAAB[1]) or nz(u5_RVOL1xB[1]) or nz(u5_GrandSlam[1]) or nz(u5_Pentagon[1]) or nz(u5_WTC[1]) or nz(u5_Hiroshima[1]) or nz(u5_Nagasaki[1]))
bool u5_CS1_Bear = barstate.isconfirmed and u5_cs_vb and (u5_gz_bearHV or u5_gz_bearGZI) and (nz(u5_Kratos[1]) or nz(u5_RVOL1xR[1]) or nz(u5_MOAB[1]) or nz(u5_Pentagon[1]) or nz(u5_WTC[1]) or nz(u5_Hiroshima[1]) or nz(u5_Nagasaki[1]))

// ══════════════════════════════════════════════════════════════════════════════
// DYNAMITE v2 — B2B Displacement + FAUNA on bar[1] AND bar[2] + bar[0] FVG
// ──────────────────────────────────────────────────────────────────────────────
// v2 changes (Verification Protocol Rule 1 + Rule 4 compliance):
//   • FVG check now MANDATORY (was missing — calling stdev range "displacement"
//     without FVG was indefensible per Rule 1).
//   • Displacement candles are bar[1] AND bar[2] (D2+ pattern). bar[0] is the
//     confirmation bar that gaps above/below bar[2] (FVG).
//   • FAUNA checked on bar[1] AND bar[2] (the displacement candles), NOT on
//     bar[0] which is the confirmation bar (Rule 4 / Example 9).
//   • Boolean true on bar[0]; visual plot offset = -1 (anchors to bar[1],
//     the most recent displacement candle).
// ══════════════════════════════════════════════════════════════════════════════
float dyn_disp = math.abs(open - close)
float dyn_std = ta.stdev(dyn_disp, 100)
// Both bar[1] AND bar[2] must exceed the range threshold (D2+ pattern)
bool dyn_disp_b1 = dyn_disp[1] > nz(dyn_std[1]) * dynStdMult
bool dyn_disp_b2 = dyn_disp[2] > nz(dyn_std[2]) * dynStdMult
// FVG confirmation on bar[0] vs bar[2] (gap that bar[1] body spans)
bool dyn_bullFVG = low > high[2] and close[1] > open[1]
bool dyn_bearFVG = high < low[2] and close[1] < open[1]
// Both displacement candles same color
bool dyn_bull_dir = close[1] > open[1] and close[2] > open[2]
bool dyn_bear_dir = close[1] < open[1] and close[2] < open[2]
// FAUNA on each displacement candle (NOT on confirmation bar[0])
bool dyn_fauna_bull = nz(u5_FAUNABull[1]) and nz(u5_FAUNABull[2])
bool dyn_fauna_bear = nz(u5_FAUNABear[1]) and nz(u5_FAUNABear[2])
bool det_dynamiteBull = barstate.isconfirmed and dyn_disp_b1 and dyn_disp_b2 and dyn_bull_dir and dyn_fauna_bull and dyn_bullFVG
bool det_dynamiteBear = barstate.isconfirmed and dyn_disp_b1 and dyn_disp_b2 and dyn_bear_dir and dyn_fauna_bear and dyn_bearFVG

// ══════════════════════════════════════════════════════════════════════════════
// HEAVY PENTAGON — 5 Heavy Combo classifications + WBUSH aggregate
// ──────────────────────────────────────────────────────────────────────────────
// Ports HEAVY PENTAGON's Stage-5 combo detections into TNT OD using existing
// USE V5 pipeline outputs (u5_*). Mirrors HEAVY PENTAGON exactly:
//   Group A (Pipeline 1, directional, excludes SAAB/Kratos):
//     groupA_Bull = u5_RVOL1xB OR u5_GrandSlam
//     groupA_Bear = u5_RVOL1xR OR u5_MOAB
//   Group B (Pipeline 2, neutral heavy):
//     groupB = u5_Pentagon OR u5_WTC OR u5_Hiroshima
//   Direction classifier: u5_DISPBull / u5_DISPBear / noDisp (no FVG-confirmed
//                         displacement either direction → neutral)
//
// 5 base combos × 3 directions = 15 sub-signals. WBUSH = any of the 15 fired.
// ══════════════════════════════════════════════════════════════════════════════
bool hp_groupA_Bull = u5_RVOL1xB or u5_GrandSlam
bool hp_groupA_Bear = u5_RVOL1xR or u5_MOAB
bool hp_groupB      = u5_Pentagon or u5_WTC or u5_Hiroshima

bool hp_baseYinYang   = (hp_groupA_Bull or hp_groupA_Bear) and hp_groupB
bool hp_baseNagasaki  = u5_Nagasaki and (hp_groupA_Bull or hp_groupA_Bear)
bool hp_baseNagasakiV = u5_Nagasaki and hp_groupB
bool hp_baseTrident   = u5_Nagasaki and (hp_groupA_Bull or hp_groupA_Bear) and hp_groupB
bool hp_baseNHx2      = (u5_Pentagon and u5_WTC) or (u5_Pentagon and u5_Hiroshima) or (u5_WTC and u5_Hiroshima)

bool hp_noDisp = (not u5_DISPBull) and (not u5_DISPBear)

// Heavy Yin-Yang (P1 + P2)
bool hp_HYYBull    = hp_baseYinYang and u5_DISPBull
bool hp_HYYBear    = hp_baseYinYang and u5_DISPBear
bool hp_HYYNeutral = hp_baseYinYang and hp_noDisp
// Heavy Nagasaki (P3 + P1)
bool hp_HNBull     = hp_baseNagasaki and u5_DISPBull
bool hp_HNBear     = hp_baseNagasaki and u5_DISPBear
bool hp_HNNeutral  = hp_baseNagasaki and hp_noDisp
// Heavy Nagasaki Vol (P3 + P2)
bool hp_HNVBull    = hp_baseNagasakiV and u5_DISPBull
bool hp_HNVBear    = hp_baseNagasakiV and u5_DISPBear
bool hp_HNVNeutral = hp_baseNagasakiV and hp_noDisp
// Heavy Trident (P1 + P2 + P3)
bool hp_HTBull     = hp_baseTrident and u5_DISPBull
bool hp_HTBear     = hp_baseTrident and u5_DISPBear
bool hp_HTNeutral  = hp_baseTrident and hp_noDisp
// Neutral Heavy x2 (P2 × 2)
bool hp_NHx2Bull    = hp_baseNHx2 and u5_DISPBull
bool hp_NHx2Bear    = hp_baseNHx2 and u5_DISPBear
bool hp_NHx2Neutral = hp_baseNHx2 and hp_noDisp

// WBUSH aggregates — any of the 15 fired
bool sig_WBUSH_Bull    = hp_HYYBull    or hp_HNBull    or hp_HNVBull    or hp_HTBull    or hp_NHx2Bull
bool sig_WBUSH_Bear    = hp_HYYBear    or hp_HNBear    or hp_HNVBear    or hp_HTBear    or hp_NHx2Bear
bool sig_WBUSH_Neutral = hp_HYYNeutral or hp_HNNeutral or hp_HNVNeutral or hp_HTNeutral or hp_NHx2Neutral

// ══════════════════════════════════════════════════════════════════════════════
// COMBO DETECTION — VISUAL BAR ALIGNED
// ══════════════════════════════════════════════════════════════════════════════
// RC NPM+TNT: NPM detects bar[0] (visual bar[0]-1), TNT at [1] = visual bar[0]-1 → same visual bar
bool sig_rcNTBull = det_bullNapalm and (det_bullTNT[1] == true) and en_rcNTBull
bool sig_rcNTBear = det_bearNapalm and (det_bearTNT[1] == true) and en_rcNTBear
// RC TNT+RET: both offset-0, same detection bar = same visual bar
bool det_rcTRBull = det_bullTNT and det_bullRetTNT, bool det_rcTRBear = det_bearTNT and det_bearRetTNT
// RC RET+NPM: NPM detects bar[0] (visual bar[0]-1), Return at [1] = visual bar[0]-1 → same visual bar
bool det_rcRNBull = det_bullNapalm and (det_bullRetTNT[1] == true), bool det_rcRNBear = det_bearNapalm and (det_bearRetTNT[1] == true)
// PBJ+NPM: NPM offset-1 (visual bar[0]-1), PBJ at [1] = visual bar[0]-1 → same visual bar
bool det_pnBull = det_bullNapalm and (u5_PBJBull[1] == true), bool det_pnBear = det_bearNapalm and (u5_PBJBear[1] == true)
// PBJ+TNT: both offset-0, same detection bar = same visual bar
bool det_ptBull = det_bullTNT and u5_PBJBull, bool det_ptBear = det_bearTNT and u5_PBJBear
// PBJ+RET: both offset-0, same detection bar = same visual bar
bool det_prBull = det_bullRetTNT and u5_PBJBull, bool det_prBear = det_bearRetTNT and u5_PBJBear

// FUSE: NPM→TNT→CONT sequential within proximity window
var int lastBullNPMVis = na, var int lastBullTNTVis = na, var int lastBearNPMVis = na, var int lastBearTNTVis = na
if det_bullNapalm
    lastBullNPMVis := bar_index - 1
if det_bullTNT
    lastBullTNTVis := bar_index
if det_bearNapalm
    lastBearNPMVis := bar_index - 1
if det_bearTNT
    lastBearTNTVis := bar_index
bool det_fuseBull = det_contBull and not na(lastBullTNTVis) and not na(lastBullNPMVis) and lastBullNPMVis < lastBullTNTVis and lastBullTNTVis < bar_index and (bar_index - lastBullTNTVis) <= SUDDEN_PROX and (lastBullTNTVis - lastBullNPMVis) <= SUDDEN_PROX and lastBullNPMVis >= nz(sessionFirstBarIdx, 0)
bool det_fuseBear = det_contBear and not na(lastBearTNTVis) and not na(lastBearNPMVis) and lastBearNPMVis < lastBearTNTVis and lastBearTNTVis < bar_index and (bar_index - lastBearTNTVis) <= SUDDEN_PROX and (lastBearTNTVis - lastBearNPMVis) <= SUDDEN_PROX and lastBearNPMVis >= nz(sessionFirstBarIdx, 0)

// IGNITE: (TNT or NPM) + Continuous same visual bar
bool ign_tc_bull = det_bullTNT and det_contBull, bool ign_tc_bear = det_bearTNT and det_contBear
// NPM offset-1 (visual bar[0]-1), CONT at [1] = visual bar[0]-1 → same visual bar
bool ign_nc_bull = det_bullNapalm and (det_contBull[1] == true), bool ign_nc_bear = det_bearNapalm and (det_contBear[1] == true)
bool det_igniteBull = ign_tc_bull or ign_nc_bull, bool det_igniteBear = ign_tc_bear or ign_nc_bear

// CATALYST: NPM + CS1 same visual bar
// FIX (v3.3 audit): Both NPM and CS1 have displacement+FVG in chain → both offset-1.
// Both detect on bar[0] (bar[1] displaced, bar[0] FVG). Same detection bar = same visual bar.
// Previous code had u5_CS1_Bull[1] which shifted CS1 visual to bar[0]-2 (WRONG).
bool det_catBull = det_bullNapalm and u5_CS1_Bull, bool det_catBear = det_bearNapalm and u5_CS1_Bear

// ══════════════════════════════════════════════════════════════════════════════
// SUPPRESSION
// ══════════════════════════════════════════════════════════════════════════════
bool supp_bullNPM = sig_rcNTBull or det_rcRNBull or det_pnBull
bool supp_bearNPM = sig_rcNTBear or det_rcRNBear or det_pnBear
bool supp_bullTNT = sig_rcNTBull or det_rcTRBull or det_ptBull
bool supp_bearTNT = sig_rcNTBear or det_rcTRBear or det_ptBear

// ══════════════════════════════════════════════════════════════════════════════
// TIER 2 ENRICHMENT GATE
// Enrichment for visual bar N (non-offset Tier 2 signals):
// Enrichment for visual bar N-1 (offset-1 Tier 2 signals):
// ══════════════════════════════════════════════════════════════════════════════
// v2: DYNAMITE moved from offset 0 → offset -1. det_dynamiteBull at bar[0] = visual bar 1.
//     Removed from enrichBull_N (was incorrectly treated as visual bar 0). enrichBull_N1 keeps it.
bool enrichBull_N = u5_RVOL1xB or u5_GrandSlam or u5_PUP or u5_CS1_Bull or u5_FAUNABull or u5_WMD or u5_HV1000
bool enrichBear_N = u5_RVOL1xR or u5_MOAB or u5_PPD or u5_CS1_Bear or u5_FAUNABear or u5_WMD or u5_HV1000
bool enrichBull_N1 = nz(u5_RVOL1xB[1]) or nz(u5_GrandSlam[1]) or nz(u5_PUP[1]) or nz(u5_CS1_Bull[1]) or nz(u5_FAUNABull[1]) or nz(u5_Pentagon[1]) or nz(u5_WTC[1]) or nz(u5_Hiroshima[1]) or nz(u5_Nagasaki[1]) or nz(u5_HV1000[1]) or det_dynamiteBull or nz(det_dynamiteBull[1])
bool enrichBear_N1 = nz(u5_RVOL1xR[1]) or nz(u5_MOAB[1]) or nz(u5_PPD[1]) or nz(u5_CS1_Bear[1]) or nz(u5_FAUNABear[1]) or nz(u5_Pentagon[1]) or nz(u5_WTC[1]) or nz(u5_Hiroshima[1]) or nz(u5_Nagasaki[1]) or nz(u5_HV1000[1]) or det_dynamiteBear or nz(det_dynamiteBear[1])

// ≤1min TF gate for PBJ+NPM and PBJ+TNT
bool pnGateBull = not isSubMinute or (nz(u5_RVOL1xB[1]) or nz(u5_GrandSlam[1]) or nz(u5_PUP[1]) or nz(u5_HV1000[1]) or nz(u5_Pentagon[1]) or nz(u5_WTC[1]) or nz(u5_Hiroshima[1]) or nz(u5_Nagasaki[1]))
bool pnGateBear = not isSubMinute or (nz(u5_RVOL1xR[1]) or nz(u5_MOAB[1]) or nz(u5_PPD[1]) or nz(u5_HV1000[1]) or nz(u5_Pentagon[1]) or nz(u5_WTC[1]) or nz(u5_Hiroshima[1]) or nz(u5_Nagasaki[1]))
bool ptGateBull = not isSubMinute or (u5_RVOL1xB or u5_GrandSlam or u5_PUP or u5_HV1000 or u5_WMD)
bool ptGateBear = not isSubMinute or (u5_RVOL1xR or u5_MOAB or u5_PPD or u5_HV1000 or u5_WMD)

// ══════════════════════════════════════════════════════════════════════════════
// FINAL PLOT BOOLEANS
// ══════════════════════════════════════════════════════════════════════════════
// TIER 1
bool p_b2bBull = det_bullNapalm and not supp_bullNPM and (det_bullNapalm[1] == true) and not na(sessionFirstBarIdx) and (bar_index - 2) >= sessionFirstBarIdx and en_b2bBull
bool p_b2bBear = det_bearNapalm and not supp_bearNPM and (det_bearNapalm[1] == true) and not na(sessionFirstBarIdx) and (bar_index - 2) >= sessionFirstBarIdx and en_b2bBear
bool p_pnBull = det_pnBull and pnGateBull and en_pnBull, bool p_pnBear = det_pnBear and pnGateBear and en_pnBear
bool p_ptBull = det_ptBull and ptGateBull and en_ptBull, bool p_ptBear = det_ptBear and ptGateBear and en_ptBear
// NPM+PBJ Unsup REMOVED — was identical boolean to PBJ+NPM (det_pnBull). See audit Finding 2.
bool p_fuseBull = det_fuseBull and en_fuseBull, bool p_fuseBear = det_fuseBear and en_fuseBear
bool p_catBull = det_catBull and en_catBull, bool p_catBear = det_catBear and en_catBear
bool p_ignBull = det_igniteBull and en_ignBull, bool p_ignBear = det_igniteBear and en_ignBear
bool p_dynBull = det_dynamiteBull and en_dynBull, bool p_dynBear = det_dynamiteBear and en_dynBear

// TIER 2 (hard-gated)
bool p_t2tntBull = det_bullTNT and not supp_bullTNT and enrichBull_N and en_t2tntBull
bool p_t2tntBear = det_bearTNT and not supp_bearTNT and enrichBear_N and en_t2tntBear
bool p_t2npmBull = det_bullNapalm and not supp_bullNPM and enrichBull_N1 and en_t2npmBull
bool p_t2npmBear = det_bearNapalm and not supp_bearNPM and enrichBear_N1 and en_t2npmBear
bool p_t2contBull = det_contBull and enrichBull_N and en_t2contBull
bool p_t2contBear = det_contBear and enrichBear_N and en_t2contBear
bool p_t2trBull = det_rcTRBull and enrichBull_N and en_t2trBull, bool p_t2trBear = det_rcTRBear and enrichBear_N and en_t2trBear
bool p_t2rnBull = det_rcRNBull and enrichBull_N1 and en_t2rnBull, bool p_t2rnBear = det_rcRNBear and enrichBear_N1 and en_t2rnBear
bool p_t2prBull = det_prBull and enrichBull_N and en_t2prBull, bool p_t2prBear = det_prBear and enrichBear_N and en_t2prBear

// ══════════════════════════════════════════════════════════════════════════════
// DENSITY — VISUAL-BAR-ALIGNED ROLLING WINDOW
// v2: Density now treated as offset -1 plot (chain touches Napalm w/ FVG → Rule 2)
//     denVisBull / denVisBear definitions unchanged — they already track visual bar 1.
//     Plotshape offset and alert gating updated below to use N1.
// ══════════════════════════════════════════════════════════════════════════════
bool denVisBull = nz(det_bullTNT[1]) or nz(det_contBull[1]) or nz(det_rcTRBull[1]) or nz(det_ptBull[1]) or nz(det_prBull[1]) or det_bullNapalm or sig_rcNTBull or det_rcRNBull or det_pnBull
bool denVisBear = nz(det_bearTNT[1]) or nz(det_contBear[1]) or nz(det_rcTRBear[1]) or nz(det_ptBear[1]) or nz(det_prBear[1]) or det_bearNapalm or sig_rcNTBear or det_rcRNBear or det_pnBear

var int d1br = -1, var int d1sr = -1, var bool d1ba = true, var bool d1sa = true
var int d2br = -1, var int d2sr = -1, var bool d2ba = true, var bool d2sa = true
var int d3br = -1, var int d3sr = -1, var bool d3ba = true, var bool d3sa = true
bool sig_d1b = false, bool sig_d1s = false, bool sig_d2b = false, bool sig_d2s = false, bool sig_d3b = false, bool sig_d3s = false
if isFirstBar
    d1br := bar_index - 1, d1sr := bar_index - 1, d1ba := true, d1sa := true
    d2br := bar_index - 1, d2sr := bar_index - 1, d2ba := true, d2sa := true
    d3br := bar_index - 1, d3sr := bar_index - 1, d3ba := true, d3sa := true
if barstate.isconfirmed
    int c1b = 0
    for i = 0 to den1_Y - 1
        if nz(denVisBull[i]) and (bar_index - 1 - i) >= nz(sessionFirstBarIdx, 0) and (bar_index - 1 - i) > d1br
            c1b += 1
    if c1b >= den1_X and d1ba
        sig_d1b := true, d1br := bar_index - 2, d1ba := false
    if c1b < den1_X
        d1ba := true
    int c1s = 0
    for i = 0 to den1_Y - 1
        if nz(denVisBear[i]) and (bar_index - 1 - i) >= nz(sessionFirstBarIdx, 0) and (bar_index - 1 - i) > d1sr
            c1s += 1
    if c1s >= den1_X and d1sa
        sig_d1s := true, d1sr := bar_index - 2, d1sa := false
    if c1s < den1_X
        d1sa := true
    int c2b = 0
    for i = 0 to den2_Y - 1
        if nz(denVisBull[i]) and (bar_index - 1 - i) >= nz(sessionFirstBarIdx, 0) and (bar_index - 1 - i) > d2br
            c2b += 1
    if c2b >= den2_X and d2ba
        sig_d2b := true, d2br := bar_index - 2, d2ba := false
    if c2b < den2_X
        d2ba := true
    int c2s = 0
    for i = 0 to den2_Y - 1
        if nz(denVisBear[i]) and (bar_index - 1 - i) >= nz(sessionFirstBarIdx, 0) and (bar_index - 1 - i) > d2sr
            c2s += 1
    if c2s >= den2_X and d2sa
        sig_d2s := true, d2sr := bar_index - 2, d2sa := false
    if c2s < den2_X
        d2sa := true
    int c3b = 0
    for i = 0 to den3_Y - 1
        if nz(denVisBull[i]) and (bar_index - 1 - i) >= nz(sessionFirstBarIdx, 0) and (bar_index - 1 - i) > d3br
            c3b += 1
    if c3b >= den3_X and d3ba
        sig_d3b := true, d3br := bar_index - 2, d3ba := false
    if c3b < den3_X
        d3ba := true
    int c3s = 0
    for i = 0 to den3_Y - 1
        if nz(denVisBear[i]) and (bar_index - 1 - i) >= nz(sessionFirstBarIdx, 0) and (bar_index - 1 - i) > d3sr
            c3s += 1
    if c3s >= den3_X and d3sa
        sig_d3s := true, d3sr := bar_index - 2, d3sa := false
    if c3s < den3_X
        d3sa := true
bool p_d1b = sig_d1b and en_d1b, bool p_d1s = sig_d1s and en_d1s
bool p_d2b = sig_d2b and en_d2b, bool p_d2s = sig_d2s and en_d2s
bool p_d3b = sig_d3b and en_d3b, bool p_d3s = sig_d3s and en_d3s

// ══════════════════════════════════════════════════════════════════════════════
// UU/UUU/UUUU + TNT INDICATOR ANY SIGNAL
// ══════════════════════════════════════════════════════════════════════════════
// Step 1: U-streak qualification (from USE V5)
bool u5_u_qual_bull = barstate.isconfirmed and u5_bb_baseBull and u5_bb_normPrice >= 0.5
bool u5_u_qual_bear = barstate.isconfirmed and u5_bb_baseBear and u5_bb_normPrice >= 0.5
var int u5_u_bull_streak = 0, var int u5_u_bear_streak = 0
var bool u5_u_bull_hasDay1 = false, var bool u5_u_bear_hasDay1 = false
if barstate.isconfirmed
    if u5_u_qual_bull
        u5_u_bull_streak += 1, u5_u_bull_hasDay1 := u5_u_bull_hasDay1 or u5_is_new_day
    else
        u5_u_bull_streak := 0, u5_u_bull_hasDay1 := false
    if u5_u_qual_bear
        u5_u_bear_streak += 1, u5_u_bear_hasDay1 := u5_u_bear_hasDay1 or u5_is_new_day
    else
        u5_u_bear_streak := 0, u5_u_bear_hasDay1 := false

// Step 2+3: Unrolled path qualification + TNT ANY check (constant indices only)
bool bp0_pbj = u5_PBJBull, bool bp0_disp = u5_DISPBull, bool bp0_fauna = u5_FAUNABull
bool bp0_saab = u5_SAAB or u5_RVOL1xB or u5_GrandSlam
bool bp1_pbj = bar_index >= 1 ? nz(u5_PBJBull[1]) : false
bool bp1_disp = bar_index >= 1 ? nz(u5_DISPBull[1]) : false
bool bp1_fauna = bar_index >= 1 ? nz(u5_FAUNABull[1]) : false
bool bp1_saab = bar_index >= 1 ? (nz(u5_SAAB[1]) or nz(u5_RVOL1xB[1]) or nz(u5_GrandSlam[1])) : false
bool bp2_pbj = bar_index >= 2 ? nz(u5_PBJBull[2]) : false
bool bp2_disp = bar_index >= 2 ? nz(u5_DISPBull[2]) : false
bool bp2_fauna = bar_index >= 2 ? nz(u5_FAUNABull[2]) : false
bool bp2_saab = bar_index >= 2 ? (nz(u5_SAAB[2]) or nz(u5_RVOL1xB[2]) or nz(u5_GrandSlam[2])) : false
bool bp3_pbj = bar_index >= 3 ? nz(u5_PBJBull[3]) : false
bool bp3_disp = bar_index >= 3 ? nz(u5_DISPBull[3]) : false
bool bp3_fauna = bar_index >= 3 ? nz(u5_FAUNABull[3]) : false
bool bp3_saab = bar_index >= 3 ? (nz(u5_SAAB[3]) or nz(u5_RVOL1xB[3]) or nz(u5_GrandSlam[3])) : false

bool sp0_pbj = u5_PBJBear, bool sp0_disp = u5_DISPBear, bool sp0_fauna = u5_FAUNABear
bool sp0_saab = u5_Kratos or u5_RVOL1xR or u5_MOAB
bool sp1_pbj = bar_index >= 1 ? nz(u5_PBJBear[1]) : false
bool sp1_disp = bar_index >= 1 ? nz(u5_DISPBear[1]) : false
bool sp1_fauna = bar_index >= 1 ? nz(u5_FAUNABear[1]) : false
bool sp1_saab = bar_index >= 1 ? (nz(u5_Kratos[1]) or nz(u5_RVOL1xR[1]) or nz(u5_MOAB[1])) : false
bool sp2_pbj = bar_index >= 2 ? nz(u5_PBJBear[2]) : false
bool sp2_disp = bar_index >= 2 ? nz(u5_DISPBear[2]) : false
bool sp2_fauna = bar_index >= 2 ? nz(u5_FAUNABear[2]) : false
bool sp2_saab = bar_index >= 2 ? (nz(u5_Kratos[2]) or nz(u5_RVOL1xR[2]) or nz(u5_MOAB[2])) : false
bool sp3_pbj = bar_index >= 3 ? nz(u5_PBJBear[3]) : false
bool sp3_disp = bar_index >= 3 ? nz(u5_DISPBear[3]) : false
bool sp3_fauna = bar_index >= 3 ? nz(u5_FAUNABear[3]) : false
bool sp3_saab = bar_index >= 3 ? (nz(u5_Kratos[3]) or nz(u5_RVOL1xR[3]) or nz(u5_MOAB[3])) : false

// === v2: separate per-bar qualifier breakdown for pG path (count distinct qualifier types) ===
// Bull side: SAAB / RVOL1x / GS as 3 separate qualifier types (mutually exclusive in TNT OD)
bool bp0_sa = u5_SAAB,    bool bp0_r1 = u5_RVOL1xB, bool bp0_gs = u5_GrandSlam
bool bp1_sa = bar_index >= 1 ? nz(u5_SAAB[1])      : false
bool bp1_r1 = bar_index >= 1 ? nz(u5_RVOL1xB[1])   : false
bool bp1_gs = bar_index >= 1 ? nz(u5_GrandSlam[1]) : false
bool bp2_sa = bar_index >= 2 ? nz(u5_SAAB[2])      : false
bool bp2_r1 = bar_index >= 2 ? nz(u5_RVOL1xB[2])   : false
bool bp2_gs = bar_index >= 2 ? nz(u5_GrandSlam[2]) : false
bool bp3_sa = bar_index >= 3 ? nz(u5_SAAB[3])      : false
bool bp3_r1 = bar_index >= 3 ? nz(u5_RVOL1xB[3])   : false
bool bp3_gs = bar_index >= 3 ? nz(u5_GrandSlam[3]) : false
// Bear side: Kratos / RVOL1xR / MOAB as 3 separate qualifier types
bool sp0_sa = u5_Kratos,  bool sp0_r1 = u5_RVOL1xR, bool sp0_gs = u5_MOAB
bool sp1_sa = bar_index >= 1 ? nz(u5_Kratos[1])    : false
bool sp1_r1 = bar_index >= 1 ? nz(u5_RVOL1xR[1])   : false
bool sp1_gs = bar_index >= 1 ? nz(u5_MOAB[1])      : false
bool sp2_sa = bar_index >= 2 ? nz(u5_Kratos[2])    : false
bool sp2_r1 = bar_index >= 2 ? nz(u5_RVOL1xR[2])   : false
bool sp2_gs = bar_index >= 2 ? nz(u5_MOAB[2])      : false
bool sp3_sa = bar_index >= 3 ? nz(u5_Kratos[3])    : false
bool sp3_r1 = bar_index >= 3 ? nz(u5_RVOL1xR[3])   : false
bool sp3_gs = bar_index >= 3 ? nz(u5_MOAB[3])      : false

// === v2: pG path — count distinct qualifier types in streak ===
// Bull streak2 (UU): bars 0-1 — 6 qualifier types: PBJ, DISP, FAUNA, SAAB, RVOL1x, GS
bool s2pbj_b   = bp0_pbj   or bp1_pbj
bool s2disp_b  = bp0_disp  or bp1_disp
bool s2fauna_b = bp0_fauna or bp1_fauna
bool s2sa_b    = bp0_sa    or bp1_sa
bool s2r1_b    = bp0_r1    or bp1_r1
bool s2gs_b    = bp0_gs    or bp1_gs
int  qc2_b     = (s2pbj_b?1:0) + (s2disp_b?1:0) + (s2fauna_b?1:0) + (s2sa_b?1:0) + (s2r1_b?1:0) + (s2gs_b?1:0)
bool pG_uu_b   = qc2_b >= 2
// Bull streak3 (UUU): bars 0-2
bool s3pbj_b   = s2pbj_b   or bp2_pbj
bool s3disp_b  = s2disp_b  or bp2_disp
bool s3fauna_b = s2fauna_b or bp2_fauna
bool s3sa_b    = s2sa_b    or bp2_sa
bool s3r1_b    = s2r1_b    or bp2_r1
bool s3gs_b    = s2gs_b    or bp2_gs
int  qc3_b     = (s3pbj_b?1:0) + (s3disp_b?1:0) + (s3fauna_b?1:0) + (s3sa_b?1:0) + (s3r1_b?1:0) + (s3gs_b?1:0)
bool pG_uuu_b  = qc3_b >= 3
// Bull streak4 (UUUU): bars 0-3
bool s4pbj_b   = s3pbj_b   or bp3_pbj
bool s4disp_b  = s3disp_b  or bp3_disp
bool s4fauna_b = s3fauna_b or bp3_fauna
bool s4sa_b    = s3sa_b    or bp3_sa
bool s4r1_b    = s3r1_b    or bp3_r1
bool s4gs_b    = s3gs_b    or bp3_gs
int  qc4_b     = (s4pbj_b?1:0) + (s4disp_b?1:0) + (s4fauna_b?1:0) + (s4sa_b?1:0) + (s4r1_b?1:0) + (s4gs_b?1:0)
bool pG_uuuu_b = qc4_b >= 4

// Bear streak2/3/4
bool s2pbj_s   = sp0_pbj   or sp1_pbj
bool s2disp_s  = sp0_disp  or sp1_disp
bool s2fauna_s = sp0_fauna or sp1_fauna
bool s2sa_s    = sp0_sa    or sp1_sa
bool s2r1_s    = sp0_r1    or sp1_r1
bool s2gs_s    = sp0_gs    or sp1_gs
int  qc2_s     = (s2pbj_s?1:0) + (s2disp_s?1:0) + (s2fauna_s?1:0) + (s2sa_s?1:0) + (s2r1_s?1:0) + (s2gs_s?1:0)
bool pG_uu_s   = qc2_s >= 2
bool s3pbj_s   = s2pbj_s   or sp2_pbj
bool s3disp_s  = s2disp_s  or sp2_disp
bool s3fauna_s = s2fauna_s or sp2_fauna
bool s3sa_s    = s2sa_s    or sp2_sa
bool s3r1_s    = s2r1_s    or sp2_r1
bool s3gs_s    = s2gs_s    or sp2_gs
int  qc3_s     = (s3pbj_s?1:0) + (s3disp_s?1:0) + (s3fauna_s?1:0) + (s3sa_s?1:0) + (s3r1_s?1:0) + (s3gs_s?1:0)
bool pG_uuu_s  = qc3_s >= 3
bool s4pbj_s   = s3pbj_s   or sp3_pbj
bool s4disp_s  = s3disp_s  or sp3_disp
bool s4fauna_s = s3fauna_s or sp3_fauna
bool s4sa_s    = s3sa_s    or sp3_sa
bool s4r1_s    = s3r1_s    or sp3_r1
bool s4gs_s    = s3gs_s    or sp3_gs
int  qc4_s     = (s4pbj_s?1:0) + (s4disp_s?1:0) + (s4fauna_s?1:0) + (s4sa_s?1:0) + (s4r1_s?1:0) + (s4gs_s?1:0)
bool pG_uuuu_s = qc4_s >= 4

f_path_agg(bool p0, bool d0, bool f0, bool s0, bool p1, bool d1, bool f1, bool s1, bool p2, bool d2, bool f2, bool s2, bool p3, bool d3, bool f3, bool s3, int streak, bool hasDay1) =>
    int _n = math.min(streak, 4)
    bool _hp = false, bool _hd = false, bool _hf = false
    bool _ad = true, bool _asd = true
    bool _dnp = false, bool _pnd = false
    bool df0 = d0 or f0
    if p0
        _hp := true
    if d0
        _hd := true
    if f0
        _hf := true
    if not d0
        _ad := false
    if not s0 or not df0
        _asd := false
    if df0 and not p0
        _dnp := true
    if p0 and not df0
        _pnd := true
    if _n >= 2
        bool df1 = d1 or f1
        if p1
            _hp := true
        if d1
            _hd := true
        if f1
            _hf := true
        if not d1
            _ad := false
        if not s1 or not df1
            _asd := false
        if df1 and not p1
            _dnp := true
        if p1 and not df1
            _pnd := true
    if _n >= 3
        bool df2 = d2 or f2
        if p2
            _hp := true
        if d2
            _hd := true
        if f2
            _hf := true
        if not d2
            _ad := false
        if not s2 or not df2
            _asd := false
        if df2 and not p2
            _dnp := true
        if p2 and not df2
            _pnd := true
    if _n >= 4
        bool df3 = d3 or f3
        if p3
            _hp := true
        if d3
            _hd := true
        if f3
            _hf := true
        if not d3
            _ad := false
        if not s3 or not df3
            _asd := false
        if df3 and not p3
            _dnp := true
        if p3 and not df3
            _pnd := true
    bool pA = hasDay1 and _hp
    bool pB = _ad
    bool pC = _asd
    bool pE = (_dnp and _hp) or (_pnd and (_hd or _hf))
    bool pF = streak >= 4 and (_hf or _hd) and _hp
    pA or pB or pC or pE or pF

// v2: u_pathBull/Bear now ORs existing path_agg (pA/pB/pC/pE/pF) with new pG (k-of-6 distinct qualifiers in streak).
bool u_pathBull2 = barstate.isconfirmed and u5_u_bull_streak == 2 and bar_index >= 1 and (f_path_agg(bp0_pbj, bp0_disp, bp0_fauna, bp0_saab, bp1_pbj, bp1_disp, bp1_fauna, bp1_saab, false, false, false, false, false, false, false, false, 2, u5_u_bull_hasDay1) or pG_uu_b)
bool u_pathBull3 = barstate.isconfirmed and u5_u_bull_streak == 3 and bar_index >= 2 and (f_path_agg(bp0_pbj, bp0_disp, bp0_fauna, bp0_saab, bp1_pbj, bp1_disp, bp1_fauna, bp1_saab, bp2_pbj, bp2_disp, bp2_fauna, bp2_saab, false, false, false, false, 3, u5_u_bull_hasDay1) or pG_uuu_b)
bool u_pathBull4 = barstate.isconfirmed and u5_u_bull_streak >= 4 and bar_index >= 3 and (f_path_agg(bp0_pbj, bp0_disp, bp0_fauna, bp0_saab, bp1_pbj, bp1_disp, bp1_fauna, bp1_saab, bp2_pbj, bp2_disp, bp2_fauna, bp2_saab, bp3_pbj, bp3_disp, bp3_fauna, bp3_saab, u5_u_bull_streak, u5_u_bull_hasDay1) or pG_uuuu_b)
bool u_pathBear2 = barstate.isconfirmed and u5_u_bear_streak == 2 and bar_index >= 1 and (f_path_agg(sp0_pbj, sp0_disp, sp0_fauna, sp0_saab, sp1_pbj, sp1_disp, sp1_fauna, sp1_saab, false, false, false, false, false, false, false, false, 2, u5_u_bear_hasDay1) or pG_uu_s)
bool u_pathBear3 = barstate.isconfirmed and u5_u_bear_streak == 3 and bar_index >= 2 and (f_path_agg(sp0_pbj, sp0_disp, sp0_fauna, sp0_saab, sp1_pbj, sp1_disp, sp1_fauna, sp1_saab, sp2_pbj, sp2_disp, sp2_fauna, sp2_saab, false, false, false, false, 3, u5_u_bear_hasDay1) or pG_uuu_s)
bool u_pathBear4 = barstate.isconfirmed and u5_u_bear_streak >= 4 and bar_index >= 3 and (f_path_agg(sp0_pbj, sp0_disp, sp0_fauna, sp0_saab, sp1_pbj, sp1_disp, sp1_fauna, sp1_saab, sp2_pbj, sp2_disp, sp2_fauna, sp2_saab, sp3_pbj, sp3_disp, sp3_fauna, sp3_saab, u5_u_bear_streak, u5_u_bear_hasDay1) or pG_uuuu_s)

// Step 3: TNT ANY check — pre-computed at global scope, constant indices
// Non-offset signals on bar N-0,1,2,3 + offset signals visual = detection[i-1]
// NPM+PBJ Unsup (det_npbBull/Bear) REMOVED — was identical to det_pnBull/Bear, OR-redundant
// v2: DYNAMITE moved offset 0 → -1; references shifted (visual 0 → none, 1 → bare, 2 → [1], 3 → [2]).
//     Density (sig_d1b/etc) ALSO moved offset 0 → -1; same shift applied.
bool tntAnyBull0 = det_bullTNT or det_contBull or det_rcTRBull or det_ptBull or det_prBull or det_fuseBull or det_igniteBull
bool tntAnyBull1 = bar_index >= 1 ? (nz(det_bullTNT[1]) or nz(det_contBull[1]) or nz(det_rcTRBull[1]) or nz(det_ptBull[1]) or nz(det_prBull[1]) or nz(det_fuseBull[1]) or nz(det_igniteBull[1]) or sig_d1b or sig_d2b or sig_d3b or det_dynamiteBull or det_bullNapalm or sig_rcNTBull or det_rcRNBull or det_pnBull or det_catBull) : false
bool tntAnyBull2 = bar_index >= 2 ? (nz(det_bullTNT[2]) or nz(det_contBull[2]) or nz(det_rcTRBull[2]) or nz(det_ptBull[2]) or nz(det_prBull[2]) or nz(det_fuseBull[2]) or nz(det_igniteBull[2]) or nz(sig_d1b[1]) or nz(sig_d2b[1]) or nz(sig_d3b[1]) or nz(det_dynamiteBull[1]) or nz(det_bullNapalm[1]) or nz(sig_rcNTBull[1]) or nz(det_rcRNBull[1]) or nz(det_pnBull[1]) or nz(det_catBull[1])) : false
bool tntAnyBull3 = bar_index >= 3 ? (nz(det_bullTNT[3]) or nz(det_contBull[3]) or nz(det_rcTRBull[3]) or nz(det_ptBull[3]) or nz(det_prBull[3]) or nz(det_fuseBull[3]) or nz(det_igniteBull[3]) or nz(sig_d1b[2]) or nz(sig_d2b[2]) or nz(sig_d3b[2]) or nz(det_dynamiteBull[2]) or nz(det_bullNapalm[2]) or nz(sig_rcNTBull[2]) or nz(det_rcRNBull[2]) or nz(det_pnBull[2]) or nz(det_catBull[2])) : false

bool tntAnyBear0 = det_bearTNT or det_contBear or det_rcTRBear or det_ptBear or det_prBear or det_fuseBear or det_igniteBear
bool tntAnyBear1 = bar_index >= 1 ? (nz(det_bearTNT[1]) or nz(det_contBear[1]) or nz(det_rcTRBear[1]) or nz(det_ptBear[1]) or nz(det_prBear[1]) or nz(det_fuseBear[1]) or nz(det_igniteBear[1]) or sig_d1s or sig_d2s or sig_d3s or det_dynamiteBear or det_bearNapalm or sig_rcNTBear or det_rcRNBear or det_pnBear or det_catBear) : false
bool tntAnyBear2 = bar_index >= 2 ? (nz(det_bearTNT[2]) or nz(det_contBear[2]) or nz(det_rcTRBear[2]) or nz(det_ptBear[2]) or nz(det_prBear[2]) or nz(det_fuseBear[2]) or nz(det_igniteBear[2]) or nz(sig_d1s[1]) or nz(sig_d2s[1]) or nz(sig_d3s[1]) or nz(det_dynamiteBear[1]) or nz(det_bearNapalm[1]) or nz(sig_rcNTBear[1]) or nz(det_rcRNBear[1]) or nz(det_pnBear[1]) or nz(det_catBear[1])) : false
bool tntAnyBear3 = bar_index >= 3 ? (nz(det_bearTNT[3]) or nz(det_contBear[3]) or nz(det_rcTRBear[3]) or nz(det_ptBear[3]) or nz(det_prBear[3]) or nz(det_fuseBear[3]) or nz(det_igniteBear[3]) or nz(sig_d1s[2]) or nz(sig_d2s[2]) or nz(sig_d3s[2]) or nz(det_dynamiteBear[2]) or nz(det_bearNapalm[2]) or nz(sig_rcNTBear[2]) or nz(det_rcRNBear[2]) or nz(det_pnBear[2]) or nz(det_catBear[2])) : false

bool hasTntBull2 = tntAnyBull0 or tntAnyBull1
bool hasTntBull3 = hasTntBull2 or tntAnyBull2
bool hasTntBull4 = hasTntBull3 or tntAnyBull3
bool hasTntBear2 = tntAnyBear0 or tntAnyBear1
bool hasTntBear3 = hasTntBear2 or tntAnyBear2
bool hasTntBear4 = hasTntBear3 or tntAnyBear3

bool p_uuBull   = u_pathBull2 and hasTntBull2 and en_uu_bull
bool p_uuBear   = u_pathBear2 and hasTntBear2 and en_uu_bear
bool p_uuuBull  = u_pathBull3 and hasTntBull3 and en_uuu_bull
bool p_uuuBear  = u_pathBear3 and hasTntBear3 and en_uuu_bear
bool p_uuuuBull = u_pathBull4 and hasTntBull4 and en_uuuu_bull
bool p_uuuuBear = u_pathBear4 and hasTntBear4 and en_uuuu_bear

// ══════════════════════════════════════════════════════════════════════════════
// WBUSH PLOTS — HEAVY PENTAGON state × TNTOD any plot
// ──────────────────────────────────────────────────────────────────────────────
// tntod_any_bull / tntod_any_bear — does ANY TNTOD detection plot fire on this
// bar (ignoring direction-mismatched ones)? Used by WBUSH bull/bear plots only.
// (Excludes WBUSH itself to avoid feedback.)
// ══════════════════════════════════════════════════════════════════════════════
bool tntod_any_bull = p_b2bBull or sig_rcNTBull or p_fuseBull or p_catBull or p_pnBull or p_ptBull or p_ignBull or p_dynBull or p_t2tntBull or p_t2npmBull or p_t2contBull or p_t2trBull or p_t2rnBull or p_t2prBull or p_d1b or p_d2b or p_d3b or p_uuBull or p_uuuBull or p_uuuuBull
bool tntod_any_bear = p_b2bBear or sig_rcNTBear or p_fuseBear or p_catBear or p_pnBear or p_ptBear or p_ignBear or p_dynBear or p_t2tntBear or p_t2npmBear or p_t2contBear or p_t2trBear or p_t2rnBear or p_t2prBear or p_d1s or p_d2s or p_d3s or p_uuBear or p_uuuBear or p_uuuuBear

bool p_wbushBull    = en_wbushBull    and sig_WBUSH_Bull    and tntod_any_bull
bool p_wbushBear    = en_wbushBear    and sig_WBUSH_Bear    and tntod_any_bear
bool p_wbushNeutral = en_wbushNeutral and sig_WBUSH_Neutral

// ══════════════════════════════════════════════════════════════════════════════
// NAGASAKI ALERT GATE (v2 — was always-on; now checkbox, default OFF)
// ══════════════════════════════════════════════════════════════════════════════
grpNag = "★ NAGASAKI ALERT ★"
bool en_nagAlert = input.bool(false, "✓ Fire NAGASAKI alert (default OFF — floods)", group = grpNag, tooltip = "When OFF, NAGASAKI does NOT fire its standalone alert. Default OFF because Nagasaki = all-time-high volume which fires often and floods the alert feed. Turn ON only when you want a 'note me on every all-time-high volume bar' workflow.")

// ══════════════════════════════════════════════════════════════════════════════
// FIRST BAR + GAP QUALIFIER + HV RANK — ALERT GATING
// ══════════════════════════════════════════════════════════════════════════════
bool isF_N = isFirstBar
bool isF_N1 = not na(sessionFirstBarIdx) and (bar_index - 1) == sessionFirstBarIdx

// Gap qualifier for bar[0] (offset-0 plot bar)
float gap_N  = math.abs(open - close[1])
float rng_N  = high - low
string firstStatus_N = not isF_N ? "NOT !!!" : (gap_N <= rng_N ? "FIRST !!!" : "FIRST XXX")

// Gap qualifier for bar[1] (offset-1 plot bar)
float gap_N1 = bar_index >= 1 ? math.abs(open[1] - close[2]) : 0.0
float rng_N1 = bar_index >= 1 ? (high[1] - low[1]) : 1.0
string firstStatus_N1 = not isF_N1 ? "NOT !!!" : (gap_N1 <= rng_N1 ? "FIRST !!!" : "FIRST XXX")

// HV rank: volume is highest in 50-bar lookback (covers all ranks 50 through 1000)
bool anyHVRank_N  = volume >= ta.highest(volume, 50)[1]
bool anyHVRank_N1 = bar_index >= 1 ? volume[1] >= ta.highest(volume, 50)[2] : false

// Master gate: First Bar Only requires first bar + HV rank on the PLOT bar
bool alertOK_N  = not masterFirstBar or (isF_N and anyHVRank_N)
bool alertOK_N1 = not masterFirstBar or (isF_N1 and anyHVRank_N1)

// Alert format: DIRECTION | FIRST_STATUS | NAME
f_alert(string dir, string firstSt, string name) => dir + " | " + firstSt + " | " + name

// ══════════════════════════════════════════════════════════════════════════════
// PLOTSHAPES — 42 total (limit: 64) ✓
