bool en_uuu_bull  = input.bool(true, "✓ UUU + TNT ANY Bull",  group = grpU, tooltip = "UUU = 3-bar bullish RVOL streak. Path pG requires ≥3 distinct qualifiers (or pA/pB/pC/pE). Plus any TNTOD bullish signal in window. Offset = -1.")
