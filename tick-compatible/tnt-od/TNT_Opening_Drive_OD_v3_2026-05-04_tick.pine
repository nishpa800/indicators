bool en_uuuu_bull = input.bool(true, "✓ UUUU + TNT ANY Bull", group = grpU, tooltip = "UUUU = 4+ bar bullish RVOL streak. Path pG requires ≥4 distinct qualifiers (or pA/pB/pC/pE/pF). Plus any TNTOD bullish signal in window. Offset = -1.")
