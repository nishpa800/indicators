bool en_b2bBear    = input.bool(true, "✓ B2B Napalm Bear",        group = grpT1, tooltip = "Back-to-back Napalm on consecutive visual bars, bearish. Two-bar confirmation. Offset = -1.")
bool en_rcNTBull   = input.bool(true, "✓ RC NPM+TNT Bull",        group = grpT1, tooltip = "Rare Combo: Napalm AND TNT fired on the same visual bar. Detects: displacement event coincides with structural confluence (VOB+ANISH+FLUX). Offset = -1.")
bool en_rcNTBear   = input.bool(true, "✓ RC NPM+TNT Bear",        group = grpT1, tooltip = "Rare Combo: bearish Napalm AND bearish TNT on the same visual bar. Offset = -1.")
bool en_fuseBull   = input.bool(true, "✓ FUSE Bull",              group = grpT1, tooltip = "Sequential cascade: Napalm → TNT → CONT all within proximity window (Sudden Change Max Bar Distance). Detects escalating event cascade in tight temporal cluster. Offset = 0.")
bool en_fuseBear   = input.bool(true, "✓ FUSE Bear",              group = grpT1, tooltip = "Bearish sequential cascade: NPM → TNT → CONT in tight window. Offset = 0.")
bool en_catBull    = input.bool(true, "✓ CATALYST Bull",          group = grpT1, tooltip = "Napalm AND CS1 (FVG Combo) on the same visual bar. Detects displacement event backed by FVG clustering or HV-FVG structure. Both have displacement+FVG in chain → Offset = -1.")
bool en_catBear    = input.bool(true, "✓ CATALYST Bear",          group = grpT1, tooltip = "Bearish Napalm AND bearish CS1 same visual bar. Offset = -1.")
bool en_pnBull     = input.bool(true, "✓ PBJ+NPM Bull",           group = grpT1, tooltip = "PBJ supertrend reversal AND Napalm on same visual bar. Detects supertrend reversal coinciding with zone displacement. Offset = -1 (NPM has displacement+FVG).")
bool en_pnBear     = input.bool(true, "✓ PBJ+NPM Bear",           group = grpT1, tooltip = "PBJ bearish reversal AND bearish Napalm same visual bar. Offset = -1.")
bool en_ptBull     = input.bool(true, "✓ PBJ+TNT Bull",           group = grpT1, tooltip = "PBJ supertrend reversal AND TNT on same visual bar. Detects supertrend reversal coinciding with structural breakout. No displacement+FVG in chain → Offset = 0.")
