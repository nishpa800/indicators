bool en_ignBear    = input.bool(true, "✓ IGNITE Bear",            group = grpT1, tooltip = "Bearish version of IGNITE. Mixed offset (T+C = 0, N+C = -1).")
bool en_dynBull    = input.bool(true, "✓ DYNAMITE Bull",          group = grpT1, tooltip = "B2B displacement (bar[1] AND bar[2] both exceed stdev range AND same bullish color) + FAUNA on bar[1] AND bar[2] + bar[0] confirms bullish FVG. v2: FVG check now mandatory. Offset = -1.")
bool en_dynBear    = input.bool(true, "✓ DYNAMITE Bear",          group = grpT1, tooltip = "B2B bearish displacement on bar[1] AND bar[2] + FAUNA bearish on each + bar[0] confirms bearish FVG. v2: FVG mandatory. Offset = -1.")

