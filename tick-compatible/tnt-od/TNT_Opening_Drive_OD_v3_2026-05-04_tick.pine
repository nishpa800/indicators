plotshape(p_t2rnBear,   "RC RET+NPM Enriched Bear", shape.flag, location.abovebar, #bf360c, size=size.small, text="RC R+N ENR",    textcolor=#bf360c, display=display.pane, offset=-1)
// TIER 2 — offset 0
plotshape(p_t2prBull,   "PBJ+RET Enriched Bull", shape.diamond, location.belowbar, #81c784, size=size.small, text="PBJ+RET ENR",   textcolor=#81c784, display=display.pane)
