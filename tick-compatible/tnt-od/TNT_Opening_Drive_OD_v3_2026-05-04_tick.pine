// Nagasaki standalone — v2: now CHECKBOX-GATED (default OFF). When OFF, no alert fires.
// Stays AGGREGATOR BYPASSER (always its own line, never bundled).
if u5_Nagasaki and en_nagAlert
    string nagDir = close > open ? "BULL" : "BEAR"
    string nagFirst = not isFirstBar ? "NOT !!!" : (math.abs(open - close[1]) <= (high - low) ? "FIRST !!!" : "FIRST XXX")
    alert(f_alert(nagDir, nagFirst, "NAGASAKI ALL-TIME HIGH VOLUME"), alert.freq_once_per_bar_close)

