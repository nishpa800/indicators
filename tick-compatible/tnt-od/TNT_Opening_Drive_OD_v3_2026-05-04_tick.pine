plotshape(p_t2npmBear,  "NPM Enriched Bear",     shape.arrowdown,    location.abovebar, #ff9800, size=size.small, text="NPM ENR",       textcolor=#ff9800, display=display.pane, offset=-1)
// TIER 2 — offset 0
plotshape(p_t2contBull, "CONT Enriched Bull",    shape.triangleup,   location.belowbar, #00acc1, size=size.small, text="CONT ENR",      textcolor=#00acc1, display=display.pane)
plotshape(p_t2contBear, "CONT Enriched Bear",    shape.triangledown, location.abovebar, #f06292, size=size.small, text="CONT ENR",      textcolor=#f06292, display=display.pane)
// TIER 2 — offset 0
plotshape(p_t2trBull,   "RC TNT+RET Enriched Bull", shape.flag, location.belowbar, #fdd835, size=size.small, text="RC T+R ENR",    textcolor=#fdd835, display=display.pane)
plotshape(p_t2trBear,   "RC TNT+RET Enriched Bear", shape.flag, location.abovebar, #e65100, size=size.small, text="RC T+R ENR",    textcolor=#e65100, display=display.pane)
// TIER 2 — offset -1
