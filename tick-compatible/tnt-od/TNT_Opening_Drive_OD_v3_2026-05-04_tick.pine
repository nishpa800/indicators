// TIER 1 — offset -1
plotshape(p_b2bBull,  "B2B Napalm Bull",       shape.diamond,   location.bottom,   #1de9b6, size=size.normal, text="B2B NAPALM",    textcolor=#1de9b6, display=display.pane, offset=-1)
plotshape(p_b2bBear,  "B2B Napalm Bear",       shape.diamond,   location.top,      #ff1744, size=size.normal, text="B2B NAPALM",    textcolor=#ff1744, display=display.pane, offset=-1)
plotshape(sig_rcNTBull,"RC NPM+TNT Bull",      shape.flag,      location.belowbar, #ffeb3b, size=size.normal, text="RC NPM+TNT",    textcolor=#ffeb3b, display=display.pane, offset=-1)
plotshape(sig_rcNTBear,"RC NPM+TNT Bear",      shape.flag,      location.abovebar, #ff6f00, size=size.normal, text="RC NPM+TNT",    textcolor=#ff6f00, display=display.pane, offset=-1)
