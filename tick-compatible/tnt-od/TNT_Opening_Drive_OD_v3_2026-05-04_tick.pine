plotshape(p_ignBear and ign_tc_bear, "IGNITE TNT+CONT Bear", shape.labeldown, location.abovebar, #d500f9, size=size.normal, text="IGNITE T+C",    textcolor=color.white, display=display.pane)
plotshape(p_ignBull and ign_nc_bull, "IGNITE NPM+CONT Bull", shape.labelup, location.belowbar, #76ff03, size=size.normal, text="IGNITE N+C",    textcolor=color.white, display=display.pane, offset=-1)
plotshape(p_ignBear and ign_nc_bear, "IGNITE NPM+CONT Bear", shape.labeldown, location.abovebar, #d500f9, size=size.normal, text="IGNITE N+C",    textcolor=color.white, display=display.pane, offset=-1)
// TIER 1 — offset -1 (v2: DYNAMITE chain now contains FVG → Rule 2 → offset -1)
plotshape(p_dynBull, "DYNAMITE Bull",          shape.labelup,   location.belowbar, #FF0000, size=size.large,  text="★ DYNAMITE",    textcolor=color.white, display=display.pane, offset=-1)
plotshape(p_dynBear, "DYNAMITE Bear",          shape.labeldown, location.abovebar, #FF0000, size=size.large,  text="★ DYNAMITE",    textcolor=color.white, display=display.pane, offset=-1)

