// ============================================================================
// PIPELINE D: TRIPLE CO-OCCURRENCE — full tooltips
// ============================================================================
grp_co = "★★★ PIPELINE D: TRIPLE CO-OCCURRENCE ★★★"
bool co_en_bullPBJ = input.bool(true, "Bull PBJ co-occurrence", group=grp_co, inline="co1", tooltip="TRIPLE AND: HV+D Bull (Pipeline A) + PBJ Bull (Pipeline B) + ANY USE Bull detection (Pipeline C) — all describing bar N-1. Three independent pipelines confirm the SAME candle.")
bool co_en_bullPB  = input.bool(true, "Bull PB co-occurrence",  group=grp_co, inline="co1", tooltip="Same but with PB Bull (Zoo VWMA pullback) instead of PBJ.")
bool co_en_bearPBJ = input.bool(true, "Bear PBJ co-occurrence", group=grp_co, inline="co2", tooltip="Bear mirror — HV+D Bear + PBJ Bear + ANY USE Bear detection on N-1.")
bool co_en_bearPB  = input.bool(true, "Bear PB co-occurrence",  group=grp_co, inline="co2", tooltip="Bear mirror with PB.")
bool co_en_bull_any= input.bool(true, "UC+HV+D Bull (any)",     group=grp_co, inline="co3", tooltip="Master OR — fires for ANY of {UC+HVD alone, UC+HVD+PB, UC+HVD+PBJ}. PB/PBJ NOT required. UC = any USE bull on N-1.")
bool co_en_bear_any= input.bool(true, "UC+HV+D Bear (any)",     group=grp_co, inline="co3", tooltip="Bear mirror.")

bool co_bull_pbj = hvd_fire_bull and co_en_bullPBJ and nz(sigBullPBJ[1]) and nz(use_any_bull[1])
bool co_bull_pb  = hvd_fire_bull and co_en_bullPB  and nz(sigBullPB[1])  and nz(use_any_bull[1])
bool co_bear_pbj = hvd_fire_bear and co_en_bearPBJ and nz(sigBearPBJ[1]) and nz(use_any_bear[1])
bool co_bear_pb  = hvd_fire_bear and co_en_bearPB  and nz(sigBearPB[1])  and nz(use_any_bear[1])
bool co_bull_any = co_en_bull_any and uc_hvd_bull_any
bool co_bear_any = co_en_bear_any and uc_hvd_bear_any
bool co_any = co_bull_pbj or co_bull_pb or co_bear_pbj or co_bear_pb

plotshape(co_bull_pbj and masterGate, "CO: HV+D+PBJ+USE Bull", shape.diamond,      location.top, color.new(#FFD700, 0), text="CO\nPBJ", textcolor=color.white, size=size.huge, offset=-1)
plotshape(co_bull_pb and masterGate,  "CO: HV+D+PB+USE Bull",  shape.triangleup,   location.top, color.new(#00E5FF, 0), text="CO\nPB",  textcolor=color.white, size=size.large, offset=-1)
plotshape(co_bear_pbj and masterGate, "CO: HV+D+PBJ+USE Bear", shape.diamond,      location.belowbar, color.new(#FF1744, 0), text="CO\nPBJ", textcolor=color.white, size=size.huge, offset=-1)
plotshape(co_bear_pb and masterGate,  "CO: HV+D+PB+USE Bear",  shape.triangledown, location.belowbar, color.new(#FF6D00, 0), text="CO\nPB",  textcolor=color.white, size=size.large, offset=-1)

// ============================================================================
// BACK-TO-BACK HV+D — full tooltips
// ============================================================================
grp_b2b = "★★★ BACK-TO-BACK HV+D ★★★"
bool b2b_en_bull      = input.bool(true, "B2B HV+D Bull",         group=grp_b2b, inline="b1", tooltip="Two consecutive HV+D Bull candles (N-1 AND N-2 are BOTH HV+D Bull). Mutually exclusive — this plot fires ONLY when neither PBJ nor PB was present on either candle.")
bool b2b_en_bear      = input.bool(true, "B2B HV+D Bear",         group=grp_b2b, inline="b1", tooltip="Bear mirror — no PBJ, no PB on either candle.")
bool b2b_en_bull_pbj  = input.bool(true, "B2B HV+D+PBJ Bull",     group=grp_b2b, inline="b2", tooltip="Two consecutive HV+D Bull candles AND PBJ Bull fired on EITHER of those two candles (N-1 or N-2).")
bool b2b_en_bear_pbj  = input.bool(true, "B2B HV+D+PBJ Bear",     group=grp_b2b, inline="b2", tooltip="Bear mirror.")
bool b2b_en_bull_pb   = input.bool(true, "B2B HV+D+PB Bull",      group=grp_b2b, inline="b3", tooltip="Two consecutive HV+D Bull candles AND PB Bull (not PBJ) on either. Suppressed if PBJ variant also true.")
bool b2b_en_bear_pb   = input.bool(true, "B2B HV+D+PB Bear",      group=grp_b2b, inline="b3", tooltip="Bear mirror.")
bool b2b_en_uc_bull   = input.bool(true, "UC+B2B HV+D Bull",      group=grp_b2b, inline="b4", tooltip="UC + B2B HV+D Bull — ANY of {B2B alone, B2B+PB, B2B+PBJ} AND any USE bull detection on N-1. Master OR.")
bool b2b_en_uc_bear   = input.bool(true, "UC+B2B HV+D Bear",      group=grp_b2b, inline="b4", tooltip="Bear mirror.")

bool b2b_bull_raw = hvd_fire_bull and nz(hvd_fire_bull[1])
bool b2b_bear_raw = hvd_fire_bear and nz(hvd_fire_bear[1])
bool b2b_bull_pbj = b2b_bull_raw and (nz(sigBullPBJ[1]) or nz(sigBullPBJ[2]))
bool b2b_bear_pbj = b2b_bear_raw and (nz(sigBearPBJ[1]) or nz(sigBearPBJ[2]))
bool b2b_bull_pb  = b2b_bull_raw and (nz(sigBullPB[1]) or nz(sigBullPB[2])) and not b2b_bull_pbj
bool b2b_bear_pb  = b2b_bear_raw and (nz(sigBearPB[1]) or nz(sigBearPB[2])) and not b2b_bear_pbj
bool b2b_bull_nopb = b2b_bull_raw and not b2b_bull_pbj and not b2b_bull_pb
bool b2b_bear_nopb = b2b_bear_raw and not b2b_bear_pbj and not b2b_bear_pb
bool uc_b2b_bull = b2b_bull_raw and nz(use_any_bull[1])
bool uc_b2b_bear = b2b_bear_raw and nz(use_any_bear[1])

plotshape(b2b_en_bull     and b2b_bull_nopb and masterGate, "B2B HV+D Bull",      shape.flag, location.belowbar, color.new(#00E676, 0), text="B2B",         textcolor=color.white, size=size.large, offset=-1)
plotshape(b2b_en_bull_pbj and b2b_bull_pbj and masterGate,  "B2B HV+D+PBJ Bull",  shape.flag, location.bottom,   color.new(#FFD700, 0), text="B2B\nPBJ",    textcolor=color.white, size=size.huge,  offset=-1)
plotshape(b2b_en_bull_pb  and b2b_bull_pb and masterGate,   "B2B HV+D+PB Bull",   shape.flag, location.bottom,   color.new(#00E5FF, 0), text="B2B\nPB",     textcolor=color.white, size=size.large, offset=-1)
plotshape(b2b_en_bear     and b2b_bear_nopb and masterGate, "B2B HV+D Bear",      shape.flag, location.bottom,   color.new(#FF1744, 0), text="B2B",         textcolor=color.white, size=size.large, offset=-1)
plotshape(b2b_en_bear_pbj and b2b_bear_pbj and masterGate,  "B2B HV+D+PBJ Bear",  shape.flag, location.abovebar, color.new(#FF1744, 0), text="B2B\nPBJ",    textcolor=color.white, size=size.huge,  offset=-1)
plotshape(b2b_en_bear_pb  and b2b_bear_pb and masterGate,   "B2B HV+D+PB Bear",   shape.flag, location.bottom,   color.new(#FF6D00, 0), text="B2B\nPB",     textcolor=color.white, size=size.large, offset=-1)
plotshape(b2b_en_uc_bull and uc_b2b_bull and masterGate, "UC+B2B HV+D Bull", shape.square, location.belowbar, color.new(#FFD700, 0), text="UC\nB2B", textcolor=color.black, size=size.large, offset=-1)
plotshape(b2b_en_uc_bear and uc_b2b_bear and masterGate, "UC+B2B HV+D Bear", shape.square, location.abovebar, color.new(#FF1744, 0), text="UC\nB2B", textcolor=color.white, size=size.large, offset=-1)

if b2b_en_bull and b2b_bull_nopb and masterGate
    alert("BULL | " + _FIRST + " | B2B-HVD", alert.freq_once_per_bar_close)
if b2b_en_bear and b2b_bear_nopb and masterGate
    alert("BEAR | " + _FIRST + " | B2B-HVD", alert.freq_once_per_bar_close)
if b2b_en_bull_pbj and b2b_bull_pbj and masterGate
    alert("BULL | " + _FIRST + " | B2B-HVD+PBJ", alert.freq_once_per_bar_close)
if b2b_en_bear_pbj and b2b_bear_pbj and masterGate
    alert("BEAR | " + _FIRST + " | B2B-HVD+PBJ", alert.freq_once_per_bar_close)
if b2b_en_bull_pb and b2b_bull_pb and masterGate
    alert("BULL | " + _FIRST + " | B2B-HVD+PB", alert.freq_once_per_bar_close)
if b2b_en_bear_pb and b2b_bear_pb and masterGate
    alert("BEAR | " + _FIRST + " | B2B-HVD+PB", alert.freq_once_per_bar_close)
if b2b_en_uc_bull and uc_b2b_bull and masterGate
    alert("BULL | " + _FIRST + " | UC+B2B-HVD", alert.freq_once_per_bar_close)
if b2b_en_uc_bear and uc_b2b_bear and masterGate
    alert("BEAR | " + _FIRST + " | UC+B2B-HVD", alert.freq_once_per_bar_close)

// ============================================================================
// HV+D MOMENTUM CO-OCCURRENCE
// CONVERTED FROM LABELS TO PLOTSHAPES (2 master plots, no labels).
// Detailed sub-detections preserved in alerts. Mutual exclusivity cascade
// preserved: 3of3 > 2of3 > individual PBJ > individual no-PBJ.
// RVOL = (RVOL1x OR Grand Slam) bull / (RVOL1x OR MOAB) bear.
// SAAB, Kratos, WTC, Hiroshima, Pentagon, Nagasaki, VPA RVOL all EXCLUDED.
// CMB = csNew3 Unified Combo (FVG-combo NOW AND Matrix-combo on PRIOR bar).
// ============================================================================

grp_hvdm = "★★★ HV+D MOMENTUM CO-OCC ★★★"
bool en_hvdm_pup_bull  = input.bool(true, "HV+D+PUP Bull",  group=grp_hvdm, inline="m1", tooltip="HV+D Bull on N-1 + PUP fired on N-1, NO PBJ. PUP = Pocket Pivot Up = 3%-body bull bar + volume > max-red-vol of prior 10 bars. Suppressed if PBJ variant or 2of3/3of3 true.")
bool en_hvdm_ppd_bear  = input.bool(true, "HV+D+PPD Bear",  group=grp_hvdm, inline="m1", tooltip="Bear mirror — HV+D Bear + PPD on N-1, no PBJ.")
bool en_hvdm_rvol_bull = input.bool(true, "HV+D+RVOL Bull", group=grp_hvdm, inline="m2", tooltip="HV+D Bull + (RVOL1x OR Grand Slam) on N-1, NO PBJ. SAAB, Kratos, WTC, Hiroshima, Pentagon, Nagasaki, VPA RVOL EXCLUDED. Suppressed if PBJ variant or 2of3/3of3 true.")
bool en_hvdm_rvol_bear = input.bool(true, "HV+D+RVOL Bear", group=grp_hvdm, inline="m2", tooltip="Bear mirror — HV+D Bear + (RVOL1x OR MOAB) on N-1, no PBJ. Same exclusions.")
bool en_hvdm_cmb_bull  = input.bool(true, "HV+D+CMB Bull",  group=grp_hvdm, inline="m3", tooltip="HV+D Bull + Unified Combo (csNew3 = FVG-combo NOW AND Matrix-combo on PRIOR bar) on N-1, NO PBJ.")
bool en_hvdm_cmb_bear  = input.bool(true, "HV+D+CMB Bear",  group=grp_hvdm, inline="m3", tooltip="Bear mirror.")
bool en_hvdm_2of3_bull = input.bool(true, "2of3 Bull",      group=grp_hvdm, inline="m4", tooltip="HV+D Bull + PBJ + (2 of {PUP, RVOL, CMB}) on N-1. Suppressed only by 3of3.")
bool en_hvdm_2of3_bear = input.bool(true, "2of3 Bear",      group=grp_hvdm, inline="m4", tooltip="Bear mirror with PPD/RVOL/CMB.")
bool en_hvdm_3of3_bull = input.bool(true, "3of3 Bull",      group=grp_hvdm, inline="m5", tooltip="HV+D Bull + PBJ + ALL THREE of {PUP, RVOL, CMB} on N-1. Top tier — suppresses 2of3 and individual PBJ variants.")
bool en_hvdm_3of3_bear = input.bool(true, "3of3 Bear",      group=grp_hvdm, inline="m5", tooltip="Bear mirror.")
bool en_hvdm_uc_bull   = input.bool(true, "UC+HVDM Bull",    group=grp_hvdm, inline="m6", tooltip="UC + HV+D Momentum Bull — any HVDM bull variant (PUP/RVOL/CMB ±PBJ, 2of3, 3of3) AND any USE bull detection on N-1.")
bool en_hvdm_uc_bear   = input.bool(true, "UC+HVDM Bear",    group=grp_hvdm, inline="m6", tooltip="Bear mirror.")

bool _m_pup1 = nz(sigPUP[1])
bool _m_ppd1 = nz(sigPPD[1])
bool _m_rv1b = nz(sigBullRVOL1x[1]) or nz(sigGrandSlam[1])
bool _m_rv1r = nz(sigBearRVOL1x[1]) or nz(sigMOAB[1])
bool _m_cb1b = csNew3_Bull
bool _m_cb1r = csNew3_Bear
bool _m_pj1b = nz(sigBullPBJ[1])
bool _m_pj1r = nz(sigBearPBJ[1])

bool hvdm_pup_nopbj_b  = hvd_fire_bull and _m_pup1 and not _m_pj1b
bool hvdm_pbjpup_b     = hvd_fire_bull and _m_pj1b and _m_pup1
bool hvdm_rvol_nopbj_b = hvd_fire_bull and _m_rv1b and not _m_pj1b
bool hvdm_pbjrvol_b    = hvd_fire_bull and _m_pj1b and _m_rv1b
bool hvdm_cmb_nopbj_b  = hvd_fire_bull and _m_cb1b and not _m_pj1b
bool hvdm_pbjcmb_b     = hvd_fire_bull and _m_pj1b and _m_cb1b
int  hvdm_b_cnt      = (_m_pup1 ? 1 : 0) + (_m_rv1b ? 1 : 0) + (_m_cb1b ? 1 : 0)
bool hvdm_2of3_b_raw = hvd_fire_bull and _m_pj1b and hvdm_b_cnt >= 2
bool hvdm_3of3_b     = hvd_fire_bull and _m_pj1b and _m_pup1 and _m_rv1b and _m_cb1b
bool hvdm_2of3_b     = hvdm_2of3_b_raw and not hvdm_3of3_b
bool hvdm_vis_pbjpup_b  = hvdm_pbjpup_b  and not hvdm_2of3_b_raw
bool hvdm_vis_pbjrvol_b = hvdm_pbjrvol_b and not hvdm_2of3_b_raw
bool hvdm_vis_pbjcmb_b  = hvdm_pbjcmb_b  and not hvdm_2of3_b_raw

bool hvdm_ppd_nopbj_r  = hvd_fire_bear and _m_ppd1 and not _m_pj1r
bool hvdm_pbjppd_r     = hvd_fire_bear and _m_pj1r and _m_ppd1
bool hvdm_rvol_nopbj_r = hvd_fire_bear and _m_rv1r and not _m_pj1r
bool hvdm_pbjrvol_r    = hvd_fire_bear and _m_pj1r and _m_rv1r
bool hvdm_cmb_nopbj_r  = hvd_fire_bear and _m_cb1r and not _m_pj1r
bool hvdm_pbjcmb_r     = hvd_fire_bear and _m_pj1r and _m_cb1r
int  hvdm_r_cnt      = (_m_ppd1 ? 1 : 0) + (_m_rv1r ? 1 : 0) + (_m_cb1r ? 1 : 0)
bool hvdm_2of3_r_raw = hvd_fire_bear and _m_pj1r and hvdm_r_cnt >= 2
bool hvdm_3of3_r     = hvd_fire_bear and _m_pj1r and _m_ppd1 and _m_rv1r and _m_cb1r
bool hvdm_2of3_r     = hvdm_2of3_r_raw and not hvdm_3of3_r
bool hvdm_vis_pbjppd_r  = hvdm_pbjppd_r  and not hvdm_2of3_r_raw
bool hvdm_vis_pbjrvol_r = hvdm_pbjrvol_r and not hvdm_2of3_r_raw
bool hvdm_vis_pbjcmb_r  = hvdm_pbjcmb_r  and not hvdm_2of3_r_raw

// Master plotshapes (replace 16 labels with 2 plotshapes)
bool hvdm_any_bull = hvdm_pup_nopbj_b or hvdm_vis_pbjpup_b or hvdm_rvol_nopbj_b or hvdm_vis_pbjrvol_b or hvdm_cmb_nopbj_b or hvdm_vis_pbjcmb_b or hvdm_2of3_b or hvdm_3of3_b
bool hvdm_any_bear = hvdm_ppd_nopbj_r or hvdm_vis_pbjppd_r or hvdm_rvol_nopbj_r or hvdm_vis_pbjrvol_r or hvdm_cmb_nopbj_r or hvdm_vis_pbjcmb_r or hvdm_2of3_r or hvdm_3of3_r
bool uc_hvdm_bull = hvdm_any_bull and nz(use_any_bull[1])
bool uc_hvdm_bear = hvdm_any_bear and nz(use_any_bear[1])

plotshape(hvdm_any_bull and masterGate, "HVDM Bull", shape.diamond, location.top, color.new(#FFD700, 0), text="HVDM", textcolor=color.black, size=size.normal, offset=-1)
plotshape(hvdm_any_bear and masterGate, "HVDM Bear", shape.diamond, location.bottom, color.new(#FF1744, 0), text="HVDM", textcolor=color.white, size=size.normal, offset=-1)
plotshape(en_hvdm_uc_bull and uc_hvdm_bull and masterGate, "UC+HVDM Bull", shape.square, location.top, color.new(#00E5FF, 0), text="UC\nHVDM", textcolor=color.black, size=size.large, offset=-1)
plotshape(en_hvdm_uc_bear and uc_hvdm_bear and masterGate, "UC+HVDM Bear", shape.square, location.bottom, color.new(#FF6D00, 0), text="UC\nHVDM", textcolor=color.white, size=size.large, offset=-1)

// HVDM alerts — preserve per-variant detail
if en_hvdm_pup_bull and hvdm_pup_nopbj_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PUP", alert.freq_once_per_bar_close)
if en_hvdm_pup_bull and hvdm_vis_pbjpup_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ+PUP", alert.freq_once_per_bar_close)
if en_hvdm_rvol_bull and hvdm_rvol_nopbj_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+RVOL", alert.freq_once_per_bar_close)
if en_hvdm_rvol_bull and hvdm_vis_pbjrvol_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ+RVOL", alert.freq_once_per_bar_close)
if en_hvdm_cmb_bull and hvdm_cmb_nopbj_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+COMBO", alert.freq_once_per_bar_close)
if en_hvdm_cmb_bull and hvdm_vis_pbjcmb_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ+COMBO", alert.freq_once_per_bar_close)
if en_hvdm_2of3_bull and hvdm_2of3_b and masterGate
    string _2ba = ""
    if _m_pup1
        _2ba := f_add(_2ba, "PUP")
    if _m_rv1b
        _2ba := f_add(_2ba, "RVOL")
    if _m_cb1b
        _2ba := f_add(_2ba, "CMB")
    alert("BULL | " + _FIRST + " | HVD+PBJ 2of3[" + _2ba + "]", alert.freq_once_per_bar_close)
if en_hvdm_3of3_bull and hvdm_3of3_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ 3of3[PUP+RVOL+CMB]", alert.freq_once_per_bar_close)
if en_hvdm_uc_bull and uc_hvdm_bull and masterGate
    alert("BULL | " + _FIRST + " | UC+HVDM", alert.freq_once_per_bar_close)

if en_hvdm_ppd_bear and hvdm_ppd_nopbj_r and masterGate
    alert("BEAR | " + _FIRST + " | HVD+PPD", alert.freq_once_per_bar_close)
if en_hvdm_ppd_bear and hvdm_vis_pbjppd_r and masterGate
    alert("BEAR | " + _FIRST + " | HVD+PBJ+PPD", alert.freq_once_per_bar_close)
if en_hvdm_rvol_bear and hvdm_rvol_nopbj_r and masterGate
    alert("BEAR | " + _FIRST + " | HVD+RVOL", alert.freq_once_per_bar_close)
if en_hvdm_rvol_bear and hvdm_vis_pbjrvol_r and masterGate
    alert("BEAR | " + _FIRST + " | HVD+PBJ+RVOL", alert.freq_once_per_bar_close)
if en_hvdm_cmb_bear and hvdm_cmb_nopbj_r and masterGate
    alert("BEAR | " + _FIRST + " | HVD+COMBO", alert.freq_once_per_bar_close)
if en_hvdm_cmb_bear and hvdm_vis_pbjcmb_r and masterGate
    alert("BEAR | " + _FIRST + " | HVD+PBJ+COMBO", alert.freq_once_per_bar_close)
if en_hvdm_2of3_bear and hvdm_2of3_r and masterGate
    string _2ra = ""
    if _m_ppd1
        _2ra := f_add(_2ra, "PPD")
    if _m_rv1r
        _2ra := f_add(_2ra, "RVOL")
    if _m_cb1r
        _2ra := f_add(_2ra, "CMB")
    alert("BEAR | " + _FIRST + " | HVD+PBJ 2of3[" + _2ra + "]", alert.freq_once_per_bar_close)
if en_hvdm_3of3_bear and hvdm_3of3_r and masterGate
    alert("BEAR | " + _FIRST + " | HVD+PBJ 3of3[PPD+RVOL+CMB]", alert.freq_once_per_bar_close)
if en_hvdm_uc_bear and uc_hvdm_bear and masterGate
    alert("BEAR | " + _FIRST + " | UC+HVDM", alert.freq_once_per_bar_close)

// ============================================================================
// AGGREGATOR ALERTS — Bloomberg format
// ============================================================================
f_co_bull_list() =>
    string _l=""
    if nz(sduperBull[1])
        _l:=f_add(_l,"SD")
    if nz(superBull[1]) and not nz(sduperBull[1])
        _l:=f_add(_l,"SUPER")
    if nz(hwBull[1])
        _l:=f_add(_l,"HW")
    if nz(anyBullFloor[1])
        _l:=f_add(_l,"FLOOR")
    if nz(anyBull2nd[1])
        _l:=f_add(_l,"2F")
    if nz(sigP21BullUUUU[1])
        _l:=f_add(_l,"UUUU")
    if nz(sigP21BullUUU[1])
        _l:=f_add(_l,"UUU")
    if nz(sigUUBull[1])
        _l:=f_add(_l,"UU")
    if nz(sigAlphaStrikeBull[1])
        _l:=f_add(_l,"A-STRIKE")
    if nz(sigFoxtrotBull[1])
        _l:=f_add(_l,"FOX")
    if nz(sigOmegaLong[1])
        _l:=f_add(_l,"OMEGA")
    if nz(sigODBull[1])
        _l:=f_add(_l,"OD")
    if nz(sigDispConsBull2[1])
        _l:=f_add(_l,"D2+")
    if nz(sigDispConsBull3[1])
        _l:=f_add(_l,"D3+")
    if nz(sigGolfBull[1])
        _l:=f_add(_l,"GOLF")
    if nz(sigPAFBull[1])
        _l:=f_add(_l,"PAF")
    if nz(csNew1_Bull[1])
        _l:=f_add(_l,"FVG")
    if nz(csNew2_Bull[1])
        _l:=f_add(_l,"MAT")
    if nz(csNew3_Bull[1])
        _l:=f_add(_l,"COMBO")
    if nz(sigCCBull[1])
        _l:=f_add(_l,"CC")
    if nz(sigLSCBull[1])
        _l:=f_add(_l,"LSC")
    _l

f_co_bear_list() =>
    string _l=""
    if nz(sduperBear[1])
        _l:=f_add(_l,"SD")
    if nz(superBear[1]) and not nz(sduperBear[1])
        _l:=f_add(_l,"SUPER")
    if nz(hwBear[1])
        _l:=f_add(_l,"HW")
    if nz(anyBearRoof[1])
        _l:=f_add(_l,"ROOF")
    if nz(anyBearPent[1])
        _l:=f_add(_l,"PH")
    if nz(sigP21BearUUUU[1])
        _l:=f_add(_l,"DDDD")
    if nz(sigP21BearUUU[1])
        _l:=f_add(_l,"DDD")
    if nz(sigUUBear[1])
        _l:=f_add(_l,"DD")
    if nz(sigAlphaStrikeBear[1])
        _l:=f_add(_l,"A-STRIKE")
    if nz(sigFoxtrotBear[1])
        _l:=f_add(_l,"FOX")
    if nz(sigODBear[1])
        _l:=f_add(_l,"OD")
    if nz(sigDispConsBear2[1])
        _l:=f_add(_l,"D2+")
    if nz(sigDispConsBear3[1])
        _l:=f_add(_l,"D3+")
    if nz(sigGolfBear[1])
        _l:=f_add(_l,"GOLF")
    if nz(sigPAFBear[1])
        _l:=f_add(_l,"PAF")
    if nz(csNew1_Bear[1])
        _l:=f_add(_l,"FVG")
    if nz(csNew2_Bear[1])
        _l:=f_add(_l,"MAT")
    if nz(csNew3_Bear[1])
        _l:=f_add(_l,"COMBO")
    if nz(sigCCBear[1])
        _l:=f_add(_l,"CC")
    if nz(sigLSCBear[1])
        _l:=f_add(_l,"LSC")
    _l

if co_any
    string co_dir = (co_bull_pbj or co_bull_pb) ? "BULL" : "BEAR"
    string co_pb_type = (co_bull_pbj or co_bear_pbj) ? "PBJ" : "PB"
    string co_use_list = (co_bull_pbj or co_bull_pb) ? f_co_bull_list() : f_co_bear_list()
    alert(co_dir + " | " + _FIRST + " | CO " + co_pb_type + " [" + co_use_list + "]", alert.freq_once_per_bar_close)

if co_bull_any and masterGate
    alert("BULL | " + _FIRST + " | UC+HV+D (any)", alert.freq_once_per_bar_close)
if co_bear_any and masterGate
    alert("BEAR | " + _FIRST + " | UC+HV+D (any)", alert.freq_once_per_bar_close)

f_agg_bull() =>
    string _s=""
    if fire_SDuperBull
        _s:=f_add(_s,"SUPER DUPER")
    if fire_SuperBull and not fire_SDuperBull
        _s:=f_add(_s,"SUPER")
    if fire_HWBull
        _s:=f_add(_s,"HW")
    if fire_BullFloor
        _s:=f_add(_s,"FLOOR")
    if fire_Bull2ndFloor
        _s:=f_add(_s,"2F")
    if fire_BullUUUU
        _s:=f_add(_s,"UUUU")
    if fire_BullUUU
        _s:=f_add(_s,"UUU")
    if fire_BullUU
        _s:=f_add(_s,"UU")
    if fire_AlphaStrikeB
        _s:=f_add(_s,"A-STRIKE")
    if fire_FoxtrotB
        _s:=f_add(_s,"FOX")
    if fire_OmegaLongA
        _s:=f_add(_s,"OMEGA")
    if fire_ODBull
        _s:=f_add(_s,"OD")
    if fire_DispConsBull2
        _s:=f_add(_s,"D2+")
    if fire_DispConsBull3
        _s:=f_add(_s,"D3+")
    if fire_GolfBull
        _s:=f_add(_s,"GOLF")
    if fire_PAFBull
        _s:=f_add(_s,"PAF")
    if fire_CS1B
        _s:=f_add(_s,"FVG")
    if fire_CS2B
        _s:=f_add(_s,"MAT")
    if fire_CS3B
        _s:=f_add(_s,"COMBO")
    if fire_CCBull
        _s:=f_add(_s,"CC")
    if fire_LSCBull
        _s:=f_add(_s,"LSC")
    _s

f_agg_bear() =>
    string _s=""
    if fire_SDuperBear
        _s:=f_add(_s,"SUPER DUPER")
    if fire_SuperBear and not fire_SDuperBear
        _s:=f_add(_s,"SUPER")
    if fire_HWBear
        _s:=f_add(_s,"HW")
    if fire_BearRooftop
        _s:=f_add(_s,"ROOF")
    if fire_BearPent
        _s:=f_add(_s,"PH")
    if fire_BearUUUU
        _s:=f_add(_s,"DDDD")
    if fire_BearUUU
        _s:=f_add(_s,"DDD")
    if fire_BearUU
        _s:=f_add(_s,"DD")
    if fire_AlphaStrikeR
        _s:=f_add(_s,"A-STRIKE")
    if fire_FoxtrotR
        _s:=f_add(_s,"FOX")
    if fire_ODBear
        _s:=f_add(_s,"OD")
    if fire_DispConsBear2
        _s:=f_add(_s,"D2+")
    if fire_DispConsBear3
        _s:=f_add(_s,"D3+")
    if fire_GolfBear
        _s:=f_add(_s,"GOLF")
    if fire_PAFBear
        _s:=f_add(_s,"PAF")
    if fire_CS1R
        _s:=f_add(_s,"FVG")
    if fire_CS2R
        _s:=f_add(_s,"MAT")
    if fire_CS3R
        _s:=f_add(_s,"COMBO")
    if fire_CCBear
        _s:=f_add(_s,"CC")
    if fire_LSCBear
        _s:=f_add(_s,"LSC")
    _s

if conf
    string bs=f_agg_bull()
    string rs=f_agg_bear()
    if en_aggregate and str.length(bs)>0
        alert("BULL | " + _FIRST + " | " + bs, alert.freq_once_per_bar_close)
    if en_aggregate and str.length(rs)>0
        alert("BEAR | " + _FIRST + " | " + rs, alert.freq_once_per_bar_close)
    if sigNagasaki
        string nd=nag_dir_bull and nag_dir_bear?"BOTH":nag_dir_bull?"BULL":nag_dir_bear?"BEAR":"NEUTRAL"
        alert("BULL | " + _FIRST + " | NAGASAKI " + nd, alert.freq_once_per_bar_close)
