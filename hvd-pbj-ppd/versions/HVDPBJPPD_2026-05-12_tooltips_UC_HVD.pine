i_disp2_type=input.string("Open to Close","Range Type",options=["Open to Close","High to Low"],group=grp_disp2)
i_disp2_std_len=input.int(100,"Std Dev Length",minval=1,group=grp_disp2)
i_disp2_std_min=input.float(5.0,"Min Mult",minval=0,step=0.5,group=grp_disp2)
i_disp2_std_max=input.float(100.0,"Max Mult",minval=0,step=0.5,group=grp_disp2)
i_disp2_req_fvg=input.bool(true,"Require FVG",group=grp_disp2)

grp_disp3 = "Displacement 3+"
i_disp3_type=input.string("Open to Close","Range Type",options=["Open to Close","High to Low"],group=grp_disp3)
i_disp3_std_len=input.int(100,"Std Dev Length",minval=1,group=grp_disp3)
i_disp3_std_min=input.float(3.0,"Min Mult",minval=0,step=0.5,group=grp_disp3)
i_disp3_std_max=input.float(100.0,"Max Mult",minval=0,step=0.5,group=grp_disp3)
i_disp3_req_fvg=input.bool(true,"Require FVG",group=grp_disp3)

grp_fvg = "GZ1 & HV FVG"
gz1_auto=input.bool(true,"Auto Threshold",group=grp_fvg)
gz1_thresh=input.float(2,"FVG Threshold %",minval=0,step=0.1,group=grp_fvg)
gz1_dist=input.int(12,"GZ1 Max Bar Distance",minval=1,group=grp_fvg)

grp_hv = "HV Settings"
hv150_len=input.int(150,"Hotspot Lookback",minval=10,group=grp_hv)

pp_barSize=3.0, pp_lookback=10
zoo_ma_type="VWMA", zoo_ma_len=5, zoo_price_src=close, enable_PB=true
zoo_pbj_ma_period=20, zoo_pbj_atr_period=14, zoo_pbj_hh_ll=25, zoo_pbj_atr_mult=3.0, zoo_pbj_vol_period=20, zoo_pbj_vol_mult=0.1
zoo_use_st=true, zoo_st_period=10, zoo_st_mult=2.0
pp_min_candles=2, pp_buffer_ticks=10, pp_atr_mult=2.0, pp_trend_cnt=1, pp_max_levels=50
pp_trust_mode="Trusted Only", pp_min_count=3

grp_swing = "Swingin (Pivot)"
sw_leftBars=input.int(5,"Left Bars",minval=1,group=grp_swing), sw_rightBars=input.int(1,"Right Bars",minval=1,group=grp_swing), sw_useAtr=input.bool(true,"Use ATR Filter",group=grp_swing), sw_atrMult=input.float(2.0,"ATR Multiplier",step=0.1,group=grp_swing), pp_atr_len=input.int(100,"ATR Length",group=grp_swing)

grp_useq = "Consecutive Streak (P21)"
p21_pbj_dist=input.int(4,"PBJ Proximity (bars)",minval=1,maxval=20,group=grp_useq)

grp_od = "Opening Drive"
od_max_bars=input.int(2,"Max Bars Into Session",minval=1,maxval=10,group=grp_od)

grp_neo = "Matrix Number (Neo)"
neo_len=input.int(67,"Matrix Number Lookback",minval=1,group=grp_neo)

grp_m1 = "Momentum 1"
ls_reg1=input.float(7.0,"Reg Floor",minval=0.5,step=0.1,group=grp_m1), ls_cum1=input.float(3.5,"Cum Floor",minval=0.5,step=0.1,group=grp_m1), ls_body1=input.float(0.69,"Body Ratio",minval=0.0,maxval=1.0,step=0.05,group=grp_m1)
grp_m2 = "Momentum 2"
ls_reg2=input.float(5.0,"Reg Floor",minval=0.5,step=0.1,group=grp_m2), ls_cum2=input.float(2.5,"Cum Floor",minval=0.5,step=0.1,group=grp_m2), ls_body2=input.float(0.69,"Body Ratio",minval=0.0,maxval=1.0,step=0.05,group=grp_m2)

grp_cs_set = "Combo Set Settings"
cs_bodyPct_FVG=input.float(0.69,"Min Body% FVG",minval=0.0,maxval=1.0,step=0.05,group=grp_cs_set), cs_bodyPct_MAT=input.float(0.69,"Min Body% Matrix",minval=0.0,maxval=1.0,step=0.05,group=grp_cs_set), cs_inc_pentagon_FVG=input.bool(true,"Pentagon in FVG Sets",group=grp_cs_set), cs_inc_pentagon_MAT=input.bool(true,"Pentagon in Matrix Sets",group=grp_cs_set)

grp_cc = "Combo Chain"
cc_min_hits=input.int(2,"Min Hits",minval=1,group=grp_cc,tooltip="Number of VISUAL combo plot positions required inside the rolling window. Visual = Matrix combo (offset 0) OR FVG combo (offset -1) OR Unified combo (offset -1).")
cc_window=input.int(3,"Within Bars",minval=1,group=grp_cc,tooltip="Rolling window size in bars.")

grp_lsc = "Long/Short Chain"
lsc_min_hits=input.int(2,"Min Hits",minval=1,group=grp_lsc), lsc_window=input.int(2,"Within Bars",minval=1,group=grp_lsc)
grp_lsc_m1 = "LS Chain Mom 1"
lsc_reg1=input.float(7.0,"Reg",minval=0.5,step=0.1,group=grp_lsc_m1), lsc_cum1=input.float(3.5,"Cum",minval=0.5,step=0.1,group=grp_lsc_m1), lsc_body1=input.float(0.60,"Body",minval=0.0,maxval=1.0,step=0.05,group=grp_lsc_m1)
grp_lsc_m2 = "LS Chain Mom 2"
lsc_reg2=input.float(5.0,"Reg",minval=0.5,step=0.1,group=grp_lsc_m2), lsc_cum2=input.float(2.5,"Cum",minval=0.5,step=0.1,group=grp_lsc_m2), lsc_body2=input.float(0.75,"Body",minval=0.0,maxval=1.0,step=0.05,group=grp_lsc_m2)

bh_LPPeriod=6, bh_K1=0, bh_trigno=2, bh_LPPeriod2=27, bh_K12=0.8, bh_K22=0.3
bh_LPPeriod3=11, bh_n1=9, bh_n2=6, bh_n3=3, bh_n4=21, bh_n5=0, bh_lsmaline=200
bh_leftBars=1, bh_rightBars=1, bh_leftBars2=5, bh_rightBars2=5, bh_greyDist=30

pp_atr = ta.atr(pp_atr_len)
bb_spike=math.abs(close-open), bb_avgSpikeDenom=ta.sma(bb_spike,bb_avgLength)[1], bb_normalizedPrice=bb_spike/nz(bb_avgSpikeDenom,1.0)
bb_avgVolDenom=ta.sma(volume,bb_avgLength)[1], bb_normalizedVolume=volume/nz(bb_avgVolDenom,1.0)
bb_diff=bb_normalizedPrice-bb_normalizedVolume, bb_positiveDiff=bb_diff>0?bb_diff:na, bb_smaDiff=ta.sma(bb_positiveDiff,bb_smaLength)
bb_baseBullish=(close>open) and (bb_positiveDiff>bb_smaDiff), bb_baseBearish=(close<open) and (bb_positiveDiff>bb_smaDiff)
bb_inRange(v,lo,hi) => v>=lo and v<hi

// === ENGINE 1: RVOL ===
f_rvol_1x_threshold(_s) => _s<=10?38.0:_s<=15?33.0:_s<=30?28.0:_s<=45?23.0:_s<=60?20.0:_s<=120?18.0:_s<=300?13.0:_s<=360?13.0:_s<=540?11.0:_s<=600?10.0:_s<=660?9.0:_s<=900?7.5:_s<=1560?6.5:_s<=2340?6.0:_s<=3600?4.5:_s<=9000?4.0:_s<=11700?3.5:_s<259200?1.8:1.0
f_gs_moab_threshold(_s) => _s<60?f_rvol_1x_threshold(_s)*3.0:_s<=300?35.0:_s<=600?25.0:_s<=1500?20.0:_s<=3000?20.0:_s<=7260?10.0:_s<=11700?8.0:_s<=86400?7.5:_s<=259200?3.5:3.0
f_saab_kratos_threshold(_s) => f_rvol_1x_threshold(_s) * 0.56
f_wtc_threshold(_s) => f_rvol_1x_threshold(_s) * 2.0
f_hiroshima_threshold(_s) => _s<60?f_rvol_1x_threshold(_s)*3.0:_s<=300?35.0:_s<=600?25.0:_s<=1500?25.0:_s<=3060?20.0:_s<=7260?10.0:_s<=11700?8.0:_s<=86400?7.5:_s<=259200?5:3.5

th_saab_kratos=f_saab_kratos_threshold(tfSec), th_1x=f_rvol_1x_threshold(tfSec), th_gs_moab=f_gs_moab_threshold(tfSec), th_wtc=f_wtc_threshold(tfSec), th_hiroshima=f_hiroshima_threshold(tfSec)

sigSAAB=conf and bb_baseBullish and bb_inRange(bb_normalizedPrice,th_saab_kratos,th_1x)
sigKratos=conf and bb_baseBearish and bb_inRange(bb_normalizedPrice,th_saab_kratos,th_1x)
sigGrandSlam=conf and bb_baseBullish and (bb_normalizedPrice>=th_gs_moab)
sigMOAB=conf and bb_baseBearish and (bb_normalizedPrice>=th_gs_moab)
sigBullRVOL1x=conf and bb_baseBullish and bb_inRange(bb_normalizedPrice,th_1x,th_gs_moab) and not sigGrandSlam
sigBearRVOL1x=conf and bb_baseBearish and bb_inRange(bb_normalizedPrice,th_1x,th_gs_moab) and not sigMOAB

[currentVolume_reg,pastVolume_reg,_unused]=tv_ta.relativeVolume(reg_length,reg_anchorTimeframe,reg_calculationMode=="Cumulative",reg_adjustRealtime)
relVolRatio=currentVolume_reg/pastVolume_reg
sigWTC=conf and (relVolRatio>th_wtc) and (relVolRatio<=th_hiroshima)
sigHiroshima=conf and (relVolRatio>th_hiroshima)
sigPentagon=conf and (relVolRatio>=th_1x) and (relVolRatio<=th_wtc)

var float maxVol=0.0
bool isNagasaki=false
if bar_index==0
    maxVol:=volume
else if volume>maxVol
    isNagasaki:=true
    maxVol:=volume
sigNagasaki=isNagasaki

bool is_new_day=ta.change(time("D"))!=0
var int sessionBarCount=0, var int lastCountedBar=-1
if is_new_day and bar_index!=lastCountedBar
    sessionBarCount:=1
    lastCountedBar:=bar_index
else if bar_index!=lastCountedBar
    sessionBarCount+=1
    lastCountedBar:=bar_index

// === ENGINE 2: FAUNA ===
fauna_atr=atr14, fauna_avgVol=ta.sma(volume,20), fauna_avgBody=ta.sma(math.abs(close-open),20)
fauna_avgDelta=ta.sma(math.abs(close-close[1]),10), fauna_trendMA=ta.sma(close,50)
fauna_body=close-open, fauna_rng=high-low, fauna_bodySz=math.abs(fauna_body)
fauna_bodyRat=fauna_rng==0?0.0:fauna_bodySz/fauna_rng
fauna_up=fauna_body>0, fauna_dn=fauna_body<0
fauna_prev_body=close[1]-open[1], fauna_prev_range=high[1]-low[1]

MB_b=fauna_up and fauna_bodySz>1.6*fauna_atr and fauna_bodyRat>0.70 and volume>1.8*fauna_avgVol
RE_b=fauna_up and fauna_rng>2.2*fauna_atr and (high-close)<0.15*fauna_rng and volume>1.8*fauna_avgVol
TA_b=fauna_trendMA>fauna_trendMA[1] and (close-close[1])>1.6*fauna_avgDelta and fauna_up and volume>1.8*fauna_avgVol
GG_b=(open-close[1])>0.9*fauna_atr and fauna_up and low>close[1] and volume>1.8*fauna_avgVol
StrongBear=close[1]<open[1] and math.abs(fauna_prev_body)>1.5*fauna_avgBody[1] and volume[1]>1.5*fauna_avgVol[1]
WeakBear=close[1]<open[1] and (fauna_prev_range==0?0.0:math.abs(fauna_prev_body)/fauna_prev_range)<=0.2
TR_b=WeakBear and (MB_b or RE_b or TA_b), ES_b=StrongBear and (MB_b or RE_b or TA_b), GDR_b=close[1]<open[1] and GG_b
int b_core_cnt=(MB_b?1:0)+(RE_b?1:0)+(TA_b?1:0)
bool b_gg_pass=fauna_gg_master and (b_core_cnt>=2) and (fauna_bodyRat>=fauna_gg_body)
bool b_gg_exc=GG_b and not b_gg_pass
excluded_bull=TR_b or ES_b or GDR_b or b_gg_exc
sigFAUNABull=conf and (MB_b or RE_b or TA_b) and not excluded_bull

MB_r=fauna_dn and fauna_bodySz>1.6*fauna_atr and fauna_bodyRat>0.70 and volume>1.8*fauna_avgVol
RE_r=fauna_dn and fauna_rng>2.2*fauna_atr and (close-low)<0.15*fauna_rng and volume>1.8*fauna_avgVol
TA_r=fauna_trendMA<fauna_trendMA[1] and (close[1]-close)>1.6*fauna_avgDelta and fauna_dn and volume>1.8*fauna_avgVol
GG_r=(close[1]-open)>0.9*fauna_atr and fauna_dn and high<close[1] and volume>1.8*fauna_avgVol
StrongBull=close[1]>open[1] and math.abs(fauna_prev_body)>1.5*fauna_avgBody[1] and volume[1]>1.5*fauna_avgVol[1]
WeakBull=close[1]>open[1] and (fauna_prev_range==0?0.0:math.abs(fauna_prev_body)/fauna_prev_range)<=0.2
TR_r=WeakBull and (MB_r or RE_r or TA_r), ES_r=StrongBull and (MB_r or RE_r or TA_r), GDR_r=close[1]>open[1] and GG_r
int s_core_cnt=(MB_r?1:0)+(RE_r?1:0)+(TA_r?1:0)
bool s_gg_pass=fauna_gg_master and (s_core_cnt>=2) and (fauna_bodyRat>=fauna_gg_body)
bool s_gg_exc=GG_r and not s_gg_pass
excluded_bear=TR_r or ES_r or GDR_r or s_gg_exc
sigFAUNABear=conf and (MB_r or RE_r or TA_r) and not excluded_bear

// === ENGINE 3: USE DISPLACEMENT ===
float disp_rng=i_disp_type=="Open to Close"?math.abs(open-close):high-low
float disp_std=ta.stdev(disp_rng,i_std_len)
float disp_thresh_min=disp_std*i_std_min, float disp_thresh_max=disp_std*i_std_max
bool disp_prevDisp=disp_rng[1]>disp_thresh_min[1] and disp_rng[1]<=disp_thresh_max[1]
bool disp_currDisp=disp_rng[0]>disp_thresh_min[0] and disp_rng[0]<=disp_thresh_max[0]
bool disp_bullFVG=low>high[2] and close[1]>open[1], bool disp_bearFVG=high<low[2] and close[1]<open[1]
sigDISPBull=conf and (i_req_fvg?(disp_prevDisp and disp_bullFVG):(disp_currDisp and close>open))
sigDISPBear=conf and (i_req_fvg?(disp_prevDisp and disp_bearFVG):(disp_currDisp and close<open))
float disp5_thresh=disp_std*5.0
bool disp5_bull=conf and disp_std>0 and disp_rng>disp5_thresh and close>open
bool disp5_bear=conf and disp_std>0 and disp_rng>disp5_thresh and close<open

float disp2_rng=i_disp2_type=="Open to Close"?math.abs(open-close):high-low
float disp2_std=ta.stdev(disp2_rng,i_disp2_std_len)
bool sigDISP2Bull=conf and (i_disp2_req_fvg?(disp2_rng[1]>disp2_std[1]*i_disp2_std_min and disp2_rng[1]<=disp2_std[1]*i_disp2_std_max and low>high[2] and close[1]>open[1]):(disp2_rng>disp2_std*i_disp2_std_min and disp2_rng<=disp2_std*i_disp2_std_max and close>open))
bool sigDISP2Bear=conf and (i_disp2_req_fvg?(disp2_rng[1]>disp2_std[1]*i_disp2_std_min and disp2_rng[1]<=disp2_std[1]*i_disp2_std_max and high<low[2] and close[1]<open[1]):(disp2_rng>disp2_std*i_disp2_std_min and disp2_rng<=disp2_std*i_disp2_std_max and close<open))
var int disp2_bullStreak=0, var int disp2_bearStreak=0
disp2_bullStreak := sigDISP2Bull ? disp2_bullStreak+1 : 0
disp2_bearStreak := sigDISP2Bear ? disp2_bearStreak+1 : 0
bool sigDispConsBull2=sigDISP2Bull and disp2_bullStreak>=2 and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2])
bool sigDispConsBear2=sigDISP2Bear and disp2_bearStreak>=2 and nz(sigFAUNABear[1]) and nz(sigFAUNABear[2])

float disp3_rng=i_disp3_type=="Open to Close"?math.abs(open-close):high-low
float disp3_std=ta.stdev(disp3_rng,i_disp3_std_len)
bool sigDISP3Bull=conf and (i_disp3_req_fvg?(disp3_rng[1]>disp3_std[1]*i_disp3_std_min and disp3_rng[1]<=disp3_std[1]*i_disp3_std_max and low>high[2] and close[1]>open[1]):(disp3_rng>disp3_std*i_disp3_std_min and disp3_rng<=disp3_std*i_disp3_std_max and close>open))
bool sigDISP3Bear=conf and (i_disp3_req_fvg?(disp3_rng[1]>disp3_std[1]*i_disp3_std_min and disp3_rng[1]<=disp3_std[1]*i_disp3_std_max and high<low[2] and close[1]<open[1]):(disp3_rng>disp3_std*i_disp3_std_min and disp3_rng<=disp3_std*i_disp3_std_max and close<open))
var int disp3_bullStreak=0, var int disp3_bearStreak=0
disp3_bullStreak := sigDISP3Bull ? disp3_bullStreak+1 : 0
disp3_bearStreak := sigDISP3Bear ? disp3_bearStreak+1 : 0
bool sigDispConsBull3=sigDISP3Bull and disp3_bullStreak>=3 and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2]) and nz(sigFAUNABull[3])
bool sigDispConsBear3=sigDISP3Bear and disp3_bearStreak>=3 and nz(sigFAUNABear[1]) and nz(sigFAUNABear[2]) and nz(sigFAUNABear[3])

// === ENGINE 4: GZ1/HV FVG ===
type fvg_struct
    float mx
    float mn
    bool bull
    int t
    int idx
    bool hv

float gz_v1=volume[1], float _hv5000=ta.highest(volume,5000)[1], float _hv252=ta.highest(volume,252)[1], float _hv63=ta.highest(volume,63)[1]
bool gz_isHV=(gz_v1==_hv5000) or (gz_v1==_hv252) or (gz_v1==_hv63)
float gz_thresh=gz1_auto?ta.cum((high-low)/low)/bar_index:gz1_thresh/100
bool gz_bFVG=low>high[2] and close[1]>high[2] and (low-high[2])/high[2]>gz_thresh
bool gz_sFVG=high<low[2] and close[1]<low[2] and (low[2]-high)/high>gz_thresh

var gz_fvgs=array.new<fvg_struct>(0)
var int gz_lastT=0
bool gz_bullGZI=false, bool gz_bearGZI=false, bool gz_bullHV=false, bool gz_bearHV=false

if conf and gz_bFVG and time!=gz_lastT
    float mx=low, float mn=high[2]
    if gz_isHV
        gz_bullHV:=true
    if gz_fvgs.size()>0
        for i=0 to gz_fvgs.size()-1
            fvg_struct e=gz_fvgs.get(i)
            if e.bull and bar_index-e.idx<=gz1_dist
                if math.max(e.mn,mn)<math.min(e.mx,mx) or (math.max(e.mn,mn)<=math.min(e.mx,mx) and e.hv and gz_isHV)
                    gz_bullGZI:=true
                    break
    gz_fvgs.unshift(fvg_struct.new(mx,mn,true,time,bar_index,gz_isHV))
    gz_lastT:=time

if conf and gz_sFVG and time!=gz_lastT
    float mx=low[2], float mn=high
    if gz_isHV
        gz_bearHV:=true
    if gz_fvgs.size()>0
        for i=0 to gz_fvgs.size()-1
            fvg_struct e=gz_fvgs.get(i)
            if not e.bull and bar_index-e.idx<=gz1_dist
                if math.max(e.mn,mn)<math.min(e.mx,mx) or (math.max(e.mn,mn)<=math.min(e.mx,mx) and e.hv and gz_isHV)
                    gz_bearGZI:=true
                    break
    gz_fvgs.unshift(fvg_struct.new(mx,mn,false,time,bar_index,gz_isHV))
    gz_lastT:=time

if gz_fvgs.size()>0
    for i=gz_fvgs.size()-1 to 0
        fvg_struct g=gz_fvgs.get(i)
        if g.bull and close<g.mn
            gz_fvgs.remove(i)
        else if not g.bull and close>g.mx
            gz_fvgs.remove(i)
if gz_fvgs.size()>50
    gz_fvgs.pop()

// === ENGINE 5: PUP/PPD ===
float pp_redVol=close<open?volume:0.0, float pp_greenVol=close>open?volume:0.0
float pp_hiRedVol=ta.highest(pp_redVol[1],pp_lookback), float pp_hiGreenVol=ta.highest(pp_greenVol[1],pp_lookback)
bool pp_priceUp=((close-open)/open)*100>pp_barSize, bool pp_priceDn=((open-close)/open)*100>pp_barSize
bool sigPUP=conf and pp_priceUp and volume>pp_hiRedVol
bool sigPPD=conf and pp_priceDn and volume>pp_hiGreenVol

// === ENGINE 6: PBJ (Pipeline B) ===
type lvl
    float upper
    float lower
    float vol
    bool approached

float atr_pb=atr14*2.0
f_ma(src,len,t) => switch t
    "EMA"=>ta.ema(src,len)
    "SMA"=>ta.sma(src,len)
    "WMA"=>ta.wma(src,len)
    "HMA"=>ta.hma(src,len)
    "VWMA"=>ta.vwma(src,len)
    =>ta.sma(src,len)

float base_ma=f_ma(zoo_price_src,zoo_ma_len,zoo_ma_type)
float zoo_st_atr=zoo_st_mult*ta.atr(zoo_st_period)
var int st_dir=1
float curr_long=0.0
curr_long:=base_ma>nz(curr_long[1],base_ma-zoo_st_atr)?math.max(base_ma-zoo_st_atr,nz(curr_long[1])):base_ma-zoo_st_atr
float curr_short=0.0
curr_short:=base_ma<nz(curr_short[1],base_ma+zoo_st_atr)?math.min(base_ma+zoo_st_atr,nz(curr_short[1])):base_ma+zoo_st_atr
float sig_line=0.0
if zoo_use_st
    if nz(st_dir[1])==-1 and zoo_price_src>nz(curr_short[1])
        st_dir:=1
    else if nz(st_dir[1])==1 and zoo_price_src<nz(curr_long[1])
        st_dir:=-1
    sig_line:=st_dir==1?curr_long:curr_short
else
    sig_line:=base_ma

bool buy_cross=ta.crossover(zoo_price_src,sig_line), bool sell_cross=ta.crossunder(zoo_price_src,sig_line)
bool bull_reaccel=st_dir==1 and sig_line>nz(sig_line[1]) and nz(sig_line[1])==nz(sig_line[2])
bool bear_reaccel=st_dir==-1 and sig_line<nz(sig_line[1]) and nz(sig_line[1])==nz(sig_line[2])

float pbj_ma=ta.ema(close,zoo_pbj_ma_period), float pbj_atr=ta.atr(zoo_pbj_atr_period)
float zoo_avg_vol=ta.sma(volume,zoo_pbj_vol_period)
float zoo_thresh=close==0?0:(pbj_atr/close*zoo_pbj_atr_mult)
bool pbj_buy=low<pbj_ma*(1-zoo_thresh) and low==ta.lowest(low,zoo_pbj_hh_ll) and volume>zoo_avg_vol*zoo_pbj_vol_mult
bool pbj_sell=high>pbj_ma*(1+zoo_thresh) and high==ta.highest(high,zoo_pbj_hh_ll) and volume>zoo_avg_vol*zoo_pbj_vol_mult

var bull_lvls=array.new<lvl>(), var bear_lvls=array.new<lvl>()
f_add_lvl(arr,up,lo,v)=>
    if math.abs(up-lo)>=syminfo.mintick
        array.push(arr,lvl.new(up,lo,v,false))
f_add_lander(is_bull,cross_sig,arr)=>
    if cross_sig
        float up=0.0, float lo=0.0
        if is_bull
            up:=math.max(open[1],close[1]), lo:=low[1]
            if up-lo<atr_pb*0.5
                up:=lo+atr_pb*0.5
        else
            up:=high[1], lo:=math.min(open[1],close[1])
            if up-lo<atr_pb*0.5
                lo:=up-atr_pb*0.5
        f_add_lvl(arr,up,lo,volume[1])
f_add_reaccel(is_bull,sig,arr)=>
    if sig and not na(sig_line)
        float p1=sig_line, float p2=is_bull?math.min(open,close):math.max(open,close)
        f_add_lvl(arr,math.max(p1,p2),math.min(p1,p2),volume)
f_check_approach(arr,is_bull)=>
    bool approached=false
    if array.size(arr)>0
        for i=array.size(arr)-1 to 0
            if i>=array.size(arr)
                continue
            l=array.get(arr,i)
            if is_bull and close<l.lower
                array.remove(arr,i)
                continue
            if not is_bull and close>l.upper
                array.remove(arr,i)
                continue
            float ap=is_bull?l.upper*1.005:l.lower*0.995
            if is_bull
                if not l.approached and low<=ap
                    approached:=true
                    l.approached:=true
                else if l.approached and low>l.upper
                    l.approached:=false
            else
                if not l.approached and high>=ap
                    approached:=true
                    l.approached:=true
                else if l.approached and high<l.lower
                    l.approached:=false
    approached

f_add_lander(true,buy_cross,bull_lvls), f_add_lander(false,sell_cross,bear_lvls)
f_add_reaccel(true,bull_reaccel,bull_lvls), f_add_reaccel(false,bear_reaccel,bear_lvls)

var bool wait_buy=false, var bool wait_sell=false, var bool wait_pbj_buy=false, var bool wait_pbj_sell=false
if conf
    if f_check_approach(bull_lvls,true)
        wait_buy:=true
    if f_check_approach(bear_lvls,false)
        wait_sell:=true
if pbj_buy
    wait_pbj_buy:=true
if pbj_sell
    wait_pbj_sell:=true
while array.size(bull_lvls)>30
    array.shift(bull_lvls)
while array.size(bear_lvls)>30
    array.shift(bear_lvls)

bool sig_pbj_buy=buy_cross and wait_pbj_buy, bool sig_pb_buy=buy_cross and wait_buy
bool sig_pbj_sell=sell_cross and wait_pbj_sell, bool sig_pb_sell=sell_cross and wait_sell
if sig_pb_buy
    wait_buy:=false
if sig_pbj_buy
    wait_pbj_buy:=false
if sig_pb_sell
    wait_sell:=false
if sig_pbj_sell
    wait_pbj_sell:=false

bool sigBullPBJ=conf and sig_pbj_buy, bool sigBullPB=conf and enable_PB and sig_pb_buy and not sig_pbj_buy
bool sigBearPBJ=conf and sig_pbj_sell, bool sigBearPB=conf and enable_PB and sig_pb_sell and not sig_pbj_sell

// === ENGINE 7: PING PONG SR ===
type srLevel
    float price
    int levelType
    int originType
    int state
    int count
    line lnID

var srLevels=array.new<srLevel>(0)
var int last_bounce_side=0, var string lastBreakType=na
float sig_bull_break=na, float sig_bear_break=na, float sig_res_bounce=na, float sig_sup_bounce=na
float sig_piv_bull=na, float sig_piv_bear=na, float sig_res_reject=na, float sig_sup_reject=na
bool bullRegime=false, bool bearRegime=false

float body_top=math.max(open,close), float body_bot=math.min(open,close)
float price_tolerance=math.max(syminfo.mintick*pp_buffer_ticks,syminfo.mintick/10)
bool is_new_flat_res=true, bool is_new_flat_sup=true
for i=0 to pp_min_candles-1
    if math.abs(math.max(open[i],close[i])-body_top)>price_tolerance
        is_new_flat_res:=false
    if math.abs(math.min(open[i],close[i])-body_bot)>price_tolerance
        is_new_flat_sup:=false

rawHigh=ta.pivothigh(high,sw_leftBars,sw_rightBars), rawLow=ta.pivotlow(low,sw_leftBars,sw_rightBars)
var float lastValidSwingLevel=na
thresholdSwing=sw_useAtr?(pp_atr*sw_atrMult):0

bool validSwingHigh=false
if not na(rawHigh)
    if na(lastValidSwingLevel) or math.abs(rawHigh-lastValidSwingLevel)>=thresholdSwing
        validSwingHigh:=true
        lastValidSwingLevel:=rawHigh
bool validSwingLow=false
if not na(rawLow)
    if na(lastValidSwingLevel) or math.abs(rawLow-lastValidSwingLevel)>=thresholdSwing
        validSwingLow:=true
        lastValidSwingLevel:=rawLow

has_level(price,type_val)=>
    bool found=false
    if array.size(srLevels)>0
        for i=0 to array.size(srLevels)-1
            lv=array.get(srLevels,i)
            if math.abs(lv.price-price)<=price_tolerance and lv.levelType==type_val
                found:=true
                break
    found

if is_new_flat_res and not has_level(body_top,1)
    ln=line.new(bar_index-pp_min_candles+1,body_top,bar_index,body_top,color=color.new(color.white,100),style=line.style_dashed)
    array.push(srLevels,srLevel.new(body_top,1,0,0,0,ln))
if is_new_flat_sup and not has_level(body_bot,-1)
    ln=line.new(bar_index-pp_min_candles+1,body_bot,bar_index,body_bot,color=color.new(color.white,100),style=line.style_dashed)
    array.push(srLevels,srLevel.new(body_bot,-1,0,0,0,ln))
if validSwingHigh
    ln=line.new(bar_index-sw_rightBars,rawHigh,bar_index,rawHigh,color=color.new(color.white,100),width=1,style=line.style_solid)
    array.push(srLevels,srLevel.new(rawHigh,1,1,1,0,ln))
if validSwingLow
    ln=line.new(bar_index-sw_rightBars,rawLow,bar_index,rawLow,color=color.new(color.white,100),width=1,style=line.style_solid)
    array.push(srLevels,srLevel.new(rawLow,-1,1,1,0,ln))

if array.size(srLevels)>0
    for i=array.size(srLevels)-1 to 0
        lv=array.get(srLevels,i)
        bool remove_lv=false
        if lv.levelType==1
            if close>lv.price
                if lv.state==1 or lv.originType==1
                    sig_bull_break:=high
                    if lastBreakType=="BD"
                        bullRegime:=true
                    lastBreakType:="BO"
                remove_lv:=true
            else
                line.set_x2(lv.lnID,bar_index)
                if (lv.state==1 or lv.originType==1) and high>=lv.price
                    sig_res_reject:=high
                    lv.count:=0
                if lv.state==0 or (lv.state==1 and lv.count>=0)
                    if close<open
                        lv.count+=1
                    if (lv.price-close)>(pp_atr*pp_atr_mult) and lv.count>=pp_trend_cnt
                        if lv.state==0
                            lv.state:=1
                            line.set_style(lv.lnID,line.style_solid)
                            line.set_width(lv.lnID,2)
                        lv.count:=-1
                        sig_res_bounce:=high
                        if last_bounce_side==1
                            sig_piv_bear:=high
                        last_bounce_side:=-1
        else if lv.levelType==-1
            if close<lv.price
                if lv.state==1 or lv.originType==1
                    sig_bear_break:=low
                    if lastBreakType=="BO"
                        bearRegime:=true
                    lastBreakType:="BD"
                remove_lv:=true
            else
                line.set_x2(lv.lnID,bar_index)
                if (lv.state==1 or lv.originType==1) and low<=lv.price
                    sig_sup_reject:=low
                    lv.count:=0
                if lv.state==0 or (lv.state==1 and lv.count>=0)
                    if close>open
                        lv.count+=1
                    if (close-lv.price)>(pp_atr*pp_atr_mult) and lv.count>=pp_trend_cnt
                        if lv.state==0
                            lv.state:=1
                            line.set_style(lv.lnID,line.style_solid)
                            line.set_width(lv.lnID,2)
                        lv.count:=-1
                        sig_sup_bounce:=low
                        if last_bounce_side==-1
                            sig_piv_bull:=low
                        last_bounce_side:=1
        if remove_lv
            line.set_x2(lv.lnID,bar_index)
            array.remove(srLevels,i)

while array.size(srLevels)>pp_max_levels
    oldLv=array.get(srLevels,0)
    line.delete(oldLv.lnID)
    array.remove(srLevels,0)

int bull_state=(validSwingLow?32:0)+(not na(sig_piv_bull)?16:0)+(bullRegime?8:0)+(not na(sig_sup_bounce)?4:0)+(not na(sig_bull_break)?2:0)+(not na(sig_res_reject)?1:0)
int bull_cnt=(validSwingLow?1:0)+(not na(sig_piv_bull)?1:0)+(bullRegime?1:0)+(not na(sig_sup_bounce)?1:0)+(not na(sig_bull_break)?1:0)+(not na(sig_res_reject)?1:0)
bool bull_has_floor_gravity=(bull_state%8>=4) or (bull_state%32>=16) or (bull_state>=32)
int bear_state=(validSwingHigh?32:0)+(not na(sig_piv_bear)?16:0)+(bearRegime?8:0)+(not na(sig_res_bounce)?4:0)+(not na(sig_bear_break)?2:0)+(not na(sig_sup_reject)?1:0)
int bear_cnt=(validSwingHigh?1:0)+(not na(sig_piv_bear)?1:0)+(bearRegime?1:0)+(not na(sig_res_bounce)?1:0)+(not na(sig_bear_break)?1:0)+(not na(sig_sup_reject)?1:0)
bool bear_has_ceiling_gravity=(bear_state%8>=4) or (bear_state%32>=16) or (bear_state>=32)

bool bull_pp=bull_cnt>=pp_min_count and bull_has_floor_gravity and bull_state>0
bool bear_pp=bear_cnt>=pp_min_count and bear_has_ceiling_gravity and bear_state>0

bool is_matrix_number=volume==ta.highest(volume,neo_len)
bool sigNeoBull=conf and is_matrix_number and sigFAUNABull, bool sigNeoBear=conf and is_matrix_number and sigFAUNABear
bool sigTrinityBull=conf and is_matrix_number and not sigFAUNABull and close>open, bool sigTrinityBear=conf and is_matrix_number and not sigFAUNABear and close<open

var bool dayDetFired=false
if is_new_day
    dayDetFired:=false
bool firstOfDay=not dayDetFired

bool sigFoxtrotBull=conf and sigFAUNABull and nz(sigFAUNABull[1]) and nz(sigFAUNABull[2]) and nz(sigFAUNABull[3])
bool sigFoxtrotBear=conf and sigFAUNABear and nz(sigFAUNABear[1]) and nz(sigFAUNABear[2]) and nz(sigFAUNABear[3])

[currentVol_r,pastVol_r,_r2]=tv_ta.relativeVolume(reg_length,reg_anchorTimeframe,false,reg_adjustRealtime)
[currentVol_c,pastVol_c,_c2]=tv_ta.relativeVolume(reg_length,reg_anchorTimeframe,true,reg_adjustRealtime)
float ls_regRatio=nz(currentVol_r/pastVol_r), float ls_cumRatio=nz(currentVol_c/pastVol_c)
float ls_bodyRat=(high-low)==0?0.0:math.abs(close-open)/(high-low)
bool sigLong1=conf and ls_regRatio>ls_reg1 and ls_cumRatio>ls_cum1 and close>open and ls_bodyRat>=ls_body1
bool sigShort1=conf and ls_regRatio>ls_reg1 and ls_cumRatio>ls_cum1 and close<open and ls_bodyRat>=ls_body1
bool sigLong2=conf and ls_regRatio>ls_reg2 and ls_cumRatio>ls_cum2 and close>open and ls_bodyRat>=ls_body2
bool sigShort2=conf and ls_regRatio>ls_reg2 and ls_cumRatio>ls_cum2 and close<open and ls_bodyRat>=ls_body2

bool neo_bull_aligned=sigNeoBull and (sigLong1 or sigLong2), bool neo_bear_aligned=sigNeoBear and (sigShort1 or sigShort2)
bool trinity_bull_aligned=sigTrinityBull and (sigLong1 or sigLong2), bool trinity_bear_aligned=sigTrinityBear and (sigShort1 or sigShort2)

// === COMBO SETS — booleans kept; visual plotshapes for CS1/CS2 REMOVED ===
float cs_bp1=high[1]-low[1]==0?0.0:math.abs(close[1]-open[1])/(high[1]-low[1])
bool cs_vb=cs_bp1>=cs_bodyPct_FVG
bool comboSet1_Bull=conf and cs_vb and (gz_bullHV or gz_bullGZI) and (sigSAAB[1] or sigBullRVOL1x[1] or sigGrandSlam[1])
bool comboSet1_Bear=conf and cs_vb and (gz_bearHV or gz_bearGZI) and (sigKratos[1] or sigBearRVOL1x[1] or sigMOAB[1])
bool comboSet2_Bull=conf and cs_vb and (gz_bullHV or gz_bullGZI) and ((cs_inc_pentagon_FVG and sigPentagon[1]) or sigWTC[1] or sigHiroshima[1] or sigNagasaki[1])
bool comboSet2_Bear=conf and cs_vb and (gz_bearHV or gz_bearGZI) and ((cs_inc_pentagon_FVG and sigPentagon[1]) or sigWTC[1] or sigHiroshima[1] or sigNagasaki[1])
bool cs_vm=ls_bodyRat>=cs_bodyPct_MAT
bool matrix_any_bull=sigNeoBull or sigTrinityBull or neo_bull_aligned or trinity_bull_aligned
bool matrix_any_bear=sigNeoBear or sigTrinityBear or neo_bear_aligned or trinity_bear_aligned
bool comboSet3_Bull=cs_vm and matrix_any_bull and (sigSAAB or sigBullRVOL1x or sigGrandSlam)
bool comboSet3_Bear=cs_vm and matrix_any_bear and (sigKratos or sigBearRVOL1x or sigMOAB)
bool comboSet4_Bull=cs_vm and matrix_any_bull and ((cs_inc_pentagon_MAT and sigPentagon) or sigWTC or sigHiroshima or sigNagasaki)
bool comboSet4_Bear=cs_vm and matrix_any_bear and ((cs_inc_pentagon_MAT and sigPentagon) or sigWTC or sigHiroshima or sigNagasaki)

bool csNew1_Bull=comboSet1_Bull or comboSet2_Bull, bool csNew1_Bear=comboSet1_Bear or comboSet2_Bear
bool csNew2_Bull=comboSet3_Bull or comboSet4_Bull, bool csNew2_Bear=comboSet3_Bear or comboSet4_Bear
bool csNew3_Bull=csNew1_Bull and nz(csNew2_Bull[1]), bool csNew3_Bear=csNew1_Bear and nz(csNew2_Bear[1])

// Nagasaki directional
bool nag_dir_bull=sigBullRVOL1x or sigGrandSlam or sigFAUNABull or sigDISPBull or sigBullPBJ or sigPUP or gz_bullHV or gz_bullGZI
bool nag_dir_bear=sigBearRVOL1x or sigMOAB or sigFAUNABear or sigDISPBear or sigBearPBJ or sigPPD or gz_bearHV or gz_bearGZI

bool bull_hw_slot=sigBullRVOL1x or sigGrandSlam or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bull)
bool bear_hw_slot=sigBearRVOL1x or sigMOAB or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bear)
bool anyBullFloor=conf and bull_pp and sigBullPBJ and bull_hw_slot
bool anyBull2nd=conf and bull_pp and sigBullPB and bull_hw_slot
bool anyBearRoof=conf and bear_pp and sigBearPBJ and bear_hw_slot
bool anyBearPent=conf and bear_pp and sigBearPB and bear_hw_slot

bool hwBull=(close>open) and disp5_bull and sigBullPBJ and (sigGrandSlam or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bull)) and (anyBullFloor or anyBull2nd)
bool hwBear=(close<open) and disp5_bear and sigBearPBJ and (sigMOAB or sigWTC or sigHiroshima or (sigNagasaki and nag_dir_bear)) and (anyBearRoof or anyBearPent)

bool super_hw_bull=sigBullRVOL1x or sigGrandSlam or sigWTC or sigHiroshima or sigNagasaki
bool super_hw_bear=sigBearRVOL1x or sigMOAB or sigWTC or sigHiroshima or sigNagasaki
bool super_comboAny_bull=csNew1_Bull or csNew2_Bull, bool super_comboAny_bear=csNew1_Bear or csNew2_Bear
bool superBull=conf and sigBullPBJ and sigDISPBull and (sigFAUNABull or sigLong1) and super_hw_bull and ((super_comboAny_bull and sigPUP) or (anyBullFloor or anyBull2nd))
bool superBear=conf and sigBearPBJ and sigDISPBear and (sigFAUNABear or sigShort1) and super_hw_bear and ((super_comboAny_bear and sigPPD) or (anyBearRoof or anyBearPent))
bool sduperBull=conf and (anyBullFloor or anyBull2nd) and sigBullPBJ and super_hw_bull and super_comboAny_bull and sigPUP and sigDISPBull and (sigFAUNABull or sigLong1)
bool sduperBear=conf and (anyBearRoof or anyBearPent) and sigBearPBJ and super_hw_bear and super_comboAny_bear and sigPPD and sigDISPBear and (sigFAUNABear or sigShort1)

bool sigGolfBull=conf and sigDISPBull and nz(sigFAUNABull[1]) and nz(sigPUP[1]) and nz(sigDISPBull[1]) and nz(sigFAUNABull[2]) and nz(sigPUP[2])
bool sigGolfBear=conf and sigDISPBear and nz(sigFAUNABear[1]) and nz(sigPPD[1]) and nz(sigDISPBear[1]) and nz(sigFAUNABear[2]) and nz(sigPPD[2])
bool sigPAFBull=conf and sigPUP and sigFAUNABull and nz(sigPUP[1]) and nz(sigFAUNABull[1])
bool sigPAFBear=conf and sigPPD and sigFAUNABear and nz(sigPPD[1]) and nz(sigFAUNABear[1])

bool od_fvg_bull=gz_bullGZI or comboSet1_Bull or comboSet2_Bull or comboSet3_Bull or comboSet4_Bull
bool od_fvg_bear=gz_bearGZI or comboSet1_Bear or comboSet2_Bear or comboSet3_Bear or comboSet4_Bear
bool sigODBull=conf and sessionBarCount<=od_max_bars and od_fvg_bull and disp_prevDisp and sigPUP and sigBullPBJ
bool sigODBear=conf and sessionBarCount<=od_max_bars and od_fvg_bear and disp_prevDisp and sigPPD and sigBearPBJ

bool sigHV75=conf and volume>=ta.highest(volume,75)[1], bool sigHV150=conf and volume>=ta.highest(volume,hv150_len)[1]
bool sigHV500=conf and volume>=ta.highest(volume,500)[1], bool sigHV1000=conf and volume>=ta.highest(volume,1000)[1]

// =============================================================================
// COMBO CHAIN — REWRITTEN as rolling-window of VISUAL plot positions
// At position-offset i (looking back from current bar):
//   • Matrix combo visual at i = csNew2_Bull[i]   (offset=0 plot)
//   • FVG combo visual at i    = csNew1_Bull[i-1] (offset=-1 plot) for i>=1
//   • Unified combo visual at i = csNew3_Bull[i-1] (offset=-1 plot) for i>=1
//
// csNew3_Bull implies csNew1_Bull (csNew3 := csNew1 AND csNew2[1]), so the
// FVG branch already captures Unified visuals. Explicit OR with csNew3
// kept for clarity in tooltip semantics.
// NON-STICKY — fires on the bar where rolling-window threshold is met.
// =============================================================================
int cc_win_bull = 0
bool cc_pbj_bull = false
for i = 0 to cc_window - 1
    bool visual_hit = nz(csNew2_Bull[i])
    if i >= 1
        if nz(csNew1_Bull[i-1]) or nz(csNew3_Bull[i-1])
            visual_hit := true
    if visual_hit
        cc_win_bull += 1
    if nz(sigBullPBJ[i]) or nz(sigBullPB[i])
        cc_pbj_bull := true
bool sigCCBull = conf and cc_win_bull >= cc_min_hits and cc_pbj_bull

int cc_win_bear = 0
bool cc_pbj_bear = false
for i = 0 to cc_window - 1
    bool visual_hit = nz(csNew2_Bear[i])
    if i >= 1
        if nz(csNew1_Bear[i-1]) or nz(csNew3_Bear[i-1])
            visual_hit := true
    if visual_hit
        cc_win_bear += 1
    if nz(sigBearPBJ[i]) or nz(sigBearPB[i])
        cc_pbj_bear := true
bool sigCCBear = conf and cc_win_bear >= cc_min_hits and cc_pbj_bear

// LS Chain
bool lsc_L1=conf and ls_regRatio>lsc_reg1 and ls_cumRatio>lsc_cum1 and close>open and ls_bodyRat>=lsc_body1
bool lsc_S1=conf and ls_regRatio>lsc_reg1 and ls_cumRatio>lsc_cum1 and close<open and ls_bodyRat>=lsc_body1
bool lsc_L2=conf and ls_regRatio>lsc_reg2 and ls_cumRatio>lsc_cum2 and close>open and ls_bodyRat>=lsc_body2
bool lsc_S2=conf and ls_regRatio>lsc_reg2 and ls_cumRatio>lsc_cum2 and close<open and ls_bodyRat>=lsc_body2
int lsc_wb=0
bool lsc_pbj_bull=false
for i=0 to lsc_window-1
    if nz(lsc_L1[i]) or nz(lsc_L2[i])
        lsc_wb+=1
    if nz(sigBullPBJ[i]) or nz(sigBullPB[i])
        lsc_pbj_bull:=true
int lsc_ws=0
bool lsc_pbj_bear=false
for i=0 to lsc_window-1
    if nz(lsc_S1[i]) or nz(lsc_S2[i])
        lsc_ws+=1
    if nz(sigBearPBJ[i]) or nz(sigBearPB[i])
        lsc_pbj_bear:=true
bool sigLSCBull=conf and lsc_wb>=lsc_min_hits and lsc_pbj_bull
bool sigLSCBear=conf and lsc_ws>=lsc_min_hits and lsc_pbj_bear

bool sigNagPlusBull=sigNagasaki and (sigBullRVOL1x or sigGrandSlam or sigFAUNABull or sigDISPBull or sigBullPBJ or sigPUP or gz_bullHV or gz_bullGZI or sigLong1 or anyBullFloor or anyBull2nd)
bool sigNagPlusBear=sigNagasaki and (sigBearRVOL1x or sigMOAB or sigFAUNABear or sigDISPBear or sigBearPBJ or sigPPD or gz_bearHV or gz_bearGZI or sigShort1 or anyBearRoof or anyBearPent)

// === ENGINE 8: UU / UUU / UUUU (Squareify pathways A-F) ===
bool u_qual_bull=conf and bb_baseBullish and bb_normalizedPrice>=0.5
bool u_qual_bear=conf and bb_baseBearish and bb_normalizedPrice>=0.5
var int u_bull_streak=0, var int u_bear_streak=0
var bool u_bull_hasDay1=false, var bool u_bear_hasDay1=false
if conf
    if u_qual_bull
        u_bull_streak+=1
        u_bull_hasDay1:=u_bull_hasDay1 or is_new_day
    else
        u_bull_streak:=0
        u_bull_hasDay1:=false
    if u_qual_bear
        u_bear_streak+=1
        u_bear_hasDay1:=u_bear_hasDay1 or is_new_day
    else
        u_bear_streak:=0
        u_bear_hasDay1:=false
bool rawBullUU=conf and u_bull_streak==2, bool rawBullUUU=conf and u_bull_streak==3, bool rawBullUUUU=conf and u_bull_streak>=4
bool rawBearUU=conf and u_bear_streak==2, bool rawBearUUU=conf and u_bear_streak==3, bool rawBearUUUU=conf and u_bear_streak>=4

f_uu_bull_scan(int _n) =>
    bool _hp=false, bool _hpb=false, bool _hh=false, bool _hd=false, bool _hf=false
    bool _ad=true, bool _asd=true, bool _dnp=false, bool _pnd=false
    for i=0 to _n-1
        bool bpbj=nz(sigBullPBJ[i]), bool bpb=nz(sigBullPB[i])
        bool bhvd=i>=1?nz(hvd_fire_bull[i-1]):false
        bool bdisp=nz(sigDISPBull[i]) or bhvd, bool bfauna=nz(sigFAUNABull[i])
        bool bsaab=nz(sigSAAB[i]) or nz(sigBullRVOL1x[i]) or nz(sigGrandSlam[i])
        bool bdf=bdisp or bfauna
        if bpbj
            _hp:=true
        if bpb
            _hpb:=true
        if bhvd
            _hh:=true
        if bdisp
            _hd:=true
        if bfauna
            _hf:=true
        if not bdisp
            _ad:=false
        if not bsaab or not bdf
            _asd:=false
        if bdf and not bpbj
            _dnp:=true
        if bpbj and not bdf
            _pnd:=true
    [_hp, _hpb, _hh, _hd, _hf, _ad, _asd, _dnp, _pnd]

f_uu_bear_scan(int _n) =>
    bool _hp=false, bool _hpb=false, bool _hh=false, bool _hd=false, bool _hf=false
    bool _ad=true, bool _asd=true, bool _dnp=false, bool _pnd=false
    for i=0 to _n-1
        bool bpbj=nz(sigBearPBJ[i]), bool bpb=nz(sigBearPB[i])
        bool bhvd=i>=1?nz(hvd_fire_bear[i-1]):false
        bool bdisp=nz(sigDISPBear[i]) or bhvd, bool bfauna=nz(sigFAUNABear[i])
        bool bsaab=nz(sigKratos[i]) or nz(sigBearRVOL1x[i]) or nz(sigMOAB[i])
        bool bdf=bdisp or bfauna
        if bpbj
            _hp:=true
        if bpb
            _hpb:=true
        if bhvd
            _hh:=true
        if bdisp
            _hd:=true
        if bfauna
            _hf:=true
        if not bdisp
            _ad:=false
        if not bsaab or not bdf
            _asd:=false
        if bdf and not bpbj
            _dnp:=true
        if bpbj and not bdf
            _pnd:=true
    [_hp, _hpb, _hh, _hd, _hf, _ad, _asd, _dnp, _pnd]

bool sigP21BullUUUU=false, bool sigP21BullUUUU_indep=false
if conf and u_bull_streak>=4
    [hp,hpb,hh,hd,hf,ad,asd,dnp,pnd]=f_uu_bull_scan(math.min(u_bull_streak,4))
    bool pA=u_bull_hasDay1 and hp, bool pB=ad, bool pC=asd, bool pD=hh
    bool pE=(dnp and hp) or (pnd and (hd or hf)), bool pF=(hf or hd) and hp
    float _s=bb_normalizedPrice+nz(bb_normalizedPrice[1])+nz(bb_normalizedPrice[2])+nz(bb_normalizedPrice[3])
    bool _p=nz(sigBullPBJ) or nz(sigBullPBJ[1]) or nz(sigBullPBJ[2]) or nz(sigBullPBJ[3])
    bool _ok=tfSec>120 or (_s>=th_saab_kratos and (_s>=th_1x or _p))
    sigP21BullUUUU:=(pA or pB or pC or pD or pE or pF) and _ok
    sigP21BullUUUU_indep:=(pA or pB or pC or pE or pF) and _ok

bool sigP21BullUUU=false, bool sigP21BullUUU_indep=false
if conf and u_bull_streak==3
    [hp,hpb,hh,hd,hf,ad,asd,dnp,pnd]=f_uu_bull_scan(3)
    bool pA=u_bull_hasDay1 and hp, bool pB=ad, bool pC=asd, bool pD=hh
    bool pE=(dnp and hp) or (pnd and (hd or hf))
    float _s=bb_normalizedPrice+nz(bb_normalizedPrice[1])+nz(bb_normalizedPrice[2])
    bool _p=nz(sigBullPBJ) or nz(sigBullPBJ[1]) or nz(sigBullPBJ[2])
    bool _ok=tfSec>120 or (_s>=th_saab_kratos and (_s>=th_1x or _p))
    sigP21BullUUU:=(pA or pB or pC or pD or pE) and _ok
    sigP21BullUUU_indep:=(pA or pB or pC or pE) and _ok

bool sigUUBull=false, bool sigUUBull_indep=false
if conf and u_bull_streak==2
    [hp,hpb,hh,hd,hf,ad,asd,dnp,pnd]=f_uu_bull_scan(2)
    bool pA=u_bull_hasDay1 and hp, bool pB=ad, bool pC=asd, bool pD=hh and (hpb or hp)
    bool pE=(dnp and hp) or (pnd and (hd or hf))
    float _s=bb_normalizedPrice+nz(bb_normalizedPrice[1])
    bool _p=nz(sigBullPBJ) or nz(sigBullPBJ[1])
    bool _ok=tfSec>120 or (_s>=th_saab_kratos and (_s>=th_1x or _p))
    sigUUBull:=(pA or pB or pC or pD or pE) and _ok
    sigUUBull_indep:=(pA or pB or pC or pE) and _ok

bool sigP21BearUUUU=false, bool sigP21BearUUUU_indep=false
if conf and u_bear_streak>=4
    [hp,hpb,hh,hd,hf,ad,asd,dnp,pnd]=f_uu_bear_scan(math.min(u_bear_streak,4))
    sigP21BearUUUU:=(u_bear_hasDay1 and hp) or ad or asd or hh or ((dnp and hp) or (pnd and (hd or hf))) or ((hf or hd) and hp)
    sigP21BearUUUU_indep:=(u_bear_hasDay1 and hp) or ad or asd or ((dnp and hp) or (pnd and (hd or hf))) or ((hf or hd) and hp)

bool sigP21BearUUU=false, bool sigP21BearUUU_indep=false
if conf and u_bear_streak==3
    [hp,hpb,hh,hd,hf,ad,asd,dnp,pnd]=f_uu_bear_scan(3)
    sigP21BearUUU:=(u_bear_hasDay1 and hp) or ad or asd or hh or ((dnp and hp) or (pnd and (hd or hf)))
    sigP21BearUUU_indep:=(u_bear_hasDay1 and hp) or ad or asd or ((dnp and hp) or (pnd and (hd or hf)))

bool sigUUBear=false, bool sigUUBear_indep=false
if conf and u_bear_streak==2
    [hp,hpb,hh,hd,hf,ad,asd,dnp,pnd]=f_uu_bear_scan(2)
    sigUUBear:=(u_bear_hasDay1 and hp) or ad or asd or (hh and (hpb or hp)) or ((dnp and hp) or (pnd and (hd or hf)))
    sigUUBear_indep:=(u_bear_hasDay1 and hp) or ad or asd or ((dnp and hp) or (pnd and (hd or hf)))

bool oneOfThese_forUU=sigP21BullUUUU or sigP21BullUUU or sigDISPBull or hvd_fire_bull or sigFAUNABull or sigPUP or sigBullPBJ or sigLong1 or sigGrandSlam or sigBullRVOL1x or csNew3_Bull or csNew1_Bull or csNew2_Bull or sigCCBull or sigNagPlusBull or sigDispConsBull2 or sigDispConsBull3
bool uu_gated_bull=sigUUBull and oneOfThese_forUU

bool as_fauna_bull=sigFAUNABull or sigLong1 or sigDISPBull or hvd_fire_bull or sigPUP or sigWTC or sigHiroshima or sigNagasaki
bool as_fauna_bear=sigFAUNABear or sigShort1 or sigDISPBear or hvd_fire_bear or sigPPD or sigWTC or sigHiroshima or sigNagasaki
bool sigAlphaStrikeBull=conf and firstOfDay and bull_pp and (sigGrandSlam or sigBullRVOL1x) and sigBullPBJ and as_fauna_bull
bool sigAlphaStrikeBear=conf and firstOfDay and bear_pp and (sigMOAB or sigBearRVOL1x) and sigBearPBJ and as_fauna_bear

bool oneOfThese=sigP21BullUUUU or sigP21BullUUU or sigUUBull or csNew3_Bull or csNew1_Bull or csNew2_Bull or sigNagPlusBull or sigDispConsBull2 or sigDispConsBull3
bool cb_uu_any=sigP21BullUUUU or sigP21BullUUU or sigUUBull
bool cb_disp9=conf and disp_rng>disp_std*9.0 and close>open
bool cb1_pass_floor=(cb_uu_any) or (csNew3_Bull) or (cb_disp9) or (sigPUP) or (sigLong1)
bool cb1_pass=(cb_uu_any) or (csNew3_Bull) or (cb_disp9) or (sigPUP) or (sigBullPBJ) or (sigLong1)
bool floor_gated=anyBullFloor and oneOfThese and cb1_pass_floor
bool floor2_gated=anyBull2nd and oneOfThese and cb1_pass

// === BOOM HUNTER + OMEGA ===
float bh_K2=0.3, float bh_pi=2*math.asin(1)
float bh_alpha1=(math.cos(.707*2*bh_pi/100)+math.sin(.707*2*bh_pi/100)-1)/math.cos(.707*2*bh_pi/100)
float bh_HP=0.0
bh_HP:=(1-bh_alpha1/2)*(1-bh_alpha1/2)*(close-2*nz(close[1])+nz(close[2]))+2*(1-bh_alpha1)*nz(bh_HP[1])-(1-bh_alpha1)*(1-bh_alpha1)*nz(bh_HP[2])
float bh_a1=math.exp(-1.414*bh_pi/bh_LPPeriod), float bh_b1=2*bh_a1*math.cos(1.414*bh_pi/bh_LPPeriod)
float bh_c2=bh_b1, float bh_c3=-bh_a1*bh_a1, float bh_c1=1-bh_c2-bh_c3
float bh_Filt=0.0
bh_Filt:=bh_c1*(bh_HP+nz(bh_HP[1]))/2+bh_c2*nz(bh_Filt[1])+bh_c3*nz(bh_Filt[2])
float bh_Peak=0.0
bh_Peak:=.991*nz(bh_Peak[1])
if math.abs(bh_Filt)>bh_Peak
    bh_Peak:=math.abs(bh_Filt)
float bh_X=bh_Peak!=0?bh_Filt/bh_Peak:0.0
float bh_Quotient1=(bh_X+bh_K1)/(bh_K1*bh_X+1), float bh_Quotient2=(bh_X+bh_K2)/(bh_K2*bh_X+1)

float bh_HP2=0.0
bh_HP2:=(1-bh_alpha1/2)*(1-bh_alpha1/2)*(close-2*nz(close[1])+nz(close[2]))+2*(1-bh_alpha1)*nz(bh_HP2[1])-(1-bh_alpha1)*(1-bh_alpha1)*nz(bh_HP2[2])
float bh_a12=math.exp(-1.414*bh_pi/bh_LPPeriod2), float bh_b12=2*bh_a12*math.cos(1.414*bh_pi/bh_LPPeriod2)
float bh_c22=bh_b12, float bh_c32=-bh_a12*bh_a12, float bh_c12=1-bh_c22-bh_c32
float bh_Filt2=0.0
bh_Filt2:=bh_c12*(bh_HP2+nz(bh_HP2[1]))/2+bh_c22*nz(bh_Filt2[1])+bh_c32*nz(bh_Filt2[2])
float bh_Peak2=0.0
bh_Peak2:=.991*nz(bh_Peak2[1])
if math.abs(bh_Filt2)>bh_Peak2
    bh_Peak2:=math.abs(bh_Filt2)
float bh_X2=bh_Peak2!=0?bh_Filt2/bh_Peak2:0.0
float bh_Quotient3=(bh_X2+bh_K12)/(bh_K12*bh_X2+1)

bh_src5=hlc3
bh_tci(src)=>ta.ema((src-ta.ema(src,bh_n1))/(0.025*ta.ema(math.abs(src-ta.ema(src,bh_n1)),bh_n1)),bh_n2)+50
bh_mf(src)=>100.0-100.0/(1.0+math.sum(volume*(ta.change(src)<=0?0:src),bh_n3)/math.sum(volume*(ta.change(src)>=0?0:src),bh_n3))
bh_tradition(src)=>math.avg(bh_tci(src),bh_mf(src),ta.rsi(src,bh_n3))

float bh_wt1=bh_tradition(bh_src5), float bh_wt2=ta.sma(bh_wt1,6), float bh_wt3=ta.linreg(bh_wt1,bh_n4,bh_n5)

bool bh_bounceUp=ta.barssince(ta.crossunder(bh_wt2,20))<=1 and ta.crossover(bh_wt2,20)
bool bh_bounceDown=ta.barssince(ta.crossover(bh_wt2,80))<=1 and ta.crossunder(bh_wt2,80)

float bh_q1=bh_Quotient1*60+50, float bh_trigger2=ta.sma(bh_q1,bh_trigno)
bool bh_warn2=ta.crossover(bh_Quotient1,-0.9), bool bh_warn3=ta.crossunder(bh_Quotient1,0.9)
bool bh_enter3=bh_Quotient3<=-0.9 and ta.crossover(bh_q1,bh_trigger2) and ta.barssince(bh_warn2)<=7 and bh_q1<=20 and ta.barssince(ta.crossover(bh_q1,20))<=21
bool bh_enter5=ta.barssince(bh_q1<=0 and ta.crossunder(bh_q1,bh_trigger2))<=5 and ta.crossover(bh_q1,bh_trigger2)
bool bh_enter6=ta.barssince(bh_q1<=20 and ta.crossunder(bh_q1,bh_trigger2))<=11 and ta.crossover(bh_q1,bh_trigger2)
bool bh_enter7=bh_Quotient3<=-0.9 and ta.crossover(bh_q1,bh_trigger2)

bool bh_greyFired=bh_enter6 and bh_q1<=60
bool bh_loneLimeOnly=bh_enter3 and not bh_enter5 and not bh_enter7 and not bh_greyFired
bool bh_anyOmega=(bh_enter3 and bh_enter5 and bh_enter7) or bh_loneLimeOnly or bh_bounceUp or bh_bounceDown

bool bh_senter3=bh_Quotient3>=-0.9 and ta.crossunder(bh_q1,bh_trigger2) and ta.barssince(bh_warn3)<=7 and bh_q1>=99 and ta.barssince(ta.crossover(bh_q1,80))<=21
bool bh_crossunder2=ta.crossunder(bh_q1,bh_trigger2)
bool sigShortPlusPress=conf and bh_senter3 and bh_wt2>=80 and bh_crossunder2

bool omega_cosignal=(tfSec>=45?(sigSAAB or sigPentagon):false) or sigBullRVOL1x or sigGrandSlam or (tfSec>=60?sigBullPBJ:false) or (tfSec>=300?sigBullPB:false) or sigPUP or (tfSec>=300?(gz_bullGZI or gz_bullHV):false) or sigLong1 or sigLong2 or sigP21BullUUUU or sigP21BullUUU or sigUUBull or sigNeoBull or (tfSec>=300?sigTrinityBull:false) or (tfSec>=120?sigHV500:false) or (tfSec>=60?sigHV1000:false) or sigWTC or sigHiroshima or sigNagasaki or sigAlphaStrikeBull or sigFoxtrotBull or comboSet1_Bull or comboSet2_Bull or comboSet3_Bull or comboSet4_Bull or sigDispConsBull2 or sigDispConsBull3 or sigODBull or sigCCBull or sigLSCBull or sigGolfBull or sigPAFBull or anyBullFloor or anyBull2nd or hwBull or superBull or sduperBull
bool sigOmegaLong=conf and bh_anyOmega and omega_cosignal and not sigMOAB and not sigDISPBear

bool omega_cosignal_A=(tfSec>=60?sigBullPBJ:false) or sigP21BullUUUU or anyBullFloor or anyBull2nd or hwBull or superBull or sduperBull or sigAlphaStrikeBull or sigFoxtrotBull or sigODBull or sigDispConsBull3 or sigGolfBull or sigGrandSlam or (sigBullRVOL1x and sigDISPBull)
bool sigOmegaLongA=conf and bh_anyOmega and omega_cosignal_A and not sigMOAB and not sigDISPBear

if conf and (sigP21BullUUUU or sigP21BearUUUU or sigP21BullUUU or sigP21BearUUU or sigUUBull or sigUUBear or sigAlphaStrikeBull or sigAlphaStrikeBear or sigFoxtrotBull or sigFoxtrotBear or sigOmegaLong or sigOmegaLongA or sigODBull or sigODBear or sigDispConsBull2 or sigDispConsBear2 or sigDispConsBull3 or sigDispConsBear3 or csNew1_Bull or csNew1_Bear or csNew2_Bull or csNew2_Bear or csNew3_Bull or csNew3_Bear or anyBullFloor or anyBull2nd or anyBearRoof or anyBearPent or hwBull or hwBear or sigCCBull or sigCCBear or sigLSCBull or sigLSCBear or sigGolfBull or sigGolfBear or sigPAFBull or sigPAFBear or superBull or superBear or sduperBull or sduperBear or sigNagPlusBull or sigNagPlusBear)
    dayDetFired:=true

// ============================================================================
// PIPELINE C FIRE BOOLEANS (show_ AND sig_ AND masterGate)
// ============================================================================
bool fire_BullUUUU=show_BullUUUU and sigP21BullUUUU and masterGate, bool fire_BullUUU=show_BullUUU and sigP21BullUUU and masterGate
bool fire_BullUU=show_BullUU and uu_gated_bull and masterGate
bool fire_AlphaStrikeB=show_AlphaStrikeB and sigAlphaStrikeBull and masterGate, bool fire_FoxtrotB=show_FoxtrotB and sigFoxtrotBull and masterGate
bool fire_OmegaLong=show_OmegaLong and sigOmegaLong and masterGate, bool fire_OmegaLongA=show_OmegaLongA and sigOmegaLongA and masterGate
bool fire_ODBull=show_ODBull and sigODBull and masterGate
bool fire_DispConsBull2=show_DispConsBull2 and sigDispConsBull2 and masterGate, bool fire_DispConsBull3=show_DispConsBull3 and sigDispConsBull3 and masterGate
bool fire_GolfBull=show_GolfBull and sigGolfBull and masterGate, bool fire_PAFBull=show_PAFBull and sigPAFBull and masterGate
bool fire_CS1B=show_CS1B and csNew1_Bull and masterGate, bool fire_CS2B=show_CS2B and csNew2_Bull and masterGate, bool fire_CS3B=show_CS3B and csNew3_Bull and masterGate
bool fire_CCBull=show_CCBull and sigCCBull and masterGate, bool fire_LSCBull=show_LSCBull and sigLSCBull and masterGate
bool fire_BullFloor=show_BullFloor and floor_gated and masterGate, bool fire_Bull2ndFloor=show_Bull2ndFloor and floor2_gated and masterGate
bool fire_HWBull=show_HWBull and hwBull and masterGate, bool fire_SuperBull=show_SuperBull and superBull and masterGate, bool fire_SDuperBull=show_SDuperBull and sduperBull and masterGate
bool fire_NagPlusBull=sigNagPlusBull

bool fire_BearUUUU=show_BearUUUU and sigP21BearUUUU and masterGate, bool fire_BearUUU=show_BearUUU and sigP21BearUUU and masterGate
bool fire_BearUU=show_BearUU and sigUUBear and masterGate
bool fire_AlphaStrikeR=show_AlphaStrikeR and sigAlphaStrikeBear and masterGate, bool fire_FoxtrotR=show_FoxtrotR and sigFoxtrotBear and masterGate
bool fire_ODBear=show_ODBear and sigODBear and masterGate
bool fire_DispConsBear2=show_DispConsBear2 and sigDispConsBear2 and masterGate, bool fire_DispConsBear3=show_DispConsBear3 and sigDispConsBear3 and masterGate
bool fire_GolfBear=show_GolfBear and sigGolfBear and masterGate, bool fire_PAFBear=show_PAFBear and sigPAFBear and masterGate
bool fire_CS1R=show_CS1R and csNew1_Bear and masterGate, bool fire_CS2R=show_CS2R and csNew2_Bear and masterGate, bool fire_CS3R=show_CS3R and csNew3_Bear and masterGate
bool fire_CCBear=show_CCBear and sigCCBear and masterGate, bool fire_LSCBear=show_LSCBear and sigLSCBear and masterGate
bool fire_BearRooftop=show_BearRooftop and anyBearRoof and masterGate, bool fire_BearPent=show_BearPenthouse and anyBearPent and masterGate
bool fire_HWBear=show_HWBear and hwBear and masterGate, bool fire_SuperBear=show_SuperBear and superBear and masterGate, bool fire_SDuperBear=show_SDuperBear and sduperBear and masterGate

// === USE ANY booleans ===
bool use_any_bull = sigP21BullUUUU_indep or sigP21BullUUU_indep or sigUUBull_indep or sigAlphaStrikeBull or sigFoxtrotBull or sigOmegaLong or sigOmegaLongA or sigODBull or sigDispConsBull2 or sigDispConsBull3 or sigGolfBull or sigPAFBull or csNew1_Bull or csNew2_Bull or csNew3_Bull or sigCCBull or sigLSCBull or anyBullFloor or anyBull2nd or hwBull or superBull or sduperBull
bool use_any_bear = sigP21BearUUUU_indep or sigP21BearUUU_indep or sigUUBear_indep or sigAlphaStrikeBear or sigFoxtrotBear or sigODBear or sigDispConsBear2 or sigDispConsBear3 or sigGolfBear or sigPAFBear or csNew1_Bear or csNew2_Bear or csNew3_Bear or sigCCBear or sigLSCBear or anyBearRoof or anyBearPent or hwBear or superBear or sduperBear

// ============================================================================
// HV+D DETECTION TOGGLES — full tooltips
// ============================================================================
grp_hvd_sig = "★★★ HV+D DETECTION TOGGLES ★★★"
bool en_hvd_bull    = input.bool(true, "HV+D Bull",     group=grp_hvd_sig, inline="h1", tooltip="STANDALONE HV+D BULL: bar N-1 showed a candle whose range exceeded (Std Dev × Multiplier) AND bar N completed a bullish FVG (low > high[2], close[1] > open[1]), AND the volume rank on N-1 matched any enabled tier (base 50-1000-bar, or HTF1, or HTF2, or HEV all-time high). Plot offset=-1 marks the candle that fired (N-1). No PBJ/PB required.")
bool en_hvd_bear    = input.bool(true, "HV+D Bear",     group=grp_hvd_sig, inline="h1", tooltip="Bear mirror — bar N-1 bearish displacement + bearish FVG + volume rank hit. No PBJ/PB required.")
bool en_hvd_pb_bull = input.bool(true, "HV+D+PB Bull",  group=grp_hvd_sig, inline="h2", tooltip="HV+D Bull (above) AND PB Bull on N-1 (Zoo VWMA/Supertrend pullback that approached a prior lander/reaccel level, then crossed back up — NOT a PBJ).")
bool en_hvd_pb_bear = input.bool(true, "HV+D+PB Bear",  group=grp_hvd_sig, inline="h2", tooltip="Bear mirror.")
bool en_hvd_pbj_bull= input.bool(true, "HV+D+PBJ Bull", group=grp_hvd_sig, inline="h3", tooltip="HV+D Bull AND PBJ Bull on N-1 (price tagged 20-EMA from below by 3×ATR/close AND made a 25-bar low — the classic PB&J).")
bool en_hvd_pbj_bear= input.bool(true, "HV+D+PBJ Bear", group=grp_hvd_sig, inline="h3", tooltip="Bear mirror.")
bool en_uc_hvd_bull = input.bool(true, "UC+HV+D Bull",  group=grp_hvd_sig, inline="h4", tooltip="UC + HV+D Bull — ANY of {UC+HVD alone, UC+HVD+PB, UC+HVD+PBJ}. UC = any of 22 USE bull detections fired on N-1. PB/PBJ NOT required. Master OR over all three PBJ-states.")
bool en_uc_hvd_bear = input.bool(true, "UC+HV+D Bear",  group=grp_hvd_sig, inline="h4", tooltip="Bear mirror.")

bool hvd_pb_bull  = hvd_fire_bull and nz(sigBullPB[1])
bool hvd_pbj_bull = hvd_fire_bull and nz(sigBullPBJ[1])
bool hvd_pb_bear  = hvd_fire_bear and nz(sigBearPB[1])
bool hvd_pbj_bear = hvd_fire_bear and nz(sigBearPBJ[1])
bool uc_hvd_bull_any = hvd_fire_bull and nz(use_any_bull[1])
bool uc_hvd_bear_any = hvd_fire_bear and nz(use_any_bear[1])

plotshape(en_hvd_bull and hvd_fire_bull and masterGate, "HV+D Bull", shape.triangleup,   location.top, color.new(#00E676, 0), text="HV+D", textcolor=color.white, size=size.small, offset=-1)
plotshape(en_hvd_bear and hvd_fire_bear and masterGate, "HV+D Bear", shape.triangledown, location.bottom, color.new(#FF1744, 0), text="HV+D", textcolor=color.white, size=size.small, offset=-1)
plotshape(en_hvd_pb_bull  and hvd_pb_bull and masterGate,  "PB Bull",  shape.labelup,  location.bottom, color.new(color.aqua, 75),   size=size.small,  text="HV+D\nPB",  textcolor=color.white, offset=-1)
plotshape(en_hvd_pbj_bull and hvd_pbj_bull and masterGate, "PBJ Bull", shape.diamond,  location.bottom, color.new(color.yellow, 25), size=size.normal, text="HV+D\nPBJ", textcolor=color.white, offset=-1)
plotshape(en_hvd_pb_bear  and hvd_pb_bear and masterGate,  "PB Bear",  shape.labeldown, location.top,   color.new(color.orange, 75), size=size.small,  text="HV+D\nPB",  textcolor=color.white, offset=-1)
plotshape(en_hvd_pbj_bear and hvd_pbj_bear and masterGate, "PBJ Bear", shape.diamond,  location.top,    color.new(color.red, 25),    size=size.normal, text="HV+D\nPBJ", textcolor=color.white, offset=-1)
plotshape(en_uc_hvd_bull and uc_hvd_bull_any and masterGate, "UC+HV+D Bull", shape.square, location.bottom, color.new(#FFD700, 0), text="UC\nHV+D", textcolor=color.black, size=size.normal, offset=-1)
plotshape(en_uc_hvd_bear and uc_hvd_bear_any and masterGate, "UC+HV+D Bear", shape.square, location.top, color.new(#FF1744, 0), text="UC\nHV+D", textcolor=color.white, size=size.normal, offset=-1)

if en_hvd_bull and hvd_fire_bull and masterGate and not hvd_pbj_bull and not hvd_pb_bull
    alert("BULL | " + _FIRST + " | HV+D", alert.freq_once_per_bar_close)
if en_hvd_bear and hvd_fire_bear and masterGate and not hvd_pbj_bear and not hvd_pb_bear
    alert("BEAR | " + _FIRST + " | HV+D", alert.freq_once_per_bar_close)
if en_hvd_pbj_bull and hvd_pbj_bull and masterGate
    alert("BULL | " + _FIRST + " | HV+D+PBJ", alert.freq_once_per_bar_close)
if en_hvd_pb_bull and hvd_pb_bull and masterGate
    alert("BULL | " + _FIRST + " | HV+D+PB", alert.freq_once_per_bar_close)
if en_hvd_pbj_bear and hvd_pbj_bear and masterGate
    alert("BEAR | " + _FIRST + " | HV+D+PBJ", alert.freq_once_per_bar_close)
if en_hvd_pb_bear and hvd_pb_bear and masterGate
    alert("BEAR | " + _FIRST + " | HV+D+PB", alert.freq_once_per_bar_close)
if en_uc_hvd_bull and uc_hvd_bull_any and masterGate
    alert("BULL | " + _FIRST + " | UC+HV+D", alert.freq_once_per_bar_close)
if en_uc_hvd_bear and uc_hvd_bear_any and masterGate
    alert("BEAR | " + _FIRST + " | UC+HV+D", alert.freq_once_per_bar_close)

