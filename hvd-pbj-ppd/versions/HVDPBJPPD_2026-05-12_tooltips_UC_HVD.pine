// ╔════════════════════════════════════════════════════════════════════════════════╗
// ║  HV+D ↔ PBJ ↔ USE ALARM — TRIPLE CO-OCCURRENCE  (2026-05-12 build)            ║
// ║                                                                              ║
// ║  v3 CHANGES vs 2026-05-10:                                                   ║
// ║   • Tooltips on EVERY toggle in HV+D Detection / Pipeline D / B2B / HVDM     ║
// ║   • RVOL clarified — RVOL1x OR Grand Slam (bull) / RVOL1x OR MOAB (bear).   ║
// ║     SAAB, Kratos, WTC, Hiroshima, Pentagon, Nagasaki, VPA RVOL EXCLUDED.     ║
// ║   • CS1B/CS1R/CS2B/CS2R plotshapes REMOVED (booleans kept for csNew3+CC).    ║
// ║   • HVDM labels → 2 master plotshapes (no labels permitted anywhere).         ║
// ║   • CC rolling-window restructured: explicit count of visual hits in window. ║
// ║   • 8 new UC+HV+D plotshapes — one bull + one bear in each of the 4 sections.║
// ╠════════════════════════════════════════════════════════════════════════════════╣
// ║                                                                              ║
// ║  ┌────────────────────────────────────────────────────────────────────────┐   ║
// ║  │  DECOUPLED PIPELINE ARCHITECTURE — MANDATORY RULES                   │   ║
// ║  │  PIPELINE A: HV+D   → hvd_fire_bull/bear (volume rank + σ + FVG)    │   ║
// ║  │  PIPELINE B: PB/PBJ → sigBullPBJ/PB, sigBearPBJ/PB                  │   ║
// ║  │  PIPELINE C: USE    → all detection booleans                         │   ║
// ║  │  PIPELINE D: AND-GATE (consumes terminals only, never internals)     │   ║
// ║  │  OFFSET: hvd_fire fires N, describes N-1, plot offset=-1.            │   ║
// ║  │          PBJ/PB[1] aligns to N-1. USE[1] aligns to N-1.              │   ║
// ║  └────────────────────────────────────────────────────────────────────────┘   ║
// ╚════════════════════════════════════════════════════════════════════════════════╝

//@version=5
indicator("HV+D ↔ PBJ ↔ USE — 2026-05-12 build", shorttitle="HVD PBJ PPD v3", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500, max_bars_back=1100)

import TradingView/ta/7 as tv_ta

// ============================================================================
// SHARED
// ============================================================================
conf = barstate.isconfirmed
int tfSec = timeframe.in_seconds(timeframe.period)
f_add(string base, string part) => base == "" ? part : base + " + " + part
atr14 = ta.atr(14)

// ── MASTER TOGGLES ──
grpM = "★ MASTER ★"
bool en_firstBarOnly = input.bool(false, "First Candle of Day Required", group=grpM, tooltip="ON: detection requires first bar of session AND any HV rank (HV50/75/100/150/200/250/300/350/400/450/500/550/600/650/700/750/1000/HEV). OFF: no restriction.")
bool en_aggregate = input.bool(true, "Aggregate Alerts", group=grpM, tooltip="ON: one combined alert per bar. OFF: each detection fires individually.")
bool isFirstBar = session.isfirstbar

// ── GAP CALCULATION ──
var float _prevSessionHigh = na
var float _prevSessionClose = na
bool _sessionChange = session.isfirstbar
if _sessionChange and bar_index > 0
    _prevSessionHigh := high[1]
    _prevSessionClose := close[1]
float _gapDist = _sessionChange and not na(_prevSessionHigh) ? math.abs(low - _prevSessionHigh) : 0.0
float _barRange = high - low
bool _gapExceedsRange = _gapDist > _barRange and _barRange > 0
string _FIRST = not isFirstBar ? "NOT !!!" : _gapExceedsRange ? "FIRST XXX" : "FIRST !!!"

// ── FIRST BAR ONLY GATE: requires first bar AND any HV rank ──
bool _anyHV_bar0 = volume == ta.highest(volume, 50) or volume == ta.highest(volume, 75) or volume == ta.highest(volume, 100) or volume == ta.highest(volume, 150) or volume == ta.highest(volume, 200) or volume == ta.highest(volume, 250) or volume == ta.highest(volume, 300) or volume == ta.highest(volume, 350) or volume == ta.highest(volume, 400) or volume == ta.highest(volume, 450) or volume == ta.highest(volume, 500) or volume == ta.highest(volume, 550) or volume == ta.highest(volume, 600) or volume == ta.highest(volume, 650) or volume == ta.highest(volume, 700) or volume == ta.highest(volume, 750) or volume == ta.highest(volume, 1000)
bool masterGate = not en_firstBarOnly or (isFirstBar and _anyHV_bar0)

// ============================================================================
// PIPELINE A — HV+D (HIGH VOLUME + DISPLACEMENT)
// ============================================================================
hvd_tf2sec(string t) =>
    switch t
        "1 Min"=>60
        "2 Min"=>120
        "3 Min"=>180
        "4 Min"=>240
        "5 Min"=>300
        "10 Min"=>600
        "15 Min"=>900
        "30 Min"=>1800
        "1 Hour"=>3600
        "2 Hour"=>7200
        "3 Hour"=>10800
        "4 Hour"=>14400
        "1 Day"=>86400
        "2 Day"=>172800
        "3 Day"=>259200
        "1 Week"=>604800
        "1 Month"=>2592000
        "3 Month"=>7776000
        => 0

grp_hvd1 = "── HV+D: DISP BASE ──"
d1_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_hvd1)
d1_len  = input.int(100, "Std Dev Length", minval=1, group=grp_hvd1)
d1_mult = input.float(5.0, "Std Dev Multiplier", minval=0.1, step=0.1, group=grp_hvd1)
float d1_rng = d1_type == "Open to Close" ? math.abs(open - close) : high - low
float d1_std = ta.stdev(d1_rng, d1_len)
bool  d1_prevDisp = d1_rng[1] > d1_std[1] * d1_mult
bool  d1_bullFVG  = low > high[2] and close[1] > open[1]
bool  d1_bearFVG  = high < low[2] and close[1] < open[1]
bool  d1_bull = conf and d1_prevDisp and d1_bullFVG
bool  d1_bear = conf and d1_prevDisp and d1_bearFVG

grp_hvd2 = "── HV+D: DISP HTF1 ──"
d2_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_hvd2)
d2_len  = input.int(100, "Std Dev Length", minval=1, group=grp_hvd2)
d2_mult = input.float(4.0, "Std Dev Multiplier", minval=0.1, step=0.1, group=grp_hvd2)
float d2_rng = d2_type == "Open to Close" ? math.abs(open - close) : high - low
float d2_std = ta.stdev(d2_rng, d2_len)
bool  d2_prevDisp = d2_rng[1] > d2_std[1] * d2_mult
bool  d2_bullFVG  = low > high[2] and close[1] > open[1]
bool  d2_bearFVG  = high < low[2] and close[1] < open[1]
bool  d2_bull = conf and d2_prevDisp and d2_bullFVG
bool  d2_bear = conf and d2_prevDisp and d2_bearFVG

grp_hvd3 = "── HV+D: DISP HTF2 ──"
d3_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_hvd3)
d3_len  = input.int(100, "Std Dev Length", minval=1, group=grp_hvd3)
d3_mult = input.float(2.5, "Std Dev Multiplier", minval=0.1, step=0.1, group=grp_hvd3)
float d3_rng = d3_type == "Open to Close" ? math.abs(open - close) : high - low
float d3_std = ta.stdev(d3_rng, d3_len)
bool  d3_prevDisp = d3_rng[1] > d3_std[1] * d3_mult
bool  d3_bullFVG  = low > high[2] and close[1] > open[1]
bool  d3_bearFVG  = high < low[2] and close[1] < open[1]
bool  d3_bull = conf and d3_prevDisp and d3_bullFVG
bool  d3_bear = conf and d3_prevDisp and d3_bearFVG

string grpHVBase = "── HV+D: BASE HV ──"
bool ub50=input.bool(true,"50-Bar",group=grpHVBase), bool ub75=input.bool(true,"75-Bar",group=grpHVBase), bool ub100=input.bool(true,"100-Bar",group=grpHVBase), bool ub150=input.bool(true,"150-Bar",group=grpHVBase), bool ub200=input.bool(true,"200-Bar",group=grpHVBase), bool ub250=input.bool(true,"250-Bar",group=grpHVBase), bool ub300=input.bool(true,"300-Bar",group=grpHVBase), bool ub350=input.bool(true,"350-Bar",group=grpHVBase), bool ub400=input.bool(true,"400-Bar",group=grpHVBase), bool ub450=input.bool(true,"450-Bar",group=grpHVBase), bool ub500=input.bool(true,"500-Bar",group=grpHVBase), bool ub550=input.bool(true,"550-Bar",group=grpHVBase), bool ub600=input.bool(true,"600-Bar",group=grpHVBase), bool ub650=input.bool(true,"650-Bar",group=grpHVBase), bool ub700=input.bool(true,"700-Bar",group=grpHVBase), bool ub750=input.bool(true,"750-Bar",group=grpHVBase), bool ub1000=input.bool(true,"1000-Bar",group=grpHVBase), bool useHEV=input.bool(true,"All-Time High Volume (HEV)",group=grpHVBase)

string grpHTF1 = "── HV+D: HTF1 ──"
bool h1On=input.bool(true,"Enable HTF Profile 1",group=grpHTF1)
string h1From=input.string("15 Min","From TF",group=grpHTF1,options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
string h1To=input.string("2 Hour","To TF",group=grpHTF1,options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
bool uh1_5=input.bool(false,"5-Bar",group=grpHTF1), bool uh1_10=input.bool(false,"10-Bar",group=grpHTF1), bool uh1_20=input.bool(true,"20-Bar",group=grpHTF1), bool uh1_25=input.bool(true,"25-Bar",group=grpHTF1), bool uh1_30=input.bool(true,"30-Bar",group=grpHTF1), bool uh1_40=input.bool(true,"40-Bar",group=grpHTF1), bool uh1_50=input.bool(true,"50-Bar",group=grpHTF1), bool uh1_60=input.bool(true,"60-Bar",group=grpHTF1), bool uh1_70=input.bool(true,"70-Bar",group=grpHTF1), bool uh1_75=input.bool(true,"75-Bar",group=grpHTF1), bool uh1_80=input.bool(true,"80-Bar",group=grpHTF1), bool uh1_90=input.bool(true,"90-Bar",group=grpHTF1)

string grpHTF2 = "── HV+D: HTF2 ──"
bool h2On=input.bool(true,"Enable HTF Profile 2",group=grpHTF2)
string h2From=input.string("2 Hour","From TF",group=grpHTF2,options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
string h2To=input.string("3 Month","To TF",group=grpHTF2,options=["1 Min","2 Min","3 Min","4 Min","5 Min","10 Min","15 Min","30 Min","1 Hour","2 Hour","3 Hour","4 Hour","1 Day","2 Day","3 Day","1 Week","1 Month","3 Month"])
bool uh2_5=input.bool(true,"5-Bar",group=grpHTF2), bool uh2_10=input.bool(true,"10-Bar",group=grpHTF2), bool uh2_20=input.bool(true,"20-Bar",group=grpHTF2), bool uh2_25=input.bool(true,"25-Bar",group=grpHTF2), bool uh2_30=input.bool(true,"30-Bar",group=grpHTF2), bool uh2_40=input.bool(true,"40-Bar",group=grpHTF2), bool uh2_50=input.bool(true,"50-Bar",group=grpHTF2), bool uh2_60=input.bool(true,"60-Bar",group=grpHTF2), bool uh2_70=input.bool(true,"70-Bar",group=grpHTF2), bool uh2_75=input.bool(true,"75-Bar",group=grpHTF2), bool uh2_80=input.bool(true,"80-Bar",group=grpHTF2), bool uh2_90=input.bool(true,"90-Bar",group=grpHTF2)

bool htf1Active = h1On and tfSec >= hvd_tf2sec(h1From) and tfSec <= hvd_tf2sec(h1To)
bool htf2Active = h2On and tfSec >= hvd_tf2sec(h2From) and tfSec <= hvd_tf2sec(h2To)

bool is50=volume[1]==ta.highest(volume,50)[1], bool is75=volume[1]==ta.highest(volume,75)[1], bool is100=volume[1]==ta.highest(volume,100)[1], bool is150=volume[1]==ta.highest(volume,150)[1], bool is200=volume[1]==ta.highest(volume,200)[1], bool is250=volume[1]==ta.highest(volume,250)[1], bool is300=volume[1]==ta.highest(volume,300)[1], bool is350=volume[1]==ta.highest(volume,350)[1], bool is400=volume[1]==ta.highest(volume,400)[1], bool is450=volume[1]==ta.highest(volume,450)[1], bool is500=volume[1]==ta.highest(volume,500)[1], bool is550=volume[1]==ta.highest(volume,550)[1], bool is600=volume[1]==ta.highest(volume,600)[1], bool is650=volume[1]==ta.highest(volume,650)[1], bool is700=volume[1]==ta.highest(volume,700)[1], bool is750=volume[1]==ta.highest(volume,750)[1], bool is1000=volume[1]==ta.highest(volume,1000)[1]
bool isH5=volume[1]==ta.highest(volume,5)[1], bool isH10=volume[1]==ta.highest(volume,10)[1], bool isH20=volume[1]==ta.highest(volume,20)[1], bool isH25=volume[1]==ta.highest(volume,25)[1], bool isH30=volume[1]==ta.highest(volume,30)[1], bool isH40=volume[1]==ta.highest(volume,40)[1], bool isH50=volume[1]==ta.highest(volume,50)[1], bool isH60=volume[1]==ta.highest(volume,60)[1], bool isH70=volume[1]==ta.highest(volume,70)[1], bool isH75=volume[1]==ta.highest(volume,75)[1], bool isH80=volume[1]==ta.highest(volume,80)[1], bool isH90=volume[1]==ta.highest(volume,90)[1]

var float maxVolEver = 0.0
bool isHEV = false
if volume[1] > maxVolEver
    maxVolEver := volume[1]
    isHEV := true

int baseRank = is1000?1000:is750?750:is700?700:is650?650:is600?600:is550?550:is500?500:is450?450:is400?400:is350?350:is300?300:is250?250:is200?200:is150?150:is100?100:is75?75:is50?50:0
int h1Rank = not htf1Active?0:uh1_90 and isH90?90:uh1_80 and isH80?80:uh1_75 and isH75?75:uh1_70 and isH70?70:uh1_60 and isH60?60:uh1_50 and isH50?50:uh1_40 and isH40?40:uh1_30 and isH30?30:uh1_25 and isH25?25:uh1_20 and isH20?20:uh1_10 and isH10?10:uh1_5 and isH5?5:0
int h2Rank = not htf2Active?0:uh2_90 and isH90?90:uh2_80 and isH80?80:uh2_75 and isH75?75:uh2_70 and isH70?70:uh2_60 and isH60?60:uh2_50 and isH50?50:uh2_40 and isH40?40:uh2_30 and isH30?30:uh2_25 and isH25?25:uh2_20 and isH20?20:uh2_10 and isH10?10:uh2_5 and isH5?5:0

bool base_enabled = (ub50 and baseRank==50) or (ub75 and baseRank==75) or (ub100 and baseRank==100) or (ub150 and baseRank==150) or (ub200 and baseRank==200) or (ub250 and baseRank==250) or (ub300 and baseRank==300) or (ub350 and baseRank==350) or (ub400 and baseRank==400) or (ub450 and baseRank==450) or (ub500 and baseRank==500) or (ub550 and baseRank==550) or (ub600 and baseRank==600) or (ub650 and baseRank==650) or (ub700 and baseRank==700) or (ub750 and baseRank==750) or (ub1000 and baseRank==1000)
bool hev_hit = useHEV and isHEV
bool base_hv_hit = hev_hit or (base_enabled and not isHEV)
bool hvd_fire_bull = (base_hv_hit and d1_bull) or (h1Rank>0 and d2_bull) or (h2Rank>0 and d3_bull)
bool hvd_fire_bear = (base_hv_hit and d1_bear) or (h1Rank>0 and d2_bear) or (h2Rank>0 and d3_bear)

// ============================================================================
// PIPELINES B + C: USE ALARM
// ============================================================================
bb_avgLength = 30, bb_smaLength = 20
reg_anchorTimeframe = "", reg_length = 30, reg_calculationMode = "Cumulative", reg_adjustRealtime = true
fauna_gg_master = true, fauna_gg_body = 0.80

// === DETECTION TOGGLES ===
grp_t1 = "★ TIER 1 ★"
show_BullUUUU=input.bool(true,"Bull UUUU",group=grp_t1,inline="a",tooltip="4 consecutive bullish bars + must include first bar of trading day + PBJ on at least one bar + displacement on at least one bar.")
