// ╔════════════════════════════════════════════════════════════════════════════╗
// ║  PB & PBJ — 4 Dedicated Signals                                         ║
// ║  Extracted from: Yin Yang + Displacement + PBJ (YY+D+PBJ)               ║
// ║                                                                          ║
// ║  ENGINE: OKEH Zoo Engine + OKEH PB&J Filter + OKEH Supertrend            ║
// ║  ALL DEFAULT SETTINGS PRESERVED                                          ║
// ║                                                                          ║
// ║  ┌──────────────────────────────────────────────────────────────────┐     ║
// ║  │  SIGNAL REGISTRY                                                │     ║
// ║  │  ─────────────────                                              │     ║
// ║  │  Sig #1 — Bull PB     │ offset = 0 │ belowbar │ labelup  aqua  │     ║
// ║  │  Sig #2 — Bull PBJ    │ offset = 0 │ belowbar │ diamond yellow │     ║
// ║  │  Sig #3 — Bear PB     │ offset = 0 │ abovebar │ labeldown org  │     ║
// ║  │  Sig #4 — Bear PBJ    │ offset = 0 │ abovebar │ labeldown red  │     ║
// ║  └──────────────────────────────────────────────────────────────────┘     ║
// ║                                                                          ║
// ║  ┌──────────────────────────────────────────────────────────────────┐     ║
// ║  │  OFFSET REGISTRY                                                │     ║
// ║  │  ───────────────                                                │     ║
// ║  │  ALL FOUR SIGNALS: offset = 0                                   │     ║
// ║  │  Signals fire on the CURRENT confirmed bar.                     │     ║
// ║  │  No lookback shift. No future shift. Zero offset.               │     ║
// ║  │  Plot bar === Alert bar === Condition bar. Always.               │     ║
// ║  └──────────────────────────────────────────────────────────────────┘     ║
// ║                                                                          ║
// ║  NON-REPAINTING GUARANTEE:                                               ║
// ║  • All signals gated by barstate.isconfirmed                             ║
// ║  • All alerts fire alert.freq_once_per_bar_close                         ║
// ║  • 1:1 parity: plotted signal ↔ alert log. Indivisible.                  ║
// ╚════════════════════════════════════════════════════════════════════════════╝

//@version=5
indicator("PB & PBJ — 4 Signals PB PBJ ONLY THIS", shorttitle="PBJ pb ONLY THIS", overlay=true, max_labels_count=500, max_bars_back=3000)


// ============================================================================
// INPUTS — OKEH Zoo Engine  (defaults preserved)
// ============================================================================
grp_eng = "OKEH — Zoo Engine"
zoo_ma_type   = input.string("VWMA", "Base MA Type", options=["VWMA","EMA","SMA","WMA","HMA"], group=grp_eng)
zoo_ma_len    = input.int(5, "Base MA Length", minval=1, group=grp_eng)
zoo_price_src = input.source(close, "Price Source", group=grp_eng)


// ============================================================================
// INPUTS — OKEH PB&J Filter  (defaults preserved)
// ============================================================================
grp_pbj_filter = "OKEH — PB&J Filter"
zoo_pbj_ma_period   = input.int(20,   "MA Period",          minval=1,          group=grp_pbj_filter)
zoo_pbj_atr_period  = input.int(14,   "ATR Period",         minval=1,          group=grp_pbj_filter)
zoo_pbj_hh_ll       = input.int(25,   "HH/LL Lookback",    minval=1,          group=grp_pbj_filter)
zoo_pbj_atr_mult    = input.float(3.0,"ATR Multiplier",     step=0.1,         group=grp_pbj_filter)
zoo_pbj_vol_period  = input.int(20,   "Volume MA Period",   minval=1,          group=grp_pbj_filter)
zoo_pbj_vol_mult    = input.float(0.1,"Volume Multiplier",  step=0.1,         group=grp_pbj_filter)


// ============================================================================
// INPUTS — OKEH Supertrend  (defaults preserved)
// ============================================================================
grp_st = "OKEH — Supertrend"
zoo_use_st    = input.bool(true,  "Apply ATR Supertrend", group=grp_st)
zoo_st_period = input.int(10,     "ATR Period",           group=grp_st)
zoo_st_mult   = input.float(2.0,  "Multiplier",           group=grp_st)


// ============================================================================
// INPUTS — Plot Toggles  (all ON by default)
// ============================================================================
grp_plots = "★ Signal Plot Toggles ★"
show_BullPB   = input.bool(true, "Plot: Bull PB",   group=grp_plots, inline="pt")
show_BullPBJ  = input.bool(true, "Plot: Bull PBJ",  group=grp_plots, inline="pt")
show_BearPB   = input.bool(true, "Plot: Bear PB",   group=grp_plots, inline="pt2")
show_BearPBJ  = input.bool(true, "Plot: Bear PBJ",  group=grp_plots, inline="pt2")


// ============================================================================
// INPUTS — Alert Toggles  (all ON by default)
// ============================================================================
grp_alerts = "★ Signal Alert Toggles ★"
alert_BullPB   = input.bool(true, "Alert: Bull PB",   group=grp_alerts, inline="at")
alert_BullPBJ  = input.bool(true, "Alert: Bull PBJ",  group=grp_alerts, inline="at")
alert_BearPB   = input.bool(true, "Alert: Bear PB",   group=grp_alerts, inline="at2")
alert_BearPBJ  = input.bool(true, "Alert: Bear PBJ",  group=grp_alerts, inline="at2")


// ============================================================================
// INPUTS — Alert Multiplexer
// ============================================================================
grp_mux = "★ Alert Multiplexer ★"
mux_choice = input.string("All Signals", "Multiplexer Signal Select",
     options=["All Signals", "Bull PB", "Bull PBJ", "Bear PB", "Bear PBJ",
              "Bull Only", "Bear Only", "PB Only", "PBJ Only"],
     group=grp_mux,
     tooltip="Select which signal(s) the multiplexed alert() fires for.")


// ============================================================================
// ENGINE — Zoo Moving Average
// ============================================================================
f_ma(src, len, t) =>
    switch t
        "EMA"  => ta.ema(src, len)
        "SMA"  => ta.sma(src, len)
        "WMA"  => ta.wma(src, len)
        "HMA"  => ta.hma(src, len)
        "VWMA" => ta.vwma(src, len)
        => ta.sma(src, len)

float base_ma = f_ma(zoo_price_src, zoo_ma_len, zoo_ma_type)


// ============================================================================
// ENGINE — Supertrend
// ============================================================================
float st_atr     = zoo_st_mult * ta.atr(zoo_st_period)
float dyn_long   = base_ma - st_atr
float dyn_short  = base_ma + st_atr

var int st_dir   = 1
float sig_line   = 0.0
float curr_long  = 0.0
curr_long  := base_ma > nz(curr_long[1], dyn_long)   ? math.max(dyn_long, nz(curr_long[1]))   : dyn_long
float curr_short = 0.0
curr_short := base_ma < nz(curr_short[1], dyn_short) ? math.min(dyn_short, nz(curr_short[1])) : dyn_short

if zoo_use_st
    if nz(st_dir[1]) == -1 and zoo_price_src > nz(curr_short[1])
        st_dir := 1
    else if nz(st_dir[1]) == 1 and zoo_price_src < nz(curr_long[1])
        st_dir := -1
    sig_line := st_dir == 1 ? curr_long : curr_short
else
    sig_line := base_ma


// ============================================================================
// ENGINE — Crossovers & Re-acceleration
// ============================================================================
bool buy_cross    = ta.crossover(zoo_price_src, sig_line)
bool sell_cross   = ta.crossunder(zoo_price_src, sig_line)
bool is_rising    = sig_line > nz(sig_line[1])
bool is_falling   = sig_line < nz(sig_line[1])
bool bull_reaccel = st_dir == 1  and is_rising  and nz(sig_line[1]) == nz(sig_line[2])
bool bear_reaccel = st_dir == -1 and is_falling and nz(sig_line[1]) == nz(sig_line[2])


// ============================================================================
// ENGINE — PB&J Filter
// ============================================================================
float pbj_ma  = ta.ema(close, zoo_pbj_ma_period)
float pbj_atr = ta.atr(zoo_pbj_atr_period)
float avg_vol = ta.sma(volume, zoo_pbj_vol_period)
float thresh  = close == 0 ? 0 : (pbj_atr / close * zoo_pbj_atr_mult)

bool pbj_buy  = low  < pbj_ma * (1 - thresh) and low  == ta.lowest(low, zoo_pbj_hh_ll)   and volume > avg_vol * zoo_pbj_vol_mult
bool pbj_sell = high > pbj_ma * (1 + thresh) and high == ta.highest(high, zoo_pbj_hh_ll) and volume > avg_vol * zoo_pbj_vol_mult


// ============================================================================
// ENGINE — Level Management (PB zones)
// ============================================================================
type lvl
    float upper
    float lower
    float vol
    bool  approached

float atr_pb = ta.atr(14) * 2.0

var bull_lvls = array.new<lvl>()
var bear_lvls = array.new<lvl>()

f_add_lvl(arr, up, lo, v) =>
    if math.abs(up - lo) >= syminfo.mintick
        array.push(arr, lvl.new(up, lo, v, false))

f_add_lander(is_bull, cross, arr) =>
    if cross
        float up = 0.0
        float lo = 0.0
        if is_bull
            up := math.max(open[1], close[1])
            lo := low[1]
            if up - lo < atr_pb * 0.5
                up := lo + atr_pb * 0.5
        else
            up := high[1]
            lo := math.min(open[1], close[1])
            if up - lo < atr_pb * 0.5
                lo := up - atr_pb * 0.5
        f_add_lvl(arr, up, lo, volume[1])

f_add_reaccel(is_bull, sig, arr) =>
    if sig and not na(sig_line)
        float p1 = sig_line
        float p2 = is_bull ? math.min(open, close) : math.max(open, close)
        f_add_lvl(arr, math.max(p1, p2), math.min(p1, p2), volume)

f_check_approach(arr, is_bull) =>
    bool approached = false
    if array.size(arr) > 0
        for i = array.size(arr) - 1 to 0
            if i >= array.size(arr)
                continue
            l = array.get(arr, i)
            if is_bull and close < l.lower
                array.remove(arr, i)
                continue
            if not is_bull and close > l.upper
                array.remove(arr, i)
                continue
            float ap = is_bull ? l.upper * 1.005 : l.lower * 0.995
            if is_bull
                if not l.approached and low <= ap
                    approached := true
                    l.approached := true
                else if l.approached and low > l.upper
                    l.approached := false
            else
                if not l.approached and high >= ap
                    approached := true
                    l.approached := true
                else if l.approached and high < l.lower
                    l.approached := false
    approached

f_add_lander(true,  buy_cross,  bull_lvls)
f_add_lander(false, sell_cross, bear_lvls)
f_add_reaccel(true,  bull_reaccel, bull_lvls)
f_add_reaccel(false, bear_reaccel, bear_lvls)

var bool wait_buy      = false
var bool wait_sell     = false
var bool wait_pbj_buy  = false
var bool wait_pbj_sell = false

if barstate.isconfirmed
    if f_check_approach(bull_lvls, true)
        wait_buy := true
    if f_check_approach(bear_lvls, false)
        wait_sell := true

if pbj_buy
    wait_pbj_buy := true
if pbj_sell
    wait_pbj_sell := true

while array.size(bull_lvls) > 30
    array.shift(bull_lvls)
while array.size(bear_lvls) > 30
    array.shift(bear_lvls)


// ============================================================================
// RAW SIGNAL BOOLS (pre-confirmation intermediate)
// ============================================================================
bool sig_pb_buy   = buy_cross and wait_buy
bool sig_pbj_buy  = buy_cross and wait_pbj_buy
bool sig_pb_sell  = sell_cross and wait_sell
bool sig_pbj_sell = sell_cross and wait_pbj_sell

if sig_pb_buy
    wait_buy     := false
if sig_pbj_buy
    wait_pbj_buy := false
if sig_pb_sell
    wait_sell     := false
if sig_pbj_sell
    wait_pbj_sell := false


// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                                                                          ║
// ║  DEDICATED SIGNAL BOOLS — THE FOUR PILLARS                               ║
// ║                                                                          ║
// ║  Each bool is indivisible. One candle. One truth. Zero ambiguity.        ║
// ║  barstate.isconfirmed gates every signal for non-repainting guarantee.   ║
// ║                                                                          ║
// ╚════════════════════════════════════════════════════════════════════════════╝


// ──────────────────────────────────────────────────────────────────────────────
// SIG #1 — BULL PB  │  offset = 0  │  belowbar  │  labelup  │  aqua
// ──────────────────────────────────────────────────────────────────────────────
bool sigBullPB  = barstate.isconfirmed and sig_pb_buy and not sig_pbj_buy

// ──────────────────────────────────────────────────────────────────────────────
// SIG #2 — BULL PBJ  │  offset = 0  │  belowbar  │  diamond  │  yellow
// ──────────────────────────────────────────────────────────────────────────────
bool sigBullPBJ = barstate.isconfirmed and sig_pbj_buy

// ──────────────────────────────────────────────────────────────────────────────
// SIG #3 — BEAR PB  │  offset = 0  │  abovebar  │  labeldown  │  orange
// ──────────────────────────────────────────────────────────────────────────────
bool sigBearPB  = barstate.isconfirmed and sig_pb_sell and not sig_pbj_sell

// ──────────────────────────────────────────────────────────────────────────────
// SIG #4 — BEAR PBJ  │  offset = 0  │  abovebar  │  labeldown  │  red
// ──────────────────────────────────────────────────────────────────────────────
bool sigBearPBJ = barstate.isconfirmed and sig_pbj_sell


// ============================================================================
// sigAny — UNIFIED ANY-SIGNAL FLAG
// ============================================================================
bool sigAny = sigBullPB or sigBullPBJ or sigBearPB or sigBearPBJ


// ============================================================================
// PLOTS — SOVEREIGN SHAPES  (offset = 0 on all four)
// Each plotshape is gated by its dedicated bool AND its plot toggle.
// ============================================================================

// SIG #1 — BULL PB  │  offset = 0
plotshape(show_BullPB  and sigBullPB,  title="Sig#1 Bull PB",  style=shape.labelup,   location=location.bottom, color=color.new(color.aqua, 75),   size=size.small,  text="PB",  textcolor=color.white, offset=0)

// SIG #2 — BULL PBJ  │  offset = 0
plotshape(show_BullPBJ and sigBullPBJ, title="Sig#2 Bull PBJ", style=shape.diamond,   location=location.bottom, color=color.new(color.yellow, 25), size=size.normal, text="PBJ", textcolor=color.white, offset=0)

// SIG #3 — BEAR PB  │  offset = 0
plotshape(show_BearPB  and sigBearPB,  title="Sig#3 Bear PB",  style=shape.labeldown, location=location.top, color=color.new(color.orange, 75),  size=size.small,  text="PB",  textcolor=color.white, offset=0)

// SIG #4 — BEAR PBJ  │  offset = 0
plotshape(show_BearPBJ and sigBearPBJ, title="Sig#4 Bear PBJ", style=shape.diamond, location=location.top, color=color.new(color.red, 25),     size=size.normal, text="PBJ", textcolor=color.white, offset=0)


// ============================================================================
// INDIVIDUAL ALERTS — alertcondition() per signal
// Each fires ONLY when its dedicated bool AND its alert toggle are true.
// ============================================================================
alertcondition(alert_BullPB  and sigBullPB,  title="Sig#1 Bull PB",  message="🟢 Bull PB fired")
alertcondition(alert_BullPBJ and sigBullPBJ, title="Sig#2 Bull PBJ", message="🟢 Bull PBJ fired")
alertcondition(alert_BearPB  and sigBearPB,  title="Sig#3 Bear PB",  message="🔴 Bear PB fired")
alertcondition(alert_BearPBJ and sigBearPBJ, title="Sig#4 Bear PBJ", message="🔴 Bear PBJ fired")
alertcondition(sigAny,                        title="ANY Signal",     message="Signal fired — check chart")


// ============================================================================
// f_getAny() — Returns true if ANY signal fired this confirmed bar
// ============================================================================
f_getAny() =>
    sigBullPB or sigBullPBJ or sigBearPB or sigBearPBJ


// ============================================================================
// f_getAll() — Returns full name string + count of every signal that fired
// ============================================================================
f_getAll() =>
    int   _count = 0
    string _msg  = ""
    if sigBullPB
        _count += 1
        _msg   += "Sig#1 Bull PB | "
    if sigBullPBJ
        _count += 1
        _msg   += "Sig#2 Bull PBJ | "
    if sigBearPB
        _count += 1
        _msg   += "Sig#3 Bear PB | "
    if sigBearPBJ
        _count += 1
        _msg   += "Sig#4 Bear PBJ | "
    [_msg, _count]


// ============================================================================
// AGGREGATED ALERT — dynamic alert() with full detail string
// Fires alert.freq_once_per_bar_close — 1:1 parity with plot.
// ============================================================================
[allMsg, allCount] = f_getAll()

if allCount > 0
    alert("PB/PBJ [" + str.tostring(allCount) + "] → " + allMsg, alert.freq_once_per_bar_close)


// ============================================================================
// MULTIPLEXER ALERT — fires only for the user-selected signal(s)
// Uses alert.freq_once_per_bar_close — 1:1 parity guaranteed.
// ============================================================================
bool mux_fire = switch mux_choice
    "Bull PB"      => alert_BullPB  and sigBullPB
    "Bull PBJ"     => alert_BullPBJ and sigBullPBJ
    "Bear PB"      => alert_BearPB  and sigBearPB
    "Bear PBJ"     => alert_BearPBJ and sigBearPBJ
    "Bull Only"    => (alert_BullPB and sigBullPB) or (alert_BullPBJ and sigBullPBJ)
    "Bear Only"    => (alert_BearPB and sigBearPB) or (alert_BearPBJ and sigBearPBJ)
    "PB Only"      => (alert_BullPB and sigBullPB) or (alert_BearPB and sigBearPB)
    "PBJ Only"     => (alert_BullPBJ and sigBullPBJ) or (alert_BearPBJ and sigBearPBJ)
    "All Signals"  => sigAny
    => sigAny

string mux_msg = ""
if mux_fire
    if mux_choice == "All Signals" or mux_choice == "Bull Only" or mux_choice == "Bear Only" or mux_choice == "PB Only" or mux_choice == "PBJ Only"
        mux_msg := allMsg
    else
        mux_msg := mux_choice
    mux_msg

if mux_fire and mux_msg != ""
    alert("MUX [" + mux_choice + "] → " + mux_msg, alert.freq_once_per_bar_close)


// ============================================================================
// NOTE: Supertrend calculation is fully active (sig_line, st_dir, curr_long,
// curr_short, buy_cross, sell_cross, bull_reaccel, bear_reaccel).
// No plotted line — by design. The engine runs; the line does not draw.
// ============================================================================


// ╔════════════════════════════════════════════════════════════════════════════╗
// ║  AUDIT CHECKLIST — every requirement accounted for                        ║
// ║                                                                          ║
// ║  ✅ Signal registry       — header block, 4 signals numbered #1-#4       ║
// ║  ✅ Offset registry       — header block, all four = offset 0            ║
// ║  ✅ Dedicated bool        — sigBullPB, sigBullPBJ, sigBearPB, sigBearPBJ ║
// ║  ✅ Section header+offset — stamped on every signal section              ║
// ║  ✅ Plot sovereignty      — unique shape/location/color/size/text/offset ║
// ║  ✅ Plot toggle (on)      — show_BullPB, show_BullPBJ, etc.             ║
// ║  ✅ Alert toggle (on)     — alert_BullPB, alert_BullPBJ, etc.           ║
// ║  ✅ Individual alert      — 4x alertcondition + 1x ANY                  ║
// ║  ✅ Aggregated alert      — dynamic alert() with name+count string      ║
// ║  ✅ f_getAny()            — returns true if any signal fired             ║
// ║  ✅ f_getAll()            — returns full name string + count             ║
// ║  ✅ Multiplexer option    — input dropdown with 9 selections            ║
// ║  ✅ Multiplexer switch    — switch block routes to correct signals       ║
// ║  ✅ Multiplexer alert     — dedicated alert() for mux selection         ║
// ║  ✅ sigAny inclusion      — unified OR of all four bools                ║
// ║  ✅ Non-repainting        — barstate.isconfirmed gates all signals      ║
// ║  ✅ 1:1 parity            — alert.freq_once_per_bar_close everywhere    ║
// ║  ✅ Default settings      — Zoo/PBJ/Supertrend all match source         ║
// ╚════════════════════════════════════════════════════════════════════════════╝
