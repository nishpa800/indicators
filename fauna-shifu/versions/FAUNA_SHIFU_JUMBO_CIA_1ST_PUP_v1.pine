    extras := str.length(extras) > 2 ? str.substring(extras, 0, str.length(extras) - 2) : extras
    string rvol_part = f_rvol_name_bull()
    string qty = f_rvol_qty_bull()
    alert("{{ticker}} | BULL | " + pp_col + " | " + pbj_col + " | FVG STACK | " + qty + " | " + extras + " | \"" + rvol_part + ", FAUNA, DISP, HVFVG, GZI\" | " + priceStr, alert.freq_once_per_bar_close)

if show_FVGStack and sigFVGStackBear and fbm and al_mf_bear
    string pp_col = al_PPD ? "PPD" : "No"
    string pbj_col = al_anyBearPBJ ? "PBJ" : "No"
    string extras = ""
    if al_WhaleBear
        extras += "WHALE, "
    if al_bearGZI
        extras += "GZI, "
    if al_bearHV
        extras += "HVFVG, "
    if al_Kratos
        extras += "KRATOS2, "
    if al_FAUNABear
        extras += "FAUNA, "
    if al_DISPBear
        extras += "DISP, "
    extras := str.length(extras) > 2 ? str.substring(extras, 0, str.length(extras) - 2) : extras
    string rvol_part = f_rvol_name_bear()
