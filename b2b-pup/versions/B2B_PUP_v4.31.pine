// ║  PLOTSHAPES — 17 bull + 17 bear S-plots + 2 plotA + 2 plotB             ║
// ║  v4.30: offset fixes on S6 / S9 / S11 / S16 / S17 / S18.                ║
// ╚══════════════════════════════════════════════════════════════════════════╝
plotshape(fire_S1_bull,"B2B Bull",shape.diamond,location.belowbar,color.new(#4CAF50,0),text="B2B",textcolor=color.white,size=size.normal)
plotshape(fire_S1_bear,"B2B Bear",shape.diamond,location.abovebar,color.new(#E91E63,0),text="B2B",textcolor=color.white,size=size.normal)
plotshape(fire_S2_bull,"B2B+FAU Bull",shape.diamond,location.belowbar,color.new(#00E676,0),text="B2B\nFAU",textcolor=color.white,size=size.normal)
plotshape(fire_S2_bear,"B2B+FAU Bear",shape.diamond,location.abovebar,color.new(#FF1744,0),text="B2B\nFAU",textcolor=color.white,size=size.normal)
plotshape(fire_S3_bull,"B2B+DISP Bull",shape.diamond,location.belowbar,color.new(#00BCD4,0),text="B2B\nDISP",textcolor=color.white,size=size.normal,offset=-1)
