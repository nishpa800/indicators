// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ALERT AGGREGATOR — Bloomberg format                                    ║
// ╚══════════════════════════════════════════════════════════════════════════╝
f_agg_bull_b2b()=>
    string _s=""
    if fire_S1_bull
        _s:=f_add(_s,"B2B")
    if fire_S2_bull
        _s:=f_add(_s,"B2B-FAU")
    if fire_S3_bull
        _s:=f_add(_s,det_S3d_bull?"B2B-HVD":"B2B-DISP")
    if fire_S4_bull
        _s:=f_add(_s,det_S4d_bull?"B2B-FAU-HVD":"B2B-FAU-DISP")
    if fire_S5_bull
        _s:=f_add(_s,"B2B-SAAB")
    if fire_S6_bull
        _s:=f_add(_s,"B2B-PBJ")
    if fire_S8_bull
        _s:=f_add(_s,"UC-B2B")
    if fire_S9_bull
        _s:=f_add(_s,"UNI-B2B")
    if fire_S10_bull
        _s:=f_add(_s,"L1B2B")
    if fire_S11_bull
        _s:=f_add(_s,"FVG-L1")
    if fire_S12_bull
        _s:=f_add(_s,(det_UUUUBull?"UUUU":det_UUUBull?"UUU":"UU")+"-B2B")
    if fire_S13_bull
        _s:=f_add(_s,"B2BNPM")
    if fire_S14_bull
        _s:=f_add(_s,"CONT")
    if fire_S15_bull
        _s:=f_add(_s,"TNT")
    if fire_S16_bull
        _s:=f_add(_s,"NPM")
    if fire_S17_bull
        _s:=f_add(_s,"B2BHVD")
    if fire_S18_bull
        _s:=f_add(_s,"B2BHVDPBJ")
    if fire_UC2_bull
        _s:=f_add(_s,"S19")
    if fire_FMU_bull
        _s:=f_add(_s,"S20")
    _s
f_agg_bear_b2b()=>
    string _s=""
    if fire_S1_bear
        _s:=f_add(_s,"B2B")
    if fire_S2_bear
        _s:=f_add(_s,"B2B-FAU")
    if fire_S3_bear
        _s:=f_add(_s,det_S3d_bear?"B2B-HVD":"B2B-DISP")
    if fire_S4_bear
        _s:=f_add(_s,det_S4d_bear?"B2B-FAU-HVD":"B2B-FAU-DISP")
    if fire_S5_bear
        _s:=f_add(_s,"B2B-KRAT")
    if fire_S6_bear
        _s:=f_add(_s,"B2B-PBJ")
    if fire_S8_bear
        _s:=f_add(_s,"UC-B2B")
    if fire_S9_bear
        _s:=f_add(_s,"UNI-B2B")
    if fire_S10_bear
        _s:=f_add(_s,"S1B2B")
    if fire_S11_bear
        _s:=f_add(_s,"FVG-S1")
    if fire_S12_bear
        _s:=f_add(_s,(det_UUUUBear?"DDDD":det_UUUBear?"DDD":"DD")+"-B2B")
    if fire_S13_bear
        _s:=f_add(_s,"B2BNPM")
    if fire_S14_bear
        _s:=f_add(_s,"CONT")
    if fire_S15_bear
        _s:=f_add(_s,"TNT")
    if fire_S16_bear
        _s:=f_add(_s,"NPM")
    if fire_S17_bear
        _s:=f_add(_s,"B2BHVD")
    if fire_S18_bear
        _s:=f_add(_s,"B2BHVDPBJ")
    if fire_UC2_bear
        _s:=f_add(_s,"S19")
    if fire_FMU_bear
        _s:=f_add(_s,"S20")
    _s

if conf
    string bs=f_agg_bull_b2b()
    string rs=f_agg_bear_b2b()
    if en_aggregate and str.length(bs)>0
        alert("BULL | "+_FIRST+" | "+bs,alert.freq_once_per_bar_close)
    if en_aggregate and str.length(rs)>0
        alert("BEAR | "+_FIRST+" | "+rs,alert.freq_once_per_bar_close)
    if not en_aggregate and str.length(bs)>0
        if fire_S1_bull
            alert("BULL | "+_FIRST+" | B2B",alert.freq_once_per_bar_close)
        if fire_S2_bull
            alert("BULL | "+_FIRST+" | B2B-FAU",alert.freq_once_per_bar_close)
        if fire_S3_bull
            alert("BULL | "+_FIRST+" | "+(det_S3d_bull?"B2B-HVD":"B2B-DISP"),alert.freq_once_per_bar_close)
        if fire_S4_bull
            alert("BULL | "+_FIRST+" | "+(det_S4d_bull?"B2B-FAU-HVD":"B2B-FAU-DISP"),alert.freq_once_per_bar_close)
        if fire_S5_bull
            alert("BULL | "+_FIRST+" | B2B-SAAB",alert.freq_once_per_bar_close)
        if fire_S6_bull
            alert("BULL | "+_FIRST+" | B2B-PBJ",alert.freq_once_per_bar_close)
        if fire_S8_bull
            alert("BULL | "+_FIRST+" | UC-B2B",alert.freq_once_per_bar_close)
        if fire_S9_bull
            alert("BULL | "+_FIRST+" | UNI-B2B",alert.freq_once_per_bar_close)
        if fire_S10_bull
            alert("BULL | "+_FIRST+" | L1B2B",alert.freq_once_per_bar_close)
        if fire_S11_bull
            alert("BULL | "+_FIRST+" | FVG-L1",alert.freq_once_per_bar_close)
        if fire_S12_bull
            alert("BULL | "+_FIRST+" | UU-B2B",alert.freq_once_per_bar_close)
        if fire_S13_bull
            alert("BULL | "+_FIRST+" | B2BNPM",alert.freq_once_per_bar_close)
        if fire_S14_bull
            alert("BULL | "+_FIRST+" | CONT",alert.freq_once_per_bar_close)
        if fire_S15_bull
            alert("BULL | "+_FIRST+" | TNT",alert.freq_once_per_bar_close)
        if fire_S16_bull
            alert("BULL | "+_FIRST+" | NPM",alert.freq_once_per_bar_close)
        if fire_S17_bull
            alert("BULL | "+_FIRST+" | B2BHVD",alert.freq_once_per_bar_close)
        if fire_S18_bull
            alert("BULL | "+_FIRST+" | B2BHVDPBJ",alert.freq_once_per_bar_close)
        if fire_UC2_bull
            alert("BULL | "+_FIRST+" | S19",alert.freq_once_per_bar_close)
        if fire_FMU_bull
            alert("BULL | "+_FIRST+" | S20",alert.freq_once_per_bar_close)
    if not en_aggregate and str.length(rs)>0
        if fire_S1_bear
            alert("BEAR | "+_FIRST+" | B2B",alert.freq_once_per_bar_close)
        if fire_S2_bear
            alert("BEAR | "+_FIRST+" | B2B-FAU",alert.freq_once_per_bar_close)
        if fire_S3_bear
            alert("BEAR | "+_FIRST+" | "+(det_S3d_bear?"B2B-HVD":"B2B-DISP"),alert.freq_once_per_bar_close)
        if fire_S4_bear
            alert("BEAR | "+_FIRST+" | "+(det_S4d_bear?"B2B-FAU-HVD":"B2B-FAU-DISP"),alert.freq_once_per_bar_close)
        if fire_S5_bear
            alert("BEAR | "+_FIRST+" | B2B-KRAT",alert.freq_once_per_bar_close)
        if fire_S6_bear
            alert("BEAR | "+_FIRST+" | B2B-PBJ",alert.freq_once_per_bar_close)
        if fire_S8_bear
            alert("BEAR | "+_FIRST+" | UC-B2B",alert.freq_once_per_bar_close)
        if fire_S9_bear
            alert("BEAR | "+_FIRST+" | UNI-B2B",alert.freq_once_per_bar_close)
        if fire_S10_bear
            alert("BEAR | "+_FIRST+" | S1B2B",alert.freq_once_per_bar_close)
        if fire_S11_bear
            alert("BEAR | "+_FIRST+" | FVG-S1",alert.freq_once_per_bar_close)
        if fire_S12_bear
            alert("BEAR | "+_FIRST+" | DD-B2B",alert.freq_once_per_bar_close)
        if fire_S13_bear
            alert("BEAR | "+_FIRST+" | B2BNPM",alert.freq_once_per_bar_close)
        if fire_S14_bear
            alert("BEAR | "+_FIRST+" | CONT",alert.freq_once_per_bar_close)
        if fire_S15_bear
            alert("BEAR | "+_FIRST+" | TNT",alert.freq_once_per_bar_close)
        if fire_S16_bear
            alert("BEAR | "+_FIRST+" | NPM",alert.freq_once_per_bar_close)
        if fire_S17_bear
            alert("BEAR | "+_FIRST+" | B2BHVD",alert.freq_once_per_bar_close)
        if fire_S18_bear
            alert("BEAR | "+_FIRST+" | B2BHVDPBJ",alert.freq_once_per_bar_close)
        if fire_UC2_bear
            alert("BEAR | "+_FIRST+" | S19",alert.freq_once_per_bar_close)
        if fire_FMU_bear
            alert("BEAR | "+_FIRST+" | S20",alert.freq_once_per_bar_close)
