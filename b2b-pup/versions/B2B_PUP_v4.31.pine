plotshape(fire_S5_bull,"B2B+SAAB Bull",shape.diamond,location.belowbar,color.new(#FFD700,0),text="B2B\nSAAB",textcolor=color.black,size=size.normal)
plotshape(fire_S5_bear,"B2B+KRAT Bear",shape.diamond,location.abovebar,color.new(#FF6F00,0),text="B2B\nKRAT",textcolor=color.white,size=size.normal)
plotshape(fire_S6_bull,"B2B+PBJ Bull",shape.labelup,location.belowbar,color.new(#7C4DFF,0),text="B2B\nPBJ",textcolor=color.white,size=size.large,offset=-1)
plotshape(fire_S6_bear,"B2B+PBJ Bear",shape.labeldown,location.abovebar,color.new(#AA00FF,0),text="B2B\nPBJ",textcolor=color.white,size=size.large,offset=-1)
plotshape(fire_S8_bull,"UC+B2B Bull",shape.labelup,location.belowbar,color.new(#00C853,0),text="UC\nB2B",textcolor=color.black,size=size.large,offset=-1)
plotshape(fire_S8_bear,"UC+B2B Bear",shape.labeldown,location.abovebar,color.new(#D500F9,0),text="UC\nB2B",textcolor=color.white,size=size.large,offset=-1)
plotshape(fire_S9_bull,"Uni+B2B Bull",shape.flag,location.belowbar,color.new(#FFAB00,0),text="Uni\nB2B",textcolor=color.black,size=size.large,offset=-1)
plotshape(fire_S9_bear,"Uni+B2B Bear",shape.flag,location.abovebar,color.new(#FF3D00,0),text="Uni\nB2B",textcolor=color.white,size=size.large,offset=-1)
plotshape(fire_S10_bull,"L1B2B Bull",shape.flag,location.belowbar,color.new(#64DD17,0),text="L1\nB2B",textcolor=color.black,size=size.large)
plotshape(fire_S10_bear,"S1B2B Bear",shape.flag,location.abovebar,color.new(#DD2C00,0),text="S1\nB2B",textcolor=color.white,size=size.large)
plotshape(fire_S11_bull,"FVG/L1 Bull",shape.labelup,location.belowbar,color.new(#18FFFF,0),text="FVG\nL1",textcolor=color.black,size=size.normal,offset=-1)
plotshape(fire_S11_bear,"FVG/S1 Bear",shape.labeldown,location.abovebar,color.new(#FF6E40,0),text="FVG\nS1",textcolor=color.white,size=size.normal,offset=-1)
plotshape(fire_S12_bull,"UU+B2B Bull",shape.labelup,location.belowbar,color.new(#76FF03,0),text="UU\nB2B",textcolor=color.black,size=size.large)
