//@version=5
// =============================================================================
// ROOTS VOLUME TEST v1 — heavy-pentagon RVOL roots only
// =============================================================================
//
// PURPOSE
//   Prove every root in the RVOL family fires when expected, by isolating
//   them in a minimal indicator with provenance-named plots.
//
// SOURCE
//   Verbatim copy from heavy-pentagon/versions/HEAVY_PENTAGON_v1.pine
//   (25,160 bytes, 444 lines, Pine v5).
//
//   Stripped: 15 Heavy Combo composites (out of scope for Stage 2 — they get
//   tested in Stage 4); displacement engine (helper for combos, not a root);
//   18 phantom toggles (no logic connected per canonical CHANGELOG).
//
// PLOT NAMING
//   Every plotshape title is `heavy-pentagon::<ROOT>` so provenance shows in
//   the TradingView legend. All 10 toggles default ON (canonical defaults
//   some OFF; this test wants all 10 visible).
//
// ROOTS COVERED (10)
//   Pipeline 1 (Standard RVOL — bb_normalizedPrice spike):
//     - heavy-pentagon::SAAB           Bull, top, square
//     - heavy-pentagon::KRATOS         Bear, bottom, square
//     - heavy-pentagon::RVOL_1X_BULL   Bull, bottom, xcross
//     - heavy-pentagon::RVOL_1X_BEAR   Bear, bottom, xcross
//     - heavy-pentagon::GRAND_SLAM     Bull, bottom, triangleup
//     - heavy-pentagon::MOAB           Bear, top, triangledown
//   Pipeline 2 (Reg@Time RVOL — relVolRatio):
//     - heavy-pentagon::PENTAGON       top, diamond
//     - heavy-pentagon::WTC            bottom, xcross
//     - heavy-pentagon::HIROSHIMA      top, diamond
//   Pipeline 3 (All-Time High Volume — vs running max):
//     - heavy-pentagon::NAGASAKI       top, flag
//
// VERIFICATION (Stage 3)
//   1. Load this on the same chart as HEAVY_PENTAGON_v1.pine.
//   2. Each of the 10 plots should fire on identical bars to the canonical
//      (with the SAME shape and location — only the title differs).
//   3. Discrepancy → drift; investigate via docs/sop/drift-triage.md.
//
// BIBLE REFERENCES
//   - docs/roots.md (rvol family, 10 entries)
//   - docs/lineage/heavy-pentagon__*.md (15 Heavy Combo composites — Stage 4)
//   - bible-input/extract-heavy-pentagon.yaml (extraction source)
//   - SOP: docs/sop/root-validation.md
//
// CAVEAT
//   This is a Stage-2 DRAFT generated by Claude. Verify each plot fires
//   identically to canonical heavy-pentagon BEFORE trusting in production.
//   Drift findings → docs/validation-log/.
// =============================================================================

indicator("ROOTS VOLUME TEST v1 — heavy-pentagon RVOL roots only",
          shorttitle="ROOTS VOL", overlay=true,
          max_labels_count=500, max_bars_back=5000)

import TradingView/ta/7 as tv_ta

// =============================================================================
// PIPELINE 1: RVOL BULL/BEAR (Standard — Normalized Price Spike)
// SOURCE: heavy-pentagon L110-L190 — verbatim
// =============================================================================
groupBullBear = "RVOL - Bull/Bear Calculation"
bb_avgLength  = input.int(30, "Lookback Length", minval=1, group=groupBullBear)
bb_smaLength  = input.int(20, "SMA Length",      minval=1, group=groupBullBear)

f_rvol_1x_threshold(_tfSec) =>
    float s = _tfSec
    float th = s <= 10   ? 38.0 :
               s <= 15   ? 33.0 :
               s <= 30   ? 28.0 :
               s <= 45   ? 23.0 :
               s <= 60   ? 20.0 :
               s <= 120  ? 19.0 :
               s <= 180  ? 17.0 :
               s <= 240  ? 16.0 :
               s <= 300  ? 15.0 :
               s <= 360  ? 14.0 :
               s <= 420  ? 12.0 :
               s <= 480  ? 11.0 :
               s <= 540  ? 10.0 :
               s <= 600  ? 10.0 :
               s <= 900  ? 8.4  :
               s <= 1800 ? 6.9  :
               s <= 3600 ? 5.9  :
               s <= 7200 ? 3.0  : 1.8
    th

f_saab_kratos_threshold(_tfSec) => f_rvol_1x_threshold(_tfSec) * 0.56

f_gs_moab_threshold(_tfSec) =>
    float s = _tfSec
    float th = s <= 10   ? 114.0 :
               s <= 15   ? 99.0  :
               s <= 30   ? 84.0  :
               s <= 45   ? 69.0  :
               s <= 60   ? 35.0  :
               s <= 300  ? 35.0  :
               s <= 600  ? 25.0  :
               s <= 900  ? 20.0  :
               s <= 3600 ? 10.0  : 8.0
    th

f_wtc_threshold(_tfSec)       => f_rvol_1x_threshold(_tfSec) * 2.0
f_hiroshima_threshold(_tfSec) => f_gs_moab_threshold(_tfSec)

tfSec = timeframe.in_seconds(timeframe.period)

th_saab_kratos = f_saab_kratos_threshold(tfSec)
th_1x          = f_rvol_1x_threshold(tfSec)
th_gs_moab     = f_gs_moab_threshold(tfSec)
th_wtc         = f_wtc_threshold(tfSec)
th_hiroshima   = f_hiroshima_threshold(tfSec)

bb_spike            = math.abs(close - open)
bb_avgSpikeDenom    = ta.sma(bb_spike, bb_avgLength)[1]
bb_normalizedPrice  = bb_spike / nz(bb_avgSpikeDenom, 1.0)
bb_avgVolDenom      = ta.sma(volume, bb_avgLength)[1]
bb_normalizedVolume = volume / nz(bb_avgVolDenom, 1.0)
bb_diff             = bb_normalizedPrice - bb_normalizedVolume
bb_positiveDiff     = bb_diff > 0 ? bb_diff : na
bb_smaDiff          = ta.sma(bb_positiveDiff, bb_smaLength)

bb_baseBullish = (close > open) and (bb_positiveDiff > bb_smaDiff)
bb_baseBearish = (close < open) and (bb_positiveDiff > bb_smaDiff)

bb_inRange(v, lowTh, highTh) => v >= lowTh and v < highTh

conf = barstate.isconfirmed

// SOURCE: heavy-pentagon L185-L190 — verbatim signal definitions
sigSAAB       = conf and bb_baseBullish and bb_inRange(bb_normalizedPrice, th_saab_kratos, th_1x)
sigKratos     = conf and bb_baseBearish and bb_inRange(bb_normalizedPrice, th_saab_kratos, th_1x)
sigBullRVOL1x = conf and bb_baseBullish and bb_inRange(bb_normalizedPrice, th_1x, th_gs_moab)
sigBearRVOL1x = conf and bb_baseBearish and bb_inRange(bb_normalizedPrice, th_1x, th_gs_moab)
sigGrandSlam  = conf and bb_baseBullish and (bb_normalizedPrice >= th_gs_moab)
sigMOAB       = conf and bb_baseBearish and (bb_normalizedPrice >= th_gs_moab)

// =============================================================================
// PIPELINE 2: RVOL REG @ TIME
// SOURCE: heavy-pentagon L192-L210 — verbatim
// =============================================================================
groupReg = "RVOL - Reg @ Time Calculation"
reg_anchorTimeframe  = input.timeframe("", "Anchor Timeframe (blank = chart)", group=groupReg)
reg_length           = input.int(30, "Length", minval=1, group=groupReg)
reg_calculationMode  = input.string("Cumulative", "Calculation Mode", options=["Cumulative", "Regular"], group=groupReg)
reg_adjustRealtime   = input.bool(true, "Adjust Unconfirmed", group=groupReg)

[currentVolume_reg, pastVolume_reg, _] = tv_ta.relativeVolume(reg_length, reg_anchorTimeframe, reg_calculationMode == "Cumulative", reg_adjustRealtime)
relVolRatio = currentVolume_reg / pastVolume_reg

sigPentagon  = conf and (relVolRatio >= th_1x)  and (relVolRatio <= th_wtc)
sigWTC       = conf and (relVolRatio >  th_wtc) and (relVolRatio <= th_hiroshima)
sigHiroshima = conf and (relVolRatio >  th_hiroshima)

// =============================================================================
// PIPELINE 3: NAGASAKI (All-Time High Volume)
// SOURCE: heavy-pentagon L212-L229 — verbatim
// =============================================================================
vol = volume
var float maxVol = 0.0
bool isNagasaki = false

if conf
    if bar_index == 0
        maxVol := vol
    else if vol > maxVol
        isNagasaki := true
        maxVol := vol

sigNagasaki = conf and isNagasaki

// =============================================================================
// PLOTSHAPES — provenance-named per Stage-2 convention
// SOURCE shape/location/color: heavy-pentagon L363-L372 — verbatim
// All toggles default ON (canonical defaults vary; we want all 10 visible)
// =============================================================================

// SOURCE: heavy-pentagon L363
plotshape(sigSAAB,       title="heavy-pentagon::SAAB",
          style=shape.square,       location=location.top,    size=size.tiny,   color=color.lime,    text="SAAB")

// SOURCE: heavy-pentagon L364
plotshape(sigKratos,     title="heavy-pentagon::KRATOS",
          style=shape.square,       location=location.bottom, size=size.tiny,   color=color.orange,  text="Krat")

// SOURCE: heavy-pentagon L365
plotshape(sigBullRVOL1x, title="heavy-pentagon::RVOL_1X_BULL",
          style=shape.xcross,       location=location.bottom, size=size.small,  color=color.green,   text="RV1x+")

// SOURCE: heavy-pentagon L366
plotshape(sigBearRVOL1x, title="heavy-pentagon::RVOL_1X_BEAR",
          style=shape.xcross,       location=location.bottom, size=size.small,  color=color.red,     text="RV1x-")

// SOURCE: heavy-pentagon L367
plotshape(sigGrandSlam,  title="heavy-pentagon::GRAND_SLAM",
          style=shape.triangleup,   location=location.bottom, size=size.normal, color=color.aqua,    text="DINGER")

// SOURCE: heavy-pentagon L368
plotshape(sigMOAB,       title="heavy-pentagon::MOAB",
          style=shape.triangledown, location=location.top,    size=size.normal, color=color.fuchsia, text="MOAB")

// SOURCE: heavy-pentagon L369
plotshape(sigPentagon,   title="heavy-pentagon::PENTAGON",
          style=shape.diamond,      location=location.top,    size=size.small,  color=color.teal,    text="PENT")

// SOURCE: heavy-pentagon L370
plotshape(sigWTC,        title="heavy-pentagon::WTC",
          style=shape.xcross,       location=location.bottom, size=size.normal, color=color.yellow,  text="WTC")

// SOURCE: heavy-pentagon L371
plotshape(sigHiroshima,  title="heavy-pentagon::HIROSHIMA",
          style=shape.diamond,      location=location.top,    size=size.normal, color=color.white,   text="H")

// SOURCE: heavy-pentagon L372
plotshape(sigNagasaki,   title="heavy-pentagon::NAGASAKI",
          style=shape.flag,         location=location.top,    size=size.normal, color=color.purple,  text="N")

// =============================================================================
// ALERTS — 1:1 parity, identical sig_* booleans
// SOURCE: heavy-pentagon L410-L419 — verbatim
// =============================================================================
alertcondition(sigSAAB,       "heavy-pentagon::SAAB",        "SAAB fired on {{ticker}}")
alertcondition(sigKratos,     "heavy-pentagon::KRATOS",      "Kratos fired on {{ticker}}")
alertcondition(sigBullRVOL1x, "heavy-pentagon::RVOL_1X_BULL", "Bull RVOL 1x fired on {{ticker}}")
alertcondition(sigBearRVOL1x, "heavy-pentagon::RVOL_1X_BEAR", "Bear RVOL 1x fired on {{ticker}}")
alertcondition(sigGrandSlam,  "heavy-pentagon::GRAND_SLAM",   "Grand Slam fired on {{ticker}}")
alertcondition(sigMOAB,       "heavy-pentagon::MOAB",         "MOAB fired on {{ticker}}")
alertcondition(sigPentagon,   "heavy-pentagon::PENTAGON",     "Pentagon fired on {{ticker}}")
alertcondition(sigWTC,        "heavy-pentagon::WTC",          "WTC fired on {{ticker}}")
alertcondition(sigHiroshima,  "heavy-pentagon::HIROSHIMA",    "Hiroshima fired on {{ticker}}")
alertcondition(sigNagasaki,   "heavy-pentagon::NAGASAKI",     "Nagasaki fired on {{ticker}}")
