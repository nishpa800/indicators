//@version=5
// =============================================================================
// ROOTS FAUNA TEST v1 — ultra-combo FAUNA components
// =============================================================================
//
// PURPOSE
//   Prove every root in the FAUNA decomposition fires correctly, AND that the
//   locked FAUNA composite formula `(MB OR RE OR TA) AND NOT (GG OR TR OR ES
//   OR GDR)` produces the same fire bars as ultra-combo's sigFAUNABull /
//   sigFAUNABear.
//
// SOURCE
//   Verbatim extract from ultra-combo/versions/ULTRA_COMBO_v57_pine6.pine
//   L700-L748 (the full FAUNA block). All helper definitions and exclusion
//   logic copied as-is.
//
// PLOT NAMING
//   Every plotshape title is `ultra-combo::<COMPONENT>` so provenance shows
//   in the TradingView legend. The composite check uses
//   `ultra-combo::FAUNA_BULL` / `_BEAR`.
//
// ROOTS COVERED (14 bull/bear pairs = 7 named roots × 2 directions)
//   Bull positives (3): MB_BULL, RE_BULL, TA_BULL
//   Bull excluders (4): GG_BULL, TR_BULL, ES_BULL, GDR_BULL
//   Bear positives (3): MB_BEAR, RE_BEAR, TA_BEAR
//   Bear excluders (4): GG_BEAR, TR_BEAR, ES_BEAR, GDR_BEAR
//
// COMPOSITE COVERAGE (2)
//   - ultra-combo::FAUNA_BULL = (MB_BULL OR RE_BULL OR TA_BULL)
//                                AND NOT (GG_BULL OR TR_BULL OR ES_BULL OR GDR_BULL)
//   - ultra-combo::FAUNA_BEAR = mirror
//
// VERIFICATION (Stage 3)
//   1. Load this on the same chart as ULTRA_COMBO_v57_pine6.pine.
//   2. The 14 root markers should fire on the bars where each FAUNA component
//      condition is met (positives mark inclusions; excluders mark
//      suppressions).
//   3. The FAUNA_BULL / FAUNA_BEAR composite plot should match ultra-combo's
//      sigFAUNABull / sigFAUNABear bar-for-bar.
//   4. Discrepancy → drift on FAUNA components or the locked formula;
//      investigate via docs/sop/composite-validation.md.
//
// BIBLE REFERENCES
//   - docs/roots.md (FAUNA component primitives — search for ultra-combo::MB_)
//   - docs/redundancy.md (FAUNA decomposition entry — locked formula)
//   - bible-input/extract-ultra-combo.yaml (extraction with `fauna_decomposition`)
//   - SOP: docs/sop/root-validation.md
//
// CAVEAT
//   This is a Stage-2 DRAFT generated by Claude. Verify each plot fires
//   identically to canonical ultra-combo BEFORE trusting in production.
// =============================================================================

indicator("ROOTS FAUNA TEST v1 — ultra-combo FAUNA components",
          shorttitle="ROOTS FAUNA", overlay=true,
          max_labels_count=500, max_bars_back=5000)

conf = barstate.isconfirmed

// =============================================================================
// FAUNA HELPERS — verbatim from ultra-combo L703-L714
// =============================================================================
fauna_atr      = ta.atr(14)
fauna_avgVol   = ta.sma(volume, 20)
fauna_avgBody  = ta.sma(math.abs(close - open), 20)
fauna_avgRange = ta.sma(high - low, 20)
fauna_avgDelta = ta.sma(math.abs(close - close[1]), 10)
fauna_trendMA  = ta.sma(close, 50)
fauna_body     = close - open
fauna_rng2     = high - low
fauna_bodySz   = math.abs(fauna_body)
fauna_bodyRat  = fauna_rng2 == 0 ? 0 : fauna_bodySz / fauna_rng2
fauna_up       = fauna_body > 0
fauna_dn       = fauna_body < 0

// =============================================================================
// FAUNA BULL COMPONENTS — verbatim from ultra-combo L716-L730
// =============================================================================

// SOURCE: ultra-combo L717
// CANONICAL: ultra-combo::MB_BULL — Marubozu Bullish (large bullish body, high body ratio, high volume)
fMB_b = conf and fauna_up and fauna_bodySz > 1.6 * fauna_atr and fauna_bodyRat > 0.7 and volume > 1.8 * fauna_avgVol

// SOURCE: ultra-combo L718
// CANONICAL: ultra-combo::RE_BULL — Range Expansion Bullish
fRE_b = conf and fauna_up and fauna_rng2 > 2.2 * fauna_atr and (high - close) < 0.15 * fauna_rng2 and volume > 1.8 * fauna_avgVol

// SOURCE: ultra-combo L719
// CANONICAL: ultra-combo::TA_BULL — Trend Acceleration Bullish
fTA_b = conf and fauna_trendMA > fauna_trendMA[1] and (close - close[1]) > 1.6 * fauna_avgDelta and fauna_up and volume > 1.8 * fauna_avgVol

// --- Bullish exclusions ---
// SOURCE: ultra-combo L722
// CANONICAL: ultra-combo::GG_BULL — Gap-and-Go Bullish (suppresses MB/RE/TA bull when present)
fGG_b = (open - close[1]) > 0.9 * fauna_atr and fauna_up and low > close[1] and volume > 1.8 * fauna_avgVol

// SOURCE: ultra-combo L723-L726 — helpers used by TR/ES/GDR
fauna_prev_body  = close[1] - open[1]
fauna_prev_range = high[1] - low[1]
fauna_StrongBear = close[1] < open[1] and math.abs(fauna_prev_body) > 1.5 * fauna_avgBody[1] and volume[1] > 1.5 * fauna_avgVol[1]
fauna_WeakBear   = close[1] < open[1] and (fauna_prev_range == 0 ? 0.0 : math.abs(fauna_prev_body) / fauna_prev_range) <= 0.2

// SOURCE: ultra-combo L727
// CANONICAL: ultra-combo::TR_BULL — Trapping Reversal Bullish (weak-bear → bull = false signal)
fTR_b  = fauna_WeakBear   and (fMB_b or fRE_b or fTA_b)

// SOURCE: ultra-combo L728
// CANONICAL: ultra-combo::ES_BULL — Exhaustion Setup Bullish (strong-bear → bull = false signal)
fES_b  = fauna_StrongBear and (fMB_b or fRE_b or fTA_b)

// SOURCE: ultra-combo L729
// CANONICAL: ultra-combo::GDR_BULL — Gap-Down-Reversal Bullish (close[1]<open[1] + GG)
fGDR_b = close[1] < open[1] and fGG_b

// SOURCE: ultra-combo L730 — exclusion union
excluded_bull = fGG_b or fTR_b or fES_b or fGDR_b

// SOURCE: ultra-combo L732 — locked FAUNA bull formula
sigFAUNABull = (fMB_b or fRE_b or fTA_b) and not excluded_bull

// =============================================================================
// FAUNA BEAR COMPONENTS — verbatim from ultra-combo L735-L748
// =============================================================================

// SOURCE: ultra-combo L735
// CANONICAL: ultra-combo::MB_BEAR — Marubozu Bearish
fMB_r = conf and fauna_dn and fauna_bodySz > 1.6 * fauna_atr and fauna_bodyRat > 0.7 and volume > 1.8 * fauna_avgVol

// SOURCE: ultra-combo L736
// CANONICAL: ultra-combo::RE_BEAR — Range Expansion Bearish
fRE_r = conf and fauna_dn and fauna_rng2 > 2.2 * fauna_atr and (close - low) < 0.15 * fauna_rng2 and volume > 1.8 * fauna_avgVol

// SOURCE: ultra-combo L737
// CANONICAL: ultra-combo::TA_BEAR — Trend Acceleration Bearish
fTA_r = conf and fauna_trendMA < fauna_trendMA[1] and (close[1] - close) > 1.6 * fauna_avgDelta and fauna_dn and volume > 1.8 * fauna_avgVol

// --- Bearish exclusions ---
// SOURCE: ultra-combo L740
// CANONICAL: ultra-combo::GG_BEAR
fGG_r = (close[1] - open) > 0.9 * fauna_atr and fauna_dn and high < close[1] and volume > 1.8 * fauna_avgVol

// SOURCE: ultra-combo L741-L742
fauna_StrongBull = close[1] > open[1] and math.abs(fauna_prev_body) > 1.5 * fauna_avgBody[1] and volume[1] > 1.5 * fauna_avgVol[1]
fauna_WeakBull   = close[1] > open[1] and (fauna_prev_range == 0 ? 0.0 : math.abs(fauna_prev_body) / fauna_prev_range) <= 0.2

// SOURCE: ultra-combo L743
// CANONICAL: ultra-combo::TR_BEAR
fTR_r  = fauna_WeakBull   and (fMB_r or fRE_r or fTA_r)

// SOURCE: ultra-combo L744
// CANONICAL: ultra-combo::ES_BEAR
fES_r  = fauna_StrongBull and (fMB_r or fRE_r or fTA_r)

// SOURCE: ultra-combo L745
// CANONICAL: ultra-combo::GDR_BEAR
fGDR_r = close[1] > open[1] and fGG_r

// SOURCE: ultra-combo L746
excluded_bear = fGG_r or fTR_r or fES_r or fGDR_r

// SOURCE: ultra-combo L748 — locked FAUNA bear formula
sigFAUNABear = (fMB_r or fRE_r or fTA_r) and not excluded_bear

// =============================================================================
// PLOTSHAPES — bull positives (top) + bear positives (bottom)
// =============================================================================

// Bull positives — green tones
plotshape(fMB_b, title="ultra-combo::MB_BULL", style=shape.triangleup,
          location=location.bottom, color=color.new(color.lime, 0), size=size.small, text="MB+")
plotshape(fRE_b, title="ultra-combo::RE_BULL", style=shape.triangleup,
          location=location.bottom, color=color.new(color.green, 0), size=size.small, text="RE+")
plotshape(fTA_b, title="ultra-combo::TA_BULL", style=shape.triangleup,
          location=location.bottom, color=color.new(color.aqua, 0), size=size.small, text="TA+")

// Bull excluders — orange/yellow tones (visible but distinct)
plotshape(fGG_b, title="ultra-combo::GG_BULL", style=shape.xcross,
          location=location.bottom, color=color.new(color.orange, 0), size=size.tiny, text="GG+")
plotshape(fTR_b, title="ultra-combo::TR_BULL", style=shape.xcross,
          location=location.bottom, color=color.new(color.yellow, 0), size=size.tiny, text="TR+")
plotshape(fES_b, title="ultra-combo::ES_BULL", style=shape.xcross,
          location=location.bottom, color=color.new(color.olive, 0), size=size.tiny, text="ES+")
plotshape(fGDR_b, title="ultra-combo::GDR_BULL", style=shape.xcross,
          location=location.bottom, color=color.new(color.gray, 0), size=size.tiny, text="GDR+")

// Bear positives — red tones
plotshape(fMB_r, title="ultra-combo::MB_BEAR", style=shape.triangledown,
          location=location.top, color=color.new(color.red, 0), size=size.small, text="MB-")
plotshape(fRE_r, title="ultra-combo::RE_BEAR", style=shape.triangledown,
          location=location.top, color=color.new(color.maroon, 0), size=size.small, text="RE-")
plotshape(fTA_r, title="ultra-combo::TA_BEAR", style=shape.triangledown,
          location=location.top, color=color.new(color.fuchsia, 0), size=size.small, text="TA-")

// Bear excluders — orange/yellow tones (mirror)
plotshape(fGG_r, title="ultra-combo::GG_BEAR", style=shape.xcross,
          location=location.top, color=color.new(color.orange, 0), size=size.tiny, text="GG-")
plotshape(fTR_r, title="ultra-combo::TR_BEAR", style=shape.xcross,
          location=location.top, color=color.new(color.yellow, 0), size=size.tiny, text="TR-")
plotshape(fES_r, title="ultra-combo::ES_BEAR", style=shape.xcross,
          location=location.top, color=color.new(color.olive, 0), size=size.tiny, text="ES-")
plotshape(fGDR_r, title="ultra-combo::GDR_BEAR", style=shape.xcross,
          location=location.top, color=color.new(color.gray, 0), size=size.tiny, text="GDR-")

// =============================================================================
// COMPOSITE PLOTS — verify locked FAUNA formula matches canonical
// =============================================================================
plotshape(sigFAUNABull, title="ultra-combo::FAUNA_BULL", style=shape.flag,
          location=location.bottom, color=color.new(color.lime, 0), size=size.normal, text="FAUNA+")
plotshape(sigFAUNABear, title="ultra-combo::FAUNA_BEAR", style=shape.flag,
          location=location.top, color=color.new(color.red, 0), size=size.normal, text="FAUNA-")

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(fMB_b, "ultra-combo::MB_BULL", "FAUNA MB Bull on {{ticker}}")
alertcondition(fRE_b, "ultra-combo::RE_BULL", "FAUNA RE Bull on {{ticker}}")
alertcondition(fTA_b, "ultra-combo::TA_BULL", "FAUNA TA Bull on {{ticker}}")
alertcondition(fGG_b, "ultra-combo::GG_BULL", "FAUNA GG Bull (excluded) on {{ticker}}")
alertcondition(fTR_b, "ultra-combo::TR_BULL", "FAUNA TR Bull (excluded) on {{ticker}}")
alertcondition(fES_b, "ultra-combo::ES_BULL", "FAUNA ES Bull (excluded) on {{ticker}}")
alertcondition(fGDR_b, "ultra-combo::GDR_BULL", "FAUNA GDR Bull (excluded) on {{ticker}}")
alertcondition(fMB_r, "ultra-combo::MB_BEAR", "FAUNA MB Bear on {{ticker}}")
alertcondition(fRE_r, "ultra-combo::RE_BEAR", "FAUNA RE Bear on {{ticker}}")
alertcondition(fTA_r, "ultra-combo::TA_BEAR", "FAUNA TA Bear on {{ticker}}")
alertcondition(fGG_r, "ultra-combo::GG_BEAR", "FAUNA GG Bear (excluded) on {{ticker}}")
alertcondition(fTR_r, "ultra-combo::TR_BEAR", "FAUNA TR Bear (excluded) on {{ticker}}")
alertcondition(fES_r, "ultra-combo::ES_BEAR", "FAUNA ES Bear (excluded) on {{ticker}}")
alertcondition(fGDR_r, "ultra-combo::GDR_BEAR", "FAUNA GDR Bear (excluded) on {{ticker}}")
alertcondition(sigFAUNABull, "ultra-combo::FAUNA_BULL", "FAUNA Bull composite on {{ticker}}")
alertcondition(sigFAUNABear, "ultra-combo::FAUNA_BEAR", "FAUNA Bear composite on {{ticker}}")
