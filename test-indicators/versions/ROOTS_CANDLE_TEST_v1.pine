//@version=5
// =============================================================================
// ROOTS CANDLE TEST v1 — hvd-pbj-ppd PUP/PPD/Displacement (PBJ/PB deferred)
// =============================================================================
//
// PURPOSE
//   Prove the candle-family roots fire when expected. Covers PUP/PPD and
//   Displacement (bull + bear) — the tractable subset. PBJ and PB are
//   intentionally NOT replicated here because their Engine 6 implementation
//   spans ~140 lines of stateful Pine (Zoo MA + Supertrend + PB&J filter +
//   landing-box arrays) — too risky to verbatim-copy without missing a
//   state mutation. Anish loads HVDPBJPPD canonical alongside this test to
//   verify PBJ/PB.
//
// SOURCE
//   PUP/PPD: hvd-pbj-ppd/versions/HVDPBJPPD_2026-05-10_THE_ONLY_ONE.pine
//            L624-L627 (Engine 5: PUP/PPD)
//   Displacement: same file L518-L526 (Engine 3: USE Displacement)
//
// PLOT NAMING
//   Every plotshape title is `hvd-pbj-ppd::<ROOT>` so provenance shows in the
//   TradingView legend.
//
// ROOTS COVERED (4 of 8 in the candle family)
//   - hvd-pbj-ppd::PUP            ≥3% body bullish + vol > 10-bar hi-red-vol
//   - hvd-pbj-ppd::PPD            ≥3% body bearish + vol > 10-bar hi-green-vol
//   - hvd-pbj-ppd::DISPLACEMENT_BULL  prev bar disp σ-met + bull FVG
//   - hvd-pbj-ppd::DISPLACEMENT_BEAR  prev bar disp σ-met + bear FVG
//
// ROOTS DEFERRED (load canonical to verify)
//   - hvd-pbj-ppd::PBJ_BULL / PBJ_BEAR   Engine 6 (Zoo + ST + PB&J)
//   - hvd-pbj-ppd::PB_BULL  / PB_BEAR    Engine 6 secondary outputs
//
// VERIFICATION (Stage 3)
//   1. Load this on the same chart as HVDPBJPPD_2026-05-10_THE_ONLY_ONE.pine.
//   2. PUP / PPD plots in this test should align with the canonical's
//      sigPUP / sigPPD plotshapes.
//   3. DISPLACEMENT_BULL / DISPLACEMENT_BEAR should align with sigDISPBull /
//      sigDISPBear in the canonical.
//   4. PBJ/PB validation requires loading the canonical separately —
//      this test does not replicate them.
//   5. Discrepancy → drift; investigate via docs/sop/drift-triage.md.
//
// BIBLE REFERENCES
//   - docs/roots.md (push family: PUP/PPD; displacement family: DISPLACEMENT_BULL/BEAR;
//     candle family: PBJ_BULL/PBJ_BEAR/PB_BULL/PB_BEAR)
//   - bible-input/extract-hvd-pbj-ppd.yaml (extraction source — 21 roots, 38 composites)
//   - SOP: docs/sop/root-validation.md
//
// CAVEAT
//   This is a Stage-2 DRAFT generated by Claude. Verify each plot fires
//   identically to canonical hvd-pbj-ppd BEFORE trusting in production.
//   PBJ/PB roots are explicitly not covered here — Stage 4 composite
//   validation will exercise them indirectly via the lineage cards.
// =============================================================================

indicator("ROOTS CANDLE TEST v1 — hvd-pbj-ppd PUP/PPD/Displacement",
          shorttitle="ROOTS CANDLE", overlay=true,
          max_labels_count=500, max_bars_back=1100)

conf = barstate.isconfirmed

// =============================================================================
// PUP / PPD — verbatim from canonical L624-L627
// Hardcoded params per canonical L389: pp_barSize=3.0, pp_lookback=10
// =============================================================================
pp_barSize  = 3.0
pp_lookback = 10

float pp_redVol     = close < open ? volume : 0.0
float pp_greenVol   = close > open ? volume : 0.0
float pp_hiRedVol   = ta.highest(pp_redVol[1],   pp_lookback)
float pp_hiGreenVol = ta.highest(pp_greenVol[1], pp_lookback)
bool  pp_priceUp    = ((close - open) / open) * 100 > pp_barSize
bool  pp_priceDn    = ((open - close) / open) * 100 > pp_barSize

// SOURCE: hvd-pbj-ppd L626
// CANONICAL: hvd-pbj-ppd::PUP — bullish ≥3% body + volume exceeds 10-bar hi red-vol
bool sigPUP = conf and pp_priceUp and volume > pp_hiRedVol

// SOURCE: hvd-pbj-ppd L627
// CANONICAL: hvd-pbj-ppd::PPD — bearish ≥3% body + volume exceeds 10-bar hi green-vol
bool sigPPD = conf and pp_priceDn and volume > pp_hiGreenVol

// =============================================================================
// USE DISPLACEMENT — verbatim from canonical L518-L526
// Inputs match canonical L355-L361 (i_disp_type, i_std_len, i_std_min, i_std_max, i_req_fvg)
// =============================================================================
grp_disp = "Displacement"
i_disp_type = input.string("Open to Close", "Range Type", options=["Open to Close","High to Low"], group=grp_disp)
i_std_len   = input.int(100, "Std Dev Length", minval=1, group=grp_disp)
i_std_min   = input.float(3.0, "Min Mult", minval=0, step=0.5, group=grp_disp,
                          tooltip="Note: heavy-pentagon uses disp_strength=6.0; B2B PUP/Squarify use 5.0; this is the canonical hvd-pbj-ppd default of 3.0. Drift logged in docs/redundancy.md.")
i_std_max   = input.float(100.0, "Max Mult", minval=0, step=0.5, group=grp_disp)
i_req_fvg   = input.bool(true, "Require FVG", group=grp_disp)

float disp_rng         = i_disp_type == "Open to Close" ? math.abs(open - close) : high - low
float disp_std         = ta.stdev(disp_rng, i_std_len)
float disp_thresh_min  = disp_std * i_std_min
float disp_thresh_max  = disp_std * i_std_max
bool  disp_prevDisp    = disp_rng[1] > disp_thresh_min[1] and disp_rng[1] <= disp_thresh_max[1]
bool  disp_currDisp    = disp_rng[0] > disp_thresh_min[0] and disp_rng[0] <= disp_thresh_max[0]
bool  disp_bullFVG     = low > high[2] and close[1] > open[1]
bool  disp_bearFVG     = high < low[2] and close[1] < open[1]

// SOURCE: hvd-pbj-ppd L525
// CANONICAL: hvd-pbj-ppd::DISPLACEMENT_BULL
bool sigDISPBull = conf and (i_req_fvg ? (disp_prevDisp and disp_bullFVG) : (disp_currDisp and close > open))

// SOURCE: hvd-pbj-ppd L526
// CANONICAL: hvd-pbj-ppd::DISPLACEMENT_BEAR
bool sigDISPBear = conf and (i_req_fvg ? (disp_prevDisp and disp_bearFVG) : (disp_currDisp and close < open))

// =============================================================================
// PLOTSHAPES — provenance-named per Stage-2 convention
// =============================================================================

// CANONICAL: hvd-pbj-ppd::PUP
plotshape(sigPUP, title="hvd-pbj-ppd::PUP",
          style=shape.triangleup, location=location.belowbar,
          color=color.new(color.lime, 0), size=size.normal, text="PUP")

// CANONICAL: hvd-pbj-ppd::PPD
plotshape(sigPPD, title="hvd-pbj-ppd::PPD",
          style=shape.triangledown, location=location.abovebar,
          color=color.new(color.red, 0), size=size.normal, text="PPD")

// CANONICAL: hvd-pbj-ppd::DISPLACEMENT_BULL (offset=-1: marks bar where prev-bar's σ was met)
plotshape(sigDISPBull, title="hvd-pbj-ppd::DISPLACEMENT_BULL",
          style=shape.diamond, location=location.belowbar,
          color=color.new(color.aqua, 0), size=size.small, text="D+", offset=-1)

// CANONICAL: hvd-pbj-ppd::DISPLACEMENT_BEAR
plotshape(sigDISPBear, title="hvd-pbj-ppd::DISPLACEMENT_BEAR",
          style=shape.diamond, location=location.abovebar,
          color=color.new(color.fuchsia, 0), size=size.small, text="D-", offset=-1)

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(sigPUP,      "hvd-pbj-ppd::PUP",                "PUP fired on {{ticker}}")
alertcondition(sigPPD,      "hvd-pbj-ppd::PPD",                "PPD fired on {{ticker}}")
alertcondition(sigDISPBull, "hvd-pbj-ppd::DISPLACEMENT_BULL",  "Bullish displacement on {{ticker}}")
alertcondition(sigDISPBear, "hvd-pbj-ppd::DISPLACEMENT_BEAR",  "Bearish displacement on {{ticker}}")
